{
  "steps": [
    {
      "id": "read-header",
      "tool": "filesystem",
      "operation": "read_file",
      "path": "tools/pipeline-runner/examples/multi-input/header.txt"
    },
    {
      "id": "read-body",
      "tool": "filesystem",
      "operation": "read_file",
      "path": "tools/pipeline-runner/examples/multi-input/body.txt"
    },
    {
      "id": "combine",
      "tool": "menai",
      "inputs": {
        "header": "read-header",
        "body": "read-body"
      },
      "expression": "(dict \"result\" (string-concat (dict-get inputs \"header\") (dict-get inputs \"body\")))",
      "outputs": {}
    },
    {
      "id": "write-output",
      "tool": "console",
      "operation": "write_stdout",
      "value_from": "combine.result"
    }
  ]
}
