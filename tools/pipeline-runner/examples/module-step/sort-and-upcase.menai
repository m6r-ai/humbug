(let ((run (lambda (inputs)
              (let* ((lines   (filter-list
                                (lambda (s) (boolean-not (string=? s "")))
                                (string->list (dict-get inputs "content") "\n")))
                     (sorted  (sort-list string<? lines))
                     (upper   (map-list string-upcase sorted))
                     (result  (string-concat (list->string upper "\n") "\n")))
                (dict "result" result)))))
  (dict "run" run))
