; test-scheduling.menai
; Tests for the scheduling module, mirroring test_scheduling_basic.py
;
; Simple 3-task chain: T1 (5 days) -> T2 (3 days) -> T3 (2 days)

(let* (
  (calendar-mod (import "tools/planner/calendar"))
  (task-mod     (import "tools/planner/task"))
  (dep-mod      (import "tools/planner/dependency"))
  (scheduling   (import "tools/planner/scheduling"))
  (calendar     (dict-get calendar-mod "calendar"))
  (task         (dict-get task-mod "task"))
  (dependency   (dict-get dep-mod "dependency"))
  (forward-pass    (dict-get scheduling "forward-pass"))
  (schedule-project (dict-get scheduling "schedule-project"))

  (cal-5day
    (calendar "cal1" "5-day week" "5-day"
              (set "mon" "tue" "wed" "thu" "fri") (set)))

  (make-task
    (lambda (id name duration)
      (task id name duration "cal1" "duration-based" #f #f "not-started" 0.0
            #f #f #f #f #f)))

  (make-fs-dep
    (lambda (from to)
      (dependency from to "finish-to-start" 0)))

  (base-project
    (dict
      "project-id"    "SIMPLE-TEST"
      "name"          "Simple Test Project"
      "project-start" "2025-03-03"
      "tasks"
        (list
          (make-task "T1" "Task 1" 5)
          (make-task "T2" "Task 2" 3)
          (make-task "T3" "Task 3" 2))
      "dependencies"
        (list
          (make-fs-dep "T1" "T2")
          (make-fs-dep "T2" "T3"))
      "calendars"
        (list cal-5day)))

  ; ============================================================================
  ; TEST 1: Forward pass schedules all three tasks
  ; ============================================================================
  (t1-result   (forward-pass base-project))
  (t1-tasks    (dict-get t1-result "tasks"))
  (t1-count-ok (integer=? (list-length t1-tasks) 3))

  (t1-t1 (find-list (lambda (t) (string=? (struct-get t 'id) "T1")) t1-tasks))
  (t1-t2 (find-list (lambda (t) (string=? (struct-get t 'id) "T2")) t1-tasks))
  (t1-t3 (find-list (lambda (t) (string=? (struct-get t 'id) "T3")) t1-tasks))

  (t1-chain-ok
    (and
      (string=? (struct-get t1-t2 'earliest-start) (struct-get t1-t1 'earliest-finish))
      (string=? (struct-get t1-t3 'earliest-start) (struct-get t1-t2 'earliest-finish))))

  (t1-ok (and t1-count-ok t1-chain-ok))

  ; ============================================================================
  ; TEST 2: Full CPM — all tasks on critical path in a simple chain
  ; ============================================================================
  (t2-result        (schedule-project base-project))
  (t2-tasks         (dict-get t2-result "tasks"))
  (t2-critical-path (dict-get t2-result "critical-path"))
  (t2-ok (and (integer=? (list-length t2-tasks) 3) (integer=? (list-length t2-critical-path) 3)))

  ; ============================================================================
  ; TEST 3: Start-to-start dependency with lag
  ; T1 --[SS, lag=2]--> T2: T2 should start 2 working days after T1 starts
  ; ============================================================================
  (ss-dep (dependency "T1" "T2" "start-to-start" 2))

  (ss-project
    (dict
      "project-id"    "SS-TEST"
      "name"          "SS Test Project"
      "project-start" "2025-03-03"
      "tasks"
        (list
          (make-task "T1" "Task 1" 5)
          (make-task "T2" "Task 2" 3)
          (make-task "T3" "Task 3" 2))
      "dependencies"
        (list
          ss-dep
          (make-fs-dep "T2" "T3"))
      "calendars"
        (list cal-5day)))

  (t3-result (forward-pass ss-project))
  (t3-tasks  (dict-get t3-result "tasks"))
  (t3-t1     (find-list (lambda (t) (string=? (struct-get t 'id) "T1")) t3-tasks))
  (t3-t2     (find-list (lambda (t) (string=? (struct-get t 'id) "T2")) t3-tasks))

  (t3-ok
    (string<? (struct-get t3-t1 'earliest-start) (struct-get t3-t2 'earliest-start)))

  (all-ok (and t1-ok t2-ok t3-ok))
)

(dict
  "test-1-forward-pass"   t1-ok
  "test-2-full-cpm"       t2-ok
  "test-3-ss-dependency"  t3-ok
  "all-passed"            all-ok)
)
