; test-validation.menai
; Tests for the validation module, mirroring test_validation_simple.py

(let* (
  (validation     (import "tools/planner/validation"))
  (get-predecessors    (dict-get validation "get-predecessors"))
  (detect-cycles       (dict-get validation "detect-cycles"))
  (find-orphaned-tasks (dict-get validation "find-orphaned-tasks"))

  ; --------------------------------------------------------------------------
  ; Example project (mirrors create_example_project() from example_project.py)
  ; --------------------------------------------------------------------------

  (cal-standard
    (dict
      (list "id"           "standard-5day")
      (list "name"         "Standard Work Week")
      (list "type"         "5-day")
      (list "working-days" (set "mon" "tue" "wed" "thu" "fri"))
      (list "holidays"     (set "2025-12-25" "2025-12-26" "2026-01-01"))))

  (cal-deploy
    (dict
      (list "id"           "deployment-7day")
      (list "name"         "Deployment Calendar (24/7)")
      (list "type"         "7-day")
      (list "working-days" (set "mon" "tue" "wed" "thu" "fri" "sat" "sun"))
      (list "holidays"     (set))))

  (cal-vendor
    (dict
      (list "id"           "vendor-calendar")
      (list "name"         "Vendor ACME Calendar")
      (list "type"         "5-day")
      (list "working-days" (set "mon" "tue" "wed" "thu" "fri"))
      (list "holidays"     (set "2025-12-25" "2025-12-26" "2026-01-01" "2026-07-04"))))

  (make-task-5day
    (lambda (id name duration status progress)
      (dict
        (list "id"            id)
        (list "name"          name)
        (list "duration-days" duration)
        (list "calendar-id"   "standard-5day")
        (list "schedule-mode" "duration-based")
        (list "start-date"    #f)
        (list "end-date"      #f)
        (list "status"        status)
        (list "progress"      progress))))

  (make-task-7day
    (lambda (id name duration status progress)
      (dict
        (list "id"            id)
        (list "name"          name)
        (list "duration-days" duration)
        (list "calendar-id"   "deployment-7day")
        (list "schedule-mode" "duration-based")
        (list "start-date"    #f)
        (list "end-date"      #f)
        (list "status"        status)
        (list "progress"      progress))))

  (make-task-vendor
    (lambda (id name duration)
      (dict
        (list "id"            id)
        (list "name"          name)
        (list "duration-days" duration)
        (list "calendar-id"   "vendor-calendar")
        (list "schedule-mode" "duration-based")
        (list "start-date"    #f)
        (list "end-date"      #f)
        (list "status"        "not-started")
        (list "progress"      0.0))))

  (example-tasks
    (list
      ; Design phase
      (dict
        (list "id"            "T001")
        (list "name"          "System Architecture Design")
        (list "duration-days" 10)
        (list "calendar-id"   "standard-5day")
        (list "schedule-mode" "duration-based")
        (list "start-date"    "2025-02-01")
        (list "end-date"      #f)
        (list "status"        "complete")
        (list "progress"      1.0))
      (dict
        (list "id"            "T002")
        (list "name"          "API Design and Specification")
        (list "duration-days" 5)
        (list "calendar-id"   "standard-5day")
        (list "schedule-mode" "duration-based")
        (list "start-date"    "2025-02-08")
        (list "end-date"      #f)
        (list "status"        "complete")
        (list "progress"      1.0))
      (dict
        (list "id"            "T003")
        (list "name"          "Database Schema Design")
        (list "duration-days" 5)
        (list "calendar-id"   "standard-5day")
        (list "schedule-mode" "duration-based")
        (list "start-date"    "2025-02-08")
        (list "end-date"      #f)
        (list "status"        "complete")
        (list "progress"      1.0))
      ; Backend development
      (make-task-5day "T004" "Backend API Implementation"     15 "in-progress" 0.4)
      (make-task-5day "T005" "Database Implementation"        10 "in-progress" 0.3)
      (make-task-5day "T006" "Authentication & Authorization"  8 "not-started" 0.0)
      ; Frontend
      (make-task-5day "T007" "Frontend Framework Setup"        5 "not-started" 0.0)
      ; External vendor
      (make-task-vendor "T008" "Payment Gateway Integration (Vendor)"      15)
      (make-task-vendor "T009" "Payment Gateway API Documentation (Vendor)" 3)
      (make-task-5day   "T010" "Payment Integration Testing"               5 "not-started" 0.0)
      ; Infrastructure
      (make-task-5day "T011" "Cloud Infrastructure Setup"   8 "not-started" 0.0)
      (make-task-5day "T012" "CI/CD Pipeline Setup"         6 "not-started" 0.0)
      (make-task-5day "T013" "Monitoring and Logging Setup" 4 "not-started" 0.0)
      ; External cloud vendor
      (make-task-7day "T014" "CDN Configuration (Vendor)"   3 "not-started" 0.0)
      ; Testing
      (make-task-5day "T015" "Integration Testing"  10 "not-started" 0.0)
      (make-task-5day "T016" "Performance Testing"   7 "not-started" 0.0)
      (make-task-5day "T017" "Security Testing"      5 "not-started" 0.0)
      ; Deployment
      (make-task-7day "T018" "Staging Deployment"          2 "not-started" 0.0)
      (make-task-7day "T019" "Production Deployment"       1 "not-started" 0.0)
      (make-task-7day "T020" "Post-Deployment Monitoring"  2 "not-started" 0.0)))

  (make-dep
    (lambda (from to type lag)
      (dict
        (list "from-task" from)
        (list "to-task"   to)
        (list "type"      type)
        (list "lag-days"  lag))))

  (example-deps
    (list
      (make-dep "T001" "T002" "finish-to-start"  0)
      (make-dep "T001" "T003" "finish-to-start"  0)
      (make-dep "T002" "T004" "finish-to-start"  0)
      (make-dep "T003" "T005" "finish-to-start"  0)
      (make-dep "T004" "T006" "start-to-start"   5)
      (make-dep "T002" "T007" "finish-to-start"  0)
      (make-dep "T002" "T008" "finish-to-start"  0)
      (make-dep "T008" "T009" "finish-to-start"  0)
      (make-dep "T009" "T010" "finish-to-start"  0)
      (make-dep "T004" "T010" "finish-to-start"  0)
      (make-dep "T001" "T011" "finish-to-start"  0)
      (make-dep "T011" "T012" "finish-to-start"  0)
      (make-dep "T011" "T013" "start-to-start"   2)
      (make-dep "T011" "T014" "finish-to-start"  0)
      (make-dep "T004" "T015" "finish-to-start"  0)
      (make-dep "T007" "T015" "finish-to-start"  0)
      (make-dep "T011" "T015" "finish-to-start"  0)
      (make-dep "T010" "T015" "finish-to-start"  0)
      (make-dep "T015" "T016" "start-to-start"   3)
      (make-dep "T015" "T017" "start-to-start"   5)
      (make-dep "T015" "T018" "finish-to-start"  0)
      (make-dep "T016" "T018" "finish-to-start"  0)
      (make-dep "T017" "T018" "finish-to-start"  0)
      (make-dep "T014" "T018" "finish-to-start"  0)
      (make-dep "T018" "T019" "finish-to-start"  2)
      (make-dep "T019" "T020" "finish-to-start"  0)
      ; Intentional cycle: T020 -> T019 (FF) creates T019 <-> T020 cycle
      (make-dep "T020" "T019" "finish-to-finish" 2)))

  (example-project
    (dict
      (list "tasks"        example-tasks)
      (list "dependencies" example-deps)))

  ; ============================================================================
  ; TEST 1: Get predecessors of T004
  ; ============================================================================
  (t1-preds (get-predecessors "T004" example-deps))
  ; T004 has one predecessor: T002 (finish-to-start)
  (t1-ok    (integer=? (list-length t1-preds) 1))

  ; ============================================================================
  ; TEST 2: Detect cycles in the example project (expects T019/T020 cycle)
  ; ============================================================================
  (t2-cycles (detect-cycles example-tasks example-deps))
  (t2-ok     (integer>? (list-length t2-cycles) 0))

  ; ============================================================================
  ; TEST 3: Detect cycles in a deliberately cyclic 3-task project
  ; ============================================================================
  (bad-tasks
    (list
      (dict (list "id" "T001") (list "name" "Task 1"))
      (dict (list "id" "T002") (list "name" "Task 2"))
      (dict (list "id" "T003") (list "name" "Task 3"))))

  (bad-deps
    (list
      (make-dep "T001" "T002" "finish-to-start" 0)
      (make-dep "T002" "T003" "finish-to-start" 0)
      (make-dep "T003" "T001" "finish-to-start" 0)))

  (t3-cycles (detect-cycles bad-tasks bad-deps))
  (t3-ok     (integer>? (list-length t3-cycles) 0))

  ; ============================================================================
  ; TEST 4: Find orphaned tasks (tasks connected to nothing)
  ; ============================================================================
  (orphan-tasks
    (list
      (dict (list "id" "T001") (list "name" "Task 1"))
      (dict (list "id" "T002") (list "name" "Task 2"))
      (dict (list "id" "T003") (list "name" "Orphan Task"))))

  (orphan-deps
    (list
      (make-dep "T001" "T002" "finish-to-start" 0)))

  (t4-orphans (find-orphaned-tasks orphan-tasks orphan-deps))
  (t4-ok      (integer>? (list-length t4-orphans) 0))

  (all-ok (and t1-ok t2-ok t3-ok t4-ok))
)

(dict
  (list "test-1-get-predecessors"   t1-ok)
  (list "test-2-cycles-example"     t2-ok)
  (list "test-3-cycles-bad-project" t3-ok)
  (list "test-4-orphaned-tasks"     t4-ok)
  (list "all-passed"                all-ok))
)
