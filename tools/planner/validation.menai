; validation.menai
; Project-level validation and consistency checks

(letrec (
  (task-mod   (import "tools/planner/task"))
  (dep-mod    (import "tools/planner/dependency"))
  (task       (dict-get task-mod "task"))
  (validate-task       (dict-get task-mod "validate-task"))
  (get-successors      (dict-get dep-mod "get-successors"))
  (get-predecessors    (dict-get dep-mod "get-predecessors"))
  (task-exists?        (dict-get dep-mod "task-exists?"))
  (validate-dependency (dict-get dep-mod "validate-dependency"))

  ; ============================================================================
  ; CIRCULAR DEPENDENCY DETECTION
  ; ============================================================================

  (detect-cycles
    (lambda (tasks dependencies)
      (letrec ((all-task-ids (map-list (lambda (t) (struct-get t 'id)) tasks))
               (dfs-visit
                 (lambda (task-id path visited-in-path)
                   (if (list-member? visited-in-path task-id)
                       (let ((cycle-start-pos (list-index path task-id)))
                         (match cycle-start-pos
                           ((? integer? pos)
                             (list (list-slice (list-concat path (list task-id)) pos)))
                           (_ (list))))
                       (let* ((successors  (get-successors task-id dependencies))
                              (new-path    (list-concat path (list task-id)))
                              (new-visited (list-append visited-in-path task-id)))
                         (fold-list list-concat (list)
                                    (map-list (lambda (succ) (dfs-visit succ new-path new-visited))
                                              successors)))))))
        (fold-list list-concat (list)
                   (map-list (lambda (task-id) (dfs-visit task-id (list) (list)))
                             all-task-ids)))))

  (has-circular-dependencies?
    (lambda (tasks dependencies)
      (integer>? (list-length (detect-cycles tasks dependencies)) 0)))

  ; ============================================================================
  ; PROJECT VALIDATION
  ; ============================================================================

  (validate-project
    (lambda (project)
      (let* ((tasks        (dict-get project "tasks"))
             (dependencies (dict-get project "dependencies"))
             (task-validations (map-list validate-task tasks))
             (dep-validations  (map-list (lambda (dep) (validate-dependency dep tasks))
                                         dependencies))
             (cycles (detect-cycles tasks dependencies))
             (task-errors
               (fold-list list-append (list)
                          (map-list (lambda (v) (dict-get v "errors"))
                                    (filter-list (lambda (v) (boolean-not (dict-get v "valid")))
                                                 task-validations))))
             (dep-errors
               (fold-list list-append (list)
                          (map-list (lambda (v) (dict-get v "errors"))
                                    (filter-list (lambda (v) (boolean-not (dict-get v "valid")))
                                                 dep-validations))))
             (cycle-errors
               (if (integer>? (list-length cycles) 0)
                   (map-list (lambda (cycle)
                               (string-concat "Circular dependency: "
                                              (string-join cycle " -> ")))
                             cycles)
                   (list)))
             (all-errors
               (list-concat task-errors dep-errors cycle-errors)))
        (dict
          "valid"                       (integer=? (list-length all-errors) 0)
          "task-count"                  (list-length tasks)
          "dependency-count"            (list-length dependencies)
          "tasks-with-errors"
                (list-length (filter-list (lambda (v) (boolean-not (dict-get v "valid")))
                                          task-validations))
          "dependencies-with-errors"
                (list-length (filter-list (lambda (v) (boolean-not (dict-get v "valid")))
                                          dep-validations))
          "circular-dependencies-found" (list-length cycles)
          "errors"                      all-errors
          "task-validations"            task-validations
          "dependency-validations"      dep-validations
          "cycles"                      cycles))))

  ; ============================================================================
  ; CONSISTENCY CHECKS
  ; ============================================================================

  (find-duplicate-task-ids
    (lambda (tasks)
      (let* ((task-ids (map-list (lambda (t) (struct-get t 'id)) tasks))
             (check-duplicates
               (lambda (ids seen duplicates)
                 (if (list-null? ids)
                     duplicates
                     (let* ((current-id (list-first ids))
                            (rest-ids   (list-rest ids)))
                       (if (set-member? seen current-id)
                           (check-duplicates rest-ids seen (list-append duplicates current-id))
                           (check-duplicates rest-ids (set-add seen current-id) duplicates)))))))
        (check-duplicates task-ids (set) (list)))))

  (find-orphaned-tasks
    (lambda (tasks dependencies)
      (let ((all-task-ids (map-list (lambda (t) (struct-get t 'id)) tasks)))
        (filter-list (lambda (task-id)
                       (and (integer=? (list-length (get-predecessors task-id dependencies)) 0)
                            (integer=? (list-length (get-successors   task-id dependencies)) 0)))
                     all-task-ids))))

  (find-tasks-with-invalid-calendars
    (lambda (tasks calendars)
      (let ((calendar-ids (list->set (map-list (lambda (c) (struct-get c 'id)) calendars))))
        (filter-list (lambda (t)
                       (boolean-not (set-member? calendar-ids (struct-get t 'calendar-id))))
                     tasks))))
)

(dict
  "detect-cycles"                   detect-cycles
  "has-circular-dependencies?"      has-circular-dependencies?
  "validate-project"                validate-project
  "find-duplicate-task-ids"         find-duplicate-task-ids
  "find-orphaned-tasks"             find-orphaned-tasks
  "find-tasks-with-invalid-calendars" find-tasks-with-invalid-calendars))
