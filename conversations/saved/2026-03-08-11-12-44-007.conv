    {
      "id": "ec5b6cb3-47f0-4fe9-8148-f80ca6167c38",
      "timestamp": "2026-03-08T11:31:17.888488+00:00",
      "type": "tool_result",
      "content": "```json\n{\n  \"id\": \"toolu_01Win7VuVxmeryQZXy2MoHVw\",\n  \"name\": \"editor\",\n  \"content\": \"{\\n  \\\"range\\\": \\\"all lines\\\",\\n  \\\"lines\\\": {\\n    \\\"1\\\": \\\"\\\\\\\"\\\\\\\"\\\\\\\"Tests for conditional operations and boolean logic.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"2\\\": \\\"\\\",\\n    \\\"3\\\": \\\"import pytest\\\",\\n    \\\"4\\\": \\\"\\\",\\n    \\\"5\\\": \\\"from menai import Menai, MenaiEvalError\\\",\\n    \\\"6\\\": \\\"\\\",\\n    \\\"7\\\": \\\"\\\",\\n    \\\"8\\\": \\\"class TestConditionals:\\\",\\n    \\\"9\\\": \\\"    \\\\\\\"\\\\\\\"\\\\\\\"Test conditional operations and boolean logic.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"10\\\": \\\"\\\",\\n    \\\"11\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"12\\\": \\\"        # Basic if expressions\\\",\\n    \\\"13\\\": \\\"        ('(if #t \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\")', '\\\\\\\"yes\\\\\\\"'),\\\",\\n    \\\"14\\\": \\\"        ('(if #f \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\")', '\\\\\\\"no\\\\\\\"'),\\\",\\n    \\\"15\\\": \\\"\\\",\\n    \\\"16\\\": \\\"        # If with numeric conditions\\\",\\n    \\\"17\\\": \\\"        ('(if (integer>? 5 3) \\\\\\\"greater\\\\\\\" \\\\\\\"less\\\\\\\")', '\\\\\\\"greater\\\\\\\"'),\\\",\\n    \\\"18\\\": \\\"        ('(if (integer<? 5 3) \\\\\\\"greater\\\\\\\" \\\\\\\"less\\\\\\\")', '\\\\\\\"less\\\\\\\"'),\\\",\\n    \\\"19\\\": \\\"        ('(if (integer=? 5 5) \\\\\\\"equal\\\\\\\" \\\\\\\"not equal\\\\\\\")', '\\\\\\\"equal\\\\\\\"'),\\\",\\n    \\\"20\\\": \\\"\\\",\\n    \\\"21\\\": \\\"        # If with different result types\\\",\\n    \\\"22\\\": \\\"        ('(if #t 42 0)', '42'),\\\",\\n    \\\"23\\\": \\\"        ('(if #f 42 0)', '0'),\\\",\\n    \\\"24\\\": \\\"        ('(if #t (list 1 2) (list 3 4))', '(1 2)'),\\\",\\n    \\\"25\\\": \\\"        ('(if #f (list 1 2) (list 3 4))', '(3 4)'),\\\",\\n    \\\"26\\\": \\\"\\\",\\n    \\\"27\\\": \\\"        # If with complex expressions in branches\\\",\\n    \\\"28\\\": \\\"        ('(if #t (integer+ 1 2) (integer* 3 4))', '3'),\\\",\\n    \\\"29\\\": \\\"        ('(if #f (integer+ 1 2) (integer* 3 4))', '12'),\\\",\\n    \\\"30\\\": \\\"    ])\\\",\\n    \\\"31\\\": \\\"    def test_basic_if_expressions(self, menai, expression, expected):\\\",\\n    \\\"32\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test basic if expressions with various conditions and result types.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"33\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"34\\\": \\\"\\\",\\n    \\\"35\\\": \\\"    def test_if_lazy_evaluation_prevents_errors(self, menai):\\\",\\n    \\\"36\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that if expressions use lazy evaluation to prevent errors.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"37\\\": \\\"        # Division by zero in unused branch should not cause error\\\",\\n    \\\"38\\\": \\\"        result = menai.evaluate_and_format('(if #t 42 (integer/ 1 0))')\\\",\\n    \\\"39\\\": \\\"        assert result == '42'\\\",\\n    \\\"40\\\": \\\"\\\",\\n    \\\"41\\\": \\\"        result = menai.evaluate_and_format('(if #f (integer/ 1 0) 24)')\\\",\\n    \\\"42\\\": \\\"        assert result == '24'\\\",\\n    \\\"43\\\": \\\"\\\",\\n    \\\"44\\\": \\\"        # Undefined symbol in unused branch should not cause error\\\",\\n    \\\"45\\\": \\\"        result = menai.evaluate_and_format('(if #t \\\\\\\"safe\\\\\\\" undefined-symbol)')\\\",\\n    \\\"46\\\": \\\"        assert result == '\\\\\\\"safe\\\\\\\"'\\\",\\n    \\\"47\\\": \\\"\\\",\\n    \\\"48\\\": \\\"        result = menai.evaluate_and_format('(if #f undefined-symbol \\\\\\\"safe\\\\\\\")')\\\",\\n    \\\"49\\\": \\\"        assert result == '\\\\\\\"safe\\\\\\\"'\\\",\\n    \\\"50\\\": \\\"\\\",\\n    \\\"51\\\": \\\"    def test_if_lazy_evaluation_with_complex_conditions(self, menai):\\\",\\n    \\\"52\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test lazy evaluation with more complex scenarios.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"53\\\": \\\"        # Safe list operations\\\",\\n    \\\"54\\\": \\\"        result = menai.evaluate_and_format('(if (list-null? (list)) \\\\\\\"empty\\\\\\\" (list-first (list)))')\\\",\\n    \\\"55\\\": \\\"        assert result == '\\\\\\\"empty\\\\\\\"'\\\",\\n    \\\"56\\\": \\\"\\\",\\n    \\\"57\\\": \\\"        # The false branch would cause an error if evaluated\\\",\\n    \\\"58\\\": \\\"        result = menai.evaluate_and_format('(if (integer>? 10 5) \\\\\\\"big\\\\\\\" (list-first (list)))')\\\",\\n    \\\"59\\\": \\\"        assert result == '\\\\\\\"big\\\\\\\"'\\\",\\n    \\\"60\\\": \\\"\\\",\\n    \\\"61\\\": \\\"    def test_if_requires_boolean_condition(self, menai):\\\",\\n    \\\"62\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that if expressions require boolean conditions.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"63\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"condition must be boolean\\\\\\\"):\\\",\\n    \\\"64\\\": \\\"            menai.evaluate('(if 1 \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\")')\\\",\\n    \\\"65\\\": \\\"\\\",\\n    \\\"66\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"condition must be boolean\\\\\\\"):\\\",\\n    \\\"67\\\": \\\"            menai.evaluate('(if \\\\\\\"hello\\\\\\\" \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\")')\\\",\\n    \\\"68\\\": \\\"\\\",\\n    \\\"69\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"condition must be boolean\\\\\\\"):\\\",\\n    \\\"70\\\": \\\"            menai.evaluate('(if (list 1 2) \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\")')\\\",\\n    \\\"71\\\": \\\"\\\",\\n    \\\"72\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"condition must be boolean\\\\\\\"):\\\",\\n    \\\"73\\\": \\\"            menai.evaluate('(if 0 \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\")')  # 0 is not false in Menai\\\",\\n    \\\"74\\\": \\\"\\\",\\n    \\\"75\\\": \\\"    def test_if_requires_exactly_three_arguments(self, menai):\\\",\\n    \\\"76\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that if expressions require exactly 3 arguments.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"77\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"wrong number of arguments[\\\\\\\\s\\\\\\\\S]*Exactly 3 arguments\\\\\\\"):\\\",\\n    \\\"78\\\": \\\"            menai.evaluate('(if #t \\\\\\\"yes\\\\\\\")')  # Missing else branch\\\",\\n    \\\"79\\\": \\\"\\\",\\n    \\\"80\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"wrong number of arguments[\\\\\\\\s\\\\\\\\S]*Exactly 3 arguments\\\\\\\"):\\\",\\n    \\\"81\\\": \\\"            menai.evaluate('(if #t)')  # Missing both branches\\\",\\n    \\\"82\\\": \\\"\\\",\\n    \\\"83\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"wrong number of arguments[\\\\\\\\s\\\\\\\\S]*Exactly 3 arguments\\\\\\\"):\\\",\\n    \\\"84\\\": \\\"            menai.evaluate('(if #t \\\\\\\"yes\\\\\\\" \\\\\\\"no\\\\\\\" \\\\\\\"extra\\\\\\\")')  # Too many arguments\\\",\\n    \\\"85\\\": \\\"\\\",\\n    \\\"86\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"87\\\": \\\"        # Nested if expressions\\\",\\n    \\\"88\\\": \\\"        ('(if #t (if #t \\\\\\\"inner-true\\\\\\\" \\\\\\\"inner-false\\\\\\\") \\\\\\\"outer-false\\\\\\\")', '\\\\\\\"inner-true\\\\\\\"'),\\\",\\n    \\\"89\\\": \\\"        ('(if #t (if #f \\\\\\\"inner-true\\\\\\\" \\\\\\\"inner-false\\\\\\\") \\\\\\\"outer-false\\\\\\\")', '\\\\\\\"inner-false\\\\\\\"'),\\\",\\n    \\\"90\\\": \\\"        ('(if #f (if #t \\\\\\\"inner-true\\\\\\\" \\\\\\\"inner-false\\\\\\\") \\\\\\\"outer-false\\\\\\\")', '\\\\\\\"outer-false\\\\\\\"'),\\\",\\n    \\\"91\\\": \\\"\\\",\\n    \\\"92\\\": \\\"        # Complex nested conditions\\\",\\n    \\\"93\\\": \\\"        ('(if (integer>? 10 5) (if (integer<? 3 7) \\\\\\\"both-true\\\\\\\" \\\\\\\"first-true-second-false\\\\\\\") \\\\\\\"first-false\\\\\\\")', '\\\\\\\"both-true\\\\\\\"'),\\\",\\n    \\\"94\\\": \\\"        ('(if (integer>? 10 5) (if (integer>? 3 7) \\\\\\\"both-true\\\\\\\" \\\\\\\"first-true-second-false\\\\\\\") \\\\\\\"first-false\\\\\\\")', '\\\\\\\"first-true-second-false\\\\\\\"'),\\\",\\n    \\\"95\\\": \\\"        ('(if (integer<? 10 5) (if (integer<? 3 7) \\\\\\\"both-true\\\\\\\" \\\\\\\"first-false-second-true\\\\\\\") \\\\\\\"first-false\\\\\\\")', '\\\\\\\"first-false\\\\\\\"'),\\\",\\n    \\\"96\\\": \\\"    ])\\\",\\n    \\\"97\\\": \\\"    def test_nested_if_expressions(self, menai, expression, expected):\\\",\\n    \\\"98\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test nested if expressions.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"99\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"100\\\": \\\"\\\",\\n    \\\"101\\\": \\\"    def test_nested_if_lazy_evaluation(self, menai):\\\",\\n    \\\"102\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that nested if expressions maintain lazy evaluation.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"103\\\": \\\"        # Inner if should not be evaluated if outer condition is false\\\",\\n    \\\"104\\\": \\\"        result = menai.evaluate_and_format('(if #f (if undefined-condition \\\\\\\"inner\\\\\\\" \\\\\\\"inner\\\\\\\") \\\\\\\"outer\\\\\\\")')\\\",\\n    \\\"105\\\": \\\"        assert result == '\\\\\\\"outer\\\\\\\"'\\\",\\n    \\\"106\\\": \\\"\\\",\\n    \\\"107\\\": \\\"        # Only the chosen inner branch should be evaluated\\\",\\n    \\\"108\\\": \\\"        result = menai.evaluate_and_format('(if #t (if #t \\\\\\\"chosen\\\\\\\" (/ 1 0)) \\\\\\\"not-chosen\\\\\\\")')\\\",\\n    \\\"109\\\": \\\"        assert result == '\\\\\\\"chosen\\\\\\\"'\\\",\\n    \\\"110\\\": \\\"\\\",\\n    \\\"111\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"112\\\": \\\"        # Basic boolean AND\\\",\\n    \\\"113\\\": \\\"        ('(and)', '#t'),  # Identity case (empty and is true)\\\",\\n    \\\"114\\\": \\\"        ('(and #t)', '#t'),\\\",\\n    \\\"115\\\": \\\"        ('(and #f)', '#f'),\\\",\\n    \\\"116\\\": \\\"        ('(and #t #t)', '#t'),\\\",\\n    \\\"117\\\": \\\"        ('(and #t #f)', '#f'),\\\",\\n    \\\"118\\\": \\\"        ('(and #f #t)', '#f'),\\\",\\n    \\\"119\\\": \\\"        ('(and #f #f)', '#f'),\\\",\\n    \\\"120\\\": \\\"\\\",\\n    \\\"121\\\": \\\"        # Multiple arguments\\\",\\n    \\\"122\\\": \\\"        ('(and #t #t #t)', '#t'),\\\",\\n    \\\"123\\\": \\\"        ('(and #t #t #f)', '#f'),\\\",\\n    \\\"124\\\": \\\"        ('(and #f #t #t)', '#f'),  # Short-circuit evaluation\\\",\\n    \\\"125\\\": \\\"    ])\\\",\\n    \\\"126\\\": \\\"    def test_boolean_and_operation(self, menai, expression, expected):\\\",\\n    \\\"127\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test boolean AND operation.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"128\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"129\\\": \\\"\\\",\\n    \\\"130\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"131\\\": \\\"        # Basic boolean OR\\\",\\n    \\\"132\\\": \\\"        ('(or)', '#f'),  # Identity case (empty or is false)\\\",\\n    \\\"133\\\": \\\"        ('(or #t)', '#t'),\\\",\\n    \\\"134\\\": \\\"        ('(or #f)', '#f'),\\\",\\n    \\\"135\\\": \\\"        ('(or #t #t)', '#t'),\\\",\\n    \\\"136\\\": \\\"        ('(or #t #f)', '#t'),\\\",\\n    \\\"137\\\": \\\"        ('(or #f #t)', '#t'),\\\",\\n    \\\"138\\\": \\\"        ('(or #f #f)', '#f'),\\\",\\n    \\\"139\\\": \\\"\\\",\\n    \\\"140\\\": \\\"        # Multiple arguments\\\",\\n    \\\"141\\\": \\\"        ('(or #f #f #f)', '#f'),\\\",\\n    \\\"142\\\": \\\"        ('(or #f #f #t)', '#t'),\\\",\\n    \\\"143\\\": \\\"        ('(or #t #f #f)', '#t'),  # Short-circuit evaluation\\\",\\n    \\\"144\\\": \\\"    ])\\\",\\n    \\\"145\\\": \\\"    def test_boolean_or_operation(self, menai, expression, expected):\\\",\\n    \\\"146\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test boolean OR operation.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"147\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"148\\\": \\\"\\\",\\n    \\\"149\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"150\\\": \\\"        # Boolean NOT\\\",\\n    \\\"151\\\": \\\"        ('(boolean-not #t)', '#f'),\\\",\\n    \\\"152\\\": \\\"        ('(boolean-not #f)', '#t'),\\\",\\n    \\\"153\\\": \\\"    ])\\\",\\n    \\\"154\\\": \\\"    def test_boolean_not_operation(self, menai, expression, expected):\\\",\\n    \\\"155\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test boolean NOT operation.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"156\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"157\\\": \\\"\\\",\\n    \\\"158\\\": \\\"    def test_boolean_operations_require_boolean_arguments(self, menai):\\\",\\n    \\\"159\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that boolean operations require boolean condition arguments.\\\",\\n    \\\"160\\\": \\\"\\\",\\n    \\\"161\\\": \\\"        Since and/or are lowered to if-chains, only the condition arguments\\\",\\n    \\\"162\\\": \\\"        (all but the last) are type-checked as booleans by JUMP_IF_FALSE/TRUE.\\\",\\n    \\\"163\\\": \\\"        Non-boolean conditions always error. The last argument (the value\\\",\\n    \\\"164\\\": \\\"        returned when all conditions are true/false) is not type-checked.\\\",\\n    \\\"165\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"166\\\": \\\"        # Non-boolean used as condition always errors\\\",\\n    \\\"167\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"must be boolean\\\\\\\"):\\\",\\n    \\\"168\\\": \\\"            menai.evaluate('(and \\\\\\\"hello\\\\\\\" #t)')\\\",\\n    \\\"169\\\": \\\"\\\",\\n    \\\"170\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"must be boolean\\\\\\\"):\\\",\\n    \\\"171\\\": \\\"            menai.evaluate('(or 1 #f)')\\\",\\n    \\\"172\\\": \\\"\\\",\\n    \\\"173\\\": \\\"        # NOT with non-boolean arguments (boolean-not is still a typed opcode)\\\",\\n    \\\"174\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"requires boolean arguments\\\\\\\"):\\\",\\n    \\\"175\\\": \\\"            menai.evaluate('(boolean-not 1)')\\\",\\n    \\\"176\\\": \\\"\\\",\\n    \\\"177\\\": \\\"        with pytest.raises(MenaiEvalError, match=r\\\\\\\"requires boolean arguments\\\\\\\"):\\\",\\n    \\\"178\\\": \\\"            menai.evaluate('(boolean-not \\\\\\\"hello\\\\\\\")')\\\",\\n    \\\"179\\\": \\\"\\\",\\n    \\\"180\\\": \\\"    def test_not_requires_exactly_one_argument(self, menai):\\\",\\n    \\\"181\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that NOT requires exactly one argument.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"182\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"183\\\": \\\"            menai.evaluate('(boolean-not)')\\\",\\n    \\\"184\\\": \\\"\\\",\\n    \\\"185\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"186\\\": \\\"            menai.evaluate('(boolean-not #t #f)')\\\",\\n    \\\"187\\\": \\\"\\\",\\n    \\\"188\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"189\\\": \\\"        # Numeric equality\\\",\\n    \\\"190\\\": \\\"        ('(integer=? 1 1)', '#t'),\\\",\\n    \\\"191\\\": \\\"        ('(integer=? 1 2)', '#f'),\\\",\\n    \\\"192\\\": \\\"        ('(integer=? 1 1 1)', '#t'),\\\",\\n    \\\"193\\\": \\\"        ('(integer=? 1 1 2)', '#f'),\\\",\\n    \\\"194\\\": \\\"        ('(integer=? 5 5 5 5)', '#t'),\\\",\\n    \\\"195\\\": \\\"\\\",\\n    \\\"196\\\": \\\"        # String equality\\\",\\n    \\\"197\\\": \\\"        ('(string=? \\\\\\\"hello\\\\\\\" \\\\\\\"hello\\\\\\\")', '#t'),\\\",\\n    \\\"198\\\": \\\"        ('(string=? \\\\\\\"hello\\\\\\\" \\\\\\\"world\\\\\\\")', '#f'),\\\",\\n    \\\"199\\\": \\\"        ('(string=? \\\\\\\"test\\\\\\\" \\\\\\\"test\\\\\\\" \\\\\\\"test\\\\\\\")', '#t'),\\\",\\n    \\\"200\\\": \\\"\\\",\\n    \\\"201\\\": \\\"        # Boolean equality\\\",\\n    \\\"202\\\": \\\"        ('(boolean=? #t #t)', '#t'),\\\",\\n    \\\"203\\\": \\\"        ('(boolean=? #f #f)', '#t'),\\\",\\n    \\\"204\\\": \\\"        ('(boolean=? #t #f)', '#f'),\\\",\\n    \\\"205\\\": \\\"\\\",\\n    \\\"206\\\": \\\"        # List equality\\\",\\n    \\\"207\\\": \\\"        ('(list=? (list 1 2) (list 1 2))', '#t'),\\\",\\n    \\\"208\\\": \\\"        ('(list=? (list 1 2) (list 2 1))', '#f'),\\\",\\n    \\\"209\\\": \\\"        ('(list=? (list) (list))', '#t'),\\\",\\n    \\\"210\\\": \\\"\\\",\\n    \\\"211\\\": \\\"        # Complex number equality\\\",\\n    \\\"212\\\": \\\"        ('(complex=? (integer->complex 1 2) (integer->complex 1 2))', '#t'),\\\",\\n    \\\"213\\\": \\\"        ('(complex=? (integer->complex 1 2) (integer->complex 2 1))', '#f'),\\\",\\n    \\\"214\\\": \\\"    ])\\\",\\n    \\\"215\\\": \\\"    def test_equality_comparison(self, menai, expression, expected):\\\",\\n    \\\"216\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test equality comparison operator.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"217\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"218\\\": \\\"\\\",\\n    \\\"219\\\": \\\"    def test_equality_requires_at_least_two_arguments(self, menai):\\\",\\n    \\\"220\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that equality requires at least 2 arguments.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"221\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"222\\\": \\\"            menai.evaluate('(integer=?)')\\\",\\n    \\\"223\\\": \\\"\\\",\\n    \\\"224\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"225\\\": \\\"            menai.evaluate('(integer=? 1)')\\\",\\n    \\\"226\\\": \\\"\\\",\\n    \\\"227\\\": \\\"    @pytest.mark.parametrize(\\\\\\\"expression,expected\\\\\\\", [\\\",\\n    \\\"228\\\": \\\"        # Less than\\\",\\n    \\\"229\\\": \\\"        ('(integer<? 1 2)', '#t'),\\\",\\n    \\\"230\\\": \\\"        ('(integer<? 2 1)', '#f'),\\\",\\n    \\\"231\\\": \\\"        ('(integer<? 1 1)', '#f'),\\\",\\n    \\\"232\\\": \\\"        ('(integer<? 1 2 3)', '#t'),  # Chain: 1 < 2 < 3\\\",\\n    \\\"233\\\": \\\"        ('(integer<? 1 3 2)', '#f'),  # Chain fails: 3 < 2 is false\\\",\\n    \\\"234\\\": \\\"\\\",\\n    \\\"235\\\": \\\"        # Less than or equal\\\",\\n    \\\"236\\\": \\\"        ('(integer<=? 1 2)', '#t'),\\\",\\n    \\\"237\\\": \\\"        ('(integer<=? 2 1)', '#f'),\\\",\\n    \\\"238\\\": \\\"        ('(integer<=? 1 1)', '#t'),  # Equal case\\\",\\n    \\\"239\\\": \\\"        ('(integer<=? 1 1 2)', '#t'),\\\",\\n    \\\"240\\\": \\\"        ('(integer<=? 1 2 1)', '#f'),\\\",\\n    \\\"241\\\": \\\"\\\",\\n    \\\"242\\\": \\\"        # Greater than\\\",\\n    \\\"243\\\": \\\"        ('(integer>? 2 1)', '#t'),\\\",\\n    \\\"244\\\": \\\"        ('(integer>? 1 2)', '#f'),\\\",\\n    \\\"245\\\": \\\"        ('(integer>? 1 1)', '#f'),\\\",\\n    \\\"246\\\": \\\"        ('(integer>? 3 2 1)', '#t'),  # Chain: 3 > 2 > 1\\\",\\n    \\\"247\\\": \\\"        ('(integer>? 3 1 2)', '#f'),  # Chain fails: 1 > 2 is false\\\",\\n    \\\"248\\\": \\\"\\\",\\n    \\\"249\\\": \\\"        # Greater than or equal\\\",\\n    \\\"250\\\": \\\"        ('(integer>=? 2 1)', '#t'),\\\",\\n    \\\"251\\\": \\\"        ('(integer>=? 1 2)', '#f'),\\\",\\n    \\\"252\\\": \\\"        ('(integer>=? 1 1)', '#t'),  # Equal case\\\",\\n    \\\"253\\\": \\\"        ('(integer>=? 2 1 1)', '#t'),\\\",\\n    \\\"254\\\": \\\"        ('(integer>=? 1 1 2)', '#f'),\\\",\\n    \\\"255\\\": \\\"    ])\\\",\\n    \\\"256\\\": \\\"    def test_numeric_comparison_operations(self, menai, expression, expected):\\\",\\n    \\\"257\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test integer ordered comparison operations.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"258\\\": \\\"        assert menai.evaluate_and_format(expression) == expected\\\",\\n    \\\"259\\\": \\\"\\\",\\n    \\\"260\\\": \\\"    def test_comparison_operations_require_numeric_arguments(self, menai):\\\",\\n    \\\"261\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that typed comparison operations require the correct argument types.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"262\\\": \\\"        # integer ops reject floats, strings, and booleans\\\",\\n    \\\"263\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"integer<\\\\\\\\\\\\\\\\?.*requires integer arguments.*string\\\\\\\"):\\\",\\n    \\\"264\\\": \\\"            menai.evaluate('(integer<? \\\\\\\"hello\\\\\\\" 1)')\\\",\\n    \\\"265\\\": \\\"\\\",\\n    \\\"266\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"integer>\\\\\\\\\\\\\\\\?.*requires integer arguments.*boolean\\\\\\\"):\\\",\\n    \\\"267\\\": \\\"            menai.evaluate('(integer>? #t 1)')\\\",\\n    \\\"268\\\": \\\"\\\",\\n    \\\"269\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"integer<=\\\\\\\\\\\\\\\\?.*requires integer arguments.*float\\\\\\\"):\\\",\\n    \\\"270\\\": \\\"            menai.evaluate('(integer<=? 1 2.0)')\\\",\\n    \\\"271\\\": \\\"\\\",\\n    \\\"272\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"integer>=\\\\\\\\\\\\\\\\?.*requires integer arguments.*list\\\\\\\"):\\\",\\n    \\\"273\\\": \\\"            menai.evaluate('(integer>=? (list 1) 2)')\\\",\\n    \\\"274\\\": \\\"\\\",\\n    \\\"275\\\": \\\"        # float ops reject integers and strings\\\",\\n    \\\"276\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"float<\\\\\\\\\\\\\\\\?.*requires float arguments.*integer\\\\\\\"):\\\",\\n    \\\"277\\\": \\\"            menai.evaluate('(float<? 1.0 2)')\\\",\\n    \\\"278\\\": \\\"\\\",\\n    \\\"279\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"float>\\\\\\\\\\\\\\\\?.*requires float arguments.*string\\\\\\\"):\\\",\\n    \\\"280\\\": \\\"            menai.evaluate('(float>? \\\\\\\"a\\\\\\\" 1.0)')\\\",\\n    \\\"281\\\": \\\"\\\",\\n    \\\"282\\\": \\\"        # string ops reject integers and booleans\\\",\\n    \\\"283\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"string<=\\\\\\\\\\\\\\\\?.*requires string arguments.*integer\\\\\\\"):\\\",\\n    \\\"284\\\": \\\"            menai.evaluate('(string<=? \\\\\\\"a\\\\\\\" 1)')\\\",\\n    \\\"285\\\": \\\"\\\",\\n    \\\"286\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"string>=\\\\\\\\\\\\\\\\?.*requires string arguments.*boolean\\\\\\\"):\\\",\\n    \\\"287\\\": \\\"            menai.evaluate('(string>=? #t \\\\\\\"a\\\\\\\")')\\\",\\n    \\\"288\\\": \\\"\\\",\\n    \\\"289\\\": \\\"    def test_comparison_operations_require_at_least_two_arguments(self, menai):\\\",\\n    \\\"290\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that comparison operations require at least 2 arguments.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"291\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"292\\\": \\\"            menai.evaluate('(integer=?)')\\\",\\n    \\\"293\\\": \\\"\\\",\\n    \\\"294\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"295\\\": \\\"            menai.evaluate('(integer=? 1)')\\\",\\n    \\\"296\\\": \\\"\\\",\\n    \\\"297\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"298\\\": \\\"            menai.evaluate('(integer!=?)')\\\",\\n    \\\"299\\\": \\\"\\\",\\n    \\\"300\\\": \\\"        with pytest.raises(MenaiEvalError, match=\\\\\\\"has wrong number of arguments\\\\\\\"):\\\",\\n    \\\"301\\\": \\\"            menai.evaluate('(integer!=? 1)')\\\",\\n    \\\"302\\\": \\\"\\\",\\n    \\\"303\\\": \\\"    def test_complex_boolean_expressions(self, menai, helpers):\\\",\\n    \\\"304\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test complex combinations of boolean operations.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"305\\\": \\\"        # De Morgan's laws\\\",\\n    \\\"306\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"307\\\": \\\"            menai,\\\",\\n    \\\"308\\\": \\\"            '(boolean=? (boolean-not (and #t #f)) (or (boolean-not #t) (boolean-not #f)))',\\\",\\n    \\\"309\\\": \\\"            '#t'\\\",\\n    \\\"310\\\": \\\"        )\\\",\\n    \\\"311\\\": \\\"\\\",\\n    \\\"312\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"313\\\": \\\"            menai,\\\",\\n    \\\"314\\\": \\\"            '(boolean=? (boolean-not (or #t #f)) (and (boolean-not #t) (boolean-not #f)))',\\\",\\n    \\\"315\\\": \\\"            '#t'\\\",\\n    \\\"316\\\": \\\"        )\\\",\\n    \\\"317\\\": \\\"\\\",\\n    \\\"318\\\": \\\"        # Complex nested boolean logic\\\",\\n    \\\"319\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"320\\\": \\\"            menai,\\\",\\n    \\\"321\\\": \\\"            '(and (or #t #f) (boolean-not #f))',\\\",\\n    \\\"322\\\": \\\"            '#t'\\\",\\n    \\\"323\\\": \\\"        )\\\",\\n    \\\"324\\\": \\\"\\\",\\n    \\\"325\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"326\\\": \\\"            menai,\\\",\\n    \\\"327\\\": \\\"            '(or (and #t #f) (and #t #t))',\\\",\\n    \\\"328\\\": \\\"            '#t'\\\",\\n    \\\"329\\\": \\\"        )\\\",\\n    \\\"330\\\": \\\"\\\",\\n    \\\"331\\\": \\\"    def test_conditional_with_comparison_operations(self, menai, helpers):\\\",\\n    \\\"332\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test conditionals using comparison operations.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"333\\\": \\\"        # Safe division based on condition\\\",\\n    \\\"334\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"335\\\": \\\"            menai,\\\",\\n    \\\"336\\\": \\\"            '(if (integer>? 10 0) (float/ 20.0 10.0) \\\\\\\"undefined\\\\\\\")',\\\",\\n    \\\"337\\\": \\\"            '2.0'\\\",\\n    \\\"338\\\": \\\"        )\\\",\\n    \\\"339\\\": \\\"\\\",\\n    \\\"340\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"341\\\": \\\"            menai,\\\",\\n    \\\"342\\\": \\\"            '(if (integer=? 0 0) \\\\\\\"zero\\\\\\\" \\\\\\\"not zero\\\\\\\")',\\\",\\n    \\\"343\\\": \\\"            '\\\\\\\"zero\\\\\\\"'\\\",\\n    \\\"344\\\": \\\"        )\\\",\\n    \\\"345\\\": \\\"\\\",\\n    \\\"346\\\": \\\"        # Multiple conditions\\\",\\n    \\\"347\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"348\\\": \\\"            menai,\\\",\\n    \\\"349\\\": \\\"            '(if (and (integer>? 5 3) (integer<? 2 4)) \\\\\\\"both true\\\\\\\" \\\\\\\"at least one false\\\\\\\")',\\\",\\n    \\\"350\\\": \\\"            '\\\\\\\"both true\\\\\\\"'\\\",\\n    \\\"351\\\": \\\"        )\\\",\\n    \\\"352\\\": \\\"\\\",\\n    \\\"353\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"354\\\": \\\"            menai,\\\",\\n    \\\"355\\\": \\\"            '(if (or (integer>? 5 10) (integer<? 2 4)) \\\\\\\"at least one true\\\\\\\" \\\\\\\"both false\\\\\\\")',\\\",\\n    \\\"356\\\": \\\"            '\\\\\\\"at least one true\\\\\\\"'\\\",\\n    \\\"357\\\": \\\"        )\\\",\\n    \\\"358\\\": \\\"\\\",\\n    \\\"359\\\": \\\"    def test_conditional_with_list_predicates(self, menai, helpers):\\\",\\n    \\\"360\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test conditionals using list predicates.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"361\\\": \\\"        # Safe list operations\\\",\\n    \\\"362\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"363\\\": \\\"            menai,\\\",\\n    \\\"364\\\": \\\"            '(if (list-null? (list)) \\\\\\\"empty\\\\\\\" \\\\\\\"not empty\\\\\\\")',\\\",\\n    \\\"365\\\": \\\"            '\\\\\\\"empty\\\\\\\"'\\\",\\n    \\\"366\\\": \\\"        )\\\",\\n    \\\"367\\\": \\\"\\\",\\n    \\\"368\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"369\\\": \\\"            menai,\\\",\\n    \\\"370\\\": \\\"            '(if (list-member? (list 1 2 3) 2) \\\\\\\"found\\\\\\\" \\\\\\\"not found\\\\\\\")',\\\",\\n    \\\"371\\\": \\\"            '\\\\\\\"found\\\\\\\"'\\\",\\n    \\\"372\\\": \\\"        )\\\",\\n    \\\"373\\\": \\\"\\\",\\n    \\\"374\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"375\\\": \\\"            menai,\\\",\\n    \\\"376\\\": \\\"            '(if (list? (list 1 2)) \\\\\\\"is list\\\\\\\" \\\\\\\"not list\\\\\\\")',\\\",\\n    \\\"377\\\": \\\"            '\\\\\\\"is list\\\\\\\"'\\\",\\n    \\\"378\\\": \\\"        )\\\",\\n    \\\"379\\\": \\\"\\\",\\n    \\\"380\\\": \\\"    def test_conditional_with_string_predicates(self, menai, helpers):\\\",\\n    \\\"381\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test conditionals using string predicates.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"382\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"383\\\": \\\"            menai,\\\",\\n    \\\"384\\\": \\\"            '(if (integer? (string-index \\\\\\\"hello world\\\\\\\" \\\\\\\"world\\\\\\\")) \\\\\\\"found\\\\\\\" \\\\\\\"not found\\\\\\\")',\\\",\\n    \\\"385\\\": \\\"            '\\\\\\\"found\\\\\\\"'\\\",\\n    \\\"386\\\": \\\"        )\\\",\\n    \\\"387\\\": \\\"\\\",\\n    \\\"388\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"389\\\": \\\"            menai,\\\",\\n    \\\"390\\\": \\\"            '(if (string-prefix? \\\\\\\"hello\\\\\\\" \\\\\\\"he\\\\\\\") \\\\\\\"has prefix\\\\\\\" \\\\\\\"no prefix\\\\\\\")',\\\",\\n    \\\"391\\\": \\\"            '\\\\\\\"has prefix\\\\\\\"'\\\",\\n    \\\"392\\\": \\\"        )\\\",\\n    \\\"393\\\": \\\"\\\",\\n    \\\"394\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"395\\\": \\\"            menai,\\\",\\n    \\\"396\\\": \\\"            '(if (string=? \\\\\\\"test\\\\\\\" \\\\\\\"test\\\\\\\") \\\\\\\"equal\\\\\\\" \\\\\\\"not equal\\\\\\\")',\\\",\\n    \\\"397\\\": \\\"            '\\\\\\\"equal\\\\\\\"'\\\",\\n    \\\"398\\\": \\\"        )\\\",\\n    \\\"399\\\": \\\"\\\",\\n    \\\"400\\\": \\\"    def test_conditional_result_type_consistency(self, menai, helpers):\\\",\\n    \\\"401\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that conditionals can return any type consistently.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"402\\\": \\\"        # Return different numbers\\\",\\n    \\\"403\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #t 42 3.14)', '42')\\\",\\n    \\\"404\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #f 42 3.14)', '3.14')\\\",\\n    \\\"405\\\": \\\"\\\",\\n    \\\"406\\\": \\\"        # Return different strings\\\",\\n    \\\"407\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #t \\\\\\\"hello\\\\\\\" \\\\\\\"world\\\\\\\")', '\\\\\\\"hello\\\\\\\"')\\\",\\n    \\\"408\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #f \\\\\\\"hello\\\\\\\" \\\\\\\"world\\\\\\\")', '\\\\\\\"world\\\\\\\"')\\\",\\n    \\\"409\\\": \\\"\\\",\\n    \\\"410\\\": \\\"        # Return different booleans\\\",\\n    \\\"411\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #t #t #f)', '#t')\\\",\\n    \\\"412\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #f #t #f)', '#f')\\\",\\n    \\\"413\\\": \\\"\\\",\\n    \\\"414\\\": \\\"        # Return different lists\\\",\\n    \\\"415\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #t (list 1 2) (list 3 4))', '(1 2)')\\\",\\n    \\\"416\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #f (list 1 2) (list 3 4))', '(3 4)')\\\",\\n    \\\"417\\\": \\\"\\\",\\n    \\\"418\\\": \\\"        # Return different types (mixed)\\\",\\n    \\\"419\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #t 42 \\\\\\\"hello\\\\\\\")', '42')\\\",\\n    \\\"420\\\": \\\"        helpers.assert_evaluates_to(menai, '(if #f 42 \\\\\\\"hello\\\\\\\")', '\\\\\\\"hello\\\\\\\"')\\\",\\n    \\\"421\\\": \\\"\\\",\\n    \\\"422\\\": \\\"    def test_deeply_nested_conditionals(self, menai, helpers):\\\",\\n    \\\"423\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test deeply nested conditional expressions.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"424\\\": \\\"        # Nested ternary-like logic\\\",\\n    \\\"425\\\": \\\"        nested_expr = '''\\\",\\n    \\\"426\\\": \\\"        (if (integer>? 10 5)\\\",\\n    \\\"427\\\": \\\"            (if (integer<? 3 7)\\\",\\n    \\\"428\\\": \\\"                (if (integer=? 2 2) \\\\\\\"all true\\\\\\\" \\\\\\\"third false\\\\\\\")\\\",\\n    \\\"429\\\": \\\"                \\\\\\\"second false\\\\\\\")\\\",\\n    \\\"430\\\": \\\"            \\\\\\\"first false\\\\\\\")\\\",\\n    \\\"431\\\": \\\"        '''\\\",\\n    \\\"432\\\": \\\"        helpers.assert_evaluates_to(menai, nested_expr, '\\\\\\\"all true\\\\\\\"')\\\",\\n    \\\"433\\\": \\\"\\\",\\n    \\\"434\\\": \\\"        # Complex decision tree\\\",\\n    \\\"435\\\": \\\"        decision_tree = '''\\\",\\n    \\\"436\\\": \\\"        (if (integer>? 15 10)\\\",\\n    \\\"437\\\": \\\"            (if (integer<? 5 8)\\\",\\n    \\\"438\\\": \\\"                (if (integer=? 3 3) \\\",\\n    \\\"439\\\": \\\"                    (if #t \\\\\\\"deeply nested true\\\\\\\" \\\\\\\"impossible\\\\\\\")\\\",\\n    \\\"440\\\": \\\"                    \\\\\\\"equality false\\\\\\\")\\\",\\n    \\\"441\\\": \\\"                \\\\\\\"comparison false\\\\\\\")\\\",\\n    \\\"442\\\": \\\"            \\\\\\\"initial false\\\\\\\")\\\",\\n    \\\"443\\\": \\\"        '''\\\",\\n    \\\"444\\\": \\\"        helpers.assert_evaluates_to(menai, decision_tree, '\\\\\\\"deeply nested true\\\\\\\"')\\\",\\n    \\\"445\\\": \\\"\\\",\\n    \\\"446\\\": \\\"    def test_conditional_with_error_prone_expressions(self, menai, helpers):\\\",\\n    \\\"447\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test conditionals that prevent errors through lazy evaluation.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"448\\\": \\\"        # Division by zero prevention\\\",\\n    \\\"449\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"450\\\": \\\"            menai,\\\",\\n    \\\"451\\\": \\\"            '(if (integer=? 5 0) (/ 10 5) \\\\\\\"divisor is zero\\\\\\\")',\\\",\\n    \\\"452\\\": \\\"            '\\\\\\\"divisor is zero\\\\\\\"'\\\",\\n    \\\"453\\\": \\\"        )\\\",\\n    \\\"454\\\": \\\"\\\",\\n    \\\"455\\\": \\\"        # Empty list access prevention\\\",\\n    \\\"456\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"457\\\": \\\"            menai,\\\",\\n    \\\"458\\\": \\\"            '(if (list-null? (list)) \\\\\\\"list is empty\\\\\\\" (list-first (list)))',\\\",\\n    \\\"459\\\": \\\"            '\\\\\\\"list is empty\\\\\\\"'\\\",\\n    \\\"460\\\": \\\"        )\\\",\\n    \\\"461\\\": \\\"\\\",\\n    \\\"462\\\": \\\"        # Invalid string index prevention\\\",\\n    \\\"463\\\": \\\"        helpers.assert_evaluates_to(\\\",\\n    \\\"464\\\": \\\"            menai,\\\",\\n    \\\"465\\\": \\\"            '(if (integer<? (string-length \\\\\\\"hi\\\\\\\") 5) \\\\\\\"short string\\\\\\\" (string-ref \\\\\\\"hi\\\\\\\" 10))',\\\",\\n    \\\"466\\\": \\\"            '\\\\\\\"short string\\\\\\\"'\\\",\\n    \\\"467\\\": \\\"        )\\\",\\n    \\\"468\\\": \\\"\\\",\\n    \\\"469\\\": \\\"    def test_boolean_short_circuit_evaluation(self, menai):\\\",\\n    \\\"470\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that boolean operations use short-circuit evaluation.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"471\\\": \\\"        # AND short-circuit: if first is false, don't evaluate second\\\",\\n    \\\"472\\\": \\\"        result = menai.evaluate_and_format('(and #f (/ 1 0))')  # Should not cause division by zero\\\",\\n    \\\"473\\\": \\\"        assert result == '#f'\\\",\\n    \\\"474\\\": \\\"\\\",\\n    \\\"475\\\": \\\"        # OR short-circuit: if first is true, don't evaluate second\\\",\\n    \\\"476\\\": \\\"        result = menai.evaluate_and_format('(or #t (/ 1 0))')  # Should not cause division by zero\\\",\\n    \\\"477\\\": \\\"        assert result == '#t'\\\",\\n    \\\"478\\\": \\\"\\\",\\n    \\\"479\\\": \\\"    def test_comparison_chain_evaluation(self, menai, helpers):\\\",\\n    \\\"480\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Test that typed comparison operations evaluate as variadic chains.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"481\\\": \\\"        # All comparisons in chain must be true\\\",\\n    \\\"482\\\": \\\"        helpers.assert_evaluates_to(menai, '(integer<? 1 2 3 4 5)', '#t')\\\",\\n    \\\"483\\\": \\\"        helpers.assert_evaluates_to(menai, '(integer<? 1 2 5 4)', '#f')  # 5 < 4 is false\\\",\\n    \\\"484\\\": \\\"\\\",\\n    \\\"485\\\": \\\"        helpers.assert_evaluates_to(menai, '(integer>? 5 4 3 2 1)', '#t')\\\",\\n    \\\"486\\\": \\\"        helpers.assert_evaluates_to(menai, '(integer>? 5 4 1 3)', '#f')  # 1 > 3 is false\\\",\\n    \\\"487\\\": \\\"\\\",\\n    \\\"488\\\": \\\"        helpers.assert_evaluates_to(menai, '(integer<=? 1 1 2 2 3)', '#t')\\\",\\n    \\\"489\\\": \\\"        helpers.assert_evaluates_to(menai, '(integer>=? 3 2 2 1 1)', '#t')\\\"\\n  }\\n}\",\n  \"error\": null\n}\n```\n`content` is:\n```json\n{\n  \"range\": \"all lines\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"Tests for conditional operations and boolean logic.\\\"\\\"\\\"\",\n    \"2\": \"\",\n    \"3\": \"import pytest\",\n    \"4\": \"\",\n    \"5\": \"from menai import Menai, MenaiEvalError\",\n    \"6\": \"\",\n    \"7\": \"\",\n    \"8\": \"class TestConditionals:\",\n    \"9\": \"    \\\"\\\"\\\"Test conditional operations and boolean logic.\\\"\\\"\\\"\",\n    \"10\": \"\",\n    \"11\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"12\": \"        # Basic if expressions\",\n    \"13\": \"        ('(if #t \\\"yes\\\" \\\"no\\\")', '\\\"yes\\\"'),\",\n    \"14\": \"        ('(if #f \\\"yes\\\" \\\"no\\\")', '\\\"no\\\"'),\",\n    \"15\": \"\",\n    \"16\": \"        # If with numeric conditions\",\n    \"17\": \"        ('(if (integer>? 5 3) \\\"greater\\\" \\\"less\\\")', '\\\"greater\\\"'),\",\n    \"18\": \"        ('(if (integer<? 5 3) \\\"greater\\\" \\\"less\\\")', '\\\"less\\\"'),\",\n    \"19\": \"        ('(if (integer=? 5 5) \\\"equal\\\" \\\"not equal\\\")', '\\\"equal\\\"'),\",\n    \"20\": \"\",\n    \"21\": \"        # If with different result types\",\n    \"22\": \"        ('(if #t 42 0)', '42'),\",\n    \"23\": \"        ('(if #f 42 0)', '0'),\",\n    \"24\": \"        ('(if #t (list 1 2) (list 3 4))', '(1 2)'),\",\n    \"25\": \"        ('(if #f (list 1 2) (list 3 4))', '(3 4)'),\",\n    \"26\": \"\",\n    \"27\": \"        # If with complex expressions in branches\",\n    \"28\": \"        ('(if #t (integer+ 1 2) (integer* 3 4))', '3'),\",\n    \"29\": \"        ('(if #f (integer+ 1 2) (integer* 3 4))', '12'),\",\n    \"30\": \"    ])\",\n    \"31\": \"    def test_basic_if_expressions(self, menai, expression, expected):\",\n    \"32\": \"        \\\"\\\"\\\"Test basic if expressions with various conditions and result types.\\\"\\\"\\\"\",\n    \"33\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"34\": \"\",\n    \"35\": \"    def test_if_lazy_evaluation_prevents_errors(self, menai):\",\n    \"36\": \"        \\\"\\\"\\\"Test that if expressions use lazy evaluation to prevent errors.\\\"\\\"\\\"\",\n    \"37\": \"        # Division by zero in unused branch should not cause error\",\n    \"38\": \"        result = menai.evaluate_and_format('(if #t 42 (integer/ 1 0))')\",\n    \"39\": \"        assert result == '42'\",\n    \"40\": \"\",\n    \"41\": \"        result = menai.evaluate_and_format('(if #f (integer/ 1 0) 24)')\",\n    \"42\": \"        assert result == '24'\",\n    \"43\": \"\",\n    \"44\": \"        # Undefined symbol in unused branch should not cause error\",\n    \"45\": \"        result = menai.evaluate_and_format('(if #t \\\"safe\\\" undefined-symbol)')\",\n    \"46\": \"        assert result == '\\\"safe\\\"'\",\n    \"47\": \"\",\n    \"48\": \"        result = menai.evaluate_and_format('(if #f undefined-symbol \\\"safe\\\")')\",\n    \"49\": \"        assert result == '\\\"safe\\\"'\",\n    \"50\": \"\",\n    \"51\": \"    def test_if_lazy_evaluation_with_complex_conditions(self, menai):\",\n    \"52\": \"        \\\"\\\"\\\"Test lazy evaluation with more complex scenarios.\\\"\\\"\\\"\",\n    \"53\": \"        # Safe list operations\",\n    \"54\": \"        result = menai.evaluate_and_format('(if (list-null? (list)) \\\"empty\\\" (list-first (list)))')\",\n    \"55\": \"        assert result == '\\\"empty\\\"'\",\n    \"56\": \"\",\n    \"57\": \"        # The false branch would cause an error if evaluated\",\n    \"58\": \"        result = menai.evaluate_and_format('(if (integer>? 10 5) \\\"big\\\" (list-first (list)))')\",\n    \"59\": \"        assert result == '\\\"big\\\"'\",\n    \"60\": \"\",\n    \"61\": \"    def test_if_requires_boolean_condition(self, menai):\",\n    \"62\": \"        \\\"\\\"\\\"Test that if expressions require boolean conditions.\\\"\\\"\\\"\",\n    \"63\": \"        with pytest.raises(MenaiEvalError, match=r\\\"condition must be boolean\\\"):\",\n    \"64\": \"            menai.evaluate('(if 1 \\\"yes\\\" \\\"no\\\")')\",\n    \"65\": \"\",\n    \"66\": \"        with pytest.raises(MenaiEvalError, match=r\\\"condition must be boolean\\\"):\",\n    \"67\": \"            menai.evaluate('(if \\\"hello\\\" \\\"yes\\\" \\\"no\\\")')\",\n    \"68\": \"\",\n    \"69\": \"        with pytest.raises(MenaiEvalError, match=r\\\"condition must be boolean\\\"):\",\n    \"70\": \"            menai.evaluate('(if (list 1 2) \\\"yes\\\" \\\"no\\\")')\",\n    \"71\": \"\",\n    \"72\": \"        with pytest.raises(MenaiEvalError, match=r\\\"condition must be boolean\\\"):\",\n    \"73\": \"            menai.evaluate('(if 0 \\\"yes\\\" \\\"no\\\")')  # 0 is not false in Menai\",\n    \"74\": \"\",\n    \"75\": \"    def test_if_requires_exactly_three_arguments(self, menai):\",\n    \"76\": \"        \\\"\\\"\\\"Test that if expressions require exactly 3 arguments.\\\"\\\"\\\"\",\n    \"77\": \"        with pytest.raises(MenaiEvalError, match=r\\\"wrong number of arguments[\\\\s\\\\S]*Exactly 3 arguments\\\"):\",\n    \"78\": \"            menai.evaluate('(if #t \\\"yes\\\")')  # Missing else branch\",\n    \"79\": \"\",\n    \"80\": \"        with pytest.raises(MenaiEvalError, match=r\\\"wrong number of arguments[\\\\s\\\\S]*Exactly 3 arguments\\\"):\",\n    \"81\": \"            menai.evaluate('(if #t)')  # Missing both branches\",\n    \"82\": \"\",\n    \"83\": \"        with pytest.raises(MenaiEvalError, match=r\\\"wrong number of arguments[\\\\s\\\\S]*Exactly 3 arguments\\\"):\",\n    \"84\": \"            menai.evaluate('(if #t \\\"yes\\\" \\\"no\\\" \\\"extra\\\")')  # Too many arguments\",\n    \"85\": \"\",\n    \"86\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"87\": \"        # Nested if expressions\",\n    \"88\": \"        ('(if #t (if #t \\\"inner-true\\\" \\\"inner-false\\\") \\\"outer-false\\\")', '\\\"inner-true\\\"'),\",\n    \"89\": \"        ('(if #t (if #f \\\"inner-true\\\" \\\"inner-false\\\") \\\"outer-false\\\")', '\\\"inner-false\\\"'),\",\n    \"90\": \"        ('(if #f (if #t \\\"inner-true\\\" \\\"inner-false\\\") \\\"outer-false\\\")', '\\\"outer-false\\\"'),\",\n    \"91\": \"\",\n    \"92\": \"        # Complex nested conditions\",\n    \"93\": \"        ('(if (integer>? 10 5) (if (integer<? 3 7) \\\"both-true\\\" \\\"first-true-second-false\\\") \\\"first-false\\\")', '\\\"both-true\\\"'),\",\n    \"94\": \"        ('(if (integer>? 10 5) (if (integer>? 3 7) \\\"both-true\\\" \\\"first-true-second-false\\\") \\\"first-false\\\")', '\\\"first-true-second-false\\\"'),\",\n    \"95\": \"        ('(if (integer<? 10 5) (if (integer<? 3 7) \\\"both-true\\\" \\\"first-false-second-true\\\") \\\"first-false\\\")', '\\\"first-false\\\"'),\",\n    \"96\": \"    ])\",\n    \"97\": \"    def test_nested_if_expressions(self, menai, expression, expected):\",\n    \"98\": \"        \\\"\\\"\\\"Test nested if expressions.\\\"\\\"\\\"\",\n    \"99\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"100\": \"\",\n    \"101\": \"    def test_nested_if_lazy_evaluation(self, menai):\",\n    \"102\": \"        \\\"\\\"\\\"Test that nested if expressions maintain lazy evaluation.\\\"\\\"\\\"\",\n    \"103\": \"        # Inner if should not be evaluated if outer condition is false\",\n    \"104\": \"        result = menai.evaluate_and_format('(if #f (if undefined-condition \\\"inner\\\" \\\"inner\\\") \\\"outer\\\")')\",\n    \"105\": \"        assert result == '\\\"outer\\\"'\",\n    \"106\": \"\",\n    \"107\": \"        # Only the chosen inner branch should be evaluated\",\n    \"108\": \"        result = menai.evaluate_and_format('(if #t (if #t \\\"chosen\\\" (/ 1 0)) \\\"not-chosen\\\")')\",\n    \"109\": \"        assert result == '\\\"chosen\\\"'\",\n    \"110\": \"\",\n    \"111\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"112\": \"        # Basic boolean AND\",\n    \"113\": \"        ('(and)', '#t'),  # Identity case (empty and is true)\",\n    \"114\": \"        ('(and #t)', '#t'),\",\n    \"115\": \"        ('(and #f)', '#f'),\",\n    \"116\": \"        ('(and #t #t)', '#t'),\",\n    \"117\": \"        ('(and #t #f)', '#f'),\",\n    \"118\": \"        ('(and #f #t)', '#f'),\",\n    \"119\": \"        ('(and #f #f)', '#f'),\",\n    \"120\": \"\",\n    \"121\": \"        # Multiple arguments\",\n    \"122\": \"        ('(and #t #t #t)', '#t'),\",\n    \"123\": \"        ('(and #t #t #f)', '#f'),\",\n    \"124\": \"        ('(and #f #t #t)', '#f'),  # Short-circuit evaluation\",\n    \"125\": \"    ])\",\n    \"126\": \"    def test_boolean_and_operation(self, menai, expression, expected):\",\n    \"127\": \"        \\\"\\\"\\\"Test boolean AND operation.\\\"\\\"\\\"\",\n    \"128\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"129\": \"\",\n    \"130\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"131\": \"        # Basic boolean OR\",\n    \"132\": \"        ('(or)', '#f'),  # Identity case (empty or is false)\",\n    \"133\": \"        ('(or #t)', '#t'),\",\n    \"134\": \"        ('(or #f)', '#f'),\",\n    \"135\": \"        ('(or #t #t)', '#t'),\",\n    \"136\": \"        ('(or #t #f)', '#t'),\",\n    \"137\": \"        ('(or #f #t)', '#t'),\",\n    \"138\": \"        ('(or #f #f)', '#f'),\",\n    \"139\": \"\",\n    \"140\": \"        # Multiple arguments\",\n    \"141\": \"        ('(or #f #f #f)', '#f'),\",\n    \"142\": \"        ('(or #f #f #t)', '#t'),\",\n    \"143\": \"        ('(or #t #f #f)', '#t'),  # Short-circuit evaluation\",\n    \"144\": \"    ])\",\n    \"145\": \"    def test_boolean_or_operation(self, menai, expression, expected):\",\n    \"146\": \"        \\\"\\\"\\\"Test boolean OR operation.\\\"\\\"\\\"\",\n    \"147\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"148\": \"\",\n    \"149\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"150\": \"        # Boolean NOT\",\n    \"151\": \"        ('(boolean-not #t)', '#f'),\",\n    \"152\": \"        ('(boolean-not #f)', '#t'),\",\n    \"153\": \"    ])\",\n    \"154\": \"    def test_boolean_not_operation(self, menai, expression, expected):\",\n    \"155\": \"        \\\"\\\"\\\"Test boolean NOT operation.\\\"\\\"\\\"\",\n    \"156\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"157\": \"\",\n    \"158\": \"    def test_boolean_operations_require_boolean_arguments(self, menai):\",\n    \"159\": \"        \\\"\\\"\\\"Test that boolean operations require boolean condition arguments.\",\n    \"160\": \"\",\n    \"161\": \"        Since and/or are lowered to if-chains, only the condition arguments\",\n    \"162\": \"        (all but the last) are type-checked as booleans by JUMP_IF_FALSE/TRUE.\",\n    \"163\": \"        Non-boolean conditions always error. The last argument (the value\",\n    \"164\": \"        returned when all conditions are true/false) is not type-checked.\",\n    \"165\": \"        \\\"\\\"\\\"\",\n    \"166\": \"        # Non-boolean used as condition always errors\",\n    \"167\": \"        with pytest.raises(MenaiEvalError, match=r\\\"must be boolean\\\"):\",\n    \"168\": \"            menai.evaluate('(and \\\"hello\\\" #t)')\",\n    \"169\": \"\",\n    \"170\": \"        with pytest.raises(MenaiEvalError, match=r\\\"must be boolean\\\"):\",\n    \"171\": \"            menai.evaluate('(or 1 #f)')\",\n    \"172\": \"\",\n    \"173\": \"        # NOT with non-boolean arguments (boolean-not is still a typed opcode)\",\n    \"174\": \"        with pytest.raises(MenaiEvalError, match=r\\\"requires boolean arguments\\\"):\",\n    \"175\": \"            menai.evaluate('(boolean-not 1)')\",\n    \"176\": \"\",\n    \"177\": \"        with pytest.raises(MenaiEvalError, match=r\\\"requires boolean arguments\\\"):\",\n    \"178\": \"            menai.evaluate('(boolean-not \\\"hello\\\")')\",\n    \"179\": \"\",\n    \"180\": \"    def test_not_requires_exactly_one_argument(self, menai):\",\n    \"181\": \"        \\\"\\\"\\\"Test that NOT requires exactly one argument.\\\"\\\"\\\"\",\n    \"182\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"183\": \"            menai.evaluate('(boolean-not)')\",\n    \"184\": \"\",\n    \"185\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"186\": \"            menai.evaluate('(boolean-not #t #f)')\",\n    \"187\": \"\",\n    \"188\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"189\": \"        # Numeric equality\",\n    \"190\": \"        ('(integer=? 1 1)', '#t'),\",\n    \"191\": \"        ('(integer=? 1 2)', '#f'),\",\n    \"192\": \"        ('(integer=? 1 1 1)', '#t'),\",\n    \"193\": \"        ('(integer=? 1 1 2)', '#f'),\",\n    \"194\": \"        ('(integer=? 5 5 5 5)', '#t'),\",\n    \"195\": \"\",\n    \"196\": \"        # String equality\",\n    \"197\": \"        ('(string=? \\\"hello\\\" \\\"hello\\\")', '#t'),\",\n    \"198\": \"        ('(string=? \\\"hello\\\" \\\"world\\\")', '#f'),\",\n    \"199\": \"        ('(string=? \\\"test\\\" \\\"test\\\" \\\"test\\\")', '#t'),\",\n    \"200\": \"\",\n    \"201\": \"        # Boolean equality\",\n    \"202\": \"        ('(boolean=? #t #t)', '#t'),\",\n    \"203\": \"        ('(boolean=? #f #f)', '#t'),\",\n    \"204\": \"        ('(boolean=? #t #f)', '#f'),\",\n    \"205\": \"\",\n    \"206\": \"        # List equality\",\n    \"207\": \"        ('(list=? (list 1 2) (list 1 2))', '#t'),\",\n    \"208\": \"        ('(list=? (list 1 2) (list 2 1))', '#f'),\",\n    \"209\": \"        ('(list=? (list) (list))', '#t'),\",\n    \"210\": \"\",\n    \"211\": \"        # Complex number equality\",\n    \"212\": \"        ('(complex=? (integer->complex 1 2) (integer->complex 1 2))', '#t'),\",\n    \"213\": \"        ('(complex=? (integer->complex 1 2) (integer->complex 2 1))', '#f'),\",\n    \"214\": \"    ])\",\n    \"215\": \"    def test_equality_comparison(self, menai, expression, expected):\",\n    \"216\": \"        \\\"\\\"\\\"Test equality comparison operator.\\\"\\\"\\\"\",\n    \"217\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"218\": \"\",\n    \"219\": \"    def test_equality_requires_at_least_two_arguments(self, menai):\",\n    \"220\": \"        \\\"\\\"\\\"Test that equality requires at least 2 arguments.\\\"\\\"\\\"\",\n    \"221\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"222\": \"            menai.evaluate('(integer=?)')\",\n    \"223\": \"\",\n    \"224\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"225\": \"            menai.evaluate('(integer=? 1)')\",\n    \"226\": \"\",\n    \"227\": \"    @pytest.mark.parametrize(\\\"expression,expected\\\", [\",\n    \"228\": \"        # Less than\",\n    \"229\": \"        ('(integer<? 1 2)', '#t'),\",\n    \"230\": \"        ('(integer<? 2 1)', '#f'),\",\n    \"231\": \"        ('(integer<? 1 1)', '#f'),\",\n    \"232\": \"        ('(integer<? 1 2 3)', '#t'),  # Chain: 1 < 2 < 3\",\n    \"233\": \"        ('(integer<? 1 3 2)', '#f'),  # Chain fails: 3 < 2 is false\",\n    \"234\": \"\",\n    \"235\": \"        # Less than or equal\",\n    \"236\": \"        ('(integer<=? 1 2)', '#t'),\",\n    \"237\": \"        ('(integer<=? 2 1)', '#f'),\",\n    \"238\": \"        ('(integer<=? 1 1)', '#t'),  # Equal case\",\n    \"239\": \"        ('(integer<=? 1 1 2)', '#t'),\",\n    \"240\": \"        ('(integer<=? 1 2 1)', '#f'),\",\n    \"241\": \"\",\n    \"242\": \"        # Greater than\",\n    \"243\": \"        ('(integer>? 2 1)', '#t'),\",\n    \"244\": \"        ('(integer>? 1 2)', '#f'),\",\n    \"245\": \"        ('(integer>? 1 1)', '#f'),\",\n    \"246\": \"        ('(integer>? 3 2 1)', '#t'),  # Chain: 3 > 2 > 1\",\n    \"247\": \"        ('(integer>? 3 1 2)', '#f'),  # Chain fails: 1 > 2 is false\",\n    \"248\": \"\",\n    \"249\": \"        # Greater than or equal\",\n    \"250\": \"        ('(integer>=? 2 1)', '#t'),\",\n    \"251\": \"        ('(integer>=? 1 2)', '#f'),\",\n    \"252\": \"        ('(integer>=? 1 1)', '#t'),  # Equal case\",\n    \"253\": \"        ('(integer>=? 2 1 1)', '#t'),\",\n    \"254\": \"        ('(integer>=? 1 1 2)', '#f'),\",\n    \"255\": \"    ])\",\n    \"256\": \"    def test_numeric_comparison_operations(self, menai, expression, expected):\",\n    \"257\": \"        \\\"\\\"\\\"Test integer ordered comparison operations.\\\"\\\"\\\"\",\n    \"258\": \"        assert menai.evaluate_and_format(expression) == expected\",\n    \"259\": \"\",\n    \"260\": \"    def test_comparison_operations_require_numeric_arguments(self, menai):\",\n    \"261\": \"        \\\"\\\"\\\"Test that typed comparison operations require the correct argument types.\\\"\\\"\\\"\",\n    \"262\": \"        # integer ops reject floats, strings, and booleans\",\n    \"263\": \"        with pytest.raises(MenaiEvalError, match=\\\"integer<\\\\\\\\?.*requires integer arguments.*string\\\"):\",\n    \"264\": \"            menai.evaluate('(integer<? \\\"hello\\\" 1)')\",\n    \"265\": \"\",\n    \"266\": \"        with pytest.raises(MenaiEvalError, match=\\\"integer>\\\\\\\\?.*requires integer arguments.*boolean\\\"):\",\n    \"267\": \"            menai.evaluate('(integer>? #t 1)')\",\n    \"268\": \"\",\n    \"269\": \"        with pytest.raises(MenaiEvalError, match=\\\"integer<=\\\\\\\\?.*requires integer arguments.*float\\\"):\",\n    \"270\": \"            menai.evaluate('(integer<=? 1 2.0)')\",\n    \"271\": \"\",\n    \"272\": \"        with pytest.raises(MenaiEvalError, match=\\\"integer>=\\\\\\\\?.*requires integer arguments.*list\\\"):\",\n    \"273\": \"            menai.evaluate('(integer>=? (list 1) 2)')\",\n    \"274\": \"\",\n    \"275\": \"        # float ops reject integers and strings\",\n    \"276\": \"        with pytest.raises(MenaiEvalError, match=\\\"float<\\\\\\\\?.*requires float arguments.*integer\\\"):\",\n    \"277\": \"            menai.evaluate('(float<? 1.0 2)')\",\n    \"278\": \"\",\n    \"279\": \"        with pytest.raises(MenaiEvalError, match=\\\"float>\\\\\\\\?.*requires float arguments.*string\\\"):\",\n    \"280\": \"            menai.evaluate('(float>? \\\"a\\\" 1.0)')\",\n    \"281\": \"\",\n    \"282\": \"        # string ops reject integers and booleans\",\n    \"283\": \"        with pytest.raises(MenaiEvalError, match=\\\"string<=\\\\\\\\?.*requires string arguments.*integer\\\"):\",\n    \"284\": \"            menai.evaluate('(string<=? \\\"a\\\" 1)')\",\n    \"285\": \"\",\n    \"286\": \"        with pytest.raises(MenaiEvalError, match=\\\"string>=\\\\\\\\?.*requires string arguments.*boolean\\\"):\",\n    \"287\": \"            menai.evaluate('(string>=? #t \\\"a\\\")')\",\n    \"288\": \"\",\n    \"289\": \"    def test_comparison_operations_require_at_least_two_arguments(self, menai):\",\n    \"290\": \"        \\\"\\\"\\\"Test that comparison operations require at least 2 arguments.\\\"\\\"\\\"\",\n    \"291\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"292\": \"            menai.evaluate('(integer=?)')\",\n    \"293\": \"\",\n    \"294\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"295\": \"            menai.evaluate('(integer=? 1)')\",\n    \"296\": \"\",\n    \"297\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"298\": \"            menai.evaluate('(integer!=?)')\",\n    \"299\": \"\",\n    \"300\": \"        with pytest.raises(MenaiEvalError, match=\\\"has wrong number of arguments\\\"):\",\n    \"301\": \"            menai.evaluate('(integer!=? 1)')\",\n    \"302\": \"\",\n    \"303\": \"    def test_complex_boolean_expressions(self, menai, helpers):\",\n    \"304\": \"        \\\"\\\"\\\"Test complex combinations of boolean operations.\\\"\\\"\\\"\",\n    \"305\": \"        # De Morgan's laws\",\n    \"306\": \"        helpers.assert_evaluates_to(\",\n    \"307\": \"            menai,\",\n    \"308\": \"            '(boolean=? (boolean-not (and #t #f)) (or (boolean-not #t) (boolean-not #f)))',\",\n    \"309\": \"            '#t'\",\n    \"310\": \"        )\",\n    \"311\": \"\",\n    \"312\": \"        helpers.assert_evaluates_to(\",\n    \"313\": \"            menai,\",\n    \"314\": \"            '(boolean=? (boolean-not (or #t #f)) (and (boolean-not #t) (boolean-not #f)))',\",\n    \"315\": \"            '#t'\",\n    \"316\": \"        )\",\n    \"317\": \"\",\n    \"318\": \"        # Complex nested boolean logic\",\n    \"319\": \"        helpers.assert_evaluates_to(\",\n    \"320\": \"            menai,\",\n    \"321\": \"            '(and (or #t #f) (boolean-not #f))',\",\n    \"322\": \"            '#t'\",\n    \"323\": \"        )\",\n    \"324\": \"\",\n    \"325\": \"        helpers.assert_evaluates_to(\",\n    \"326\": \"            menai,\",\n    \"327\": \"            '(or (and #t #f) (and #t #t))',\",\n    \"328\": \"            '#t'\",\n    \"329\": \"        )\",\n    \"330\": \"\",\n    \"331\": \"    def test_conditional_with_comparison_operations(self, menai, helpers):\",\n    \"332\": \"        \\\"\\\"\\\"Test conditionals using comparison operations.\\\"\\\"\\\"\",\n    \"333\": \"        # Safe division based on condition\",\n    \"334\": \"        helpers.assert_evaluates_to(\",\n    \"335\": \"            menai,\",\n    \"336\": \"            '(if (integer>? 10 0) (float/ 20.0 10.0) \\\"undefined\\\")',\",\n    \"337\": \"            '2.0'\",\n    \"338\": \"        )\",\n    \"339\": \"\",\n    \"340\": \"        helpers.assert_evaluates_to(\",\n    \"341\": \"            menai,\",\n    \"342\": \"            '(if (integer=? 0 0) \\\"zero\\\" \\\"not zero\\\")',\",\n    \"343\": \"            '\\\"zero\\\"'\",\n    \"344\": \"        )\",\n    \"345\": \"\",\n    \"346\": \"        # Multiple conditions\",\n    \"347\": \"        helpers.assert_evaluates_to(\",\n    \"348\": \"            menai,\",\n    \"349\": \"            '(if (and (integer>? 5 3) (integer<? 2 4)) \\\"both true\\\" \\\"at least one false\\\")',\",\n    \"350\": \"            '\\\"both true\\\"'\",\n    \"351\": \"        )\",\n    \"352\": \"\",\n    \"353\": \"        helpers.assert_evaluates_to(\",\n    \"354\": \"            menai,\",\n    \"355\": \"            '(if (or (integer>? 5 10) (integer<? 2 4)) \\\"at least one true\\\" \\\"both false\\\")',\",\n    \"356\": \"            '\\\"at least one true\\\"'\",\n    \"357\": \"        )\",\n    \"358\": \"\",\n    \"359\": \"    def test_conditional_with_list_predicates(self, menai, helpers):\",\n    \"360\": \"        \\\"\\\"\\\"Test conditionals using list predicates.\\\"\\\"\\\"\",\n    \"361\": \"        # Safe list operations\",\n    \"362\": \"        helpers.assert_evaluates_to(\",\n    \"363\": \"            menai,\",\n    \"364\": \"            '(if (list-null? (list)) \\\"empty\\\" \\\"not empty\\\")',\",\n    \"365\": \"            '\\\"empty\\\"'\",\n    \"366\": \"        )\",\n    \"367\": \"\",\n    \"368\": \"        helpers.assert_evaluates_to(\",\n    \"369\": \"            menai,\",\n    \"370\": \"            '(if (list-member? (list 1 2 3) 2) \\\"found\\\" \\\"not found\\\")',\",\n    \"371\": \"            '\\\"found\\\"'\",\n    \"372\": \"        )\",\n    \"373\": \"\",\n    \"374\": \"        helpers.assert_evaluates_to(\",\n    \"375\": \"            menai,\",\n    \"376\": \"            '(if (list? (list 1 2)) \\\"is list\\\" \\\"not list\\\")',\",\n    \"377\": \"            '\\\"is list\\\"'\",\n    \"378\": \"        )\",\n    \"379\": \"\",\n    \"380\": \"    def test_conditional_with_string_predicates(self, menai, helpers):\",\n    \"381\": \"        \\\"\\\"\\\"Test conditionals using string predicates.\\\"\\\"\\\"\",\n    \"382\": \"        helpers.assert_evaluates_to(\",\n    \"383\": \"            menai,\",\n    \"384\": \"            '(if (integer? (string-index \\\"hello world\\\" \\\"world\\\")) \\\"found\\\" \\\"not found\\\")',\",\n    \"385\": \"            '\\\"found\\\"'\",\n    \"386\": \"        )\",\n    \"387\": \"\",\n    \"388\": \"        helpers.assert_evaluates_to(\",\n    \"389\": \"            menai,\",\n    \"390\": \"            '(if (string-prefix? \\\"hello\\\" \\\"he\\\") \\\"has prefix\\\" \\\"no prefix\\\")',\",\n    \"391\": \"            '\\\"has prefix\\\"'\",\n    \"392\": \"        )\",\n    \"393\": \"\",\n    \"394\": \"        helpers.assert_evaluates_to(\",\n    \"395\": \"            menai,\",\n    \"396\": \"            '(if (string=? \\\"test\\\" \\\"test\\\") \\\"equal\\\" \\\"not equal\\\")',\",\n    \"397\": \"            '\\\"equal\\\"'\",\n    \"398\": \"        )\",\n    \"399\": \"\",\n    \"400\": \"    def test_conditional_result_type_consistency(self, menai, helpers):\",\n    \"401\": \"        \\\"\\\"\\\"Test that conditionals can return any type consistently.\\\"\\\"\\\"\",\n    \"402\": \"        # Return different numbers\",\n    \"403\": \"        helpers.assert_evaluates_to(menai, '(if #t 42 3.14)', '42')\",\n    \"404\": \"        helpers.assert_evaluates_to(menai, '(if #f 42 3.14)', '3.14')\",\n    \"405\": \"\",\n    \"406\": \"        # Return different strings\",\n    \"407\": \"        helpers.assert_evaluates_to(menai, '(if #t \\\"hello\\\" \\\"world\\\")', '\\\"hello\\\"')\",\n    \"408\": \"        helpers.assert_evaluates_to(menai, '(if #f \\\"hello\\\" \\\"world\\\")', '\\\"world\\\"')\",\n    \"409\": \"\",\n    \"410\": \"        # Return different booleans\",\n    \"411\": \"        helpers.assert_evaluates_to(menai, '(if #t #t #f)', '#t')\",\n    \"412\": \"        helpers.assert_evaluates_to(menai, '(if #f #t #f)', '#f')\",\n    \"413\": \"\",\n    \"414\": \"        # Return different lists\",\n    \"415\": \"        helpers.assert_evaluates_to(menai, '(if #t (list 1 2) (list 3 4))', '(1 2)')\",\n    \"416\": \"        helpers.assert_evaluates_to(menai, '(if #f (list 1 2) (list 3 4))', '(3 4)')\",\n    \"417\": \"\",\n    \"418\": \"        # Return different types (mixed)\",\n    \"419\": \"        helpers.assert_evaluates_to(menai, '(if #t 42 \\\"hello\\\")', '42')\",\n    \"420\": \"        helpers.assert_evaluates_to(menai, '(if #f 42 \\\"hello\\\")', '\\\"hello\\\"')\",\n    \"421\": \"\",\n    \"422\": \"    def test_deeply_nested_conditionals(self, menai, helpers):\",\n    \"423\": \"        \\\"\\\"\\\"Test deeply nested conditional expressions.\\\"\\\"\\\"\",\n    \"424\": \"        # Nested ternary-like logic\",\n    \"425\": \"        nested_expr = '''\",\n    \"426\": \"        (if (integer>? 10 5)\",\n    \"427\": \"            (if (integer<? 3 7)\",\n    \"428\": \"                (if (integer=? 2 2) \\\"all true\\\" \\\"third false\\\")\",\n    \"429\": \"                \\\"second false\\\")\",\n    \"430\": \"            \\\"first false\\\")\",\n    \"431\": \"        '''\",\n    \"432\": \"        helpers.assert_evaluates_to(menai, nested_expr, '\\\"all true\\\"')\",\n    \"433\": \"\",\n    \"434\": \"        # Complex decision tree\",\n    \"435\": \"        decision_tree = '''\",\n    \"436\": \"        (if (integer>? 15 10)\",\n    \"437\": \"            (if (integer<? 5 8)\",\n    \"438\": \"                (if (integer=? 3 3) \",\n    \"439\": \"                    (if #t \\\"deeply nested true\\\" \\\"impossible\\\")\",\n    \"440\": \"                    \\\"equality false\\\")\",\n    \"441\": \"                \\\"comparison false\\\")\",\n    \"442\": \"            \\\"initial false\\\")\",\n    \"443\": \"        '''\",\n    \"444\": \"        helpers.assert_evaluates_to(menai, decision_tree, '\\\"deeply nested true\\\"')\",\n    \"445\": \"\",\n    \"446\": \"    def test_conditional_with_error_prone_expressions(self, menai, helpers):\",\n    \"447\": \"        \\\"\\\"\\\"Test conditionals that prevent errors through lazy evaluation.\\\"\\\"\\\"\",\n    \"448\": \"        # Division by zero prevention\",\n    \"449\": \"        helpers.assert_evaluates_to(\",\n    \"450\": \"            menai,\",\n    \"451\": \"            '(if (integer=? 5 0) (/ 10 5) \\\"divisor is zero\\\")',\",\n    \"452\": \"            '\\\"divisor is zero\\\"'\",\n    \"453\": \"        )\",\n    \"454\": \"\",\n    \"455\": \"        # Empty list access prevention\",\n    \"456\": \"        helpers.assert_evaluates_to(\",\n    \"457\": \"            menai,\",\n    \"458\": \"            '(if (list-null? (list)) \\\"list is empty\\\" (list-first (list)))',\",\n    \"459\": \"            '\\\"list is empty\\\"'\",\n    \"460\": \"        )\",\n    \"461\": \"\",\n    \"462\": \"        # Invalid string index prevention\",\n    \"463\": \"        helpers.assert_evaluates_to(\",\n    \"464\": \"            menai,\",\n    \"465\": \"            '(if (integer<? (string-length \\\"hi\\\") 5) \\\"short string\\\" (string-ref \\\"hi\\\" 10))',\",\n    \"466\": \"            '\\\"short string\\\"'\",\n    \"467\": \"        )\",\n    \"468\": \"\",\n    \"469\": \"    def test_boolean_short_circuit_evaluation(self, menai):\",\n    \"470\": \"        \\\"\\\"\\\"Test that boolean operations use short-circuit evaluation.\\\"\\\"\\\"\",\n    \"471\": \"        # AND short-circuit: if first is false, don't evaluate second\",\n    \"472\": \"        result = menai.evaluate_and_format('(and #f (/ 1 0))')  # Should not cause division by zero\",\n    \"473\": \"        assert result == '#f'\",\n    \"474\": \"\",\n    \"475\": \"        # OR short-circuit: if first is true, don't evaluate second\",\n    \"476\": \"        result = menai.evaluate_and_format('(or #t (/ 1 0))')  # Should not cause division by zero\",\n    \"477\": \"        assert result == '#t'\",\n    \"478\": \"\",\n    \"479\": \"    def test_comparison_chain_evaluation(self, menai, helpers):\",\n    \"480\": \"        \\\"\\\"\\\"Test that typed comparison operations evaluate as variadic chains.\\\"\\\"\\\"\",\n    \"481\": \"        # All comparisons in chain must be true\",\n    \"482\": \"        helpers.assert_evaluates_to(menai, '(integer<? 1 2 3 4 5)', '#t')\",\n    \"483\": \"        helpers.assert_evaluates_to(menai, '(integer<? 1 2 5 4)', '#f')  # 5 < 4 is false\",\n    \"484\": \"\",\n    \"485\": \"        helpers.assert_evaluates_to(menai, '(integer>? 5 4 3 2 1)', '#t')\",\n    \"486\": \"        helpers.assert_evaluates_to(menai, '(integer>? 5 4 1 3)', '#f')  # 1 > 3 is false\",\n    \"487\": \"\",\n    \"488\": \"        helpers.assert_evaluates_to(menai, '(integer<=? 1 1 2 2 3)', '#t')\",\n    \"489\": \"        helpers.assert_evaluates_to(menai, '(integer>=? 3 2 2 1 1)', '#t')\"\n  }\n}\n```",
