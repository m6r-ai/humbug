          "content": "{\n  \"range\": \"1-80\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"Main Menai (AI Functional Programming Language) class with enhanced error messages.\\\"\\\"\\\"\",\n    \"2\": \"\",\n    \"3\": \"import hashlib\",\n    \"4\": \"import math\",\n    \"5\": \"from pathlib import Path\",\n    \"6\": \"import os\",\n    \"7\": \"from typing import Union, Dict, List, Iterator\",\n    \"8\": \"from contextlib import contextmanager\",\n    \"9\": \"\",\n    \"10\": \"from menai.menai_compiler import MenaiCompiler\",\n    \"11\": \"from menai.menai_ast import MenaiASTNode\",\n    \"12\": \"from menai.menai_value import MenaiDict, MenaiFunction, MenaiFloat, MenaiString, MenaiValue\",\n    \"13\": \"from menai.menai_vm import MenaiVM, MenaiTraceWatcher\",\n    \"14\": \"from menai.menai_error import MenaiModuleNotFoundError, MenaiModuleError, MenaiCircularImportError\",\n    \"15\": \"\",\n    \"16\": \"\",\n    \"17\": \"class Menai:\",\n    \"18\": \"    \\\"\\\"\\\"\",\n    \"19\": \"    Menai (AI Functional Programming Language) calculator with LISP-like syntax and enhanced error messages.\",\n    \"20\": \"\",\n    \"21\": \"    This version provides comprehensive error reporting with:\",\n    \"22\": \"    - Clear explanations of what went wrong\",\n    \"23\": \"    - Context showing the problematic input\",\n    \"24\": \"    - Suggestions for how to fix the problem\",\n    \"25\": \"    - Examples of correct usage\",\n    \"26\": \"    - Position information where helpful\",\n    \"27\": \"\",\n    \"28\": \"    Designed specifically to help LLMs understand and self-correct errors.\",\n    \"29\": \"\",\n    \"30\": \"    Execution Model:\",\n    \"31\": \"    - Uses bytecode ir_builder and VM for all evaluation\",\n    \"32\": \"    - Tail-call optimized for recursive functions\",\n    \"33\": \"    - High performance through bytecode compilation and optimized VM\",\n    \"34\": \"    \\\"\\\"\\\"\",\n    \"35\": \"\",\n    \"36\": \"    # Menai implementations of higher-order functions\",\n    \"37\": \"    _PRELUDE_SOURCE = \\\"\\\"\\\"\",\n    \"38\": \"(letrec\",\n    \"39\": \"  ((function? (lambda (x) ($function? x)))\",\n    \"40\": \"   (function=? (lambda (a b) ($function=? a b)))\",\n    \"41\": \"   (function!=? (lambda (a b) ($function!=? a b)))\",\n    \"42\": \"   (function-min-arity (lambda (f) ($function-min-arity f)))\",\n    \"43\": \"   (function-variadic? (lambda (f) ($function-variadic? f)))\",\n    \"44\": \"   (function-accepts? (lambda (f n) ($function-accepts? f n)))\",\n    \"45\": \"   (symbol? (lambda (x) ($symbol? x)))\",\n    \"46\": \"   (symbol=? (lambda (a b) ($symbol=? a b)))\",\n    \"47\": \"   (symbol!=? (lambda (a b) ($symbol!=? a b)))\",\n    \"48\": \"   (symbol->string (lambda (sym) ($symbol->string sym)))\",\n    \"49\": \"   (none? (lambda (x) ($none? x)))\",\n    \"50\": \"   (boolean? (lambda (x) ($boolean? x)))\",\n    \"51\": \"   (boolean=? (lambda (. args)\",\n    \"52\": \"                (if ($integer<? ($list-length args) 2)\",\n    \"53\": \"                    (error \\\"Function 'boolean=?' requires at least 2 arguments\\\")\",\n    \"54\": \"                    (letrec\",\n    \"55\": \"                      ((loop (lambda (lst prev)\",\n    \"56\": \"                               (if ($list-null? lst)\",\n    \"57\": \"                                   #t\",\n    \"58\": \"                                   (if ($boolean=? prev (list-first lst))\",\n    \"59\": \"                                       (loop (list-rest lst) ($list-first lst))\",\n    \"60\": \"                                       #f)))))\",\n    \"61\": \"                      (loop ($list-rest args) ($list-first args))))))\",\n    \"62\": \"   (boolean!=? (lambda (. args)\",\n    \"63\": \"                 (if ($integer<? ($list-length args) 2)\",\n    \"64\": \"                     (error \\\"Function 'boolean!=?' requires at least 2 arguments\\\")\",\n    \"65\": \"         