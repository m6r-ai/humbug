      "content": "```json\n{\n  \"id\": \"toolu_016yuXpWTJZuSEJUY6UN3a5w\",\n  \"name\": \"filesystem\",\n  \"content\": \"{\\n  \\\"range\\\": \\\"148-215\\\",\\n  \\\"lines\\\": {\\n    \\\"148\\\": \\\"    @staticmethod\\\",\\n    \\\"149\\\": \\\"    def _unwrap_return(node: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\\\",\\n    \\\"150\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Return (inner, was_wrapped) \\\\u2014 strips a MenaiIRReturn wrapper if present.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"151\\\": \\\"        if isinstance(node, MenaiIRReturn):\\\",\\n    \\\"152\\\": \\\"            return node.value_plan, True\\\",\\n    \\\"153\\\": \\\"        return node, False\\\",\\n    \\\"154\\\": \\\"\\\",\\n    \\\"155\\\": \\\"    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\\\",\\n    \\\"156\\\": \\\"        opt_condition = self._opt(ir.condition_plan, frame_stack)\\\",\\n    \\\"157\\\": \\\"        opt_then = self._opt(ir.then_plan, frame_stack)\\\",\\n    \\\"158\\\": \\\"        opt_else = self._opt(ir.else_plan, frame_stack)\\\",\\n    \\\"159\\\": \\\"\\\",\\n    \\\"160\\\": \\\"        # Constant-condition elimination:\\\",\\n    \\\"161\\\": \\\"        #   (if #t then else)  \\\\u2192  then\\\",\\n    \\\"162\\\": \\\"        #   (if #f then else)  \\\\u2192  else\\\",\\n    \\\"163\\\": \\\"        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\\\",\\n    \\\"164\\\": \\\"            self._eliminations += 1\\\",\\n    \\\"165\\\": \\\"            if opt_condition.value.value:\\\",\\n    \\\"166\\\": \\\"                return opt_then\\\",\\n    \\\"167\\\": \\\"\\\",\\n    \\\"168\\\": \\\"            return opt_else\\\",\\n    \\\"169\\\": \\\"\\\",\\n    \\\"170\\\": \\\"        # Boolean identity elimination:\\\",\\n    \\\"171\\\": \\\"        #   (if <cond> #t #f)  \\\\u2192  <cond>\\\",\\n    \\\"172\\\": \\\"        #   (if <cond> #f #t)  \\\\u2192  (boolean-not <cond>)\\\",\\n    \\\"173\\\": \\\"        #\\\",\\n    \\\"174\\\": \\\"        # The IR builder wraps tail-position branches in MenaiIRReturn, so we\\\",\\n    \\\"175\\\": \\\"        # must look through any such wrapper before checking for boolean constants.\\\",\\n    \\\"176\\\": \\\"        # When the branches are wrapped, the replacement is also wrapped so that\\\",\\n    \\\"177\\\": \\\"        # the caller sees the same node shape it would have from the original if.\\\",\\n    \\\"178\\\": \\\"        then_inner, then_wrapped = self._unwrap_return(opt_then)\\\",\\n    \\\"179\\\": \\\"        else_inner, else_wrapped = self._unwrap_return(opt_else)\\\",\\n    \\\"180\\\": \\\"        assert then_wrapped == else_wrapped, \\\\\\\"Branches must both be wrapped or both bare\\\\\\\"\\\",\\n    \\\"181\\\": \\\"        if (isinstance(then_inner, MenaiIRConstant)\\\",\\n    \\\"182\\\": \\\"                and isinstance(then_inner.value, MenaiBoolean)\\\",\\n    \\\"183\\\": \\\"                and isinstance(else_inner, MenaiIRConstant)\\\",\\n    \\\"184\\\": \\\"                and isinstance(else_inner.value, MenaiBoolean)):\\\",\\n    \\\"185\\\": \\\"            if then_inner.value.value and not else_inner.value.value:\\\",\\n    \\\"186\\\": \\\"                # (if cond #t #f) \\\\u2192  cond  (or Return(cond) in tail position)\\\",\\n    \\\"187\\\": \\\"                self._eliminations += 1\\\",\\n    \\\"188\\\": \\\"                if then_wrapped:\\\",\\n    \\\"189\\\": \\\"                    return MenaiIRReturn(value_plan=opt_condition)\\\",\\n    \\\"190\\\": \\\"                return opt_condition\\\",\\n    \\\"191\\\": \\\"\\\",\\n    \\\"192\\\": \\\"            if not then_inner.value.value and else_inner.value.value:\\\",\\n    \\\"193\\\": \\\"                # (if cond #f #t) \\\\u2192 (boolean-not cond)\\\",\\n    \\\"194\\\": \\\"                self._eliminations += 1\\\",\\n    \\\"195\\\": \\\"                not_call = MenaiIRCall(\\\",\\n    \\\"196\\\": \\\"                    func_plan=MenaiIRVariable(\\\",\\n    \\\"197\\\": \\\"                            name='boolean-not', var_type='global'\\\",\\n    \\\"198\\\": \\\"                    ),\\\",\\n    \\\"199\\\": \\\"                    arg_plans=[opt_condition],\\\",\\n    \\\"200\\\": \\\"                    is_tail_call=ir.in_tail_position,\\\",\\n    \\\"201\\\": \\\"                    is_builtin=True,\\\",\\n    \\\"202\\\": \\\"                    builtin_name='boolean-not',\\\",\\n    \\\"203\\\": \\\"                )\\\",\\n    \\\"204\\\": \\\"                if then_wrapped:\\\",\\n    \\\"205\\\": \\\"                    return MenaiIRReturn(value_plan=not_call)\\\",\\n    \\\"206\\\": \\\"                return not_call\\\",\\n    \\\"207\\\": \\\"\\\",\\n    \\\"208\\\": \\\"        return MenaiIRIf(\\\",\\n    \\\"209\\\": \\\"            condition_plan=opt_condition,\\\",\\n    \\\"210\\\": \\\"            then_plan=opt_then,\\\",\\n    \\\"211\\\": \\\"            else_plan=opt_else,\\\",\\n    \\\"212\\\": \\\"            in_tail_position=ir.in_tail_position,\\\",\\n    \\\"213\\\": \\\"        )\\\",\\n    \\\"214\\\": \\\"\\\",\\n    \\\"215\\\": \\\"    def _opt_lambda(self, ir: MenaiIRLambda, frame_stack: List[int]) -> MenaiIRLambda:\\\"\\n  }\\n}\",\n  \"error\": null\n}\n```\n`content` is:\n```json\n{\n  \"range\": \"148-215\",\n  \"lines\": {\n    \"148\": \"    @staticmethod\",\n    \"149\": \"    def _unwrap_return(node: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\",\n    \"150\": \"        \\\"\\\"\\\"Return (inner, was_wrapped) \\u2014 strips a MenaiIRReturn wrapper if present.\\\"\\\"\\\"\",\n    \"151\": \"        if isinstance(node, MenaiIRReturn):\",\n    \"152\": \"            return node.value_plan, True\",\n    \"153\": \"        return node, False\",\n    \"154\": \"\",\n    \"155\": \"    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\",\n    \"156\": \"        opt_condition = self._opt(ir.condition_plan, frame_stack)\",\n    \"157\": \"        opt_then = self._opt(ir.then_plan, frame_stack)\",\n    \"158\": \"        opt_else = self._opt(ir.else_plan, frame_stack)\",\n    \"159\": \"\",\n    \"160\": \"        # Constant-condition elimination:\",\n    \"161\": \"        #   (if #t then else)  \\u2192  then\",\n    \"162\": \"        #   (if #f then else)  \\u2192  else\",\n    \"163\": \"        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\",\n    \"164\": \"            self._eliminations += 1\",\n    \"165\": \"            if opt_condition.value.value:\",\n    \"166\": \"                return opt_then\",\n    \"167\": \"\",\n    \"168\": \"            return opt_else\",\n    \"169\": \"\",\n    \"170\": \"        # Boolean identity elimination:\",\n    \"171\": \"        #   (if <cond> #t #f)  \\u2192  <cond>\",\n    \"172\": \"        #   (if <cond> #f #t)  \\u2192  (boolean-not <cond>)\",\n    \"173\": \"        #\",\n    \"174\": \"        # The IR builder wraps tail-position branches in MenaiIRReturn, so we\",\n    \"175\": \"        # must look through any such wrapper before checking for boolean constants.\",\n    \"176\": \"        # When the branches are wrapped, the replacement is also wrapped so that\",\n    \"177\": \"        # the caller sees the same node shape it would have from the original if.\",\n    \"178\": \"        then_inner, then_wrapped = self._unwrap_return(opt_then)\",\n    \"179\": \"        else_inner, else_wrapped = self._unwrap_return(opt_else)\",\n    \"180\": \"        assert then_wrapped == else_wrapped, \\\"Branches must both be wrapped or both bare\\\"\",\n    \"181\": \"        if (isinstance(then_inner, MenaiIRConstant)\",\n    \"182\": \"                and isinstance(then_inner.value, MenaiBoolean)\",\n    \"183\": \"                and isinstance(else_inner, MenaiIRConstant)\",\n    \"184\": \"                and isinstance(else_inner.value, MenaiBoolean)):\",\n    \"185\": \"            if then_inner.value.value and not else_inner.value.value:\",\n    \"186\": \"                # (if cond #t #f) \\u2192  cond  (or Return(cond) in tail position)\",\n    \"187\": \"                self._eliminations += 1\",\n    \"188\": \"                if then_wrapped:\",\n    \"189\": \"                    return MenaiIRReturn(value_plan=opt_condition)\",\n    \"190\": \"                return opt_condition\",\n    \"191\": \"\",\n    \"192\": \"            if not then_inner.value.value and else_inner.value.value:\",\n    \"193\": \"                # (if cond #f #t) \\u2192 (boolean-not cond)\",\n    \"194\": \"                self._eliminations += 1\",\n    \"195\": \"                not_call = MenaiIRCall(\",\n    \"196\": \"                    func_plan=MenaiIRVariable(\",\n    \"197\": \"                            name='boolean-not', var_type='global'\",\n    \"198\": \"                    ),\",\n    \"199\": \"                    arg_plans=[opt_condition],\",\n    \"200\": \"                    is_tail_call=ir.in_tail_position,\",\n    \"201\": \"                    is_builtin=True,\",\n    \"202\": \"                    builtin_name='boolean-not',\",\n    \"203\": \"                )\",\n    \"204\": \"                if then_wrapped:\",\n    \"205\": \"                    return MenaiIRReturn(value_plan=not_call)\",\n    \"206\": \"                return not_call\",\n    \"207\": \"\",\n    \"208\": \"        return MenaiIRIf(\",\n    \"209\": \"            condition_plan=opt_condition,\",\n    \"210\": \"            then_plan=opt_then,\",\n    \"211\": \"            else_plan=opt_else,\",\n    \"212\": \"            in_tail_position=ir.in_tail_position,\",\n    \"213\": \"        )\",\n    \"214\": \"\",\n    \"215\": \"    def _opt_lambda(self, ir: MenaiIRLambda, frame_stack: List[int]) -> MenaiIRLambda:\"\n  }\n}\n```",
