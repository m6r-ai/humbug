    {
      "id": "adf3e616-ee52-47e4-9091-32ba84cd1f61",
      "timestamp": "2026-03-08T11:18:33.670431+00:00",
      "type": "tool_result",
      "content": "```json\n{\n  \"id\": \"toolu_01Wk5itmx4EFk8HQmVwJdLx8\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"\\nMenai AST Desugarer - transforms complex constructs into core language.\\n\\nThe desugarer takes a full AST (including match, and, or) and transforms it\\ninto a core AST containing only:\\n- Literals (numbers, strings, booleans)\\n- Variables (symbols)\\n- If expressions\\n- Let expressions\\n- Lambda expressions\\n- Function calls\\n\\nThis simplifies the compiler and enables better optimization.\\n\\\"\\\"\\\"\\n\\nfrom typing import List, Set, Tuple, Any, cast\\n\\nfrom menai.menai_ast import (\\n    MenaiASTNode, MenaiASTSymbol, MenaiASTList, MenaiASTInteger,\\n    MenaiASTFloat, MenaiASTComplex, MenaiASTString, MenaiASTBoolean, MenaiASTNone\\n)\\nfrom menai.menai_ast_dependency_analyzer import MenaiASTDependencyAnalyzer\\nfrom menai.menai_builtin_registry import MenaiBuiltinRegistry\\nfrom menai.menai_error import MenaiEvalError\\n\\n\\nclass MenaiASTDesugarer:\\n    \\\"\\\"\\\"Transforms complex Menai constructs into core language.\\\"\\\"\\\"\\n\\n    def __init__(self) -> None:\\n        self.temp_counter = 0  # For generating unique temp variable names\\n\\n    def _make_symbol(self, name: str, source_node: MenaiASTNode) -> MenaiASTSymbol:\\n        \\\"\\\"\\\"Create a symbol with source location from another node.\\\"\\\"\\\"\\n        return MenaiASTSymbol(\\n            name,\\n            line=source_node.line,\\n            column=source_node.column,\\n            source_file=source_node.source_file\\n        )\\n\\n    def _make_list(self, elements: tuple, source_node: MenaiASTNode) -> MenaiASTList:\\n        \\\"\\\"\\\"Create a list with source location from another node.\\\"\\\"\\\"\\n        return MenaiASTList(\\n            elements,\\n            line=source_node.line,\\n            column=source_node.column,\\n            source_file=source_node.source_file\\n        )\\n\\n    def _make_and(self, exprs: List[MenaiASTNode], source_node: MenaiASTNode) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Construct (and exprs...) as a lowered if-chain without going through desugar().\\n\\n        Used internally when building AST nodes that must already be in desugared\\n        form (e.g. inside _desugar_pattern, _desugar_fixed_list_pattern).\\n\\n        (and)      -> #t\\n        (and A)    -> A\\n        (and A B+) -> (if A (and B+) #f)\\n        \\\"\\\"\\\"\\n        if not exprs:\\n            return MenaiASTBoolean(\\n                True,\\n                line=source_node.line,\\n                column=source_node.column,\\n                source_file=source_node.source_file\\n            )\\n\\n        if len(exprs) == 1:\\n            return exprs[0]\\n\\n        return self._make_list((\\n            self._make_symbol('if', source_node),\\n            exprs[0],\\n            self._make_and(exprs[1:], source_node),\\n            MenaiASTBoolean(\\n                False,\\n                line=source_node.line,\\n                column=source_node.column,\\n                source_file=source_node.source_file\\n            ),\\n        ), source_node)\\n\\n    def _make_or(self, exprs: List[MenaiASTNode], source_node: MenaiASTNode) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Construct (or exprs...) as a lowered if-chain without going through desugar().\\n\\n        Used internally when building AST nodes that must already be in desugared\\n        form (e.g. inside _desugar_strict_equality_chain).\\n\\n        (or)      -> #f\\n        (or A)    -> A\\n        (or A B+) -> (if A #t (or B+))\\n        \\\"\\\"\\\"\\n        if not exprs:\\n            return MenaiASTBoolean(\\n                False,\\n                line=source_node.line,\\n                column=source_node.column,\\n                source_file=source_node.source_file\\n            )\\n\\n        if len(exprs) == 1:\\n            return exprs[0]\\n\\n        return self._make_list((\\n            self._make_symbol('if', source_node),\\n            exprs[0],\\n            MenaiASTBoolean(\\n                True,\\n                line=source_node.line,\\n                column=source_node.column,\\n                source_file=source_node.source_file\\n            ),\\n            self._make_or(exprs[1:], source_node),\\n        ), source_node)\\n\\n    def _desugar_and(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar (and A B ...) to a right-folded if-chain.\\n\\n        (and)      -> #t\\n        (and A)    -> (desugar A)\\n        (and A B+) -> (if (desugar A) (desugar (and B+)) #f)\\n        \\\"\\\"\\\"\\n        args = list(expr.elements[1:])\\n        if not args:\\n            return MenaiASTBoolean(True, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n        if len(args) == 1:\\n            return self.desugar(args[0])\\n\\n        desugared_first = self.desugar(args[0])\\n        rest_expr = self._make_list((self._make_symbol('and', expr),) + tuple(args[1:]), expr)\\n        desugared_rest = self._desugar_and(rest_expr)\\n        return self._make_list((\\n            self._make_symbol('if', expr),\\n            desugared_first,\\n            desugared_rest,\\n            MenaiASTBoolean(False, line=expr.line, column=expr.column, source_file=expr.source_file),\\n        ), expr)\\n\\n    def _desugar_or(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar (or A B ...) to a right-folded if-chain.\\n\\n        (or)      -> #f\\n        (or A)    -> (desugar A)\\n        (or A B+) -> (if (desugar A) #t (desugar (or B+)))\\n        \\\"\\\"\\\"\\n        args = list(expr.elements[1:])\\n        if not args:\\n            return MenaiASTBoolean(False, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n        if len(args) == 1:\\n            return self.desugar(args[0])\\n\\n        desugared_first = self.desugar(args[0])\\n        rest_expr = self._make_list((self._make_symbol('or', expr),) + tuple(args[1:]), expr)\\n        desugared_rest = self._desugar_or(rest_expr)\\n        return self._make_list((\\n            self._make_symbol('if', expr),\\n            desugared_first,\\n            MenaiASTBoolean(True, line=expr.line, column=expr.column, source_file=expr.source_file),\\n            desugared_rest,\\n        ), expr)\\n\\n    def desugar(self, expr: MenaiASTNode) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar an expression recursively.\\n\\n        Args:\\n            expr: AST to desugar\\n\\n        Returns:\\n            Desugared AST (core language only)\\n        \\\"\\\"\\\"\\n        # Lists need inspection - anything else does not\\n        if not isinstance(expr, MenaiASTList):\\n            return expr\\n\\n        if expr.is_empty():\\n            return expr\\n\\n        first = expr.first()\\n        if isinstance(first, MenaiASTSymbol):\\n            name = first.name\\n\\n            # Match expression - desugar it!\\n            if name == 'match':\\n                return self._desugar_match(expr)\\n\\n            # Core constructs - desugar children only\\n            if name == 'if':\\n                return self._desugar_if(expr)\\n\\n            if name == 'let':\\n                return self._desugar_let(expr)\\n\\n            if name == 'letrec':\\n                return self._desugar_letrec(expr)\\n\\n            if name == 'let*':\\n                # Let* desugars to nested lets\\n                return self._desugar_let_star(expr)\\n\\n            if name == 'lambda':\\n                return self._desugar_lambda(expr)\\n\\n            if name == 'quote':\\n                # Quote: don't desugar the quoted expression\\n                return expr\\n\\n            if name == 'trace':\\n                # Trace is a special form - handle it\\n                return self._desugar_trace(expr)\\n\\n            if name == 'and':\\n                return self._desugar_and(expr)\\n\\n            if name == 'or':\\n                return self._desugar_or(expr)\\n\\n            # Fixed-arity opcode rewrite: if this call is to a known builtin\\n            # with exactly its primitive arity, rewrite the function name to the\\n            # $-prefixed primitive form.  This fires before\\n            # the variadic/comparison/equality rewrites so that e.g.\\n            # (integer+ a b) \\u2192 ($integer+ a b) directly, while\\n            # (integer+ a b c) still falls through to _desugar_variadic_arithmetic.\\n            #\\n            # Several builtins have optional trailing arguments whose opcodes\\n            # always require the full argument count.  When the user omits the\\n            # optional argument(s) the desugarer synthesises the missing default\\n            # so that the $-prefixed opcode call is always fully saturated:\\n            #\\n            #   Constant defaults (1-arg min, 2-arg opcode):\\n            #     (integer->complex n)     \\u2192 ($integer->complex n 0)\\n            #     (integer->string n)      \\u2192 ($integer->string n 10)\\n            #     (float->complex x)       \\u2192 ($float->complex x 0.0)\\n            #     (string->integer s)      \\u2192 ($string->integer s 10)\\n            #     (string->list s)         \\u2192 ($string->list s \\\"\\\")\\n            #     (list->string l)         \\u2192 ($list->string l \\\"\\\")\\n            #\\n            #   Constant defaults (2-arg min, 3-arg opcode):\\n            #     (dict-get d k)           \\u2192 ($dict-get d k #none)\\n            #     (range start end)        \\u2192 ($range start end 1)\\n            #\\n            #   Computed defaults (2-arg min, 3-arg opcode):\\n            #     (string-slice s start)   \\u2192 (let ((#:t s)) ($string-slice #:t start ($string-length #:t)))\\n            #     (list-slice   l start)   \\u2192 (let ((#:t l)) ($list-slice #:t start ($list-length #:t)))\\n            #\\n            # The computed-default cases bind the collection argument to a temp\\n            # to avoid evaluating it twice.\\n            primitive_arity = MenaiBuiltinRegistry.get_primitive_arity(name)\\n            if primitive_arity is not None:\\n                n_args = len(expr.elements) - 1\\n                if n_args == primitive_arity:\\n                    dollar_name = '$' + name\\n                    desugared_args = [self.desugar(arg) for arg in expr.elements[1:]]\\n                    return self._make_list(\\n                        (self._make_symbol(dollar_name, expr),) + tuple(desugared_args),\\n                        expr\\n                    )\\n                # Constant-default completions.\\n                constant_defaults: dict[str, MenaiASTNode] = {\\n                    'integer->complex': MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'integer->string': MenaiASTInteger(10, line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'float->complex': MenaiASTFloat(0.0, line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'string->integer': MenaiASTInteger(10, line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'string->list': MenaiASTString(\\\"\\\", line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'list->string': MenaiASTString(\\\"\\\", line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'dict-get': MenaiASTNone(line=expr.line, column=expr.column, source_file=expr.source_file),\\n                    'range': MenaiASTInteger(1, line=expr.line, column=expr.column, source_file=expr.source_file),\\n                }\\n                if name in constant_defaults and n_args == primitive_arity - 1:\\n                    default = constant_defaults[name]\\n                    desugared_args = [self.desugar(arg) for arg in expr.elements[1:]]\\n                    return self._make_list(\\n                        (self._make_symbol('$' + name, expr),) + tuple(desugared_args) + (default,),\\n                        expr\\n                    )\\n                # Computed-default completions: bind the collection to a temp to\\n                # avoid double-evaluation, then synthesise the length call.\\n                if name in ('string-slice', 'list-slice') and n_args == 2:\\n                    length_fn = 'string-length' if name == 'string-slice' else 'list-length'\\n                    coll_arg = self.desugar(expr.elements[1])\\n                    start_arg = self.desugar(expr.elements[2])\\n                    temp = self._gen_temp()\\n                    temp_sym = self._make_symbol(temp, expr)\\n                    length_call = self._make_list((\\n                        self._make_symbol('$' + length_fn, expr),\\n                        temp_sym,\\n                    ), expr)\\n                    slice_call = self._make_list((\\n                        self._make_symbol('$' + name, expr),\\n                        temp_sym,\\n                        start_arg,\\n                        length_call,\\n                    ), expr)\\n                    return self._make_list((\\n                        self._make_symbol('let', expr),\\n                        self._make_list((\\n                            self._make_list((temp_sym, coll_arg), expr),\\n                        ), expr),\\n                        slice_call,\\n                    ), expr)\\n\\n            # Check for typed variadic arithmetic operations\\n            if name in [\\n                'integer+', 'integer-', 'integer*', 'integer/',\\n                'float+', 'float-', 'float*', 'float/',\\n                'complex+', 'complex-', 'complex*', 'complex/',\\n            ]:\\n                return self._desugar_variadic_arithmetic(expr)\\n\\n            # Fold-reducible variadic operations\\n            if name in [\\n                'integer-bit-or', 'integer-bit-and', 'integer-bit-xor',\\n                'integer-min', 'integer-max',\\n                'float-min', 'float-max',\\n                'list-concat',\\n                'string-concat',\\n            ]:\\n                return self._desugar_fold_variadic(expr)\\n\\n            # Variadic comparison chains (short-circuit with 'and' is correct)\\n            if name in [\\n                'integer<?', 'integer>?', 'integer<=?', 'integer>=?',\\n                'float<?',   'float>?',   'float<=?',   'float>=?',\\n                'string<?',  'string>?',  'string<=?',  'string>=?',\\n            ]:\\n                return self._desugar_comparison_chain(expr)\\n\\n            # Strict equality predicates\\n            if name in [\\n                'boolean=?', 'integer=?', 'float=?', 'complex=?', 'string=?', 'list=?', 'dict=?'\\n            ]:\\n                return self._desugar_strict_equality(expr)\\n\\n            # Strict inequality predicates\\n            if name in [\\n                'boolean!=?', 'integer!=?', 'float!=?', 'complex!=?', 'string!=?', 'list!=?', 'dict!=?'\\n            ]:\\n                return self._desugar_strict_inequality(expr)\\n\\n        # Regular function call - desugar all elements\\n        return self._desugar_call(expr)\\n\\n    def _desugar_if(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"Desugar if expression by desugaring its subexpressions.\\\"\\\"\\\"\\n        # Validation already done by semantic analyzer\\n        assert len(expr.elements) == 4, \\\"If expression should have exactly 4 elements (validated by semantic analyzer)\\\"\\n\\n        _, condition, then_expr, else_expr = expr.elements\\n\\n        # Desugar all subexpressions\\n        desugared_condition = self.desugar(condition)\\n        desugared_then = self.desugar(then_expr)\\n        desugared_else = self.desugar(else_expr)\\n\\n        return self._make_list((\\n            self._make_symbol('if', expr),\\n            desugared_condition, desugared_then, desugared_else\\n        ), expr)\\n\\n    def _desugar_let(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"Desugar let expression by desugaring its subexpressions.\\\"\\\"\\\"\\n        # Validation already done by semantic analyzer\\n        assert len(expr.elements) == 3, \\\"Let expression should have exactly 3 elements (validated by semantic analyzer)\\\"\\n\\n        let_symbol = expr.elements[0]\\n        bindings_list = expr.elements[1]\\n        body = expr.elements[2]\\n\\n        assert isinstance(bindings_list, MenaiASTList), \\\"Binding list should be a list (validated by semantic analyzer)\\\"\\n\\n        # Desugar each binding value\\n        desugared_bindings = []\\n        for i, binding in enumerate(bindings_list.elements):\\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2, \\\\\\n                f\\\"Binding {i+1} should be a list with 2 elements (validated by semantic analyzer)\\\"\\n\\n            var_name, value_expr = binding.elements\\n            desugared_value = self.desugar(value_expr)\\n            desugared_bindings.append(self._make_list((var_name, desugared_value), binding))\\n\\n        # Desugar body\\n        desugared_body = self.desugar(body)\\n\\n        return self._make_list((\\n            let_symbol, self._make_list(tuple(desugared_bindings), bindings_list), desugared_body\\n        ), expr)\\n\\n    def _desugar_letrec(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar letrec by splitting mixed bindings into nested let/letrec forms.\\n\\n        A letrec with mixed lambda and non-lambda bindings is transformed into a\\n        sequence of let/letrec forms in topological order:\\n\\n          - Non-recursive binding (lambda or non-lambda) -> let\\n          - Recursive group (always lambdas after splitting) -> letrec\\n\\n        For example:\\n\\n          (letrec ((a (list 1 2 3))\\n                   (f (lambda (x) ... a ...))\\n                   (g (lambda (x) ... f ...)))\\n            body)\\n\\n        becomes:\\n\\n          (let ((a (list 1 2 3)))\\n            (letrec ((f (lambda (x) ... a ...))\\n                     (g (lambda (x) ... f ...)))\\n              body))\\n\\n        After splitting, every remaining letrec contains only a genuine mutually-\\n        recursive group of lambdas, and all non-lambda values live in let bindings\\n        where they belong.\\n\\n        Desugaring of binding values and body happens as the split nodes are built,\\n        so no separate desugaring pass over the result is needed.\\n        \\\"\\\"\\\"\\n        assert len(expr.elements) == 3, \\\"Letrec expression should have exactly 3 elements (validated by semantic analyzer)\\\"\\n\\n        bindings_list = expr.elements[1]\\n        body = expr.elements[2]\\n\\n        assert isinstance(bindings_list, MenaiASTList), \\\"Binding list should be a list (validated by semantic analyzer)\\\"\\n\\n        # Extract raw (name, value_expr) pairs for dependency analysis.\\n        # The analyzer only inspects symbol names, so raw (pre-desugared) AST is correct here.\\n        raw_pairs: List[Tuple[str, MenaiASTNode]] = []\\n        for binding in bindings_list.elements:\\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2\\n            name_expr, value_expr = binding.elements\\n            assert isinstance(name_expr, MenaiASTSymbol)\\n            raw_pairs.append((name_expr.name, value_expr))\\n\\n        raw_dict = dict(raw_pairs)\\n\\n        # Compute topological binding groups (already in dependency order).\\n        binding_groups = MenaiASTDependencyAnalyzer().analyze_letrec_bindings(raw_pairs)\\n\\n        # Desugar the body, then wrap it in binding forms from innermost outward\\n        # (i.e. process groups in reverse topological order so each group's body\\n        # is the already-built inner expression).\\n        #\\n        # Consecutive non-recursive groups are sub-partitioned into flat lets:\\n        # bindings that are mutually independent (no sibling references) are\\n        # batched into a single let; only when a binding depends on an earlier\\n        # sibling does a new nested let begin.  This keeps nesting depth\\n        # proportional to the number of inter-sibling dependencies, not the\\n        # total number of bindings \\u2014 which matters for large letrecs like a\\n        # library module where almost all bindings are independent.\\n        result: MenaiASTNode = self.desugar(body)\\n\\n        # Build a flat list of (kind, [group, ...]) entries in topological order,\\n        # then process in reverse so each entry wraps the already-built inner result.\\n        #\\n        # For non-recursive groups we sub-partition greedily: accumulate bindings\\n        # into the current batch as long as none of them reference a name already\\n        # in the batch.  When a dependency on a batch-sibling is detected, close\\n        # the current batch and start a new one.  Each batch becomes one let.\\n        runs: List[tuple] = []\\n        current_batch: List = []\\n        current_batch_names: Set[str] = set()\\n\\n        for group in binding_groups:\\n            if group.is_recursive:\\n                if current_batch:\\n                    runs.append(('let', current_batch))\\n                    current_batch = []\\n                    current_batch_names = set()\\n                runs.append(('letrec', [group]))\\n\\n            else:\\n                # Check whether this group's binding references any name already\\n                # in the current batch.  Non-recursive singletons have exactly\\n                # one name, but we use group.depends_on for the dependency check\\n                # since the dependency analyser already computed it.\\n                if group.depends_on & current_batch_names:\\n                    # Dependency on a batch sibling \\u2014 close current batch first.\\n                    runs.append(('let', current_batch))\\n                    current_batch = [group]\\n                    current_batch_names = set(group.names)\\n\\n                else:\\n                    current_batch.append(group)\\n                    current_batch_names |= group.names\\n\\n        if current_batch:\\n            runs.append(('let', current_batch))\\n\\n        for kind, run_groups in reversed(runs):\\n            combined_bindings: List[MenaiASTNode] = []\\n            for group in run_groups:\\n                for name in group.names:\\n                    name_sym = self._make_symbol(name, expr)\\n                    desugared_value = self.desugar(raw_dict[name])\\n                    combined_bindings.append(self._make_list((name_sym, desugared_value), expr))\\n\\n            binding_list_node = self._make_list(tuple(combined_bindings), expr)\\n            result = self._make_list((\\n                self._make_symbol(kind, expr),\\n                binding_list_node,\\n                result,\\n            ), expr)\\n\\n        return result\\n\\n    def _desugar_let_star(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar let* expression to nested let expressions.\\n\\n        (let* ((x 1) (y (+ x 1)) (z (* y 2))) body)\\n        =>\\n        (let ((x 1))\\n          (let ((y (+ x 1)))\\n            (let ((z (* y 2)))\\n              body)))\\n        \\\"\\\"\\\"\\n        # Validation already done by semantic analyzer\\n        assert len(expr.elements) == 3, \\\"Let* expression should have exactly 3 elements (validated by semantic analyzer)\\\"\\n\\n        _, bindings_list, body = expr.elements\\n        assert isinstance(bindings_list, MenaiASTList), \\\"Binding list should be a list (validated by semantic analyzer)\\\"\\n\\n        # If no bindings, just return the body\\n        if len(bindings_list.elements) == 0:\\n            return self.desugar(body)\\n\\n        # Build nested lets from the inside out\\n        # Start with the body\\n        result = self.desugar(body)\\n\\n        # Wrap in nested lets, processing bindings in reverse order\\n        for binding in reversed(bindings_list.elements):\\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2, \\\\\\n                \\\"Binding should be a list with 2 elements (validated by semantic analyzer)\\\"\\n\\n            var_name, value_expr = binding.elements\\n\\n            # Desugar the value expression\\n            desugared_value = self.desugar(value_expr)\\n\\n            # Wrap result in a let with this binding\\n            result = self._make_list((\\n                self._make_symbol('let', expr),\\n                self._make_list((self._make_list((var_name, desugared_value), binding),), binding),\\n                result\\n            ), expr)\\n\\n        return result\\n\\n    def _desugar_lambda(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"Desugar lambda expression by desugaring its body.\\\"\\\"\\\"\\n        # Validation already done by semantic analyzer\\n        assert len(expr.elements) == 3, \\\"Lambda expression should have exactly 3 elements (validated by semantic analyzer)\\\"\\n\\n        lambda_symbol, params_list, body = expr.elements\\n\\n        # Desugar body\\n        desugared_body = self.desugar(body)\\n\\n        return self._make_list((lambda_symbol, params_list, desugared_body), expr)\\n\\n    def _desugar_trace(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar trace special form.\\n\\n        (trace msg1 msg2 ... msgN expr)\\n\\n        Trace is kept as-is but with desugared subexpressions.\\n        The IR builder will handle creating the trace IR node.\\n        \\\"\\\"\\\"\\n        if expr.length() < 3:  # (trace msg expr) minimum\\n            raise MenaiEvalError(\\n                message=\\\"trace requires at least 2 arguments (message, expr)\\\",\\n                suggestion=\\\"Usage: (trace \\\\\\\"message\\\\\\\" expression)\\\"\\n            )\\n\\n        # Desugar all subexpressions\\n        desugared_elements: List[MenaiASTNode] = [self._make_symbol('trace', expr)]\\n        for elem in expr.elements[1:]:  # Skip 'trace' symbol\\n            desugared_elements.append(self.desugar(elem))\\n\\n        return self._make_list(tuple(desugared_elements), expr)\\n\\n    def _desugar_call(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"Desugar function call by desugaring all elements.\\\"\\\"\\\"\\n        desugared_elements = []\\n        for elem in expr.elements:\\n            desugared_elements.append(self.desugar(elem))\\n\\n        return self._make_list(tuple(desugared_elements), expr)\\n\\n    def _desugar_variadic_arithmetic(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar variadic arithmetic operations to nested binary operations.\\n\\n        Examples:\\n            (+ 1 2 3) \\u2192 (+ (+ 1 2) 3)\\n            (- 5) \\u2192 (- 0 5)  [unary negation]\\n            (* 2 3 4) \\u2192 (* (* 2 3) 4)\\n            (+ 1) \\u2192 1  [identity]\\n            (+) \\u2192 0  [zero-arg identity]\\n\\n        Args:\\n            expr: Arithmetic expression to desugar\\n\\n        Returns:\\n            Desugared expression (binary operations only)\\n        \\\"\\\"\\\"\\n        op_symbol = expr.first()\\n        assert isinstance(op_symbol, MenaiASTSymbol)\\n        op_name = op_symbol.name\\n\\n        args = list(expr.elements[1:])\\n\\n        # Determine identity elements and sub operator for this family.\\n        if op_name in ('integer+', 'integer-', 'integer*', 'integer/'):\\n            zero: MenaiASTNode = MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\\n            one: MenaiASTNode = MenaiASTInteger(1, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n        elif op_name in ('float+', 'float-', 'float*', 'float/'):\\n            zero = MenaiASTFloat(0.0, line=expr.line, column=expr.column, source_file=expr.source_file)\\n            one = MenaiASTFloat(1.0, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n        elif op_name in ('complex+', 'complex-', 'complex*', 'complex/'):\\n            zero = MenaiASTComplex(0+0j, line=expr.line, column=expr.column, source_file=expr.source_file)\\n            one = MenaiASTComplex(1+0j, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n        else:\\n            assert False, f\\\"Unexpected operator in _desugar_variadic_arithmetic: {op_name!r}\\\"\\n\\n        is_add = op_name in ('integer+', 'float+', 'complex+')\\n        is_mul = op_name in ('integer*', 'float*', 'complex*')\\n\\n        # Handle zero-argument cases\\n        if len(args) == 0:\\n            if is_add:\\n                # (+) / (integer+) / (float+) / (complex+) \\u2192 identity element\\n                return zero\\n\\n            if is_mul:\\n                # (*) / (integer*) / (float*) / (complex*) \\u2192 identity element\\n                return one\\n\\n            # subtraction/division with no args are errors \\u2014 fall through to runtime\\n            return self._desugar_call(expr)\\n\\n        # Handle single-argument cases\\n        if len(args) == 1:\\n            desugared_arg = self.desugar(args[0])\\n\\n            if is_add or is_mul:\\n                # (+ x) \\u2192 x, (* x) \\u2192 x [identity]\\n                return desugared_arg\\n\\n            # subtraction/division with one arg is an error - fall through to runtime\\n            return self._desugar_call(expr)\\n\\n        # Handle binary case (already optimal)\\n        if len(args) == 2:\\n            desugared_args = [self.desugar(arg) for arg in args]\\n            return self._make_list(\\n                (self._make_symbol('$' + op_name, expr),) + tuple(desugared_args), expr\\n            )\\n\\n        # Handle variadic case (3+ arguments) - fold left to right\\n        # (+ 1 2 3 4) \\u2192 (+ (+ (+ 1 2) 3) 4)\\n        desugared_args = [self.desugar(arg) for arg in args]\\n\\n        # Start with first two arguments\\n        result = self._make_list((\\n            self._make_symbol('$' + op_name, expr),\\n            desugared_args[0],\\n            desugared_args[1]\\n        ), expr)\\n\\n        # Fold remaining arguments left-to-right\\n        for arg in desugared_args[2:]:\\n            result = self._make_list((\\n                self._make_symbol('$' + op_name, expr),\\n                result,\\n                arg\\n            ), expr)\\n\\n        return result\\n\\n    def _desugar_fold_variadic(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar fold-reducible variadic operations to nested binary operations.\\n\\n        These are operations where (f a b c) means (f (f a b) c) \\u2014 a left fold.\\n        Each operation has a natural identity element for the 0-arg case.\\n        \\\"\\\"\\\"\\n        op_symbol = expr.first()\\n        assert isinstance(op_symbol, MenaiASTSymbol)\\n        op_name = op_symbol.name\\n\\n        args = list(expr.elements[1:])\\n\\n        # 0-arg identity cases\\n        if len(args) == 0:\\n            if op_name == 'integer-bit-or':\\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n            if op_name == 'integer-bit-and':\\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n            if op_name == 'integer-bit-xor':\\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n            if op_name == 'string-concat':\\n                return MenaiASTString(\\\"\\\", line=expr.line, column=expr.column, source_file=expr.source_file)\\n\\n            if op_name == 'list-concat':\\n                return self._make_list((self._make_symbol('quote', expr), self._make_list((), expr)), expr)\\n\\n            # min/max with 0 args: let runtime raise the error\\n            return self._desugar_call(expr)\\n\\n        # 1-arg: identity \\u2014 return the single argument as-is\\n        if len(args) == 1:\\n            return self.desugar(args[0])\\n\\n        # 2-arg: already binary, emit directly\\n        if len(args) == 2:\\n            return self._make_list(\\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\\n            )\\n\\n        # 3+ args: left-fold\\n        desugared_args = [self.desugar(arg) for arg in args]\\n        result = self._make_list(\\n            (self._make_symbol('$' + op_name, expr), desugared_args[0], desugared_args[1]), expr\\n        )\\n        for arg in desugared_args[2:]:\\n            result = self._make_list(\\n                (self._make_symbol('$' + op_name, expr), result, arg), expr\\n            )\\n\\n        return result\\n\\n    def _desugar_comparison_chain(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar variadic comparison/equality operations to pairwise binary comparisons.\\n\\n        (op a b c) means (and (op a b) (op b c)), not a fold.\\n        Each argument is evaluated once; the desugared form uses let bindings to\\n        avoid double-evaluation when there are 3+ arguments.\\n\\n        The 2-arg case emits the binary opcode directly. The 3+-arg case wraps\\n        intermediate values in let bindings and chains with 'and'.\\n        For != the pairwise connector is 'or' rather than 'and'.\\n        \\\"\\\"\\\"\\n        op_symbol = expr.first()\\n        assert isinstance(op_symbol, MenaiASTSymbol)\\n        op_name = op_symbol.name\\n\\n        args = list(expr.elements[1:])\\n\\n        # 2-arg: emit binary opcode directly (most common case)\\n        if len(args) == 2:\\n            return self._make_list(\\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\\n            )\\n\\n        # 3+ args: (op a b c d) \\u2192 (and (op a b) (op b c) (op c d))\\n        # For != the connector is 'or' instead of 'and': any consecutive pair\\n        # differing is sufficient to make the whole expression true.\\n        # Bind each arg to a temp to avoid double-evaluation, then chain pairwise.\\n        desugared_args = [self.desugar(arg) for arg in args]\\n        temps = [self._gen_temp() for _ in args]\\n\\n        # Build pairwise comparisons\\n        pairs: List[MenaiASTNode] = [\\n            self._make_list((self._make_symbol('$' + op_name, expr),\\n                             self._make_symbol(temps[i], expr),\\n                             self._make_symbol(temps[i + 1], expr)), expr)\\n            for i in range(len(temps) - 1)\\n        ]\\n\\n        # Chain with 'and' for ordered comparisons\\n        body: MenaiASTNode = self._make_and(pairs, expr)\\n\\n        # Wrap in let* bindings from innermost outward\\n        for temp, desugared_arg in reversed(list(zip(temps, desugared_args))):\\n            body = self._make_list((\\n                self._make_symbol('let*', expr),\\n                self._make_list((\\n                    self._make_list((self._make_symbol(temp, expr), desugared_arg), expr),\\n                ), expr),\\n                body\\n            ), expr)\\n\\n        return self.desugar(body)\\n\\n    def _desugar_strict_equality_chain(self, expr: MenaiASTList, check_eq: bool) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Desugar strict type-specific equality predicates.\\n\\n        The 2-arg case is desugared to a binary opcode directly.\\n\\n        The 3+-arg case binds each argument to a temp (to avoid double-evaluation)\\n        then chains pairwise binary calls with 'and' (for equality) or 'or' (for\\n        inequality), which short-circuits left-to-right \\u2014 consistent with the\\n        prelude lambda and with _desugar_comparison_chain.\\n\\n        For example, (integer=? a b c) becomes:\\n            (let* ((t0 a) (t1 b) (t2 c))\\n              (and (integer=? t0 t1)\\n                   (integer=? t1 t2)))\\n\\n        The 0-arg and 1-arg cases fall through to a regular call, which\\n        resolves to the prelude lambda that raises the arity error.\\n        \\\"\\\"\\\"\\n        op_symbol = expr.first()\\n        assert isinstance(op_symbol, MenaiASTSymbol)\\n        op_name = op_symbol.name\\n\\n        args = list(expr.elements[1:])\\n\\n        if len(args) == 2:\\n            return self._make_list(\\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\\n            )\\n\\n        if len(args) >= 3:\\n            # Desugar all args first\\n            desugared_args = [self.desugar(arg) for arg in args]\\n\\n            # Generate temps for each arg to avoid double-evaluation\\n            temps = [self._gen_temp() for _ in args]\\n\\n            # Build pairwise binary calls directly: (op ti ti+1)\\n            pairs: List[MenaiASTNode] = [\\n                self._make_list((self._make_symbol('$' + op_name, expr),\\n                                 self._make_symbol(temps[i], expr),\\n                                 self._make_symbol(temps[i + 1], expr)), expr)\\n                for i in range(len(args) - 1)\\n            ]\\n\\n            # Body: and/or of the pair calls directly \\u2014 short-circuits left-to-right,\\n            # consistent with the prelude lambda and _desugar_comparison_chain.\\n            body: MenaiASTNode = (self._make_and(pairs, expr) if check_eq\\n                                  else self._make_or(pairs, expr))\\n\\n            # Wrap arg values in let* bindings (innermost first)\\n            for temp, desugared_arg in reversed(list(zip(temps, desugared_args))):\\n                body = self._make_list((\\n                    self._make_symbol('let*', expr),\\n                    self._make_list((\\n                        self._make_list((self._make_symbol(temp, expr), desugared_arg), expr),\\n                    ), expr),\\n                    body\\n                ), expr)\\n\\n            return self.desugar(body)\\n\\n        # 0-arg or 1-arg: fall through to regular call \\u2192 prelude lambda raises arity error\\n        return self._desugar_call(expr)\\n\\n    def _desugar_strict_equality(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"Desugar strict type-specific equality predicates.\\\"\\\"\\\"\\n        return self._desugar_strict_equality_chain(expr, check_eq=True)\\n\\n    def _desugar_strict_inequality(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"Desugar strict type-specific inequality predicates.\\\"\\\"\\\"\\n        return self._desugar_strict_equality_chain(expr, check_eq=False)\\n\\n    def _desugar_match(self, expr: MenaiASTList) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Transform match expression into if/let expressions.\\n\\n        Args:\\n            expr: Match expression AST\\n\\n        Returns:\\n            Desugared if/let AST\\n        \\\"\\\"\\\"\\n        # Validation already done by semantic analyzer\\n        assert len(expr.elements) >= 3, \\\"Match expression should have at least 3 elements (validated by semantic analyzer)\\\"\\n\\n        value_expr = expr.elements[1]\\n        clauses = list(expr.elements[2:])\\n\\n        # All clauses already validated by semantic analyzer\\n        for i, clause in enumerate(clauses):\\n            assert isinstance(clause, MenaiASTList) and len(clause.elements) == 2, \\\\\\n                f\\\"Clause {i+1} should be a list with 2 elements (validated by semantic analyzer)\\\"\\n\\n        # Generate temp variable for match value\\n        temp_var = self._gen_temp()\\n\\n        # Desugar the value expression\\n        desugared_value = self.desugar(value_expr)\\n\\n        # Build the match logic as nested if/let expressions\\n        match_logic = self._build_match_clauses(temp_var, clauses)\\n\\n        # Wrap in let to bind the temp variable\\n        # (let ((temp value)) match-logic)\\n        result = MenaiASTList((\\n            MenaiASTSymbol('let*'),\\n            MenaiASTList((\\n                MenaiASTList((MenaiASTSymbol(temp_var), desugared_value)),\\n            )),\\n            match_logic\\n        ))\\n\\n        # Recursively desugar the result to handle let* -> nested let transformation\\n        return self.desugar(result)\\n\\n    def _build_match_clauses(self, temp_var: str, clauses: List[MenaiASTNode]) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Build nested if/let structure for match clauses.\\n\\n        Args:\\n            temp_var: Name of temp variable holding the match value\\n            clauses: Non-empty list of (pattern, result) clauses (validated by semantic analyzer)\\n\\n        Returns:\\n            Nested if/let AST\\n        \\\"\\\"\\\"\\n        # Partition clauses into groups.  A group is either:\\n        #   - A maximal contiguous run of literal arms sharing the same type\\n        #     (integer, float, complex, boolean, string).  These can share a\\n        #     single hoisted type guard, with bare equality checks per arm.\\n        #   - A single non-literal arm (wildcard, variable binding, predicate\\n        #     pattern, list/cons pattern) processed individually as before.\\n        #\\n        # We build the result right-to-left so each group's else branch is the\\n        # already-built remainder.\\n\\n        no_match_error: MenaiASTNode = MenaiASTList((\\n            MenaiASTSymbol('error'),\\n            MenaiASTString(\\\"No patterns matched in match expression\\\")\\n        ))\\n\\n        # Partition into groups: list of (group_type, [clause, ...])\\n        # group_type is the Python AST class for literal groups, or None for singles.\\n        groups: List[Tuple[Any, List[MenaiASTNode]]] = []\\n        i = 0\\n        while i < len(clauses):\\n            clause = clauses[i]\\n            assert isinstance(clause, MenaiASTList)\\n            pattern = clause.elements[0]\\n            lit_type = self._literal_pattern_type(pattern)\\n\\n            if lit_type is not None:\\n                # Start or extend a literal group of this type\\n                group: List[MenaiASTNode] = [clause]\\n                j = i + 1\\n                while j < len(clauses):\\n                    next_clause = clauses[j]\\n                    assert isinstance(next_clause, MenaiASTList)\\n                    if not self._literal_pattern_type(next_clause.elements[0]) is lit_type:\\n                        break\\n\\n                    group.append(next_clause)\\n                    j += 1\\n\\n                groups.append((lit_type, group))\\n                i = j\\n\\n            else:\\n                groups.append((None, [clause]))\\n                i += 1\\n\\n        # Build right-to-left: start with the no-match error as the base.\\n        result: MenaiASTNode = no_match_error\\n\\n        for group_type, group_clauses in reversed(groups):\\n            if group_type is not None:\\n                # Literal group: hoist a single type guard over all arms.\\n                result = self._build_literal_group(temp_var, group_type, group_clauses, result)\\n\\n            else:\\n                # Single non-literal clause: use the original per-arm path.\\n                clause = group_clauses[0]\\n                assert isinstance(clause, MenaiASTList)\\n                pattern = clause.elements[0]\\n                desugared_result = self.desugar(clause.elements[1])\\n                test_expr, bindings = self._desugar_pattern(pattern, temp_var)\\n                result = self._build_clause_with_bindings(\\n                    test_expr, bindings, desugared_result, result\\n                )\\n\\n        return result\\n\\n    def _literal_pattern_type(self, pattern: MenaiASTNode) -> type | None:\\n        \\\"\\\"\\\"\\n        Return the Python AST class for a literal pattern, or None if the\\n        pattern is not a simple literal (i.e. it is a wildcard, variable,\\n        predicate pattern, or list/cons pattern).\\n\\n        Only the types that have a safe typed equality operator are included:\\n        boolean, integer, float, complex, string.  MenaiASTNone is excluded\\n        because (none? tmp) is already a singleton predicate with no equality\\n        check needed \\u2014 grouping adds no benefit there.\\n        \\\"\\\"\\\"\\n        if isinstance(pattern, (MenaiASTBoolean, MenaiASTInteger,\\n                                MenaiASTFloat, MenaiASTComplex, MenaiASTString)):\\n            return type(pattern)\\n\\n        return None\\n\\n    def _build_literal_group(\\n        self,\\n        temp_var: str,\\n        lit_type: type,\\n        clauses: List[MenaiASTNode],\\n        else_expr: MenaiASTNode,\\n    ) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Build a type-guarded block for a run of same-type literal arms.\\n\\n        Emits:\\n            (if (type? tmp)\\n                (if (type=? tmp lit0) result0\\n                (if (type=? tmp lit1) result1\\n                    ...\\n                    else_expr))\\n                else_expr)\\n\\n        The type guard is emitted once.  Each arm uses only the bare equality\\n        check, with no per-arm type predicate.\\n        \\\"\\\"\\\"\\n        # Map AST literal class \\u2192 (type-predicate name, equality-op name)\\n        _type_info: dict[type, Tuple[str, str]] = {\\n            MenaiASTBoolean: ('boolean?', 'boolean=?'),\\n            MenaiASTInteger: ('integer?', 'integer=?'),\\n            MenaiASTFloat:   ('float?',   'float=?'),\\n            MenaiASTComplex: ('complex?', 'complex=?'),\\n            MenaiASTString:  ('string?',  'string=?'),\\n        }\\n        type_pred, eq_op = _type_info[lit_type]\\n        tmp_sym = MenaiASTSymbol(temp_var)\\n\\n        # Build the inner equality chain right-to-left, falling through to else_expr.\\n        inner: MenaiASTNode = else_expr\\n        for clause in reversed(clauses):\\n            assert isinstance(clause, MenaiASTList)\\n            pattern = clause.elements[0]\\n            desugared_result = self.desugar(clause.elements[1])\\n            eq_test = MenaiASTList((MenaiASTSymbol(eq_op), tmp_sym, pattern))\\n            inner = MenaiASTList((MenaiASTSymbol('if'), eq_test, desugared_result, inner))\\n\\n        # Wrap in the single type guard.\\n        type_test = MenaiASTList((MenaiASTSymbol(type_pred), tmp_sym))\\n        return MenaiASTList((MenaiASTSymbol('if'), type_test, inner, else_expr))\\n\\n    def _build_clause_with_bindings(\\n        self,\\n        test_expr: MenaiASTNode,\\n        bindings: List[Tuple[str, Any]],  # Pattern variable bindings or special markers\\n        result_expr: MenaiASTNode,\\n        else_expr: MenaiASTNode\\n    ) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Build if/let structure for a single clause.\\n\\n        Args:\\n            test_expr: Expression that tests if pattern matches\\n            bindings: List of (var_name, value_expr) to bind if pattern matches\\n            result_expr: Expression to evaluate if pattern matches\\n            else_expr: Expression to evaluate if pattern doesn't match\\n\\n        Returns:\\n            (if test_expr\\n                (let (bindings...) result_expr)\\n                else_expr)\\n        \\\"\\\"\\\"\\n        # Check if this is a list pattern (special marker)\\n        if (bindings and len(bindings) == 1 and bindings[0][0].startswith('__LIST_PATTERN_')):\\n            # This is a list pattern - use special building logic\\n            element_info = bindings[0][1]\\n            return self._build_list_pattern_clause(\\n                test_expr,\\n                element_info,\\n                result_expr,\\n                else_expr\\n            )\\n\\n        # Check if this is a cons pattern (special marker)\\n        if (bindings and len(bindings) == 1 and bindings[0][0].startswith('__CONS_PATTERN_')):\\n            # This is a cons pattern - use same building logic as list pattern\\n            element_info = bindings[0][1]\\n            return self._build_list_pattern_clause(\\n                test_expr,\\n                element_info,\\n                result_expr,\\n                else_expr\\n            )\\n\\n        # All bindings here are pattern variable bindings (user-defined names).\\n        # They must go inside the then branch (only evaluated after test passes).\\n\\n        # Short-circuit: a constant #t test always matches \\u2014 no branch needed.\\n        # This is the wildcard (_) and unconditional variable-binding case.\\n        if isinstance(test_expr, MenaiASTBoolean) and test_expr.value:\\n            if bindings:\\n                return MenaiASTList((\\n                    MenaiASTSymbol('let*'),\\n                    MenaiASTList(tuple(MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in bindings)),\\n                    result_expr\\n                ))\\n\\n            return result_expr\\n\\n        if bindings:\\n            binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in bindings]\\n\\n            then_expr: MenaiASTNode = MenaiASTList((\\n                MenaiASTSymbol('let*'),\\n                MenaiASTList(tuple(binding_list)),\\n                result_expr\\n            ))\\n        else:\\n            then_expr = result_expr\\n\\n        # Build if expression\\n        return MenaiASTList((\\n            MenaiASTSymbol('if'),\\n            test_expr,\\n            then_expr,\\n            else_expr\\n        ))\\n\\n    def _desugar_pattern(\\n        self,\\n        pattern: MenaiASTNode,\\n        temp_var: str\\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, MenaiASTNode]]]:\\n        \\\"\\\"\\\"\\n        Desugar a pattern into (test_expr, bindings).\\n\\n        Args:\\n            pattern: Pattern AST\\n            temp_var: Name of temp variable holding the match value\\n\\n        Returns:\\n            (test_expression, [(var_name, value_expr), ...])\\n\\n        Example:\\n            Pattern: (? number? n)\\n            Temp: \\\"#:match-tmp-1\\\"\\n            Returns: ((number? #:match-tmp-1), [(\\\"n\\\", #:match-tmp-1)])  ; pred called directly\\n        \\\"\\\"\\\"\\n        # Literal patterns: #none, booleans, numbers, strings\\n        #\\n        # Each literal pattern is compiled as:\\n        #   (and (type? tmp) (type=? tmp literal))\\n        #\\n        # The type-guard is essential for correctness: without it, presenting a\\n        # value of the wrong type to the equality operator raises a type error\\n        # instead of simply not matching.  The guard short-circuits via `and`\\n        # so the equality check is only reached when the type is known correct.\\n        #\\n        # #none is the sole exception \\u2014 (none? tmp) is already a safe predicate\\n        # that returns #f for any non-none value, so no separate equality check\\n        # is needed.\\n\\n        if isinstance(pattern, MenaiASTNone):\\n            # (none? tmp) \\u2014 singleton predicate, inherently type-safe\\n            test_expr: MenaiASTNode = MenaiASTList((\\n                MenaiASTSymbol('none?'),\\n                MenaiASTSymbol(temp_var),\\n            ))\\n            return (test_expr, [])\\n\\n        if isinstance(pattern, MenaiASTBoolean):\\n            # (and (boolean? tmp) (boolean=? tmp literal))\\n            test_expr = self._make_and([\\n                MenaiASTList((MenaiASTSymbol('boolean?'), MenaiASTSymbol(temp_var))),\\n                MenaiASTList((MenaiASTSymbol('boolean=?'), MenaiASTSymbol(temp_var), pattern)),\\n            ], pattern)\\n            return (test_expr, [])\\n\\n        if isinstance(pattern, MenaiASTInteger):\\n            # (and (integer? tmp) (integer=? tmp literal))\\n            test_expr = self._make_and([\\n                MenaiASTList((MenaiASTSymbol('integer?'), MenaiASTSymbol(temp_var))),\\n                MenaiASTList((MenaiASTSymbol('integer=?'), MenaiASTSymbol(temp_var), pattern)),\\n            ], pattern)\\n            return (test_expr, [])\\n\\n        if isinstance(pattern, MenaiASTFloat):\\n            # (and (float? tmp) (float=? tmp literal))\\n            test_expr = self._make_and([\\n                MenaiASTList((MenaiASTSymbol('float?'), MenaiASTSymbol(temp_var))),\\n                MenaiASTList((MenaiASTSymbol('float=?'), MenaiASTSymbol(temp_var), pattern)),\\n            ], pattern)\\n            return (test_expr, [])\\n\\n        if isinstance(pattern, MenaiASTComplex):\\n            # (and (complex? tmp) (complex=? tmp literal))\\n            test_expr = self._make_and([\\n                MenaiASTList((MenaiASTSymbol('complex?'), MenaiASTSymbol(temp_var))),\\n                MenaiASTList((MenaiASTSymbol('complex=?'), MenaiASTSymbol(temp_var), pattern)),\\n            ], pattern)\\n            return (test_expr, [])\\n\\n        if isinstance(pattern, MenaiASTString):\\n            # (and (string? tmp) (string=? tmp literal))\\n            test_expr = self._make_and([\\n                MenaiASTList((MenaiASTSymbol('string?'), MenaiASTSymbol(temp_var))),\\n                MenaiASTList((MenaiASTSymbol('string=?'), MenaiASTSymbol(temp_var), pattern)),\\n            ], pattern)\\n            return (test_expr, [])\\n\\n        # Variable pattern: binds the value\\n        if isinstance(pattern, MenaiASTSymbol):\\n            if pattern.name == '_':\\n                # Wildcard - always matches, no binding\\n                return (MenaiASTBoolean(True), [])\\n\\n            # Variable binding - always matches, binds variable\\n            return (\\n                MenaiASTBoolean(True),\\n                [(pattern.name, MenaiASTSymbol(temp_var))]\\n            )\\n\\n        # List patterns\\n        if isinstance(pattern, MenaiASTList):\\n            return self._desugar_list_pattern(pattern, temp_var)\\n\\n        # Should never reach here - semantic analyzer validates patterns\\n        assert False, f\\\"Unknown pattern type: {type(pattern).__name__} (should be validated by semantic analyzer)\\\"\\n\\n    def _desugar_list_pattern(\\n        self,\\n        pattern: MenaiASTList,\\n        temp_var: str\\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, MenaiASTNode]]]:\\n        \\\"\\\"\\\"\\n        Desugar a list pattern.\\n\\n        Args:\\n            pattern: List pattern AST\\n            temp_var: Name of temp variable holding the match value\\n\\n        Returns:\\n            (test_expression, bindings)\\n        \\\"\\\"\\\"\\n        # Empty list pattern: ()\\n        if pattern.is_empty():\\n            # Test: (null? temp_var)\\n            test_expr = MenaiASTList((\\n                MenaiASTSymbol('list-null?'),\\n                MenaiASTSymbol(temp_var)\\n            ))\\n            return (test_expr, [])\\n\\n        # Check for predicate test pattern: (? pred var)\\n        if (len(pattern.elements) == 3 and\\n            isinstance(pattern.elements[0], MenaiASTSymbol) and\\n            pattern.elements[0].name == '?'):\\n\\n            pred_expr = pattern.elements[1]\\n            var_pattern = pattern.elements[2]\\n\\n            assert isinstance(var_pattern, MenaiASTSymbol), \\\\\\n                \\\"Predicate pattern variable should be a symbol (validated by semantic analyzer)\\\"\\n\\n            # Test: (pred temp_var) \\u2014 pred can be any expression\\n            test_expr = MenaiASTList((\\n                pred_expr,\\n                MenaiASTSymbol(temp_var)\\n            ))\\n\\n            # Binding: bind the variable to temp_var (unless wildcard)\\n            bindings: List[Tuple[str, MenaiASTNode]] = []\\n            if var_pattern.name != '_':\\n                bindings.append((var_pattern.name, MenaiASTSymbol(temp_var)))\\n\\n            return (test_expr, bindings)\\n\\n        # Check for cons pattern: (head . tail) or (a b . rest)\\n        dot_positions = []\\n        for i, elem in enumerate(pattern.elements):\\n            if isinstance(elem, MenaiASTSymbol) and elem.name == '.':\\n                dot_positions.append(i)\\n\\n        # Validation already done by semantic analyzer\\n        assert len(dot_positions) <= 1, \\\"Pattern should have at most one dot (validated by semantic analyzer)\\\"\\n\\n        # If we have a dot, use cons pattern\\n        if dot_positions:\\n            dot_position = dot_positions[0]\\n            return self._desugar_cons_pattern(pattern, temp_var, dot_position)\\n\\n        # Fixed-length list pattern: (p1 p2 p3)\\n        return self._desugar_fixed_list_pattern(pattern, temp_var)\\n\\n    def _desugar_fixed_list_pattern(\\n        self,\\n        pattern: MenaiASTList,\\n        temp_var: str\\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, Any]]]:\\n        \\\"\\\"\\\"\\n        Desugar a fixed-length list pattern like (a b c).\\n\\n        Args:\\n            pattern: List pattern AST\\n            temp_var: Name of temp variable holding the match value\\n\\n        Returns:\\n            (test_expression, bindings)\\n        \\\"\\\"\\\"\\n        num_elements = len(pattern.elements)\\n\\n        # Test: (and (list? temp_var) (= (length temp_var) num_elements))\\n        # We'll build this as nested ifs for simplicity\\n\\n        # First test: (list? temp_var)\\n        list_test = MenaiASTList((\\n            MenaiASTSymbol('list?'),\\n            MenaiASTSymbol(temp_var)\\n        ))\\n\\n        # Second test: (= (length temp_var) num_elements)\\n        length_test = MenaiASTList((\\n            MenaiASTSymbol('integer=?'),\\n            MenaiASTList((\\n                MenaiASTSymbol('list-length'),\\n                MenaiASTSymbol(temp_var)\\n            )),\\n            MenaiASTInteger(num_elements)\\n        ))\\n\\n        # Combine with and (lowered to if-chain)\\n        combined_test = self._make_and([list_test, length_test], MenaiASTList(()))\\n\\n        # For fixed-length list patterns, we need a special structure:\\n        # (and (list? x) (= (length x) n))  <- basic test\\n        # Then INSIDE the then branch:\\n        #   - Extract elements\\n        #   - Test element patterns\\n        #   - Bind pattern variables\\n        #\\n        # We can't return this as (test, bindings) because element tests\\n        # reference element temp vars which must be bound after length check.\\n        #\\n        # Solution: Return a special marker that tells the caller to use\\n        # a different building strategy.\\n\\n        # Collect element pattern info\\n        element_info: List[Tuple[MenaiASTNode, str, MenaiASTNode]] = []  # List of (pattern, temp_var, extraction_expr)\\n\\n        for i, elem_pattern in enumerate(pattern.elements):\\n            # Generate temp var for this element\\n            elem_temp = self._gen_temp()\\n\\n            # Extract element: (list-ref temp_var i)\\n            elem_value = MenaiASTList((\\n                MenaiASTSymbol('list-ref'),\\n                MenaiASTSymbol(temp_var),\\n                MenaiASTInteger(i)\\n            ))\\n\\n            element_info.append((elem_pattern, elem_temp, elem_value))\\n\\n        # Return the basic test and a special marker with element info\\n        # The caller will use this to build the proper nested structure\\n        # Use a unique marker name to avoid duplicates in nested patterns\\n        marker_name = f'__LIST_PATTERN_{self._gen_temp()}__'\\n        return (combined_test, [(marker_name, element_info)])\\n\\n    def _flatten_nested_pattern(\\n        self,\\n        pattern: MenaiASTNode,\\n        temp_var: str,\\n        extraction_bindings: List[Tuple[str, MenaiASTNode]],\\n        element_tests: List[MenaiASTNode],\\n        pattern_bindings: List[Tuple[str, MenaiASTNode]]\\n    ) -> None:\\n        \\\"\\\"\\\"\\n        Recursively flatten a nested pattern into the given lists.\\n\\n        Args:\\n            pattern: Pattern to flatten\\n            temp_var: Temp variable holding the value to match\\n            extraction_bindings: List to append extraction bindings to\\n            element_tests: List to append tests to\\n            pattern_bindings: List to append pattern variable bindings to\\n        \\\"\\\"\\\"\\n        # Desugar the pattern\\n        test, bindings = self._desugar_pattern(pattern, temp_var)\\n\\n        # Check if this is a list/cons pattern (special marker)\\n        if (bindings and len(bindings) == 1 and\\n            (bindings[0][0].startswith('__LIST_PATTERN_') or\\n             bindings[0][0].startswith('__CONS_PATTERN_'))):\\n            # This is a nested list/cons pattern - flatten it\\n            # Cast to the expected type for element_info\\n            nested_element_info = cast(List[Tuple[MenaiASTNode, str, MenaiASTNode]], bindings[0][1])\\n\\n            # Add the length/type test\\n            if not (isinstance(test, MenaiASTBoolean) and test.value):\\n                element_tests.append(test)\\n\\n            # Recursively flatten each element\\n            for elem_pattern, elem_temp, elem_value in nested_element_info:\\n                # Add extraction binding\\n                extraction_bindings.append((elem_temp, elem_value))\\n\\n                # Recursively flatten this element\\n                self._flatten_nested_pattern(\\n                    elem_pattern,\\n                    elem_temp,\\n                    extraction_bindings,\\n                    element_tests,\\n                    pattern_bindings\\n                )\\n\\n        else:\\n            # Regular pattern - add test and bindings\\n            if not (isinstance(test, MenaiASTBoolean) and test.value):\\n                element_tests.append(test)\\n            pattern_bindings.extend(bindings)\\n\\n    def _build_list_pattern_clause(\\n        self,\\n        length_test: MenaiASTNode,\\n        element_info: List,\\n        result_expr: MenaiASTNode,\\n        else_expr: MenaiASTNode\\n    ) -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Build a clause for a list pattern with proper nesting.\\n\\n        Args:\\n            length_test: Test for list? and length\\n            element_info: List of (pattern, temp_var, extraction_expr)\\n            result_expr: Result expression to evaluate if pattern matches\\n            else_expr: Expression to evaluate if pattern doesn't match\\n\\n        Returns:\\n            Properly nested if/let structure\\n        \\\"\\\"\\\"\\n        # Build: (if length_test\\n        #          (let ((#:tmp-2 (list-ref x 0)) ...)\\n        #            (if (and elem-test-1 elem-test-2 ...)\\n        #                (let ((a #:tmp-2) (b #:tmp-3) ...)\\n        #                  result)\\n        #                else))\\n        #          else)\\n\\n        # Extract elements\\n        extraction_bindings: List[Tuple[str, MenaiASTNode]] = []\\n        element_tests: List[MenaiASTNode] = []\\n        pattern_bindings: List[Tuple[str, MenaiASTNode]] = []\\n\\n        for elem_pattern, elem_temp, elem_value in element_info:\\n            # Add extraction binding\\n            extraction_bindings.append((elem_temp, elem_value))\\n\\n            # Desugar element pattern\\n            elem_test, elem_bindings = self._desugar_pattern(elem_pattern, elem_temp)\\n\\n            # Check if element pattern is itself a list/cons pattern (special marker)\\n            if (elem_bindings and len(elem_bindings) == 1 and\\n                    (elem_bindings[0][0].startswith('__LIST_PATTERN_') or\\n                     elem_bindings[0][0].startswith('__CONS_PATTERN_'))):\\n                # Nested list/cons pattern - use helper to recursively flatten it\\n                self._flatten_nested_pattern(\\n                    elem_pattern,\\n                    elem_temp,\\n                    extraction_bindings,\\n                    element_tests,\\n                    pattern_bindings\\n                )\\n\\n            else:\\n                # Regular pattern\\n                # Collect element test (unless it's just #t)\\n                if not (isinstance(elem_test, MenaiASTBoolean) and elem_test.value):\\n                    element_tests.append(elem_test)\\n\\n                # Collect pattern bindings\\n                pattern_bindings.extend(elem_bindings)\\n\\n        # Build the inner structure (after element extraction)\\n        if element_tests:\\n            # We have element tests - need nested if\\n            elem_test_combined = self._make_and(element_tests, MenaiASTList(()))\\n\\n            # Build pattern bindings let\\n            if pattern_bindings:\\n                binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in pattern_bindings]\\n                pattern_let: MenaiASTNode = MenaiASTList((\\n                    MenaiASTSymbol('let*'),\\n                    MenaiASTList(tuple(binding_list)),\\n                    result_expr\\n                ))\\n\\n            else:\\n                pattern_let = result_expr\\n\\n            # Build element test if\\n            inner_if: MenaiASTNode = MenaiASTList((\\n                MenaiASTSymbol('if'),\\n                elem_test_combined,\\n                pattern_let,\\n                else_expr\\n            ))\\n\\n        else:\\n            # No element tests - just bind pattern vars\\n            if pattern_bindings:\\n                binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in pattern_bindings]\\n                inner_if = MenaiASTList((\\n                    MenaiASTSymbol('let*'),\\n                    MenaiASTList(tuple(binding_list)),\\n                    result_expr\\n                ))\\n\\n            else:\\n                inner_if = result_expr\\n\\n        # Wrap in element extraction let\\n        extraction_binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in extraction_bindings]\\n        extraction_let = MenaiASTList((\\n            MenaiASTSymbol('let*'),\\n            MenaiASTList(tuple(extraction_binding_list)),\\n            inner_if\\n        ))\\n\\n        # Build outer if with length test\\n        return MenaiASTList((\\n            MenaiASTSymbol('if'),\\n            length_test,\\n            extraction_let,\\n            else_expr\\n        ))\\n\\n    def _desugar_cons_pattern(\\n        self,\\n        pattern: MenaiASTList,\\n        temp_var: str,\\n        dot_position: int\\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, Any]]]:\\n        \\\"\\\"\\\"\\n        Desugar a cons pattern like (head . tail) or (a b . rest).\\n\\n        Args:\\n            pattern: List pattern AST\\n            temp_var: Name of temp variable holding the match value\\n            dot_position: Index of the dot in the pattern\\n\\n        Returns:\\n            (test_expression, bindings)\\n        \\\"\\\"\\\"\\n        # Validation already done by semantic analyzer\\n        assert dot_position > 0, \\\"Dot should not be at beginning (validated by semantic analyzer)\\\"\\n        assert dot_position < len(pattern.elements) - 1, \\\"Dot should not be at end (validated by semantic analyzer)\\\"\\n        assert dot_position == len(pattern.elements) - 2, \\\\\\n            \\\"Should have exactly one element after dot (validated by semantic analyzer)\\\"\\n\\n        # Test: (and (list? temp_var) (>= (length temp_var) dot_position))\\n        list_test = MenaiASTList((\\n            MenaiASTSymbol('list?'),\\n            MenaiASTSymbol(temp_var)\\n        ))\\n\\n        length_test = MenaiASTList((\\n            MenaiASTSymbol('integer>=?'),\\n            MenaiASTList((\\n                MenaiASTSymbol('list-length'),\\n                MenaiASTSymbol(temp_var)\\n            )),\\n            MenaiASTInteger(dot_position)\\n        ))\\n        combined_test = self._make_and([list_test, length_test], MenaiASTList(()))\\n\\n        # Collect head element info\\n        head_elements: List[Tuple[MenaiASTNode, str, MenaiASTNode]] = []\\n\\n        for i in range(dot_position):\\n            elem_pattern = pattern.elements[i]\\n            elem_temp = self._gen_temp()\\n\\n            # Extract element: (list-ref temp_var i)\\n            elem_value = MenaiASTList((\\n                MenaiASTSymbol('list-ref'),\\n                MenaiASTSymbol(temp_var),\\n                MenaiASTInteger(i)\\n            ))\\n\\n            head_elements.append((elem_pattern, elem_temp, elem_value))\\n\\n        # Build binding for tail\\n        tail_pattern = pattern.elements[dot_position + 1]\\n        tail_temp = self._gen_temp()\\n\\n        # Extract tail: (list-slice temp-var dot_position)\\n        tail_value = MenaiASTList((\\n            MenaiASTSymbol('list-slice'),\\n            MenaiASTSymbol(temp_var),\\n            MenaiASTInteger(dot_position)\\n        ))\\n\\n        # Add tail to element info\\n        all_elements = head_elements + [(tail_pattern, tail_temp, tail_value)]\\n\\n        # Return special marker for cons pattern\\n        # Use a unique marker name to avoid duplicates in nested patterns\\n        marker_name = f'__CONS_PATTERN_{self._gen_temp()}__'\\n        return (combined_test, [(marker_name, all_elements)])\\n\\n    def _gen_temp(self) -> str:\\n        \\\"\\\"\\\"Generate unique temporary variable name.\\\"\\\"\\\"\\n        self.temp_counter += 1\\n        return f\\\"#:match-tmp-{self.temp_counter}\\\"\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"\nMenai AST Desugarer - transforms complex constructs into core language.\n\nThe desugarer takes a full AST (including match, and, or) and transforms it\ninto a core AST containing only:\n- Literals (numbers, strings, booleans)\n- Variables (symbols)\n- If expressions\n- Let expressions\n- Lambda expressions\n- Function calls\n\nThis simplifies the compiler and enables better optimization.\n\"\"\"\n\nfrom typing import List, Set, Tuple, Any, cast\n\nfrom menai.menai_ast import (\n    MenaiASTNode, MenaiASTSymbol, MenaiASTList, MenaiASTInteger,\n    MenaiASTFloat, MenaiASTComplex, MenaiASTString, MenaiASTBoolean, MenaiASTNone\n)\nfrom menai.menai_ast_dependency_analyzer import MenaiASTDependencyAnalyzer\nfrom menai.menai_builtin_registry import MenaiBuiltinRegistry\nfrom menai.menai_error import MenaiEvalError\n\n\nclass MenaiASTDesugarer:\n    \"\"\"Transforms complex Menai constructs into core language.\"\"\"\n\n    def __init__(self) -> None:\n        self.temp_counter = 0  # For generating unique temp variable names\n\n    def _make_symbol(self, name: str, source_node: MenaiASTNode) -> MenaiASTSymbol:\n        \"\"\"Create a symbol with source location from another node.\"\"\"\n        return MenaiASTSymbol(\n            name,\n            line=source_node.line,\n            column=source_node.column,\n            source_file=source_node.source_file\n        )\n\n    def _make_list(self, elements: tuple, source_node: MenaiASTNode) -> MenaiASTList:\n        \"\"\"Create a list with source location from another node.\"\"\"\n        return MenaiASTList(\n            elements,\n            line=source_node.line,\n            column=source_node.column,\n            source_file=source_node.source_file\n        )\n\n    def _make_and(self, exprs: List[MenaiASTNode], source_node: MenaiASTNode) -> MenaiASTNode:\n        \"\"\"\n        Construct (and exprs...) as a lowered if-chain without going through desugar().\n\n        Used internally when building AST nodes that must already be in desugared\n        form (e.g. inside _desugar_pattern, _desugar_fixed_list_pattern).\n\n        (and)      -> #t\n        (and A)    -> A\n        (and A B+) -> (if A (and B+) #f)\n        \"\"\"\n        if not exprs:\n            return MenaiASTBoolean(\n                True,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            )\n\n        if len(exprs) == 1:\n            return exprs[0]\n\n        return self._make_list((\n            self._make_symbol('if', source_node),\n            exprs[0],\n            self._make_and(exprs[1:], source_node),\n            MenaiASTBoolean(\n                False,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            ),\n        ), source_node)\n\n    def _make_or(self, exprs: List[MenaiASTNode], source_node: MenaiASTNode) -> MenaiASTNode:\n        \"\"\"\n        Construct (or exprs...) as a lowered if-chain without going through desugar().\n\n        Used internally when building AST nodes that must already be in desugared\n        form (e.g. inside _desugar_strict_equality_chain).\n\n        (or)      -> #f\n        (or A)    -> A\n        (or A B+) -> (if A #t (or B+))\n        \"\"\"\n        if not exprs:\n            return MenaiASTBoolean(\n                False,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            )\n\n        if len(exprs) == 1:\n            return exprs[0]\n\n        return self._make_list((\n            self._make_symbol('if', source_node),\n            exprs[0],\n            MenaiASTBoolean(\n                True,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            ),\n            self._make_or(exprs[1:], source_node),\n        ), source_node)\n\n    def _desugar_and(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar (and A B ...) to a right-folded if-chain.\n\n        (and)      -> #t\n        (and A)    -> (desugar A)\n        (and A B+) -> (if (desugar A) (desugar (and B+)) #f)\n        \"\"\"\n        args = list(expr.elements[1:])\n        if not args:\n            return MenaiASTBoolean(True, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        if len(args) == 1:\n            return self.desugar(args[0])\n\n        desugared_first = self.desugar(args[0])\n        rest_expr = self._make_list((self._make_symbol('and', expr),) + tuple(args[1:]), expr)\n        desugared_rest = self._desugar_and(rest_expr)\n        return self._make_list((\n            self._make_symbol('if', expr),\n            desugared_first,\n            desugared_rest,\n            MenaiASTBoolean(False, line=expr.line, column=expr.column, source_file=expr.source_file),\n        ), expr)\n\n    def _desugar_or(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar (or A B ...) to a right-folded if-chain.\n\n        (or)      -> #f\n        (or A)    -> (desugar A)\n        (or A B+) -> (if (desugar A) #t (desugar (or B+)))\n        \"\"\"\n        args = list(expr.elements[1:])\n        if not args:\n            return MenaiASTBoolean(False, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        if len(args) == 1:\n            return self.desugar(args[0])\n\n        desugared_first = self.desugar(args[0])\n        rest_expr = self._make_list((self._make_symbol('or', expr),) + tuple(args[1:]), expr)\n        desugared_rest = self._desugar_or(rest_expr)\n        return self._make_list((\n            self._make_symbol('if', expr),\n            desugared_first,\n            MenaiASTBoolean(True, line=expr.line, column=expr.column, source_file=expr.source_file),\n            desugared_rest,\n        ), expr)\n\n    def desugar(self, expr: MenaiASTNode) -> MenaiASTNode:\n        \"\"\"\n        Desugar an expression recursively.\n\n        Args:\n            expr: AST to desugar\n\n        Returns:\n            Desugared AST (core language only)\n        \"\"\"\n        # Lists need inspection - anything else does not\n        if not isinstance(expr, MenaiASTList):\n            return expr\n\n        if expr.is_empty():\n            return expr\n\n        first = expr.first()\n        if isinstance(first, MenaiASTSymbol):\n            name = first.name\n\n            # Match expression - desugar it!\n            if name == 'match':\n                return self._desugar_match(expr)\n\n            # Core constructs - desugar children only\n            if name == 'if':\n                return self._desugar_if(expr)\n\n            if name == 'let':\n                return self._desugar_let(expr)\n\n            if name == 'letrec':\n                return self._desugar_letrec(expr)\n\n            if name == 'let*':\n                # Let* desugars to nested lets\n                return self._desugar_let_star(expr)\n\n            if name == 'lambda':\n                return self._desugar_lambda(expr)\n\n            if name == 'quote':\n                # Quote: don't desugar the quoted expression\n                return expr\n\n            if name == 'trace':\n                # Trace is a special form - handle it\n                return self._desugar_trace(expr)\n\n            if name == 'and':\n                return self._desugar_and(expr)\n\n            if name == 'or':\n                return self._desugar_or(expr)\n\n            # Fixed-arity opcode rewrite: if this call is to a known builtin\n            # with exactly its primitive arity, rewrite the function name to the\n            # $-prefixed primitive form.  This fires before\n            # the variadic/comparison/equality rewrites so that e.g.\n            # (integer+ a b) \u2192 ($integer+ a b) directly, while\n            # (integer+ a b c) still falls through to _desugar_variadic_arithmetic.\n            #\n            # Several builtins have optional trailing arguments whose opcodes\n            # always require the full argument count.  When the user omits the\n            # optional argument(s) the desugarer synthesises the missing default\n            # so that the $-prefixed opcode call is always fully saturated:\n            #\n            #   Constant defaults (1-arg min, 2-arg opcode):\n            #     (integer->complex n)     \u2192 ($integer->complex n 0)\n            #     (integer->string n)      \u2192 ($integer->string n 10)\n            #     (float->complex x)       \u2192 ($float->complex x 0.0)\n            #     (string->integer s)      \u2192 ($string->integer s 10)\n            #     (string->list s)         \u2192 ($string->list s \"\")\n            #     (list->string l)         \u2192 ($list->string l \"\")\n            #\n            #   Constant defaults (2-arg min, 3-arg opcode):\n            #     (dict-get d k)           \u2192 ($dict-get d k #none)\n            #     (range start end)        \u2192 ($range start end 1)\n            #\n            #   Computed defaults (2-arg min, 3-arg opcode):\n            #     (string-slice s start)   \u2192 (let ((#:t s)) ($string-slice #:t start ($string-length #:t)))\n            #     (list-slice   l start)   \u2192 (let ((#:t l)) ($list-slice #:t start ($list-length #:t)))\n            #\n            # The computed-default cases bind the collection argument to a temp\n            # to avoid evaluating it twice.\n            primitive_arity = MenaiBuiltinRegistry.get_primitive_arity(name)\n            if primitive_arity is not None:\n                n_args = len(expr.elements) - 1\n                if n_args == primitive_arity:\n                    dollar_name = '$' + name\n                    desugared_args = [self.desugar(arg) for arg in expr.elements[1:]]\n                    return self._make_list(\n                        (self._make_symbol(dollar_name, expr),) + tuple(desugared_args),\n                        expr\n                    )\n                # Constant-default completions.\n                constant_defaults: dict[str, MenaiASTNode] = {\n                    'integer->complex': MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'integer->string': MenaiASTInteger(10, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'float->complex': MenaiASTFloat(0.0, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'string->integer': MenaiASTInteger(10, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'string->list': MenaiASTString(\"\", line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'list->string': MenaiASTString(\"\", line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'dict-get': MenaiASTNone(line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'range': MenaiASTInteger(1, line=expr.line, column=expr.column, source_file=expr.source_file),\n                }\n                if name in constant_defaults and n_args == primitive_arity - 1:\n                    default = constant_defaults[name]\n                    desugared_args = [self.desugar(arg) for arg in expr.elements[1:]]\n                    return self._make_list(\n                        (self._make_symbol('$' + name, expr),) + tuple(desugared_args) + (default,),\n                        expr\n                    )\n                # Computed-default completions: bind the collection to a temp to\n                # avoid double-evaluation, then synthesise the length call.\n                if name in ('string-slice', 'list-slice') and n_args == 2:\n                    length_fn = 'string-length' if name == 'string-slice' else 'list-length'\n                    coll_arg = self.desugar(expr.elements[1])\n                    start_arg = self.desugar(expr.elements[2])\n                    temp = self._gen_temp()\n                    temp_sym = self._make_symbol(temp, expr)\n                    length_call = self._make_list((\n                        self._make_symbol('$' + length_fn, expr),\n                        temp_sym,\n                    ), expr)\n                    slice_call = self._make_list((\n                        self._make_symbol('$' + name, expr),\n                        temp_sym,\n                        start_arg,\n                        length_call,\n                    ), expr)\n                    return self._make_list((\n                        self._make_symbol('let', expr),\n                        self._make_list((\n                            self._make_list((temp_sym, coll_arg), expr),\n                        ), expr),\n                        slice_call,\n                    ), expr)\n\n            # Check for typed variadic arithmetic operations\n            if name in [\n                'integer+', 'integer-', 'integer*', 'integer/',\n                'float+', 'float-', 'float*', 'float/',\n                'complex+', 'complex-', 'complex*', 'complex/',\n            ]:\n                return self._desugar_variadic_arithmetic(expr)\n\n            # Fold-reducible variadic operations\n            if name in [\n                'integer-bit-or', 'integer-bit-and', 'integer-bit-xor',\n                'integer-min', 'integer-max',\n                'float-min', 'float-max',\n                'list-concat',\n                'string-concat',\n            ]:\n                return self._desugar_fold_variadic(expr)\n\n            # Variadic comparison chains (short-circuit with 'and' is correct)\n            if name in [\n                'integer<?', 'integer>?', 'integer<=?', 'integer>=?',\n                'float<?',   'float>?',   'float<=?',   'float>=?',\n                'string<?',  'string>?',  'string<=?',  'string>=?',\n            ]:\n                return self._desugar_comparison_chain(expr)\n\n            # Strict equality predicates\n            if name in [\n                'boolean=?', 'integer=?', 'float=?', 'complex=?', 'string=?', 'list=?', 'dict=?'\n            ]:\n                return self._desugar_strict_equality(expr)\n\n            # Strict inequality predicates\n            if name in [\n                'boolean!=?', 'integer!=?', 'float!=?', 'complex!=?', 'string!=?', 'list!=?', 'dict!=?'\n            ]:\n                return self._desugar_strict_inequality(expr)\n\n        # Regular function call - desugar all elements\n        return self._desugar_call(expr)\n\n    def _desugar_if(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar if expression by desugaring its subexpressions.\"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 4, \"If expression should have exactly 4 elements (validated by semantic analyzer)\"\n\n        _, condition, then_expr, else_expr = expr.elements\n\n        # Desugar all subexpressions\n        desugared_condition = self.desugar(condition)\n        desugared_then = self.desugar(then_expr)\n        desugared_else = self.desugar(else_expr)\n\n        return self._make_list((\n            self._make_symbol('if', expr),\n            desugared_condition, desugared_then, desugared_else\n        ), expr)\n\n    def _desugar_let(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar let expression by desugaring its subexpressions.\"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 3, \"Let expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        let_symbol = expr.elements[0]\n        bindings_list = expr.elements[1]\n        body = expr.elements[2]\n\n        assert isinstance(bindings_list, MenaiASTList), \"Binding list should be a list (validated by semantic analyzer)\"\n\n        # Desugar each binding value\n        desugared_bindings = []\n        for i, binding in enumerate(bindings_list.elements):\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2, \\\n                f\"Binding {i+1} should be a list with 2 elements (validated by semantic analyzer)\"\n\n            var_name, value_expr = binding.elements\n            desugared_value = self.desugar(value_expr)\n            desugared_bindings.append(self._make_list((var_name, desugared_value), binding))\n\n        # Desugar body\n        desugared_body = self.desugar(body)\n\n        return self._make_list((\n            let_symbol, self._make_list(tuple(desugared_bindings), bindings_list), desugared_body\n        ), expr)\n\n    def _desugar_letrec(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar letrec by splitting mixed bindings into nested let/letrec forms.\n\n        A letrec with mixed lambda and non-lambda bindings is transformed into a\n        sequence of let/letrec forms in topological order:\n\n          - Non-recursive binding (lambda or non-lambda) -> let\n          - Recursive group (always lambdas after splitting) -> letrec\n\n        For example:\n\n          (letrec ((a (list 1 2 3))\n                   (f (lambda (x) ... a ...))\n                   (g (lambda (x) ... f ...)))\n            body)\n\n        becomes:\n\n          (let ((a (list 1 2 3)))\n            (letrec ((f (lambda (x) ... a ...))\n                     (g (lambda (x) ... f ...)))\n              body))\n\n        After splitting, every remaining letrec contains only a genuine mutually-\n        recursive group of lambdas, and all non-lambda values live in let bindings\n        where they belong.\n\n        Desugaring of binding values and body happens as the split nodes are built,\n        so no separate desugaring pass over the result is needed.\n        \"\"\"\n        assert len(expr.elements) == 3, \"Letrec expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        bindings_list = expr.elements[1]\n        body = expr.elements[2]\n\n        assert isinstance(bindings_list, MenaiASTList), \"Binding list should be a list (validated by semantic analyzer)\"\n\n        # Extract raw (name, value_expr) pairs for dependency analysis.\n        # The analyzer only inspects symbol names, so raw (pre-desugared) AST is correct here.\n        raw_pairs: List[Tuple[str, MenaiASTNode]] = []\n        for binding in bindings_list.elements:\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2\n            name_expr, value_expr = binding.elements\n            assert isinstance(name_expr, MenaiASTSymbol)\n            raw_pairs.append((name_expr.name, value_expr))\n\n        raw_dict = dict(raw_pairs)\n\n        # Compute topological binding groups (already in dependency order).\n        binding_groups = MenaiASTDependencyAnalyzer().analyze_letrec_bindings(raw_pairs)\n\n        # Desugar the body, then wrap it in binding forms from innermost outward\n        # (i.e. process groups in reverse topological order so each group's body\n        # is the already-built inner expression).\n        #\n        # Consecutive non-recursive groups are sub-partitioned into flat lets:\n        # bindings that are mutually independent (no sibling references) are\n        # batched into a single let; only when a binding depends on an earlier\n        # sibling does a new nested let begin.  This keeps nesting depth\n        # proportional to the number of inter-sibling dependencies, not the\n        # total number of bindings \u2014 which matters for large letrecs like a\n        # library module where almost all bindings are independent.\n        result: MenaiASTNode = self.desugar(body)\n\n        # Build a flat list of (kind, [group, ...]) entries in topological order,\n        # then process in reverse so each entry wraps the already-built inner result.\n        #\n        # For non-recursive groups we sub-partition greedily: accumulate bindings\n        # into the current batch as long as none of them reference a name already\n        # in the batch.  When a dependency on a batch-sibling is detected, close\n        # the current batch and start a new one.  Each batch becomes one let.\n        runs: List[tuple] = []\n        current_batch: List = []\n        current_batch_names: Set[str] = set()\n\n        for group in binding_groups:\n            if group.is_recursive:\n                if current_batch:\n                    runs.append(('let', current_batch))\n                    current_batch = []\n                    current_batch_names = set()\n                runs.append(('letrec', [group]))\n\n            else:\n                # Check whether this group's binding references any name already\n                # in the current batch.  Non-recursive singletons have exactly\n                # one name, but we use group.depends_on for the dependency check\n                # since the dependency analyser already computed it.\n                if group.depends_on & current_batch_names:\n                    # Dependency on a batch sibling \u2014 close current batch first.\n                    runs.append(('let', current_batch))\n                    current_batch = [group]\n                    current_batch_names = set(group.names)\n\n                else:\n                    current_batch.append(group)\n                    current_batch_names |= group.names\n\n        if current_batch:\n            runs.append(('let', current_batch))\n\n        for kind, run_groups in reversed(runs):\n            combined_bindings: List[MenaiASTNode] = []\n            for group in run_groups:\n                for name in group.names:\n                    name_sym = self._make_symbol(name, expr)\n                    desugared_value = self.desugar(raw_dict[name])\n                    combined_bindings.append(self._make_list((name_sym, desugared_value), expr))\n\n            binding_list_node = self._make_list(tuple(combined_bindings), expr)\n            result = self._make_list((\n                self._make_symbol(kind, expr),\n                binding_list_node,\n                result,\n            ), expr)\n\n        return result\n\n    def _desugar_let_star(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar let* expression to nested let expressions.\n\n        (let* ((x 1) (y (+ x 1)) (z (* y 2))) body)\n        =>\n        (let ((x 1))\n          (let ((y (+ x 1)))\n            (let ((z (* y 2)))\n              body)))\n        \"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 3, \"Let* expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        _, bindings_list, body = expr.elements\n        assert isinstance(bindings_list, MenaiASTList), \"Binding list should be a list (validated by semantic analyzer)\"\n\n        # If no bindings, just return the body\n        if len(bindings_list.elements) == 0:\n            return self.desugar(body)\n\n        # Build nested lets from the inside out\n        # Start with the body\n        result = self.desugar(body)\n\n        # Wrap in nested lets, processing bindings in reverse order\n        for binding in reversed(bindings_list.elements):\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2, \\\n                \"Binding should be a list with 2 elements (validated by semantic analyzer)\"\n\n            var_name, value_expr = binding.elements\n\n            # Desugar the value expression\n            desugared_value = self.desugar(value_expr)\n\n            # Wrap result in a let with this binding\n            result = self._make_list((\n                self._make_symbol('let', expr),\n                self._make_list((self._make_list((var_name, desugared_value), binding),), binding),\n                result\n            ), expr)\n\n        return result\n\n    def _desugar_lambda(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar lambda expression by desugaring its body.\"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 3, \"Lambda expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        lambda_symbol, params_list, body = expr.elements\n\n        # Desugar body\n        desugared_body = self.desugar(body)\n\n        return self._make_list((lambda_symbol, params_list, desugared_body), expr)\n\n    def _desugar_trace(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar trace special form.\n\n        (trace msg1 msg2 ... msgN expr)\n\n        Trace is kept as-is but with desugared subexpressions.\n        The IR builder will handle creating the trace IR node.\n        \"\"\"\n        if expr.length() < 3:  # (trace msg expr) minimum\n            raise MenaiEvalError(\n                message=\"trace requires at least 2 arguments (message, expr)\",\n                suggestion=\"Usage: (trace \\\"message\\\" expression)\"\n            )\n\n        # Desugar all subexpressions\n        desugared_elements: List[MenaiASTNode] = [self._make_symbol('trace', expr)]\n        for elem in expr.elements[1:]:  # Skip 'trace' symbol\n            desugared_elements.append(self.desugar(elem))\n\n        return self._make_list(tuple(desugared_elements), expr)\n\n    def _desugar_call(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar function call by desugaring all elements.\"\"\"\n        desugared_elements = []\n        for elem in expr.elements:\n            desugared_elements.append(self.desugar(elem))\n\n        return self._make_list(tuple(desugared_elements), expr)\n\n    def _desugar_variadic_arithmetic(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar variadic arithmetic operations to nested binary operations.\n\n        Examples:\n            (+ 1 2 3) \u2192 (+ (+ 1 2) 3)\n            (- 5) \u2192 (- 0 5)  [unary negation]\n            (* 2 3 4) \u2192 (* (* 2 3) 4)\n            (+ 1) \u2192 1  [identity]\n            (+) \u2192 0  [zero-arg identity]\n\n        Args:\n            expr: Arithmetic expression to desugar\n\n        Returns:\n            Desugared expression (binary operations only)\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        # Determine identity elements and sub operator for this family.\n        if op_name in ('integer+', 'integer-', 'integer*', 'integer/'):\n            zero: MenaiASTNode = MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n            one: MenaiASTNode = MenaiASTInteger(1, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        elif op_name in ('float+', 'float-', 'float*', 'float/'):\n            zero = MenaiASTFloat(0.0, line=expr.line, column=expr.column, source_file=expr.source_file)\n            one = MenaiASTFloat(1.0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        elif op_name in ('complex+', 'complex-', 'complex*', 'complex/'):\n            zero = MenaiASTComplex(0+0j, line=expr.line, column=expr.column, source_file=expr.source_file)\n            one = MenaiASTComplex(1+0j, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        else:\n            assert False, f\"Unexpected operator in _desugar_variadic_arithmetic: {op_name!r}\"\n\n        is_add = op_name in ('integer+', 'float+', 'complex+')\n        is_mul = op_name in ('integer*', 'float*', 'complex*')\n\n        # Handle zero-argument cases\n        if len(args) == 0:\n            if is_add:\n                # (+) / (integer+) / (float+) / (complex+) \u2192 identity element\n                return zero\n\n            if is_mul:\n                # (*) / (integer*) / (float*) / (complex*) \u2192 identity element\n                return one\n\n            # subtraction/division with no args are errors \u2014 fall through to runtime\n            return self._desugar_call(expr)\n\n        # Handle single-argument cases\n        if len(args) == 1:\n            desugared_arg = self.desugar(args[0])\n\n            if is_add or is_mul:\n                # (+ x) \u2192 x, (* x) \u2192 x [identity]\n                return desugared_arg\n\n            # subtraction/division with one arg is an error - fall through to runtime\n            return self._desugar_call(expr)\n\n        # Handle binary case (already optimal)\n        if len(args) == 2:\n            desugared_args = [self.desugar(arg) for arg in args]\n            return self._make_list(\n                (self._make_symbol('$' + op_name, expr),) + tuple(desugared_args), expr\n            )\n\n        # Handle variadic case (3+ arguments) - fold left to right\n        # (+ 1 2 3 4) \u2192 (+ (+ (+ 1 2) 3) 4)\n        desugared_args = [self.desugar(arg) for arg in args]\n\n        # Start with first two arguments\n        result = self._make_list((\n            self._make_symbol('$' + op_name, expr),\n            desugared_args[0],\n            desugared_args[1]\n        ), expr)\n\n        # Fold remaining arguments left-to-right\n        for arg in desugared_args[2:]:\n            result = self._make_list((\n                self._make_symbol('$' + op_name, expr),\n                result,\n                arg\n            ), expr)\n\n        return result\n\n    def _desugar_fold_variadic(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar fold-reducible variadic operations to nested binary operations.\n\n        These are operations where (f a b c) means (f (f a b) c) \u2014 a left fold.\n        Each operation has a natural identity element for the 0-arg case.\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        # 0-arg identity cases\n        if len(args) == 0:\n            if op_name == 'integer-bit-or':\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'integer-bit-and':\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'integer-bit-xor':\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'string-concat':\n                return MenaiASTString(\"\", line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'list-concat':\n                return self._make_list((self._make_symbol('quote', expr), self._make_list((), expr)), expr)\n\n            # min/max with 0 args: let runtime raise the error\n            return self._desugar_call(expr)\n\n        # 1-arg: identity \u2014 return the single argument as-is\n        if len(args) == 1:\n            return self.desugar(args[0])\n\n        # 2-arg: already binary, emit directly\n        if len(args) == 2:\n            return self._make_list(\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\n            )\n\n        # 3+ args: left-fold\n        desugared_args = [self.desugar(arg) for arg in args]\n        result = self._make_list(\n            (self._make_symbol('$' + op_name, expr), desugared_args[0], desugared_args[1]), expr\n        )\n        for arg in desugared_args[2:]:\n            result = self._make_list(\n                (self._make_symbol('$' + op_name, expr), result, arg), expr\n            )\n\n        return result\n\n    def _desugar_comparison_chain(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar variadic comparison/equality operations to pairwise binary comparisons.\n\n        (op a b c) means (and (op a b) (op b c)), not a fold.\n        Each argument is evaluated once; the desugared form uses let bindings to\n        avoid double-evaluation when there are 3+ arguments.\n\n        The 2-arg case emits the binary opcode directly. The 3+-arg case wraps\n        intermediate values in let bindings and chains with 'and'.\n        For != the pairwise connector is 'or' rather than 'and'.\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        # 2-arg: emit binary opcode directly (most common case)\n        if len(args) == 2:\n            return self._make_list(\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\n            )\n\n        # 3+ args: (op a b c d) \u2192 (and (op a b) (op b c) (op c d))\n        # For != the connector is 'or' instead of 'and': any consecutive pair\n        # differing is sufficient to make the whole expression true.\n        # Bind each arg to a temp to avoid double-evaluation, then chain pairwise.\n        desugared_args = [self.desugar(arg) for arg in args]\n        temps = [self._gen_temp() for _ in args]\n\n        # Build pairwise comparisons\n        pairs: List[MenaiASTNode] = [\n            self._make_list((self._make_symbol('$' + op_name, expr),\n                             self._make_symbol(temps[i], expr),\n                             self._make_symbol(temps[i + 1], expr)), expr)\n            for i in range(len(temps) - 1)\n        ]\n\n        # Chain with 'and' for ordered comparisons\n        body: MenaiASTNode = self._make_and(pairs, expr)\n\n        # Wrap in let* bindings from innermost outward\n        for temp, desugared_arg in reversed(list(zip(temps, desugared_args))):\n            body = self._make_list((\n                self._make_symbol('let*', expr),\n                self._make_list((\n                    self._make_list((self._make_symbol(temp, expr), desugared_arg), expr),\n                ), expr),\n                body\n            ), expr)\n\n        return self.desugar(body)\n\n    def _desugar_strict_equality_chain(self, expr: MenaiASTList, check_eq: bool) -> MenaiASTNode:\n        \"\"\"\n        Desugar strict type-specific equality predicates.\n\n        The 2-arg case is desugared to a binary opcode directly.\n\n        The 3+-arg case binds each argument to a temp (to avoid double-evaluation)\n        then chains pairwise binary calls with 'and' (for equality) or 'or' (for\n        inequality), which short-circuits left-to-right \u2014 consistent with the\n        prelude lambda and with _desugar_comparison_chain.\n\n        For example, (integer=? a b c) becomes:\n            (let* ((t0 a) (t1 b) (t2 c))\n              (and (integer=? t0 t1)\n                   (integer=? t1 t2)))\n\n        The 0-arg and 1-arg cases fall through to a regular call, which\n        resolves to the prelude lambda that raises the arity error.\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        if len(args) == 2:\n            return self._make_list(\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\n            )\n\n        if len(args) >= 3:\n            # Desugar all args first\n            desugared_args = [self.desugar(arg) for arg in args]\n\n            # Generate temps for each arg to avoid double-evaluation\n            temps = [self._gen_temp() for _ in args]\n\n            # Build pairwise binary calls directly: (op ti ti+1)\n            pairs: List[MenaiASTNode] = [\n                self._make_list((self._make_symbol('$' + op_name, expr),\n                                 self._make_symbol(temps[i], expr),\n                                 self._make_symbol(temps[i + 1], expr)), expr)\n                for i in range(len(args) - 1)\n            ]\n\n            # Body: and/or of the pair calls directly \u2014 short-circuits left-to-right,\n            # consistent with the prelude lambda and _desugar_comparison_chain.\n            body: MenaiASTNode = (self._make_and(pairs, expr) if check_eq\n                                  else self._make_or(pairs, expr))\n\n            # Wrap arg values in let* bindings (innermost first)\n            for temp, desugared_arg in reversed(list(zip(temps, desugared_args))):\n                body = self._make_list((\n                    self._make_symbol('let*', expr),\n                    self._make_list((\n                        self._make_list((self._make_symbol(temp, expr), desugared_arg), expr),\n                    ), expr),\n                    body\n                ), expr)\n\n            return self.desugar(body)\n\n        # 0-arg or 1-arg: fall through to regular call \u2192 prelude lambda raises arity error\n        return self._desugar_call(expr)\n\n    def _desugar_strict_equality(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar strict type-specific equality predicates.\"\"\"\n        return self._desugar_strict_equality_chain(expr, check_eq=True)\n\n    def _desugar_strict_inequality(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar strict type-specific inequality predicates.\"\"\"\n        return self._desugar_strict_equality_chain(expr, check_eq=False)\n\n    def _desugar_match(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Transform match expression into if/let expressions.\n\n        Args:\n            expr: Match expression AST\n\n        Returns:\n            Desugared if/let AST\n        \"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) >= 3, \"Match expression should have at least 3 elements (validated by semantic analyzer)\"\n\n        value_expr = expr.elements[1]\n        clauses = list(expr.elements[2:])\n\n        # All clauses already validated by semantic analyzer\n        for i, clause in enumerate(clauses):\n            assert isinstance(clause, MenaiASTList) and len(clause.elements) == 2, \\\n                f\"Clause {i+1} should be a list with 2 elements (validated by semantic analyzer)\"\n\n        # Generate temp variable for match value\n        temp_var = self._gen_temp()\n\n        # Desugar the value expression\n        desugared_value = self.desugar(value_expr)\n\n        # Build the match logic as nested if/let expressions\n        match_logic = self._build_match_clauses(temp_var, clauses)\n\n        # Wrap in let to bind the temp variable\n        # (let ((temp value)) match-logic)\n        result = MenaiASTList((\n            MenaiASTSymbol('let*'),\n            MenaiASTList((\n                MenaiASTList((MenaiASTSymbol(temp_var), desugared_value)),\n            )),\n            match_logic\n        ))\n\n        # Recursively desugar the result to handle let* -> nested let transformation\n        return self.desugar(result)\n\n    def _build_match_clauses(self, temp_var: str, clauses: List[MenaiASTNode]) -> MenaiASTNode:\n        \"\"\"\n        Build nested if/let structure for match clauses.\n\n        Args:\n            temp_var: Name of temp variable holding the match value\n            clauses: Non-empty list of (pattern, result) clauses (validated by semantic analyzer)\n\n        Returns:\n            Nested if/let AST\n        \"\"\"\n        # Partition clauses into groups.  A group is either:\n        #   - A maximal contiguous run of literal arms sharing the same type\n        #     (integer, float, complex, boolean, string).  These can share a\n        #     single hoisted type guard, with bare equality checks per arm.\n        #   - A single non-literal arm (wildcard, variable binding, predicate\n        #     pattern, list/cons pattern) processed individually as before.\n        #\n        # We build the result right-to-left so each group's else branch is the\n        # already-built remainder.\n\n        no_match_error: MenaiASTNode = MenaiASTList((\n            MenaiASTSymbol('error'),\n            MenaiASTString(\"No patterns matched in match expression\")\n        ))\n\n        # Partition into groups: list of (group_type, [clause, ...])\n        # group_type is the Python AST class for literal groups, or None for singles.\n        groups: List[Tuple[Any, List[MenaiASTNode]]] = []\n        i = 0\n        while i < len(clauses):\n            clause = clauses[i]\n            assert isinstance(clause, MenaiASTList)\n            pattern = clause.elements[0]\n            lit_type = self._literal_pattern_type(pattern)\n\n            if lit_type is not None:\n                # Start or extend a literal group of this type\n                group: List[MenaiASTNode] = [clause]\n                j = i + 1\n                while j < len(clauses):\n                    next_clause = clauses[j]\n                    assert isinstance(next_clause, MenaiASTList)\n                    if not self._literal_pattern_type(next_clause.elements[0]) is lit_type:\n                        break\n\n                    group.append(next_clause)\n                    j += 1\n\n                groups.append((lit_type, group))\n                i = j\n\n            else:\n                groups.append((None, [clause]))\n                i += 1\n\n        # Build right-to-left: start with the no-match error as the base.\n        result: MenaiASTNode = no_match_error\n\n        for group_type, group_clauses in reversed(groups):\n            if group_type is not None:\n                # Literal group: hoist a single type guard over all arms.\n                result = self._build_literal_group(temp_var, group_type, group_clauses, result)\n\n            else:\n                # Single non-literal clause: use the original per-arm path.\n                clause = group_clauses[0]\n                assert isinstance(clause, MenaiASTList)\n                pattern = clause.elements[0]\n                desugared_result = self.desugar(clause.elements[1])\n                test_expr, bindings = self._desugar_pattern(pattern, temp_var)\n                result = self._build_clause_with_bindings(\n                    test_expr, bindings, desugared_result, result\n                )\n\n        return result\n\n    def _literal_pattern_type(self, pattern: MenaiASTNode) -> type | None:\n        \"\"\"\n        Return the Python AST class for a literal pattern, or None if the\n        pattern is not a simple literal (i.e. it is a wildcard, variable,\n        predicate pattern, or list/cons pattern).\n\n        Only the types that have a safe typed equality operator are included:\n        boolean, integer, float, complex, string.  MenaiASTNone is excluded\n        because (none? tmp) is already a singleton predicate with no equality\n        check needed \u2014 grouping adds no benefit there.\n        \"\"\"\n        if isinstance(pattern, (MenaiASTBoolean, MenaiASTInteger,\n                                MenaiASTFloat, MenaiASTComplex, MenaiASTString)):\n            return type(pattern)\n\n        return None\n\n    def _build_literal_group(\n        self,\n        temp_var: str,\n        lit_type: type,\n        clauses: List[MenaiASTNode],\n        else_expr: MenaiASTNode,\n    ) -> MenaiASTNode:\n        \"\"\"\n        Build a type-guarded block for a run of same-type literal arms.\n\n        Emits:\n            (if (type? tmp)\n                (if (type=? tmp lit0) result0\n                (if (type=? tmp lit1) result1\n                    ...\n                    else_expr))\n                else_expr)\n\n        The type guard is emitted once.  Each arm uses only the bare equality\n        check, with no per-arm type predicate.\n        \"\"\"\n        # Map AST literal class \u2192 (type-predicate name, equality-op name)\n        _type_info: dict[type, Tuple[str, str]] = {\n            MenaiASTBoolean: ('boolean?', 'boolean=?'),\n            MenaiASTInteger: ('integer?', 'integer=?'),\n            MenaiASTFloat:   ('float?',   'float=?'),\n            MenaiASTComplex: ('complex?', 'complex=?'),\n            MenaiASTString:  ('string?',  'string=?'),\n        }\n        type_pred, eq_op = _type_info[lit_type]\n        tmp_sym = MenaiASTSymbol(temp_var)\n\n        # Build the inner equality chain right-to-left, falling through to else_expr.\n        inner: MenaiASTNode = else_expr\n        for clause in reversed(clauses):\n            assert isinstance(clause, MenaiASTList)\n            pattern = clause.elements[0]\n            desugared_result = self.desugar(clause.elements[1])\n            eq_test = MenaiASTList((MenaiASTSymbol(eq_op), tmp_sym, pattern))\n            inner = MenaiASTList((MenaiASTSymbol('if'), eq_test, desugared_result, inner))\n\n        # Wrap in the single type guard.\n        type_test = MenaiASTList((MenaiASTSymbol(type_pred), tmp_sym))\n        return MenaiASTList((MenaiASTSymbol('if'), type_test, inner, else_expr))\n\n    def _build_clause_with_bindings(\n        self,\n        test_expr: MenaiASTNode,\n        bindings: List[Tuple[str, Any]],  # Pattern variable bindings or special markers\n        result_expr: MenaiASTNode,\n        else_expr: MenaiASTNode\n    ) -> MenaiASTNode:\n        \"\"\"\n        Build if/let structure for a single clause.\n\n        Args:\n            test_expr: Expression that tests if pattern matches\n            bindings: List of (var_name, value_expr) to bind if pattern matches\n            result_expr: Expression to evaluate if pattern matches\n            else_expr: Expression to evaluate if pattern doesn't match\n\n        Returns:\n            (if test_expr\n                (let (bindings...) result_expr)\n                else_expr)\n        \"\"\"\n        # Check if this is a list pattern (special marker)\n        if (bindings and len(bindings) == 1 and bindings[0][0].startswith('__LIST_PATTERN_')):\n            # This is a list pattern - use special building logic\n            element_info = bindings[0][1]\n            return self._build_list_pattern_clause(\n                test_expr,\n                element_info,\n                result_expr,\n                else_expr\n            )\n\n        # Check if this is a cons pattern (special marker)\n        if (bindings and len(bindings) == 1 and bindings[0][0].startswith('__CONS_PATTERN_')):\n            # This is a cons pattern - use same building logic as list pattern\n            element_info = bindings[0][1]\n            return self._build_list_pattern_clause(\n                test_expr,\n                element_info,\n                result_expr,\n                else_expr\n            )\n\n        # All bindings here are pattern variable bindings (user-defined names).\n        # They must go inside the then branch (only evaluated after test passes).\n\n        # Short-circuit: a constant #t test always matches \u2014 no branch needed.\n        # This is the wildcard (_) and unconditional variable-binding case.\n        if isinstance(test_expr, MenaiASTBoolean) and test_expr.value:\n            if bindings:\n                return MenaiASTList((\n                    MenaiASTSymbol('let*'),\n                    MenaiASTList(tuple(MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in bindings)),\n                    result_expr\n                ))\n\n            return result_expr\n\n        if bindings:\n            binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in bindings]\n\n            then_expr: MenaiASTNode = MenaiASTList((\n                MenaiASTSymbol('let*'),\n                MenaiASTList(tuple(binding_list)),\n                result_expr\n            ))\n        else:\n            then_expr = result_expr\n\n        # Build if expression\n        return MenaiASTList((\n            MenaiASTSymbol('if'),\n            test_expr,\n            then_expr,\n            else_expr\n        ))\n\n    def _desugar_pattern(\n        self,\n        pattern: MenaiASTNode,\n        temp_var: str\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, MenaiASTNode]]]:\n        \"\"\"\n        Desugar a pattern into (test_expr, bindings).\n\n        Args:\n            pattern: Pattern AST\n            temp_var: Name of temp variable holding the match value\n\n        Returns:\n            (test_expression, [(var_name, value_expr), ...])\n\n        Example:\n            Pattern: (? number? n)\n            Temp: \"#:match-tmp-1\"\n            Returns: ((number? #:match-tmp-1), [(\"n\", #:match-tmp-1)])  ; pred called directly\n        \"\"\"\n        # Literal patterns: #none, booleans, numbers, strings\n        #\n        # Each literal pattern is compiled as:\n        #   (and (type? tmp) (type=? tmp literal))\n        #\n        # The type-guard is essential for correctness: without it, presenting a\n        # value of the wrong type to the equality operator raises a type error\n        # instead of simply not matching.  The guard short-circuits via `and`\n        # so the equality check is only reached when the type is known correct.\n        #\n        # #none is the sole exception \u2014 (none? tmp) is already a safe predicate\n        # that returns #f for any non-none value, so no separate equality check\n        # is needed.\n\n        if isinstance(pattern, MenaiASTNone):\n            # (none? tmp) \u2014 singleton predicate, inherently type-safe\n            test_expr: MenaiASTNode = MenaiASTList((\n                MenaiASTSymbol('none?'),\n                MenaiASTSymbol(temp_var),\n            ))\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTBoolean):\n            # (and (boolean? tmp) (boolean=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('boolean?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('boolean=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTInteger):\n            # (and (integer? tmp) (integer=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('integer?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('integer=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTFloat):\n            # (and (float? tmp) (float=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('float?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('float=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTComplex):\n            # (and (complex? tmp) (complex=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('complex?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('complex=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTString):\n            # (and (string? tmp) (string=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('string?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('string=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        # Variable pattern: binds the value\n        if isinstance(pattern, MenaiASTSymbol):\n            if pattern.name == '_':\n                # Wildcard - always matches, no binding\n                return (MenaiASTBoolean(True), [])\n\n            # Variable binding - always matches, binds variable\n            return (\n                MenaiASTBoolean(True),\n                [(pattern.name, MenaiASTSymbol(temp_var))]\n            )\n\n        # List patterns\n        if isinstance(pattern, MenaiASTList):\n            return self._desugar_list_pattern(pattern, temp_var)\n\n        # Should never reach here - semantic analyzer validates patterns\n        assert False, f\"Unknown pattern type: {type(pattern).__name__} (should be validated by semantic analyzer)\"\n\n    def _desugar_list_pattern(\n        self,\n        pattern: MenaiASTList,\n        temp_var: str\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, MenaiASTNode]]]:\n        \"\"\"\n        Desugar a list pattern.\n\n        Args:\n            pattern: List pattern AST\n            temp_var: Name of temp variable holding the match value\n\n        Returns:\n            (test_expression, bindings)\n        \"\"\"\n        # Empty list pattern: ()\n        if pattern.is_empty():\n            # Test: (null? temp_var)\n            test_expr = MenaiASTList((\n                MenaiASTSymbol('list-null?'),\n                MenaiASTSymbol(temp_var)\n            ))\n            return (test_expr, [])\n\n        # Check for predicate test pattern: (? pred var)\n        if (len(pattern.elements) == 3 and\n            isinstance(pattern.elements[0], MenaiASTSymbol) and\n            pattern.elements[0].name == '?'):\n\n            pred_expr = pattern.elements[1]\n            var_pattern = pattern.elements[2]\n\n            assert isinstance(var_pattern, MenaiASTSymbol), \\\n                \"Predicate pattern variable should be a symbol (validated by semantic analyzer)\"\n\n            # Test: (pred temp_var) \u2014 pred can be any expression\n            test_expr = MenaiASTList((\n                pred_expr,\n                MenaiASTSymbol(temp_var)\n            ))\n\n            # Binding: bind the variable to temp_var (unless wildcard)\n            bindings: List[Tuple[str, MenaiASTNode]] = []\n            if var_pattern.name != '_':\n                bindings.append((var_pattern.name, MenaiASTSymbol(temp_var)))\n\n            return (test_expr, bindings)\n\n        # Check for cons pattern: (head . tail) or (a b . rest)\n        dot_positions = []\n        for i, elem in enumerate(pattern.elements):\n            if isinstance(elem, MenaiASTSymbol) and elem.name == '.':\n                dot_positions.append(i)\n\n        # Validation already done by semantic analyzer\n        assert len(dot_positions) <= 1, \"Pattern should have at most one dot (validated by semantic analyzer)\"\n\n        # If we have a dot, use cons pattern\n        if dot_positions:\n            dot_position = dot_positions[0]\n            return self._desugar_cons_pattern(pattern, temp_var, dot_position)\n\n        # Fixed-length list pattern: (p1 p2 p3)\n        return self._desugar_fixed_list_pattern(pattern, temp_var)\n\n    def _desugar_fixed_list_pattern(\n        self,\n        pattern: MenaiASTList,\n        temp_var: str\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, Any]]]:\n        \"\"\"\n        Desugar a fixed-length list pattern like (a b c).\n\n        Args:\n            pattern: List pattern AST\n            temp_var: Name of temp variable holding the match value\n\n        Returns:\n            (test_expression, bindings)\n        \"\"\"\n        num_elements = len(pattern.elements)\n\n        # Test: (and (list? temp_var) (= (length temp_var) num_elements))\n        # We'll build this as nested ifs for simplicity\n\n        # First test: (list? temp_var)\n        list_test = MenaiASTList((\n            MenaiASTSymbol('list?'),\n            MenaiASTSymbol(temp_var)\n        ))\n\n        # Second test: (= (length temp_var) num_elements)\n        length_test = MenaiASTList((\n            MenaiASTSymbol('integer=?'),\n            MenaiASTList((\n                MenaiASTSymbol('list-length'),\n                MenaiASTSymbol(temp_var)\n            )),\n            MenaiASTInteger(num_elements)\n        ))\n\n        # Combine with and (lowered to if-chain)\n        combined_test = self._make_and([list_test, length_test], MenaiASTList(()))\n\n        # For fixed-length list patterns, we need a special structure:\n        # (and (list? x) (= (length x) n))  <- basic test\n        # Then INSIDE the then branch:\n        #   - Extract elements\n        #   - Test element patterns\n        #   - Bind pattern variables\n        #\n        # We can't return this as (test, bindings) because element tests\n        # reference element temp vars which must be bound after length check.\n        #\n        # Solution: Return a special marker that tells the caller to use\n        # a different building strategy.\n\n        # Collect element pattern info\n        element_info: List[Tuple[MenaiASTNode, str, MenaiASTNode]] = []  # List of (pattern, temp_var, extraction_expr)\n\n        for i, elem_pattern in enumerate(pattern.elements):\n            # Generate temp var for this element\n            elem_temp = self._gen_temp()\n\n            # Extract element: (list-ref temp_var i)\n            elem_value = MenaiASTList((\n                MenaiASTSymbol('list-ref'),\n                MenaiASTSymbol(temp_var),\n                MenaiASTInteger(i)\n            ))\n\n            element_info.append((elem_pattern, elem_temp, elem_value))\n\n        # Return the basic test and a special marker with element info\n        # The caller will use this to build the proper nested structure\n        # Use a unique marker name to avoid duplicates in nested patterns\n        marker_name = f'__LIST_PATTERN_{self._gen_temp()}__'\n        return (combined_test, [(marker_name, element_info)])\n\n    def _flatten_nested_pattern(\n        self,\n        pattern: MenaiASTNode,\n        temp_var: str,\n        extraction_bindings: List[Tuple[str, MenaiASTNode]],\n        element_tests: List[MenaiASTNode],\n        pattern_bindings: List[Tuple[str, MenaiASTNode]]\n    ) -> None:\n        \"\"\"\n        Recursively flatten a nested pattern into the given lists.\n\n        Args:\n            pattern: Pattern to flatten\n            temp_var: Temp variable holding the value to match\n            extraction_bindings: List to append extraction bindings to\n            element_tests: List to append tests to\n            pattern_bindings: List to append pattern variable bindings to\n        \"\"\"\n        # Desugar the pattern\n        test, bindings = self._desugar_pattern(pattern, temp_var)\n\n        # Check if this is a list/cons pattern (special marker)\n        if (bindings and len(bindings) == 1 and\n            (bindings[0][0].startswith('__LIST_PATTERN_') or\n             bindings[0][0].startswith('__CONS_PATTERN_'))):\n            # This is a nested list/cons pattern - flatten it\n            # Cast to the expected type for element_info\n            nested_element_info = cast(List[Tuple[MenaiASTNode, str, MenaiASTNode]], bindings[0][1])\n\n            # Add the length/type test\n            if not (isinstance(test, MenaiASTBoolean) and test.value):\n                element_tests.append(test)\n\n            # Recursively flatten each element\n            for elem_pattern, elem_temp, elem_value in nested_element_info:\n                # Add extraction binding\n                extraction_bindings.append((elem_temp, elem_value))\n\n                # Recursively flatten this element\n                self._flatten_nested_pattern(\n                    elem_pattern,\n                    elem_temp,\n                    extraction_bindings,\n                    element_tests,\n                    pattern_bindings\n                )\n\n        else:\n            # Regular pattern - add test and bindings\n            if not (isinstance(test, MenaiASTBoolean) and test.value):\n                element_tests.append(test)\n            pattern_bindings.extend(bindings)\n\n    def _build_list_pattern_clause(\n        self,\n        length_test: MenaiASTNode,\n        element_info: List,\n        result_expr: MenaiASTNode,\n        else_expr: MenaiASTNode\n    ) -> MenaiASTNode:\n        \"\"\"\n        Build a clause for a list pattern with proper nesting.\n\n        Args:\n            length_test: Test for list? and length\n            element_info: List of (pattern, temp_var, extraction_expr)\n            result_expr: Result expression to evaluate if pattern matches\n            else_expr: Expression to evaluate if pattern doesn't match\n\n        Returns:\n            Properly nested if/let structure\n        \"\"\"\n        # Build: (if length_test\n        #          (let ((#:tmp-2 (list-ref x 0)) ...)\n        #            (if (and elem-test-1 elem-test-2 ...)\n        #                (let ((a #:tmp-2) (b #:tmp-3) ...)\n        #                  result)\n        #                else))\n        #          else)\n\n        # Extract elements\n        extraction_bindings: List[Tuple[str, MenaiASTNode]] = []\n        element_tests: List[MenaiASTNode] = []\n        pattern_bindings: List[Tuple[str, MenaiASTNode]] = []\n\n        for elem_pattern, elem_temp, elem_value in element_info:\n            # Add extraction binding\n            extraction_bindings.append((elem_temp, elem_value))\n\n            # Desugar element pattern\n            elem_test, elem_bindings = self._desugar_pattern(elem_pattern, elem_temp)\n\n            # Check if element pattern is itself a list/cons pattern (special marker)\n            if (elem_bindings and len(elem_bindings) == 1 and\n                    (elem_bindings[0][0].startswith('__LIST_PATTERN_') or\n                     elem_bindings[0][0].startswith('__CONS_PATTERN_'))):\n                # Nested list/cons pattern - use helper to recursively flatten it\n                self._flatten_nested_pattern(\n                    elem_pattern,\n                    elem_temp,\n                    extraction_bindings,\n                    element_tests,\n                    pattern_bindings\n                )\n\n            else:\n                # Regular pattern\n                # Collect element test (unless it's just #t)\n                if not (isinstance(elem_test, MenaiASTBoolean) and elem_test.value):\n                    element_tests.append(elem_test)\n\n                # Collect pattern bindings\n                pattern_bindings.extend(elem_bindings)\n\n        # Build the inner structure (after element extraction)\n        if element_tests:\n            # We have element tests - need nested if\n            elem_test_combined = self._make_and(element_tests, MenaiASTList(()))\n\n            # Build pattern bindings let\n            if pattern_bindings:\n                binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in pattern_bindings]\n                pattern_let: MenaiASTNode = MenaiASTList((\n                    MenaiASTSymbol('let*'),\n                    MenaiASTList(tuple(binding_list)),\n                    result_expr\n                ))\n\n            else:\n                pattern_let = result_expr\n\n            # Build element test if\n            inner_if: MenaiASTNode = MenaiASTList((\n                MenaiASTSymbol('if'),\n                elem_test_combined,\n                pattern_let,\n                else_expr\n            ))\n\n        else:\n            # No element tests - just bind pattern vars\n            if pattern_bindings:\n                binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in pattern_bindings]\n                inner_if = MenaiASTList((\n                    MenaiASTSymbol('let*'),\n                    MenaiASTList(tuple(binding_list)),\n                    result_expr\n                ))\n\n            else:\n                inner_if = result_expr\n\n        # Wrap in element extraction let\n        extraction_binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in extraction_bindings]\n        extraction_let = MenaiASTList((\n            MenaiASTSymbol('let*'),\n            MenaiASTList(tuple(extraction_binding_list)),\n            inner_if\n        ))\n\n        # Build outer if with length test\n        return MenaiASTList((\n            MenaiASTSymbol('if'),\n            length_test,\n            extraction_let,\n            else_expr\n        ))\n\n    def _desugar_cons_pattern(\n        self,\n        pattern: MenaiASTList,\n        temp_var: str,\n        dot_position: int\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, Any]]]:\n        \"\"\"\n        Desugar a cons pattern like (head . tail) or (a b . rest).\n\n        Args:\n            pattern: List pattern AST\n            temp_var: Name of temp variable holding the match value\n            dot_position: Index of the dot in the pattern\n\n        Returns:\n            (test_expression, bindings)\n        \"\"\"\n        # Validation already done by semantic analyzer\n        assert dot_position > 0, \"Dot should not be at beginning (validated by semantic analyzer)\"\n        assert dot_position < len(pattern.elements) - 1, \"Dot should not be at end (validated by semantic analyzer)\"\n        assert dot_position == len(pattern.elements) - 2, \\\n            \"Should have exactly one element after dot (validated by semantic analyzer)\"\n\n        # Test: (and (list? temp_var) (>= (length temp_var) dot_position))\n        list_test = MenaiASTList((\n            MenaiASTSymbol('list?'),\n            MenaiASTSymbol(temp_var)\n        ))\n\n        length_test = MenaiASTList((\n            MenaiASTSymbol('integer>=?'),\n            MenaiASTList((\n                MenaiASTSymbol('list-length'),\n                MenaiASTSymbol(temp_var)\n            )),\n            MenaiASTInteger(dot_position)\n        ))\n        combined_test = self._make_and([list_test, length_test], MenaiASTList(()))\n\n        # Collect head element info\n        head_elements: List[Tuple[MenaiASTNode, str, MenaiASTNode]] = []\n\n        for i in range(dot_position):\n            elem_pattern = pattern.elements[i]\n            elem_temp = self._gen_temp()\n\n            # Extract element: (list-ref temp_var i)\n            elem_value = MenaiASTList((\n                MenaiASTSymbol('list-ref'),\n                MenaiASTSymbol(temp_var),\n                MenaiASTInteger(i)\n            ))\n\n            head_elements.append((elem_pattern, elem_temp, elem_value))\n\n        # Build binding for tail\n        tail_pattern = pattern.elements[dot_position + 1]\n        tail_temp = self._gen_temp()\n\n        # Extract tail: (list-slice temp-var dot_position)\n        tail_value = MenaiASTList((\n            MenaiASTSymbol('list-slice'),\n            MenaiASTSymbol(temp_var),\n            MenaiASTInteger(dot_position)\n        ))\n\n        # Add tail to element info\n        all_elements = head_elements + [(tail_pattern, tail_temp, tail_value)]\n\n        # Return special marker for cons pattern\n        # Use a unique marker name to avoid duplicates in nested patterns\n        marker_name = f'__CONS_PATTERN_{self._gen_temp()}__'\n        return (combined_test, [(marker_name, all_elements)])\n\n    def _gen_temp(self) -> str:\n        \"\"\"Generate unique temporary variable name.\"\"\"\n        self.temp_counter += 1\n        return f\"#:match-tmp-{self.temp_counter}\"\n\n```",
      "completed": true,
      "tool_results": [
        {
          "id": "toolu_01Wk5itmx4EFk8HQmVwJdLx8",
          "name": "filesystem",
          "content": "\"\"\"\nMenai AST Desugarer - transforms complex constructs into core language.\n\nThe desugarer takes a full AST (including match, and, or) and transforms it\ninto a core AST containing only:\n- Literals (numbers, strings, booleans)\n- Variables (symbols)\n- If expressions\n- Let expressions\n- Lambda expressions\n- Function calls\n\nThis simplifies the compiler and enables better optimization.\n\"\"\"\n\nfrom typing import List, Set, Tuple, Any, cast\n\nfrom menai.menai_ast import (\n    MenaiASTNode, MenaiASTSymbol, MenaiASTList, MenaiASTInteger,\n    MenaiASTFloat, MenaiASTComplex, MenaiASTString, MenaiASTBoolean, MenaiASTNone\n)\nfrom menai.menai_ast_dependency_analyzer import MenaiASTDependencyAnalyzer\nfrom menai.menai_builtin_registry import MenaiBuiltinRegistry\nfrom menai.menai_error import MenaiEvalError\n\n\nclass MenaiASTDesugarer:\n    \"\"\"Transforms complex Menai constructs into core language.\"\"\"\n\n    def __init__(self) -> None:\n        self.temp_counter = 0  # For generating unique temp variable names\n\n    def _make_symbol(self, name: str, source_node: MenaiASTNode) -> MenaiASTSymbol:\n        \"\"\"Create a symbol with source location from another node.\"\"\"\n        return MenaiASTSymbol(\n            name,\n            line=source_node.line,\n            column=source_node.column,\n            source_file=source_node.source_file\n        )\n\n    def _make_list(self, elements: tuple, source_node: MenaiASTNode) -> MenaiASTList:\n        \"\"\"Create a list with source location from another node.\"\"\"\n        return MenaiASTList(\n            elements,\n            line=source_node.line,\n            column=source_node.column,\n            source_file=source_node.source_file\n        )\n\n    def _make_and(self, exprs: List[MenaiASTNode], source_node: MenaiASTNode) -> MenaiASTNode:\n        \"\"\"\n        Construct (and exprs...) as a lowered if-chain without going through desugar().\n\n        Used internally when building AST nodes that must already be in desugared\n        form (e.g. inside _desugar_pattern, _desugar_fixed_list_pattern).\n\n        (and)      -> #t\n        (and A)    -> A\n        (and A B+) -> (if A (and B+) #f)\n        \"\"\"\n        if not exprs:\n            return MenaiASTBoolean(\n                True,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            )\n\n        if len(exprs) == 1:\n            return exprs[0]\n\n        return self._make_list((\n            self._make_symbol('if', source_node),\n            exprs[0],\n            self._make_and(exprs[1:], source_node),\n            MenaiASTBoolean(\n                False,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            ),\n        ), source_node)\n\n    def _make_or(self, exprs: List[MenaiASTNode], source_node: MenaiASTNode) -> MenaiASTNode:\n        \"\"\"\n        Construct (or exprs...) as a lowered if-chain without going through desugar().\n\n        Used internally when building AST nodes that must already be in desugared\n        form (e.g. inside _desugar_strict_equality_chain).\n\n        (or)      -> #f\n        (or A)    -> A\n        (or A B+) -> (if A #t (or B+))\n        \"\"\"\n        if not exprs:\n            return MenaiASTBoolean(\n                False,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            )\n\n        if len(exprs) == 1:\n            return exprs[0]\n\n        return self._make_list((\n            self._make_symbol('if', source_node),\n            exprs[0],\n            MenaiASTBoolean(\n                True,\n                line=source_node.line,\n                column=source_node.column,\n                source_file=source_node.source_file\n            ),\n            self._make_or(exprs[1:], source_node),\n        ), source_node)\n\n    def _desugar_and(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar (and A B ...) to a right-folded if-chain.\n\n        (and)      -> #t\n        (and A)    -> (desugar A)\n        (and A B+) -> (if (desugar A) (desugar (and B+)) #f)\n        \"\"\"\n        args = list(expr.elements[1:])\n        if not args:\n            return MenaiASTBoolean(True, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        if len(args) == 1:\n            return self.desugar(args[0])\n\n        desugared_first = self.desugar(args[0])\n        rest_expr = self._make_list((self._make_symbol('and', expr),) + tuple(args[1:]), expr)\n        desugared_rest = self._desugar_and(rest_expr)\n        return self._make_list((\n            self._make_symbol('if', expr),\n            desugared_first,\n            desugared_rest,\n            MenaiASTBoolean(False, line=expr.line, column=expr.column, source_file=expr.source_file),\n        ), expr)\n\n    def _desugar_or(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar (or A B ...) to a right-folded if-chain.\n\n        (or)      -> #f\n        (or A)    -> (desugar A)\n        (or A B+) -> (if (desugar A) #t (desugar (or B+)))\n        \"\"\"\n        args = list(expr.elements[1:])\n        if not args:\n            return MenaiASTBoolean(False, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        if len(args) == 1:\n            return self.desugar(args[0])\n\n        desugared_first = self.desugar(args[0])\n        rest_expr = self._make_list((self._make_symbol('or', expr),) + tuple(args[1:]), expr)\n        desugared_rest = self._desugar_or(rest_expr)\n        return self._make_list((\n            self._make_symbol('if', expr),\n            desugared_first,\n            MenaiASTBoolean(True, line=expr.line, column=expr.column, source_file=expr.source_file),\n            desugared_rest,\n        ), expr)\n\n    def desugar(self, expr: MenaiASTNode) -> MenaiASTNode:\n        \"\"\"\n        Desugar an expression recursively.\n\n        Args:\n            expr: AST to desugar\n\n        Returns:\n            Desugared AST (core language only)\n        \"\"\"\n        # Lists need inspection - anything else does not\n        if not isinstance(expr, MenaiASTList):\n            return expr\n\n        if expr.is_empty():\n            return expr\n\n        first = expr.first()\n        if isinstance(first, MenaiASTSymbol):\n            name = first.name\n\n            # Match expression - desugar it!\n            if name == 'match':\n                return self._desugar_match(expr)\n\n            # Core constructs - desugar children only\n            if name == 'if':\n                return self._desugar_if(expr)\n\n            if name == 'let':\n                return self._desugar_let(expr)\n\n            if name == 'letrec':\n                return self._desugar_letrec(expr)\n\n            if name == 'let*':\n                # Let* desugars to nested lets\n                return self._desugar_let_star(expr)\n\n            if name == 'lambda':\n                return self._desugar_lambda(expr)\n\n            if name == 'quote':\n                # Quote: don't desugar the quoted expression\n                return expr\n\n            if name == 'trace':\n                # Trace is a special form - handle it\n                return self._desugar_trace(expr)\n\n            if name == 'and':\n                return self._desugar_and(expr)\n\n            if name == 'or':\n                return self._desugar_or(expr)\n\n            # Fixed-arity opcode rewrite: if this call is to a known builtin\n            # with exactly its primitive arity, rewrite the function name to the\n            # $-prefixed primitive form.  This fires before\n            # the variadic/comparison/equality rewrites so that e.g.\n            # (integer+ a b) \u2192 ($integer+ a b) directly, while\n            # (integer+ a b c) still falls through to _desugar_variadic_arithmetic.\n            #\n            # Several builtins have optional trailing arguments whose opcodes\n            # always require the full argument count.  When the user omits the\n            # optional argument(s) the desugarer synthesises the missing default\n            # so that the $-prefixed opcode call is always fully saturated:\n            #\n            #   Constant defaults (1-arg min, 2-arg opcode):\n            #     (integer->complex n)     \u2192 ($integer->complex n 0)\n            #     (integer->string n)      \u2192 ($integer->string n 10)\n            #     (float->complex x)       \u2192 ($float->complex x 0.0)\n            #     (string->integer s)      \u2192 ($string->integer s 10)\n            #     (string->list s)         \u2192 ($string->list s \"\")\n            #     (list->string l)         \u2192 ($list->string l \"\")\n            #\n            #   Constant defaults (2-arg min, 3-arg opcode):\n            #     (dict-get d k)           \u2192 ($dict-get d k #none)\n            #     (range start end)        \u2192 ($range start end 1)\n            #\n            #   Computed defaults (2-arg min, 3-arg opcode):\n            #     (string-slice s start)   \u2192 (let ((#:t s)) ($string-slice #:t start ($string-length #:t)))\n            #     (list-slice   l start)   \u2192 (let ((#:t l)) ($list-slice #:t start ($list-length #:t)))\n            #\n            # The computed-default cases bind the collection argument to a temp\n            # to avoid evaluating it twice.\n            primitive_arity = MenaiBuiltinRegistry.get_primitive_arity(name)\n            if primitive_arity is not None:\n                n_args = len(expr.elements) - 1\n                if n_args == primitive_arity:\n                    dollar_name = '$' + name\n                    desugared_args = [self.desugar(arg) for arg in expr.elements[1:]]\n                    return self._make_list(\n                        (self._make_symbol(dollar_name, expr),) + tuple(desugared_args),\n                        expr\n                    )\n                # Constant-default completions.\n                constant_defaults: dict[str, MenaiASTNode] = {\n                    'integer->complex': MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'integer->string': MenaiASTInteger(10, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'float->complex': MenaiASTFloat(0.0, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'string->integer': MenaiASTInteger(10, line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'string->list': MenaiASTString(\"\", line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'list->string': MenaiASTString(\"\", line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'dict-get': MenaiASTNone(line=expr.line, column=expr.column, source_file=expr.source_file),\n                    'range': MenaiASTInteger(1, line=expr.line, column=expr.column, source_file=expr.source_file),\n                }\n                if name in constant_defaults and n_args == primitive_arity - 1:\n                    default = constant_defaults[name]\n                    desugared_args = [self.desugar(arg) for arg in expr.elements[1:]]\n                    return self._make_list(\n                        (self._make_symbol('$' + name, expr),) + tuple(desugared_args) + (default,),\n                        expr\n                    )\n                # Computed-default completions: bind the collection to a temp to\n                # avoid double-evaluation, then synthesise the length call.\n                if name in ('string-slice', 'list-slice') and n_args == 2:\n                    length_fn = 'string-length' if name == 'string-slice' else 'list-length'\n                    coll_arg = self.desugar(expr.elements[1])\n                    start_arg = self.desugar(expr.elements[2])\n                    temp = self._gen_temp()\n                    temp_sym = self._make_symbol(temp, expr)\n                    length_call = self._make_list((\n                        self._make_symbol('$' + length_fn, expr),\n                        temp_sym,\n                    ), expr)\n                    slice_call = self._make_list((\n                        self._make_symbol('$' + name, expr),\n                        temp_sym,\n                        start_arg,\n                        length_call,\n                    ), expr)\n                    return self._make_list((\n                        self._make_symbol('let', expr),\n                        self._make_list((\n                            self._make_list((temp_sym, coll_arg), expr),\n                        ), expr),\n                        slice_call,\n                    ), expr)\n\n            # Check for typed variadic arithmetic operations\n            if name in [\n                'integer+', 'integer-', 'integer*', 'integer/',\n                'float+', 'float-', 'float*', 'float/',\n                'complex+', 'complex-', 'complex*', 'complex/',\n            ]:\n                return self._desugar_variadic_arithmetic(expr)\n\n            # Fold-reducible variadic operations\n            if name in [\n                'integer-bit-or', 'integer-bit-and', 'integer-bit-xor',\n                'integer-min', 'integer-max',\n                'float-min', 'float-max',\n                'list-concat',\n                'string-concat',\n            ]:\n                return self._desugar_fold_variadic(expr)\n\n            # Variadic comparison chains (short-circuit with 'and' is correct)\n            if name in [\n                'integer<?', 'integer>?', 'integer<=?', 'integer>=?',\n                'float<?',   'float>?',   'float<=?',   'float>=?',\n                'string<?',  'string>?',  'string<=?',  'string>=?',\n            ]:\n                return self._desugar_comparison_chain(expr)\n\n            # Strict equality predicates\n            if name in [\n                'boolean=?', 'integer=?', 'float=?', 'complex=?', 'string=?', 'list=?', 'dict=?'\n            ]:\n                return self._desugar_strict_equality(expr)\n\n            # Strict inequality predicates\n            if name in [\n                'boolean!=?', 'integer!=?', 'float!=?', 'complex!=?', 'string!=?', 'list!=?', 'dict!=?'\n            ]:\n                return self._desugar_strict_inequality(expr)\n\n        # Regular function call - desugar all elements\n        return self._desugar_call(expr)\n\n    def _desugar_if(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar if expression by desugaring its subexpressions.\"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 4, \"If expression should have exactly 4 elements (validated by semantic analyzer)\"\n\n        _, condition, then_expr, else_expr = expr.elements\n\n        # Desugar all subexpressions\n        desugared_condition = self.desugar(condition)\n        desugared_then = self.desugar(then_expr)\n        desugared_else = self.desugar(else_expr)\n\n        return self._make_list((\n            self._make_symbol('if', expr),\n            desugared_condition, desugared_then, desugared_else\n        ), expr)\n\n    def _desugar_let(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar let expression by desugaring its subexpressions.\"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 3, \"Let expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        let_symbol = expr.elements[0]\n        bindings_list = expr.elements[1]\n        body = expr.elements[2]\n\n        assert isinstance(bindings_list, MenaiASTList), \"Binding list should be a list (validated by semantic analyzer)\"\n\n        # Desugar each binding value\n        desugared_bindings = []\n        for i, binding in enumerate(bindings_list.elements):\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2, \\\n                f\"Binding {i+1} should be a list with 2 elements (validated by semantic analyzer)\"\n\n            var_name, value_expr = binding.elements\n            desugared_value = self.desugar(value_expr)\n            desugared_bindings.append(self._make_list((var_name, desugared_value), binding))\n\n        # Desugar body\n        desugared_body = self.desugar(body)\n\n        return self._make_list((\n            let_symbol, self._make_list(tuple(desugared_bindings), bindings_list), desugared_body\n        ), expr)\n\n    def _desugar_letrec(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar letrec by splitting mixed bindings into nested let/letrec forms.\n\n        A letrec with mixed lambda and non-lambda bindings is transformed into a\n        sequence of let/letrec forms in topological order:\n\n          - Non-recursive binding (lambda or non-lambda) -> let\n          - Recursive group (always lambdas after splitting) -> letrec\n\n        For example:\n\n          (letrec ((a (list 1 2 3))\n                   (f (lambda (x) ... a ...))\n                   (g (lambda (x) ... f ...)))\n            body)\n\n        becomes:\n\n          (let ((a (list 1 2 3)))\n            (letrec ((f (lambda (x) ... a ...))\n                     (g (lambda (x) ... f ...)))\n              body))\n\n        After splitting, every remaining letrec contains only a genuine mutually-\n        recursive group of lambdas, and all non-lambda values live in let bindings\n        where they belong.\n\n        Desugaring of binding values and body happens as the split nodes are built,\n        so no separate desugaring pass over the result is needed.\n        \"\"\"\n        assert len(expr.elements) == 3, \"Letrec expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        bindings_list = expr.elements[1]\n        body = expr.elements[2]\n\n        assert isinstance(bindings_list, MenaiASTList), \"Binding list should be a list (validated by semantic analyzer)\"\n\n        # Extract raw (name, value_expr) pairs for dependency analysis.\n        # The analyzer only inspects symbol names, so raw (pre-desugared) AST is correct here.\n        raw_pairs: List[Tuple[str, MenaiASTNode]] = []\n        for binding in bindings_list.elements:\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2\n            name_expr, value_expr = binding.elements\n            assert isinstance(name_expr, MenaiASTSymbol)\n            raw_pairs.append((name_expr.name, value_expr))\n\n        raw_dict = dict(raw_pairs)\n\n        # Compute topological binding groups (already in dependency order).\n        binding_groups = MenaiASTDependencyAnalyzer().analyze_letrec_bindings(raw_pairs)\n\n        # Desugar the body, then wrap it in binding forms from innermost outward\n        # (i.e. process groups in reverse topological order so each group's body\n        # is the already-built inner expression).\n        #\n        # Consecutive non-recursive groups are sub-partitioned into flat lets:\n        # bindings that are mutually independent (no sibling references) are\n        # batched into a single let; only when a binding depends on an earlier\n        # sibling does a new nested let begin.  This keeps nesting depth\n        # proportional to the number of inter-sibling dependencies, not the\n        # total number of bindings \u2014 which matters for large letrecs like a\n        # library module where almost all bindings are independent.\n        result: MenaiASTNode = self.desugar(body)\n\n        # Build a flat list of (kind, [group, ...]) entries in topological order,\n        # then process in reverse so each entry wraps the already-built inner result.\n        #\n        # For non-recursive groups we sub-partition greedily: accumulate bindings\n        # into the current batch as long as none of them reference a name already\n        # in the batch.  When a dependency on a batch-sibling is detected, close\n        # the current batch and start a new one.  Each batch becomes one let.\n        runs: List[tuple] = []\n        current_batch: List = []\n        current_batch_names: Set[str] = set()\n\n        for group in binding_groups:\n            if group.is_recursive:\n                if current_batch:\n                    runs.append(('let', current_batch))\n                    current_batch = []\n                    current_batch_names = set()\n                runs.append(('letrec', [group]))\n\n            else:\n                # Check whether this group's binding references any name already\n                # in the current batch.  Non-recursive singletons have exactly\n                # one name, but we use group.depends_on for the dependency check\n                # since the dependency analyser already computed it.\n                if group.depends_on & current_batch_names:\n                    # Dependency on a batch sibling \u2014 close current batch first.\n                    runs.append(('let', current_batch))\n                    current_batch = [group]\n                    current_batch_names = set(group.names)\n\n                else:\n                    current_batch.append(group)\n                    current_batch_names |= group.names\n\n        if current_batch:\n            runs.append(('let', current_batch))\n\n        for kind, run_groups in reversed(runs):\n            combined_bindings: List[MenaiASTNode] = []\n            for group in run_groups:\n                for name in group.names:\n                    name_sym = self._make_symbol(name, expr)\n                    desugared_value = self.desugar(raw_dict[name])\n                    combined_bindings.append(self._make_list((name_sym, desugared_value), expr))\n\n            binding_list_node = self._make_list(tuple(combined_bindings), expr)\n            result = self._make_list((\n                self._make_symbol(kind, expr),\n                binding_list_node,\n                result,\n            ), expr)\n\n        return result\n\n    def _desugar_let_star(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar let* expression to nested let expressions.\n\n        (let* ((x 1) (y (+ x 1)) (z (* y 2))) body)\n        =>\n        (let ((x 1))\n          (let ((y (+ x 1)))\n            (let ((z (* y 2)))\n              body)))\n        \"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 3, \"Let* expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        _, bindings_list, body = expr.elements\n        assert isinstance(bindings_list, MenaiASTList), \"Binding list should be a list (validated by semantic analyzer)\"\n\n        # If no bindings, just return the body\n        if len(bindings_list.elements) == 0:\n            return self.desugar(body)\n\n        # Build nested lets from the inside out\n        # Start with the body\n        result = self.desugar(body)\n\n        # Wrap in nested lets, processing bindings in reverse order\n        for binding in reversed(bindings_list.elements):\n            assert isinstance(binding, MenaiASTList) and len(binding.elements) == 2, \\\n                \"Binding should be a list with 2 elements (validated by semantic analyzer)\"\n\n            var_name, value_expr = binding.elements\n\n            # Desugar the value expression\n            desugared_value = self.desugar(value_expr)\n\n            # Wrap result in a let with this binding\n            result = self._make_list((\n                self._make_symbol('let', expr),\n                self._make_list((self._make_list((var_name, desugared_value), binding),), binding),\n                result\n            ), expr)\n\n        return result\n\n    def _desugar_lambda(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar lambda expression by desugaring its body.\"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) == 3, \"Lambda expression should have exactly 3 elements (validated by semantic analyzer)\"\n\n        lambda_symbol, params_list, body = expr.elements\n\n        # Desugar body\n        desugared_body = self.desugar(body)\n\n        return self._make_list((lambda_symbol, params_list, desugared_body), expr)\n\n    def _desugar_trace(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar trace special form.\n\n        (trace msg1 msg2 ... msgN expr)\n\n        Trace is kept as-is but with desugared subexpressions.\n        The IR builder will handle creating the trace IR node.\n        \"\"\"\n        if expr.length() < 3:  # (trace msg expr) minimum\n            raise MenaiEvalError(\n                message=\"trace requires at least 2 arguments (message, expr)\",\n                suggestion=\"Usage: (trace \\\"message\\\" expression)\"\n            )\n\n        # Desugar all subexpressions\n        desugared_elements: List[MenaiASTNode] = [self._make_symbol('trace', expr)]\n        for elem in expr.elements[1:]:  # Skip 'trace' symbol\n            desugared_elements.append(self.desugar(elem))\n\n        return self._make_list(tuple(desugared_elements), expr)\n\n    def _desugar_call(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar function call by desugaring all elements.\"\"\"\n        desugared_elements = []\n        for elem in expr.elements:\n            desugared_elements.append(self.desugar(elem))\n\n        return self._make_list(tuple(desugared_elements), expr)\n\n    def _desugar_variadic_arithmetic(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar variadic arithmetic operations to nested binary operations.\n\n        Examples:\n            (+ 1 2 3) \u2192 (+ (+ 1 2) 3)\n            (- 5) \u2192 (- 0 5)  [unary negation]\n            (* 2 3 4) \u2192 (* (* 2 3) 4)\n            (+ 1) \u2192 1  [identity]\n            (+) \u2192 0  [zero-arg identity]\n\n        Args:\n            expr: Arithmetic expression to desugar\n\n        Returns:\n            Desugared expression (binary operations only)\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        # Determine identity elements and sub operator for this family.\n        if op_name in ('integer+', 'integer-', 'integer*', 'integer/'):\n            zero: MenaiASTNode = MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n            one: MenaiASTNode = MenaiASTInteger(1, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        elif op_name in ('float+', 'float-', 'float*', 'float/'):\n            zero = MenaiASTFloat(0.0, line=expr.line, column=expr.column, source_file=expr.source_file)\n            one = MenaiASTFloat(1.0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        elif op_name in ('complex+', 'complex-', 'complex*', 'complex/'):\n            zero = MenaiASTComplex(0+0j, line=expr.line, column=expr.column, source_file=expr.source_file)\n            one = MenaiASTComplex(1+0j, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n        else:\n            assert False, f\"Unexpected operator in _desugar_variadic_arithmetic: {op_name!r}\"\n\n        is_add = op_name in ('integer+', 'float+', 'complex+')\n        is_mul = op_name in ('integer*', 'float*', 'complex*')\n\n        # Handle zero-argument cases\n        if len(args) == 0:\n            if is_add:\n                # (+) / (integer+) / (float+) / (complex+) \u2192 identity element\n                return zero\n\n            if is_mul:\n                # (*) / (integer*) / (float*) / (complex*) \u2192 identity element\n                return one\n\n            # subtraction/division with no args are errors \u2014 fall through to runtime\n            return self._desugar_call(expr)\n\n        # Handle single-argument cases\n        if len(args) == 1:\n            desugared_arg = self.desugar(args[0])\n\n            if is_add or is_mul:\n                # (+ x) \u2192 x, (* x) \u2192 x [identity]\n                return desugared_arg\n\n            # subtraction/division with one arg is an error - fall through to runtime\n            return self._desugar_call(expr)\n\n        # Handle binary case (already optimal)\n        if len(args) == 2:\n            desugared_args = [self.desugar(arg) for arg in args]\n            return self._make_list(\n                (self._make_symbol('$' + op_name, expr),) + tuple(desugared_args), expr\n            )\n\n        # Handle variadic case (3+ arguments) - fold left to right\n        # (+ 1 2 3 4) \u2192 (+ (+ (+ 1 2) 3) 4)\n        desugared_args = [self.desugar(arg) for arg in args]\n\n        # Start with first two arguments\n        result = self._make_list((\n            self._make_symbol('$' + op_name, expr),\n            desugared_args[0],\n            desugared_args[1]\n        ), expr)\n\n        # Fold remaining arguments left-to-right\n        for arg in desugared_args[2:]:\n            result = self._make_list((\n                self._make_symbol('$' + op_name, expr),\n                result,\n                arg\n            ), expr)\n\n        return result\n\n    def _desugar_fold_variadic(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar fold-reducible variadic operations to nested binary operations.\n\n        These are operations where (f a b c) means (f (f a b) c) \u2014 a left fold.\n        Each operation has a natural identity element for the 0-arg case.\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        # 0-arg identity cases\n        if len(args) == 0:\n            if op_name == 'integer-bit-or':\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'integer-bit-and':\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'integer-bit-xor':\n                return MenaiASTInteger(0, line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'string-concat':\n                return MenaiASTString(\"\", line=expr.line, column=expr.column, source_file=expr.source_file)\n\n            if op_name == 'list-concat':\n                return self._make_list((self._make_symbol('quote', expr), self._make_list((), expr)), expr)\n\n            # min/max with 0 args: let runtime raise the error\n            return self._desugar_call(expr)\n\n        # 1-arg: identity \u2014 return the single argument as-is\n        if len(args) == 1:\n            return self.desugar(args[0])\n\n        # 2-arg: already binary, emit directly\n        if len(args) == 2:\n            return self._make_list(\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\n            )\n\n        # 3+ args: left-fold\n        desugared_args = [self.desugar(arg) for arg in args]\n        result = self._make_list(\n            (self._make_symbol('$' + op_name, expr), desugared_args[0], desugared_args[1]), expr\n        )\n        for arg in desugared_args[2:]:\n            result = self._make_list(\n                (self._make_symbol('$' + op_name, expr), result, arg), expr\n            )\n\n        return result\n\n    def _desugar_comparison_chain(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Desugar variadic comparison/equality operations to pairwise binary comparisons.\n\n        (op a b c) means (and (op a b) (op b c)), not a fold.\n        Each argument is evaluated once; the desugared form uses let bindings to\n        avoid double-evaluation when there are 3+ arguments.\n\n        The 2-arg case emits the binary opcode directly. The 3+-arg case wraps\n        intermediate values in let bindings and chains with 'and'.\n        For != the pairwise connector is 'or' rather than 'and'.\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        # 2-arg: emit binary opcode directly (most common case)\n        if len(args) == 2:\n            return self._make_list(\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\n            )\n\n        # 3+ args: (op a b c d) \u2192 (and (op a b) (op b c) (op c d))\n        # For != the connector is 'or' instead of 'and': any consecutive pair\n        # differing is sufficient to make the whole expression true.\n        # Bind each arg to a temp to avoid double-evaluation, then chain pairwise.\n        desugared_args = [self.desugar(arg) for arg in args]\n        temps = [self._gen_temp() for _ in args]\n\n        # Build pairwise comparisons\n        pairs: List[MenaiASTNode] = [\n            self._make_list((self._make_symbol('$' + op_name, expr),\n                             self._make_symbol(temps[i], expr),\n                             self._make_symbol(temps[i + 1], expr)), expr)\n            for i in range(len(temps) - 1)\n        ]\n\n        # Chain with 'and' for ordered comparisons\n        body: MenaiASTNode = self._make_and(pairs, expr)\n\n        # Wrap in let* bindings from innermost outward\n        for temp, desugared_arg in reversed(list(zip(temps, desugared_args))):\n            body = self._make_list((\n                self._make_symbol('let*', expr),\n                self._make_list((\n                    self._make_list((self._make_symbol(temp, expr), desugared_arg), expr),\n                ), expr),\n                body\n            ), expr)\n\n        return self.desugar(body)\n\n    def _desugar_strict_equality_chain(self, expr: MenaiASTList, check_eq: bool) -> MenaiASTNode:\n        \"\"\"\n        Desugar strict type-specific equality predicates.\n\n        The 2-arg case is desugared to a binary opcode directly.\n\n        The 3+-arg case binds each argument to a temp (to avoid double-evaluation)\n        then chains pairwise binary calls with 'and' (for equality) or 'or' (for\n        inequality), which short-circuits left-to-right \u2014 consistent with the\n        prelude lambda and with _desugar_comparison_chain.\n\n        For example, (integer=? a b c) becomes:\n            (let* ((t0 a) (t1 b) (t2 c))\n              (and (integer=? t0 t1)\n                   (integer=? t1 t2)))\n\n        The 0-arg and 1-arg cases fall through to a regular call, which\n        resolves to the prelude lambda that raises the arity error.\n        \"\"\"\n        op_symbol = expr.first()\n        assert isinstance(op_symbol, MenaiASTSymbol)\n        op_name = op_symbol.name\n\n        args = list(expr.elements[1:])\n\n        if len(args) == 2:\n            return self._make_list(\n                (op_symbol, self.desugar(args[0]), self.desugar(args[1])), expr\n            )\n\n        if len(args) >= 3:\n            # Desugar all args first\n            desugared_args = [self.desugar(arg) for arg in args]\n\n            # Generate temps for each arg to avoid double-evaluation\n            temps = [self._gen_temp() for _ in args]\n\n            # Build pairwise binary calls directly: (op ti ti+1)\n            pairs: List[MenaiASTNode] = [\n                self._make_list((self._make_symbol('$' + op_name, expr),\n                                 self._make_symbol(temps[i], expr),\n                                 self._make_symbol(temps[i + 1], expr)), expr)\n                for i in range(len(args) - 1)\n            ]\n\n            # Body: and/or of the pair calls directly \u2014 short-circuits left-to-right,\n            # consistent with the prelude lambda and _desugar_comparison_chain.\n            body: MenaiASTNode = (self._make_and(pairs, expr) if check_eq\n                                  else self._make_or(pairs, expr))\n\n            # Wrap arg values in let* bindings (innermost first)\n            for temp, desugared_arg in reversed(list(zip(temps, desugared_args))):\n                body = self._make_list((\n                    self._make_symbol('let*', expr),\n                    self._make_list((\n                        self._make_list((self._make_symbol(temp, expr), desugared_arg), expr),\n                    ), expr),\n                    body\n                ), expr)\n\n            return self.desugar(body)\n\n        # 0-arg or 1-arg: fall through to regular call \u2192 prelude lambda raises arity error\n        return self._desugar_call(expr)\n\n    def _desugar_strict_equality(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar strict type-specific equality predicates.\"\"\"\n        return self._desugar_strict_equality_chain(expr, check_eq=True)\n\n    def _desugar_strict_inequality(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"Desugar strict type-specific inequality predicates.\"\"\"\n        return self._desugar_strict_equality_chain(expr, check_eq=False)\n\n    def _desugar_match(self, expr: MenaiASTList) -> MenaiASTNode:\n        \"\"\"\n        Transform match expression into if/let expressions.\n\n        Args:\n            expr: Match expression AST\n\n        Returns:\n            Desugared if/let AST\n        \"\"\"\n        # Validation already done by semantic analyzer\n        assert len(expr.elements) >= 3, \"Match expression should have at least 3 elements (validated by semantic analyzer)\"\n\n        value_expr = expr.elements[1]\n        clauses = list(expr.elements[2:])\n\n        # All clauses already validated by semantic analyzer\n        for i, clause in enumerate(clauses):\n            assert isinstance(clause, MenaiASTList) and len(clause.elements) == 2, \\\n                f\"Clause {i+1} should be a list with 2 elements (validated by semantic analyzer)\"\n\n        # Generate temp variable for match value\n        temp_var = self._gen_temp()\n\n        # Desugar the value expression\n        desugared_value = self.desugar(value_expr)\n\n        # Build the match logic as nested if/let expressions\n        match_logic = self._build_match_clauses(temp_var, clauses)\n\n        # Wrap in let to bind the temp variable\n        # (let ((temp value)) match-logic)\n        result = MenaiASTList((\n            MenaiASTSymbol('let*'),\n            MenaiASTList((\n                MenaiASTList((MenaiASTSymbol(temp_var), desugared_value)),\n            )),\n            match_logic\n        ))\n\n        # Recursively desugar the result to handle let* -> nested let transformation\n        return self.desugar(result)\n\n    def _build_match_clauses(self, temp_var: str, clauses: List[MenaiASTNode]) -> MenaiASTNode:\n        \"\"\"\n        Build nested if/let structure for match clauses.\n\n        Args:\n            temp_var: Name of temp variable holding the match value\n            clauses: Non-empty list of (pattern, result) clauses (validated by semantic analyzer)\n\n        Returns:\n            Nested if/let AST\n        \"\"\"\n        # Partition clauses into groups.  A group is either:\n        #   - A maximal contiguous run of literal arms sharing the same type\n        #     (integer, float, complex, boolean, string).  These can share a\n        #     single hoisted type guard, with bare equality checks per arm.\n        #   - A single non-literal arm (wildcard, variable binding, predicate\n        #     pattern, list/cons pattern) processed individually as before.\n        #\n        # We build the result right-to-left so each group's else branch is the\n        # already-built remainder.\n\n        no_match_error: MenaiASTNode = MenaiASTList((\n            MenaiASTSymbol('error'),\n            MenaiASTString(\"No patterns matched in match expression\")\n        ))\n\n        # Partition into groups: list of (group_type, [clause, ...])\n        # group_type is the Python AST class for literal groups, or None for singles.\n        groups: List[Tuple[Any, List[MenaiASTNode]]] = []\n        i = 0\n        while i < len(clauses):\n            clause = clauses[i]\n            assert isinstance(clause, MenaiASTList)\n            pattern = clause.elements[0]\n            lit_type = self._literal_pattern_type(pattern)\n\n            if lit_type is not None:\n                # Start or extend a literal group of this type\n                group: List[MenaiASTNode] = [clause]\n                j = i + 1\n                while j < len(clauses):\n                    next_clause = clauses[j]\n                    assert isinstance(next_clause, MenaiASTList)\n                    if not self._literal_pattern_type(next_clause.elements[0]) is lit_type:\n                        break\n\n                    group.append(next_clause)\n                    j += 1\n\n                groups.append((lit_type, group))\n                i = j\n\n            else:\n                groups.append((None, [clause]))\n                i += 1\n\n        # Build right-to-left: start with the no-match error as the base.\n        result: MenaiASTNode = no_match_error\n\n        for group_type, group_clauses in reversed(groups):\n            if group_type is not None:\n                # Literal group: hoist a single type guard over all arms.\n                result = self._build_literal_group(temp_var, group_type, group_clauses, result)\n\n            else:\n                # Single non-literal clause: use the original per-arm path.\n                clause = group_clauses[0]\n                assert isinstance(clause, MenaiASTList)\n                pattern = clause.elements[0]\n                desugared_result = self.desugar(clause.elements[1])\n                test_expr, bindings = self._desugar_pattern(pattern, temp_var)\n                result = self._build_clause_with_bindings(\n                    test_expr, bindings, desugared_result, result\n                )\n\n        return result\n\n    def _literal_pattern_type(self, pattern: MenaiASTNode) -> type | None:\n        \"\"\"\n        Return the Python AST class for a literal pattern, or None if the\n        pattern is not a simple literal (i.e. it is a wildcard, variable,\n        predicate pattern, or list/cons pattern).\n\n        Only the types that have a safe typed equality operator are included:\n        boolean, integer, float, complex, string.  MenaiASTNone is excluded\n        because (none? tmp) is already a singleton predicate with no equality\n        check needed \u2014 grouping adds no benefit there.\n        \"\"\"\n        if isinstance(pattern, (MenaiASTBoolean, MenaiASTInteger,\n                                MenaiASTFloat, MenaiASTComplex, MenaiASTString)):\n            return type(pattern)\n\n        return None\n\n    def _build_literal_group(\n        self,\n        temp_var: str,\n        lit_type: type,\n        clauses: List[MenaiASTNode],\n        else_expr: MenaiASTNode,\n    ) -> MenaiASTNode:\n        \"\"\"\n        Build a type-guarded block for a run of same-type literal arms.\n\n        Emits:\n            (if (type? tmp)\n                (if (type=? tmp lit0) result0\n                (if (type=? tmp lit1) result1\n                    ...\n                    else_expr))\n                else_expr)\n\n        The type guard is emitted once.  Each arm uses only the bare equality\n        check, with no per-arm type predicate.\n        \"\"\"\n        # Map AST literal class \u2192 (type-predicate name, equality-op name)\n        _type_info: dict[type, Tuple[str, str]] = {\n            MenaiASTBoolean: ('boolean?', 'boolean=?'),\n            MenaiASTInteger: ('integer?', 'integer=?'),\n            MenaiASTFloat:   ('float?',   'float=?'),\n            MenaiASTComplex: ('complex?', 'complex=?'),\n            MenaiASTString:  ('string?',  'string=?'),\n        }\n        type_pred, eq_op = _type_info[lit_type]\n        tmp_sym = MenaiASTSymbol(temp_var)\n\n        # Build the inner equality chain right-to-left, falling through to else_expr.\n        inner: MenaiASTNode = else_expr\n        for clause in reversed(clauses):\n            assert isinstance(clause, MenaiASTList)\n            pattern = clause.elements[0]\n            desugared_result = self.desugar(clause.elements[1])\n            eq_test = MenaiASTList((MenaiASTSymbol(eq_op), tmp_sym, pattern))\n            inner = MenaiASTList((MenaiASTSymbol('if'), eq_test, desugared_result, inner))\n\n        # Wrap in the single type guard.\n        type_test = MenaiASTList((MenaiASTSymbol(type_pred), tmp_sym))\n        return MenaiASTList((MenaiASTSymbol('if'), type_test, inner, else_expr))\n\n    def _build_clause_with_bindings(\n        self,\n        test_expr: MenaiASTNode,\n        bindings: List[Tuple[str, Any]],  # Pattern variable bindings or special markers\n        result_expr: MenaiASTNode,\n        else_expr: MenaiASTNode\n    ) -> MenaiASTNode:\n        \"\"\"\n        Build if/let structure for a single clause.\n\n        Args:\n            test_expr: Expression that tests if pattern matches\n            bindings: List of (var_name, value_expr) to bind if pattern matches\n            result_expr: Expression to evaluate if pattern matches\n            else_expr: Expression to evaluate if pattern doesn't match\n\n        Returns:\n            (if test_expr\n                (let (bindings...) result_expr)\n                else_expr)\n        \"\"\"\n        # Check if this is a list pattern (special marker)\n        if (bindings and len(bindings) == 1 and bindings[0][0].startswith('__LIST_PATTERN_')):\n            # This is a list pattern - use special building logic\n            element_info = bindings[0][1]\n            return self._build_list_pattern_clause(\n                test_expr,\n                element_info,\n                result_expr,\n                else_expr\n            )\n\n        # Check if this is a cons pattern (special marker)\n        if (bindings and len(bindings) == 1 and bindings[0][0].startswith('__CONS_PATTERN_')):\n            # This is a cons pattern - use same building logic as list pattern\n            element_info = bindings[0][1]\n            return self._build_list_pattern_clause(\n                test_expr,\n                element_info,\n                result_expr,\n                else_expr\n            )\n\n        # All bindings here are pattern variable bindings (user-defined names).\n        # They must go inside the then branch (only evaluated after test passes).\n\n        # Short-circuit: a constant #t test always matches \u2014 no branch needed.\n        # This is the wildcard (_) and unconditional variable-binding case.\n        if isinstance(test_expr, MenaiASTBoolean) and test_expr.value:\n            if bindings:\n                return MenaiASTList((\n                    MenaiASTSymbol('let*'),\n                    MenaiASTList(tuple(MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in bindings)),\n                    result_expr\n                ))\n\n            return result_expr\n\n        if bindings:\n            binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in bindings]\n\n            then_expr: MenaiASTNode = MenaiASTList((\n                MenaiASTSymbol('let*'),\n                MenaiASTList(tuple(binding_list)),\n                result_expr\n            ))\n        else:\n            then_expr = result_expr\n\n        # Build if expression\n        return MenaiASTList((\n            MenaiASTSymbol('if'),\n            test_expr,\n            then_expr,\n            else_expr\n        ))\n\n    def _desugar_pattern(\n        self,\n        pattern: MenaiASTNode,\n        temp_var: str\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, MenaiASTNode]]]:\n        \"\"\"\n        Desugar a pattern into (test_expr, bindings).\n\n        Args:\n            pattern: Pattern AST\n            temp_var: Name of temp variable holding the match value\n\n        Returns:\n            (test_expression, [(var_name, value_expr), ...])\n\n        Example:\n            Pattern: (? number? n)\n            Temp: \"#:match-tmp-1\"\n            Returns: ((number? #:match-tmp-1), [(\"n\", #:match-tmp-1)])  ; pred called directly\n        \"\"\"\n        # Literal patterns: #none, booleans, numbers, strings\n        #\n        # Each literal pattern is compiled as:\n        #   (and (type? tmp) (type=? tmp literal))\n        #\n        # The type-guard is essential for correctness: without it, presenting a\n        # value of the wrong type to the equality operator raises a type error\n        # instead of simply not matching.  The guard short-circuits via `and`\n        # so the equality check is only reached when the type is known correct.\n        #\n        # #none is the sole exception \u2014 (none? tmp) is already a safe predicate\n        # that returns #f for any non-none value, so no separate equality check\n        # is needed.\n\n        if isinstance(pattern, MenaiASTNone):\n            # (none? tmp) \u2014 singleton predicate, inherently type-safe\n            test_expr: MenaiASTNode = MenaiASTList((\n                MenaiASTSymbol('none?'),\n                MenaiASTSymbol(temp_var),\n            ))\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTBoolean):\n            # (and (boolean? tmp) (boolean=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('boolean?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('boolean=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTInteger):\n            # (and (integer? tmp) (integer=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('integer?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('integer=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTFloat):\n            # (and (float? tmp) (float=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('float?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('float=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTComplex):\n            # (and (complex? tmp) (complex=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('complex?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('complex=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        if isinstance(pattern, MenaiASTString):\n            # (and (string? tmp) (string=? tmp literal))\n            test_expr = self._make_and([\n                MenaiASTList((MenaiASTSymbol('string?'), MenaiASTSymbol(temp_var))),\n                MenaiASTList((MenaiASTSymbol('string=?'), MenaiASTSymbol(temp_var), pattern)),\n            ], pattern)\n            return (test_expr, [])\n\n        # Variable pattern: binds the value\n        if isinstance(pattern, MenaiASTSymbol):\n            if pattern.name == '_':\n                # Wildcard - always matches, no binding\n                return (MenaiASTBoolean(True), [])\n\n            # Variable binding - always matches, binds variable\n            return (\n                MenaiASTBoolean(True),\n                [(pattern.name, MenaiASTSymbol(temp_var))]\n            )\n\n        # List patterns\n        if isinstance(pattern, MenaiASTList):\n            return self._desugar_list_pattern(pattern, temp_var)\n\n        # Should never reach here - semantic analyzer validates patterns\n        assert False, f\"Unknown pattern type: {type(pattern).__name__} (should be validated by semantic analyzer)\"\n\n    def _desugar_list_pattern(\n        self,\n        pattern: MenaiASTList,\n        temp_var: str\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, MenaiASTNode]]]:\n        \"\"\"\n        Desugar a list pattern.\n\n        Args:\n            pattern: List pattern AST\n            temp_var: Name of temp variable holding the match value\n\n        Returns:\n            (test_expression, bindings)\n        \"\"\"\n        # Empty list pattern: ()\n        if pattern.is_empty():\n            # Test: (null? temp_var)\n            test_expr = MenaiASTList((\n                MenaiASTSymbol('list-null?'),\n                MenaiASTSymbol(temp_var)\n            ))\n            return (test_expr, [])\n\n        # Check for predicate test pattern: (? pred var)\n        if (len(pattern.elements) == 3 and\n            isinstance(pattern.elements[0], MenaiASTSymbol) and\n            pattern.elements[0].name == '?'):\n\n            pred_expr = pattern.elements[1]\n            var_pattern = pattern.elements[2]\n\n            assert isinstance(var_pattern, MenaiASTSymbol), \\\n                \"Predicate pattern variable should be a symbol (validated by semantic analyzer)\"\n\n            # Test: (pred temp_var) \u2014 pred can be any expression\n            test_expr = MenaiASTList((\n                pred_expr,\n                MenaiASTSymbol(temp_var)\n            ))\n\n            # Binding: bind the variable to temp_var (unless wildcard)\n            bindings: List[Tuple[str, MenaiASTNode]] = []\n            if var_pattern.name != '_':\n                bindings.append((var_pattern.name, MenaiASTSymbol(temp_var)))\n\n            return (test_expr, bindings)\n\n        # Check for cons pattern: (head . tail) or (a b . rest)\n        dot_positions = []\n        for i, elem in enumerate(pattern.elements):\n            if isinstance(elem, MenaiASTSymbol) and elem.name == '.':\n                dot_positions.append(i)\n\n        # Validation already done by semantic analyzer\n        assert len(dot_positions) <= 1, \"Pattern should have at most one dot (validated by semantic analyzer)\"\n\n        # If we have a dot, use cons pattern\n        if dot_positions:\n            dot_position = dot_positions[0]\n            return self._desugar_cons_pattern(pattern, temp_var, dot_position)\n\n        # Fixed-length list pattern: (p1 p2 p3)\n        return self._desugar_fixed_list_pattern(pattern, temp_var)\n\n    def _desugar_fixed_list_pattern(\n        self,\n        pattern: MenaiASTList,\n        temp_var: str\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, Any]]]:\n        \"\"\"\n        Desugar a fixed-length list pattern like (a b c).\n\n        Args:\n            pattern: List pattern AST\n            temp_var: Name of temp variable holding the match value\n\n        Returns:\n            (test_expression, bindings)\n        \"\"\"\n        num_elements = len(pattern.elements)\n\n        # Test: (and (list? temp_var) (= (length temp_var) num_elements))\n        # We'll build this as nested ifs for simplicity\n\n        # First test: (list? temp_var)\n        list_test = MenaiASTList((\n            MenaiASTSymbol('list?'),\n            MenaiASTSymbol(temp_var)\n        ))\n\n        # Second test: (= (length temp_var) num_elements)\n        length_test = MenaiASTList((\n            MenaiASTSymbol('integer=?'),\n            MenaiASTList((\n                MenaiASTSymbol('list-length'),\n                MenaiASTSymbol(temp_var)\n            )),\n            MenaiASTInteger(num_elements)\n        ))\n\n        # Combine with and (lowered to if-chain)\n        combined_test = self._make_and([list_test, length_test], MenaiASTList(()))\n\n        # For fixed-length list patterns, we need a special structure:\n        # (and (list? x) (= (length x) n))  <- basic test\n        # Then INSIDE the then branch:\n        #   - Extract elements\n        #   - Test element patterns\n        #   - Bind pattern variables\n        #\n        # We can't return this as (test, bindings) because element tests\n        # reference element temp vars which must be bound after length check.\n        #\n        # Solution: Return a special marker that tells the caller to use\n        # a different building strategy.\n\n        # Collect element pattern info\n        element_info: List[Tuple[MenaiASTNode, str, MenaiASTNode]] = []  # List of (pattern, temp_var, extraction_expr)\n\n        for i, elem_pattern in enumerate(pattern.elements):\n            # Generate temp var for this element\n            elem_temp = self._gen_temp()\n\n            # Extract element: (list-ref temp_var i)\n            elem_value = MenaiASTList((\n                MenaiASTSymbol('list-ref'),\n                MenaiASTSymbol(temp_var),\n                MenaiASTInteger(i)\n            ))\n\n            element_info.append((elem_pattern, elem_temp, elem_value))\n\n        # Return the basic test and a special marker with element info\n        # The caller will use this to build the proper nested structure\n        # Use a unique marker name to avoid duplicates in nested patterns\n        marker_name = f'__LIST_PATTERN_{self._gen_temp()}__'\n        return (combined_test, [(marker_name, element_info)])\n\n    def _flatten_nested_pattern(\n        self,\n        pattern: MenaiASTNode,\n        temp_var: str,\n        extraction_bindings: List[Tuple[str, MenaiASTNode]],\n        element_tests: List[MenaiASTNode],\n        pattern_bindings: List[Tuple[str, MenaiASTNode]]\n    ) -> None:\n        \"\"\"\n        Recursively flatten a nested pattern into the given lists.\n\n        Args:\n            pattern: Pattern to flatten\n            temp_var: Temp variable holding the value to match\n            extraction_bindings: List to append extraction bindings to\n            element_tests: List to append tests to\n            pattern_bindings: List to append pattern variable bindings to\n        \"\"\"\n        # Desugar the pattern\n        test, bindings = self._desugar_pattern(pattern, temp_var)\n\n        # Check if this is a list/cons pattern (special marker)\n        if (bindings and len(bindings) == 1 and\n            (bindings[0][0].startswith('__LIST_PATTERN_') or\n             bindings[0][0].startswith('__CONS_PATTERN_'))):\n            # This is a nested list/cons pattern - flatten it\n            # Cast to the expected type for element_info\n            nested_element_info = cast(List[Tuple[MenaiASTNode, str, MenaiASTNode]], bindings[0][1])\n\n            # Add the length/type test\n            if not (isinstance(test, MenaiASTBoolean) and test.value):\n                element_tests.append(test)\n\n            # Recursively flatten each element\n            for elem_pattern, elem_temp, elem_value in nested_element_info:\n                # Add extraction binding\n                extraction_bindings.append((elem_temp, elem_value))\n\n                # Recursively flatten this element\n                self._flatten_nested_pattern(\n                    elem_pattern,\n                    elem_temp,\n                    extraction_bindings,\n                    element_tests,\n                    pattern_bindings\n                )\n\n        else:\n            # Regular pattern - add test and bindings\n            if not (isinstance(test, MenaiASTBoolean) and test.value):\n                element_tests.append(test)\n            pattern_bindings.extend(bindings)\n\n    def _build_list_pattern_clause(\n        self,\n        length_test: MenaiASTNode,\n        element_info: List,\n        result_expr: MenaiASTNode,\n        else_expr: MenaiASTNode\n    ) -> MenaiASTNode:\n        \"\"\"\n        Build a clause for a list pattern with proper nesting.\n\n        Args:\n            length_test: Test for list? and length\n            element_info: List of (pattern, temp_var, extraction_expr)\n            result_expr: Result expression to evaluate if pattern matches\n            else_expr: Expression to evaluate if pattern doesn't match\n\n        Returns:\n            Properly nested if/let structure\n        \"\"\"\n        # Build: (if length_test\n        #          (let ((#:tmp-2 (list-ref x 0)) ...)\n        #            (if (and elem-test-1 elem-test-2 ...)\n        #                (let ((a #:tmp-2) (b #:tmp-3) ...)\n        #                  result)\n        #                else))\n        #          else)\n\n        # Extract elements\n        extraction_bindings: List[Tuple[str, MenaiASTNode]] = []\n        element_tests: List[MenaiASTNode] = []\n        pattern_bindings: List[Tuple[str, MenaiASTNode]] = []\n\n        for elem_pattern, elem_temp, elem_value in element_info:\n            # Add extraction binding\n            extraction_bindings.append((elem_temp, elem_value))\n\n            # Desugar element pattern\n            elem_test, elem_bindings = self._desugar_pattern(elem_pattern, elem_temp)\n\n            # Check if element pattern is itself a list/cons pattern (special marker)\n            if (elem_bindings and len(elem_bindings) == 1 and\n                    (elem_bindings[0][0].startswith('__LIST_PATTERN_') or\n                     elem_bindings[0][0].startswith('__CONS_PATTERN_'))):\n                # Nested list/cons pattern - use helper to recursively flatten it\n                self._flatten_nested_pattern(\n                    elem_pattern,\n                    elem_temp,\n                    extraction_bindings,\n                    element_tests,\n                    pattern_bindings\n                )\n\n            else:\n                # Regular pattern\n                # Collect element test (unless it's just #t)\n                if not (isinstance(elem_test, MenaiASTBoolean) and elem_test.value):\n                    element_tests.append(elem_test)\n\n                # Collect pattern bindings\n                pattern_bindings.extend(elem_bindings)\n\n        # Build the inner structure (after element extraction)\n        if element_tests:\n            # We have element tests - need nested if\n            elem_test_combined = self._make_and(element_tests, MenaiASTList(()))\n\n            # Build pattern bindings let\n            if pattern_bindings:\n                binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in pattern_bindings]\n                pattern_let: MenaiASTNode = MenaiASTList((\n                    MenaiASTSymbol('let*'),\n                    MenaiASTList(tuple(binding_list)),\n                    result_expr\n                ))\n\n            else:\n                pattern_let = result_expr\n\n            # Build element test if\n            inner_if: MenaiASTNode = MenaiASTList((\n                MenaiASTSymbol('if'),\n                elem_test_combined,\n                pattern_let,\n                else_expr\n            ))\n\n        else:\n            # No element tests - just bind pattern vars\n            if pattern_bindings:\n                binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in pattern_bindings]\n                inner_if = MenaiASTList((\n                    MenaiASTSymbol('let*'),\n                    MenaiASTList(tuple(binding_list)),\n                    result_expr\n                ))\n\n            else:\n                inner_if = result_expr\n\n        # Wrap in element extraction let\n        extraction_binding_list = [MenaiASTList((MenaiASTSymbol(vn), ve)) for vn, ve in extraction_bindings]\n        extraction_let = MenaiASTList((\n            MenaiASTSymbol('let*'),\n            MenaiASTList(tuple(extraction_binding_list)),\n            inner_if\n        ))\n\n        # Build outer if with length test\n        return MenaiASTList((\n            MenaiASTSymbol('if'),\n            length_test,\n            extraction_let,\n            else_expr\n        ))\n\n    def _desugar_cons_pattern(\n        self,\n        pattern: MenaiASTList,\n        temp_var: str,\n        dot_position: int\n    ) -> Tuple[MenaiASTNode, List[Tuple[str, Any]]]:\n        \"\"\"\n        Desugar a cons pattern like (head . tail) or (a b . rest).\n\n        Args:\n            pattern: List pattern AST\n            temp_var: Name of temp variable holding the match value\n            dot_position: Index of the dot in the pattern\n\n        Returns:\n            (test_expression, bindings)\n        \"\"\"\n        # Validation already done by semantic analyzer\n        assert dot_position > 0, \"Dot should not be at beginning (validated by semantic analyzer)\"\n        assert dot_position < len(pattern.elements) - 1, \"Dot should not be at end (validated by semantic analyzer)\"\n        assert dot_position == len(pattern.elements) - 2, \\\n            \"Should have exactly one element after dot (validated by semantic analyzer)\"\n\n        # Test: (and (list? temp_var) (>= (length temp_var) dot_position))\n        list_test = MenaiASTList((\n            MenaiASTSymbol('list?'),\n            MenaiASTSymbol(temp_var)\n        ))\n\n        length_test = MenaiASTList((\n            MenaiASTSymbol('integer>=?'),\n            MenaiASTList((\n                MenaiASTSymbol('list-length'),\n                MenaiASTSymbol(temp_var)\n            )),\n            MenaiASTInteger(dot_position)\n        ))\n        combined_test = self._make_and([list_test, length_test], MenaiASTList(()))\n\n        # Collect head element info\n        head_elements: List[Tuple[MenaiASTNode, str, MenaiASTNode]] = []\n\n        for i in range(dot_position):\n            elem_pattern = pattern.elements[i]\n            elem_temp = self._gen_temp()\n\n            # Extract element: (list-ref temp_var i)\n            elem_value = MenaiASTList((\n                MenaiASTSymbol('list-ref'),\n                MenaiASTSymbol(temp_var),\n                MenaiASTInteger(i)\n            ))\n\n            head_elements.append((elem_pattern, elem_temp, elem_value))\n\n        # Build binding for tail\n        tail_pattern = pattern.elements[dot_position + 1]\n        tail_temp = self._gen_temp()\n\n        # Extract tail: (list-slice temp-var dot_position)\n        tail_value = MenaiASTList((\n            MenaiASTSymbol('list-slice'),\n            MenaiASTSymbol(temp_var),\n            MenaiASTInteger(dot_position)\n        ))\n\n        # Add tail to element info\n        all_elements = head_elements + [(tail_pattern, tail_temp, tail_value)]\n\n        # Return special marker for cons pattern\n        # Use a unique marker name to avoid duplicates in nested patterns\n        marker_name = f'__CONS_PATTERN_{self._gen_temp()}__'\n        return (combined_test, [(marker_name, all_elements)])\n\n    def _gen_temp(self) -> str:\n        \"\"\"Generate unique temporary variable name.\"\"\"\n        self.temp_counter += 1\n        return f\"#:match-tmp-{self.temp_counter}\"\n",
          "error": null
        }
