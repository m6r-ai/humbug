      "content": "```json\n{\n  \"id\": \"toolu_01WSMqSdBCmyfGm2HQpaE4jM\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"Menai Compiler - Orchestrates the complete compilation pipeline.\\n\\nThis is the main entry point for compiling Menai source code to bytecode.\\nIt chains together all compilation passes in the correct order.\\n\\\"\\\"\\\"\\n\\nfrom typing import List\\n\\nfrom menai.menai_ast import MenaiASTNode\\nfrom menai.menai_ast_builder import MenaiASTBuilder\\nfrom menai.menai_ast_constant_folder import MenaiASTConstantFolder\\nfrom menai.menai_ast_desugarer import MenaiASTDesugarer\\nfrom menai.menai_ast_module_resolver import MenaiASTModuleResolver, MenaiASTModuleLoader\\nfrom menai.menai_ast_optimization_pass import MenaiASTOptimizationPass\\nfrom menai.menai_ast_semantic_analyzer import MenaiASTSemanticAnalyzer\\nfrom menai.menai_bytecode import CodeObject\\nfrom menai.menai_bytecode_builder import MenaiBytecodeBuilder\\nfrom menai.menai_cfg_builder import MenaiCFGBuilder\\nfrom menai.menai_cfg_optimization_pass import MenaiCFGOptimizationPass\\nfrom menai.menai_cfg_bypass_empty_blocks import MenaiCFGBypassEmptyBlocks\\nfrom menai.menai_cfg_collapse_phi_chains import MenaiCFGCollapsePhiChains\\nfrom menai.menai_ir_builder import MenaiIRBuilder\\nfrom menai.menai_ir_optimization_pass import MenaiIROptimizationPass\\nfrom menai.menai_ir_copy_propagator import MenaiIRCopyPropagator\\nfrom menai.menai_ir_optimizer import MenaiIROptimizer\\nfrom menai.menai_ir_inline_once import MenaiIRInlineOnce\\nfrom menai.menai_lexer import MenaiLexer\\n\\n\\nclass MenaiCompiler:\\n    \\\"\\\"\\\"\\n    Main compiler pass manager.\\n    \\\"\\\"\\\"\\n\\n    def __init__(\\n        self,\\n        optimize: bool = True,\\n        module_loader: MenaiASTModuleLoader | None = None,\\n    ):\\n        \\\"\\\"\\\"\\n        Initialize compiler with all passes.\\n\\n        Args:\\n            optimize:    Enable optimization passes (AST and IR level).\\n            module_loader: Optional module loader for resolving imports.\\n        \\\"\\\"\\\"\\n        self.optimize = optimize\\n        self.module_loader = module_loader\\n\\n        self.lexer = MenaiLexer()\\n        self.ast_builder = MenaiASTBuilder()\\n        self.ast_semantic_analyzer = MenaiASTSemanticAnalyzer()\\n        self.ast_module_resolver = MenaiASTModuleResolver(module_loader)\\n        self.ast_desugarer = MenaiASTDesugarer()\\n        self.ast_passes: List[MenaiASTOptimizationPass] = []\\n        self.ir_builder = MenaiIRBuilder()\\n        self.ir_passes: List[MenaiIROptimizationPass] = []\\n        self.cfg_builder = MenaiCFGBuilder()\\n        self.cfg_passes: List[MenaiCFGOptimizationPass] = []\\n        self.bytecode_builder = MenaiBytecodeBuilder()\\n\\n        if optimize:\\n            self.ast_passes = [\\n                MenaiASTConstantFolder(),\\n            ]\\n            self.ir_passes = [\\n                MenaiIRCopyPropagator(),\\n                MenaiIRInlineOnce(),\\n                MenaiIROptimizer(),\\n            ]\\n            self.cfg_passes = [\\n                MenaiCFGCollapsePhiChains(),\\n                MenaiCFGBypassEmptyBlocks(),\\n            ]\\n\\n\\n    def compile_to_resolved_ast(self, source: str, source_file: str = \\\"\\\") -> MenaiASTNode:\\n        \\\"\\\"\\\"\\n        Compile source to fully resolved AST.\\n\\n        This runs the front-end compilation stages:\\n        - Lexing\\n        - Parsing\\n        - Semantic analysis\\n        - Module resolution (including recursive module compilation)\\n\\n        The result is a fully resolved AST ready for desugaring and backend compilation.\\n        This method is used by the module system to compile imported modules.\\n\\n        Args:\\n            source: Menai source code as a string\\n            source_file: Source file name for tracking origin of AST nodes\\n\\n        Returns:\\n            Fully resolved AST (all imports replaced with module ASTs)\\n        \\\"\\\"\\\"\\n        tokens = self.lexer.lex(source)\\n        ast = self.ast_builder.build(tokens, source, source_file)\\n        checked_ast = self.ast_semantic_analyzer.analyze(ast, source)\\n        resolved_ast = self.ast_module_resolver.resolve(checked_ast)\\n        return resolved_ast\\n\\n    def compile(self, source: str, name: str = \\\"<module>\\\") -> CodeObject:\\n        \\\"\\\"\\\"\\n        Compile Menai source code to bytecode.\\n\\n        This is the main entry point that runs the complete pipeline.\\n\\n        Args:\\n            source: Menai source code as a string\\n            name: Optional name for the code object (e.g. filename)\\n\\n        Returns:\\n            Compiled bytecode ready for execution\\n        \\\"\\\"\\\"\\n        resolved_ast = self.compile_to_resolved_ast(source, name)\\n        desugared_ast = self.ast_desugarer.desugar(resolved_ast)\\n\\n        for ast_pass in self.ast_passes:\\n            desugared_ast = ast_pass.optimize(desugared_ast)\\n\\n        ir = self.ir_builder.build(desugared_ast)\\n\\n        if self.ir_passes:\\n            changed = True\\n            while changed:\\n                changed = False\\n                for ir_pass in self.ir_passes:\\n                    ir, pass_changed = ir_pass.optimize(ir)\\n                    changed = changed or pass_changed\\n\\n        cfg = self.cfg_builder.build(ir)\\n        if self.cfg_passes:\\n            changed = True\\n            while changed:\\n                changed = False\\n                for cfg_pass in self.cfg_passes:\\n                    cfg, pass_changed = cfg_pass.optimize(cfg)\\n                    changed = changed or pass_changed\\n\\n        bytecode = self.bytecode_builder.build(cfg, name)\\n        return bytecode\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"Menai Compiler - Orchestrates the complete compilation pipeline.\n\nThis is the main entry point for compiling Menai source code to bytecode.\nIt chains together all compilation passes in the correct order.\n\"\"\"\n\nfrom typing import List\n\nfrom menai.menai_ast import MenaiASTNode\nfrom menai.menai_ast_builder import MenaiASTBuilder\nfrom menai.menai_ast_constant_folder import MenaiASTConstantFolder\nfrom menai.menai_ast_desugarer import MenaiASTDesugarer\nfrom menai.menai_ast_module_resolver import MenaiASTModuleResolver, MenaiASTModuleLoader\nfrom menai.menai_ast_optimization_pass import MenaiASTOptimizationPass\nfrom menai.menai_ast_semantic_analyzer import MenaiASTSemanticAnalyzer\nfrom menai.menai_bytecode import CodeObject\nfrom menai.menai_bytecode_builder import MenaiBytecodeBuilder\nfrom menai.menai_cfg_builder import MenaiCFGBuilder\nfrom menai.menai_cfg_optimization_pass import MenaiCFGOptimizationPass\nfrom menai.menai_cfg_bypass_empty_blocks import MenaiCFGBypassEmptyBlocks\nfrom menai.menai_cfg_collapse_phi_chains import MenaiCFGCollapsePhiChains\nfrom menai.menai_ir_builder import MenaiIRBuilder\nfrom menai.menai_ir_optimization_pass import MenaiIROptimizationPass\nfrom menai.menai_ir_copy_propagator import MenaiIRCopyPropagator\nfrom menai.menai_ir_optimizer import MenaiIROptimizer\nfrom menai.menai_ir_inline_once import MenaiIRInlineOnce\nfrom menai.menai_lexer import MenaiLexer\n\n\nclass MenaiCompiler:\n    \"\"\"\n    Main compiler pass manager.\n    \"\"\"\n\n    def __init__(\n        self,\n        optimize: bool = True,\n        module_loader: MenaiASTModuleLoader | None = None,\n    ):\n        \"\"\"\n        Initialize compiler with all passes.\n\n        Args:\n            optimize:    Enable optimization passes (AST and IR level).\n            module_loader: Optional module loader for resolving imports.\n        \"\"\"\n        self.optimize = optimize\n        self.module_loader = module_loader\n\n        self.lexer = MenaiLexer()\n        self.ast_builder = MenaiASTBuilder()\n        self.ast_semantic_analyzer = MenaiASTSemanticAnalyzer()\n        self.ast_module_resolver = MenaiASTModuleResolver(module_loader)\n        self.ast_desugarer = MenaiASTDesugarer()\n        self.ast_passes: List[MenaiASTOptimizationPass] = []\n        self.ir_builder = MenaiIRBuilder()\n        self.ir_passes: List[MenaiIROptimizationPass] = []\n        self.cfg_builder = MenaiCFGBuilder()\n        self.cfg_passes: List[MenaiCFGOptimizationPass] = []\n        self.bytecode_builder = MenaiBytecodeBuilder()\n\n        if optimize:\n            self.ast_passes = [\n                MenaiASTConstantFolder(),\n            ]\n            self.ir_passes = [\n                MenaiIRCopyPropagator(),\n                MenaiIRInlineOnce(),\n                MenaiIROptimizer(),\n            ]\n            self.cfg_passes = [\n                MenaiCFGCollapsePhiChains(),\n                MenaiCFGBypassEmptyBlocks(),\n            ]\n\n\n    def compile_to_resolved_ast(self, source: str, source_file: str = \"\") -> MenaiASTNode:\n        \"\"\"\n        Compile source to fully resolved AST.\n\n        This runs the front-end compilation stages:\n        - Lexing\n        - Parsing\n        - Semantic analysis\n        - Module resolution (including recursive module compilation)\n\n        The result is a fully resolved AST ready for desugaring and backend compilation.\n        This method is used by the module system to compile imported modules.\n\n        Args:\n            source: Menai source code as a string\n            source_file: Source file name for tracking origin of AST nodes\n\n        Returns:\n            Fully resolved AST (all imports replaced with module ASTs)\n        \"\"\"\n        tokens = self.lexer.lex(source)\n        ast = self.ast_builder.build(tokens, source, source_file)\n        checked_ast = self.ast_semantic_analyzer.analyze(ast, source)\n        resolved_ast = self.ast_module_resolver.resolve(checked_ast)\n        return resolved_ast\n\n    def compile(self, source: str, name: str = \"<module>\") -> CodeObject:\n        \"\"\"\n        Compile Menai source code to bytecode.\n\n        This is the main entry point that runs the complete pipeline.\n\n        Args:\n            source: Menai source code as a string\n            name: Optional name for the code object (e.g. filename)\n\n        Returns:\n            Compiled bytecode ready for execution\n        \"\"\"\n        resolved_ast = self.compile_to_resolved_ast(source, name)\n        desugared_ast = self.ast_desugarer.desugar(resolved_ast)\n\n        for ast_pass in self.ast_passes:\n            desugared_ast = ast_pass.optimize(desugared_ast)\n\n        ir = self.ir_builder.build(desugared_ast)\n\n        if self.ir_passes:\n            changed = True\n            while changed:\n                changed = False\n                for ir_pass in self.ir_passes:\n                    ir, pass_changed = ir_pass.optimize(ir)\n                    changed = changed or pass_changed\n\n        cfg = self.cfg_builder.build(ir)\n        if self.cfg_passes:\n            changed = True\n            while changed:\n                changed = False\n                for cfg_pass in self.cfg_passes:\n                    cfg, pass_changed = cfg_pass.optimize(cfg)\n                    changed = changed or pass_changed\n\n        bytecode = self.bytecode_builder.build(cfg, name)\n        return bytecode\n\n```",
