      "content": "```json\n{\n  \"id\": \"toolu_01WAJ9PWKkz9PkjnSx5U6qWb\",\n  \"name\": \"editor\",\n  \"content\": \"{\\n  \\\"range\\\": \\\"148-235\\\",\\n  \\\"lines\\\": {\\n    \\\"148\\\": \\\"    @staticmethod\\\",\\n    \\\"149\\\": \\\"    def _unwrap_return(node: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\\\",\\n    \\\"150\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Return (inner, was_wrapped) \\\\u2014 strips a MenaiIRReturn wrapper if present.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"151\\\": \\\"        if isinstance(node, MenaiIRReturn):\\\",\\n    \\\"152\\\": \\\"            return node.value_plan, True\\\",\\n    \\\"153\\\": \\\"        return node, False\\\",\\n    \\\"154\\\": \\\"\\\",\\n    \\\"155\\\": \\\"    @staticmethod\\\",\\n    \\\"156\\\": \\\"    def _is_boolean_typed(node: MenaiIRExpr) -> bool:\\\",\\n    \\\"157\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Return True if node is guaranteed to produce a boolean value.\\\",\\n    \\\"158\\\": \\\"\\\",\\n    \\\"159\\\": \\\"        This is a conservative check used to guard the (if cond #t #f) \\\\u2192 cond\\\",\\n    \\\"160\\\": \\\"        rewrite: replacing the if with cond directly is only sound when cond is\\\",\\n    \\\"161\\\": \\\"        known to be boolean, because the VM's JUMP_IF_TRUE/FALSE opcodes enforce\\\",\\n    \\\"162\\\": \\\"        that the condition is boolean at runtime.\\\",\\n    \\\"163\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"164\\\": \\\"        if isinstance(node, MenaiIRConstant) and isinstance(node.value, MenaiBoolean):\\\",\\n    \\\"165\\\": \\\"            return True\\\",\\n    \\\"166\\\": \\\"        if isinstance(node, MenaiIRCall) and node.is_builtin and node.builtin_name is not None:\\\",\\n    \\\"167\\\": \\\"            return node.builtin_name.endswith('?') or node.builtin_name == 'boolean-not'\\\",\\n    \\\"168\\\": \\\"        return False\\\",\\n    \\\"169\\\": \\\"\\\",\\n    \\\"170\\\": \\\"    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\\\",\\n    \\\"171\\\": \\\"        opt_condition = self._opt(ir.condition_plan, frame_stack)\\\",\\n    \\\"172\\\": \\\"        opt_then = self._opt(ir.then_plan, frame_stack)\\\",\\n    \\\"173\\\": \\\"        opt_else = self._opt(ir.else_plan, frame_stack)\\\",\\n    \\\"174\\\": \\\"\\\",\\n    \\\"175\\\": \\\"        # Constant-condition elimination:\\\",\\n    \\\"176\\\": \\\"        #   (if #t then else)  \\\\u2192  then\\\",\\n    \\\"177\\\": \\\"        #   (if #f then else)  \\\\u2192  else\\\",\\n    \\\"178\\\": \\\"        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\\\",\\n    \\\"179\\\": \\\"            self._eliminations += 1\\\",\\n    \\\"180\\\": \\\"            if opt_condition.value.value:\\\",\\n    \\\"181\\\": \\\"                return opt_then\\\",\\n    \\\"182\\\": \\\"\\\",\\n    \\\"183\\\": \\\"            return opt_else\\\",\\n    \\\"184\\\": \\\"\\\",\\n    \\\"185\\\": \\\"        # Boolean identity elimination:\\\",\\n    \\\"186\\\": \\\"        #   (if <cond> #t #f)  \\\\u2192  <cond>\\\",\\n    \\\"187\\\": \\\"        #   (if <cond> #f #t)  \\\\u2192  (boolean-not <cond>)\\\",\\n    \\\"188\\\": \\\"        #\\\",\\n    \\\"189\\\": \\\"        # The IR builder wraps tail-position branches in MenaiIRReturn.  Branches\\\",\\n    \\\"190\\\": \\\"        # can be asymmetrically wrapped (e.g. one is a tail call that needs no\\\",\\n    \\\"191\\\": \\\"        # wrapper, the other is a constant that does), so we use in_tail_position\\\",\\n    \\\"192\\\": \\\"        # to decide whether the replacement needs wrapping.  We look through any\\\",\\n    \\\"193\\\": \\\"        # MenaiIRReturn wrapper on each branch to reach the inner constant.  When\\\",\\n    \\\"194\\\": \\\"        # both branches are boolean constants, they are always symmetrically\\\",\\n    \\\"195\\\": \\\"        # wrapped (both wrapped or both bare), so then_wrapped is the right signal.\\\",\\n    \\\"196\\\": \\\"        then_inner, then_wrapped = self._unwrap_return(opt_then)\\\",\\n    \\\"197\\\": \\\"        else_inner, _ = self._unwrap_return(opt_else)\\\",\\n    \\\"198\\\": \\\"        if (isinstance(then_inner, MenaiIRConstant)\\\",\\n    \\\"199\\\": \\\"                and isinstance(then_inner.value, MenaiBoolean)\\\",\\n    \\\"200\\\": \\\"                and isinstance(else_inner, MenaiIRConstant)\\\",\\n    \\\"201\\\": \\\"                and isinstance(else_inner.value, MenaiBoolean)\\\",\\n    \\\"202\\\": \\\"                and self._is_boolean_typed(opt_condition)):\\\",\\n    \\\"203\\\": \\\"            if then_inner.value.value and not else_inner.value.value:\\\",\\n    \\\"204\\\": \\\"                # (if cond #t #f) \\\\u2192  cond  (or Return(cond) in tail position)\\\",\\n    \\\"205\\\": \\\"                self._eliminations += 1\\\",\\n    \\\"206\\\": \\\"                if then_wrapped:\\\",\\n    \\\"207\\\": \\\"                    return MenaiIRReturn(value_plan=opt_condition)\\\",\\n    \\\"208\\\": \\\"                return opt_condition\\\",\\n    \\\"209\\\": \\\"\\\",\\n    \\\"210\\\": \\\"            if not then_inner.value.value and else_inner.value.value:\\\",\\n    \\\"211\\\": \\\"                # (if cond #f #t) \\\\u2192 (boolean-not cond)\\\",\\n    \\\"212\\\": \\\"                self._eliminations += 1\\\",\\n    \\\"213\\\": \\\"                not_call = MenaiIRCall(\\\",\\n    \\\"214\\\": \\\"                    func_plan=MenaiIRVariable(\\\",\\n    \\\"215\\\": \\\"                            name='boolean-not', var_type='global'\\\",\\n    \\\"216\\\": \\\"                    ),\\\",\\n    \\\"217\\\": \\\"                    arg_plans=[opt_condition],\\\",\\n    \\\"218\\\": \\\"                    is_tail_call=ir.in_tail_position,\\\",\\n    \\\"219\\\": \\\"                    is_builtin=True,\\\",\\n    \\\"220\\\": \\\"                    builtin_name='boolean-not',\\\",\\n    \\\"221\\\": \\\"                )\\\",\\n    \\\"222\\\": \\\"                if then_wrapped:\\\",\\n    \\\"223\\\": \\\"                    return MenaiIRReturn(value_plan=not_call)\\\",\\n    \\\"224\\\": \\\"                return not_call\\\",\\n    \\\"225\\\": \\\"\\\",\\n    \\\"226\\\": \\\"        return MenaiIRIf(\\\",\\n    \\\"227\\\": \\\"            condition_plan=opt_condition,\\\",\\n    \\\"228\\\": \\\"            then_plan=opt_then,\\\",\\n    \\\"229\\\": \\\"            else_plan=opt_else,\\\",\\n    \\\"230\\\": \\\"            in_tail_position=ir.in_tail_position,\\\",\\n    \\\"231\\\": \\\"        )\\\",\\n    \\\"232\\\": \\\"\\\",\\n    \\\"233\\\": \\\"    def _opt_lambda(self, ir: MenaiIRLambda, frame_stack: List[int]) -> MenaiIRLambda:\\\",\\n    \\\"234\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Optimize the body of a lambda.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"235\\\": \\\"        counts = cast(IRUseCounts, self._counts)\\\"\\n  }\\n}\",\n  \"error\": null\n}\n```\n`content` is:\n```json\n{\n  \"range\": \"148-235\",\n  \"lines\": {\n    \"148\": \"    @staticmethod\",\n    \"149\": \"    def _unwrap_return(node: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\",\n    \"150\": \"        \\\"\\\"\\\"Return (inner, was_wrapped) \\u2014 strips a MenaiIRReturn wrapper if present.\\\"\\\"\\\"\",\n    \"151\": \"        if isinstance(node, MenaiIRReturn):\",\n    \"152\": \"            return node.value_plan, True\",\n    \"153\": \"        return node, False\",\n    \"154\": \"\",\n    \"155\": \"    @staticmethod\",\n    \"156\": \"    def _is_boolean_typed(node: MenaiIRExpr) -> bool:\",\n    \"157\": \"        \\\"\\\"\\\"Return True if node is guaranteed to produce a boolean value.\",\n    \"158\": \"\",\n    \"159\": \"        This is a conservative check used to guard the (if cond #t #f) \\u2192 cond\",\n    \"160\": \"        rewrite: replacing the if with cond directly is only sound when cond is\",\n    \"161\": \"        known to be boolean, because the VM's JUMP_IF_TRUE/FALSE opcodes enforce\",\n    \"162\": \"        that the condition is boolean at runtime.\",\n    \"163\": \"        \\\"\\\"\\\"\",\n    \"164\": \"        if isinstance(node, MenaiIRConstant) and isinstance(node.value, MenaiBoolean):\",\n    \"165\": \"            return True\",\n    \"166\": \"        if isinstance(node, MenaiIRCall) and node.is_builtin and node.builtin_name is not None:\",\n    \"167\": \"            return node.builtin_name.endswith('?') or node.builtin_name == 'boolean-not'\",\n    \"168\": \"        return False\",\n    \"169\": \"\",\n    \"170\": \"    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\",\n    \"171\": \"        opt_condition = self._opt(ir.condition_plan, frame_stack)\",\n    \"172\": \"        opt_then = self._opt(ir.then_plan, frame_stack)\",\n    \"173\": \"        opt_else = self._opt(ir.else_plan, frame_stack)\",\n    \"174\": \"\",\n    \"175\": \"        # Constant-condition elimination:\",\n    \"176\": \"        #   (if #t then else)  \\u2192  then\",\n    \"177\": \"        #   (if #f then else)  \\u2192  else\",\n    \"178\": \"        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\",\n    \"179\": \"            self._eliminations += 1\",\n    \"180\": \"            if opt_condition.value.value:\",\n    \"181\": \"                return opt_then\",\n    \"182\": \"\",\n    \"183\": \"            return opt_else\",\n    \"184\": \"\",\n    \"185\": \"        # Boolean identity elimination:\",\n    \"186\": \"        #   (if <cond> #t #f)  \\u2192  <cond>\",\n    \"187\": \"        #   (if <cond> #f #t)  \\u2192  (boolean-not <cond>)\",\n    \"188\": \"        #\",\n    \"189\": \"        # The IR builder wraps tail-position branches in MenaiIRReturn.  Branches\",\n    \"190\": \"        # can be asymmetrically wrapped (e.g. one is a tail call that needs no\",\n    \"191\": \"        # wrapper, the other is a constant that does), so we use in_tail_position\",\n    \"192\": \"        # to decide whether the replacement needs wrapping.  We look through any\",\n    \"193\": \"        # MenaiIRReturn wrapper on each branch to reach the inner constant.  When\",\n    \"194\": \"        # both branches are boolean constants, they are always symmetrically\",\n    \"195\": \"        # wrapped (both wrapped or both bare), so then_wrapped is the right signal.\",\n    \"196\": \"        then_inner, then_wrapped = self._unwrap_return(opt_then)\",\n    \"197\": \"        else_inner, _ = self._unwrap_return(opt_else)\",\n    \"198\": \"        if (isinstance(then_inner, MenaiIRConstant)\",\n    \"199\": \"                and isinstance(then_inner.value, MenaiBoolean)\",\n    \"200\": \"                and isinstance(else_inner, MenaiIRConstant)\",\n    \"201\": \"                and isinstance(else_inner.value, MenaiBoolean)\",\n    \"202\": \"                and self._is_boolean_typed(opt_condition)):\",\n    \"203\": \"            if then_inner.value.value and not else_inner.value.value:\",\n    \"204\": \"                # (if cond #t #f) \\u2192  cond  (or Return(cond) in tail position)\",\n    \"205\": \"                self._eliminations += 1\",\n    \"206\": \"                if then_wrapped:\",\n    \"207\": \"                    return MenaiIRReturn(value_plan=opt_condition)\",\n    \"208\": \"                return opt_condition\",\n    \"209\": \"\",\n    \"210\": \"            if not then_inner.value.value and else_inner.value.value:\",\n    \"211\": \"                # (if cond #f #t) \\u2192 (boolean-not cond)\",\n    \"212\": \"                self._eliminations += 1\",\n    \"213\": \"                not_call = MenaiIRCall(\",\n    \"214\": \"                    func_plan=MenaiIRVariable(\",\n    \"215\": \"                            name='boolean-not', var_type='global'\",\n    \"216\": \"                    ),\",\n    \"217\": 