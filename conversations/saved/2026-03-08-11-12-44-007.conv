    {
      "id": "ab5659ff-8ebd-4ea6-83a9-78b050899913",
      "timestamp": "2026-03-08T11:19:03.881379+00:00",
      "type": "tool_result",
      "content": "```json\n{\n  \"id\": \"toolu_0123xeBkdQFpJzFaeyXf8F1g\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"\\nTests for the boolean identity elimination in MenaiIROptimizer.\\n\\nThe optimizer rewrites two structural forms of MenaiIRIf:\\n\\n    (if <cond> #t #f)  \\u2192  <cond>\\n    (if <cond> #f #t)  \\u2192  (boolean-not <cond>)\\n\\nStrategy\\n--------\\n1. Unit tests on the optimizer directly, constructing IR nodes by hand.\\n   These verify the structural transformation without going through the\\n   full compiler pipeline.\\n\\n2. Integration tests that compile real Menai source and verify that the\\n   optimized program produces the correct result for all input cases.\\n   These catch regressions where the optimizer silently changes semantics.\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nimport pytest\\n\\nfrom menai import Menai\\nfrom menai.menai_ir import (\\n    MenaiIRCall,\\n    MenaiIRConstant,\\n    MenaiIRIf,\\n    MenaiIRReturn,\\n    MenaiIRVariable,\\n)\\nfrom menai.menai_ir_optimizer import MenaiIROptimizer\\nfrom menai.menai_value import MenaiBoolean, MenaiInteger\\n\\n\\n# ---------------------------------------------------------------------------\\n# Helpers\\n# ---------------------------------------------------------------------------\\n\\ndef _bool_const(value: bool) -> MenaiIRConstant:\\n    return MenaiIRConstant(value=MenaiBoolean(value))\\n\\n\\ndef _int_const(n: int) -> MenaiIRConstant:\\n    return MenaiIRConstant(value=MenaiInteger(n))\\n\\n\\ndef _global(name: str) -> MenaiIRVariable:\\n    return MenaiIRVariable(name=name, var_type='global')\\n\\n\\ndef _bool_p_call(arg: MenaiIRVariable) -> MenaiIRCall:\\n    \\\"\\\"\\\"Emit (boolean? arg) as a builtin call.\\\"\\\"\\\"\\n    return MenaiIRCall(\\n        func_plan=_global('boolean?'),\\n        arg_plans=[arg],\\n        is_tail_call=False,\\n        is_builtin=True,\\n        builtin_name='boolean?',\\n    )\\n\\n\\ndef _local(index: int) -> MenaiIRVariable:\\n    return MenaiIRVariable(\\n        name=f\\\"v{index}\\\", var_type='local'\\n    )\\n\\n\\ndef _run(ir):\\n    \\\"\\\"\\\"Run the optimizer and return (new_ir, changed).\\\"\\\"\\\"\\n    return MenaiIROptimizer().optimize(ir)\\n\\n\\ndef _run_opt(ir):\\n    \\\"\\\"\\\"Run the optimizer and return just the new IR.\\\"\\\"\\\"\\n    new_ir, _ = _run(ir)\\n    return new_ir\\n\\n\\n# ---------------------------------------------------------------------------\\n# Unit tests: (if cond #t #f) \\u2192 cond\\n# ---------------------------------------------------------------------------\\n\\nclass TestBooleanIdentityElimination:\\n    \\\"\\\"\\\"(if <cond> #t #f) is replaced by <cond> directly.\\\"\\\"\\\"\\n\\n    def test_if_true_false_replaced_by_condition(self):\\n        \\\"\\\"\\\"(if (boolean? v0) #t #f) \\u2192 (boolean? v0)\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(True),\\n            else_plan=_bool_const(False),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        # The MenaiIRIf should have been eliminated entirely.\\n        assert isinstance(result.value_plan, MenaiIRCall)\\n        assert result.value_plan.builtin_name == 'boolean?'\\n\\n    def test_if_true_false_sets_changed_flag(self):\\n        \\\"\\\"\\\"changed is True when the pattern fires.\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(True),\\n            else_plan=_bool_const(False),\\n            in_tail_position=True,\\n        ))\\n        _, changed = _run(ir)\\n        assert changed is True\\n\\n    def test_no_change_when_pattern_absent(self):\\n        \\\"\\\"\\\"changed is False when no boolean identity pattern is present.\\\"\\\"\\\"\\n        # (if (boolean? v0) 1 2) \\u2014 non-boolean branches, no transformation\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=_bool_p_call(_local(0)),\\n            then_plan=_int_const(1),\\n            else_plan=_int_const(2),\\n            in_tail_position=True,\\n        ))\\n        _, changed = _run(ir)\\n        assert changed is False\\n\\n    def test_if_true_false_with_constant_condition(self):\\n        \\\"\\\"\\\"(if #t #t #f) \\u2192 #t  (condition is itself a constant).\\\"\\\"\\\"\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=_bool_const(True),\\n            then_plan=_bool_const(True),\\n            else_plan=_bool_const(False),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        assert isinstance(result.value_plan, MenaiIRConstant)\\n        assert result.value_plan.value == MenaiBoolean(True)\\n\\n    def test_if_true_false_non_tail(self):\\n        \\\"\\\"\\\"Transformation preserves in_tail_position=False on the condition.\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(True),\\n            else_plan=_bool_const(False),\\n            in_tail_position=False,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        # The if was in non-tail position; the condition replaces it directly.\\n        assert isinstance(result.value_plan, MenaiIRCall)\\n        assert result.value_plan.builtin_name == 'boolean?'\\n\\n\\n# ---------------------------------------------------------------------------\\n# Unit tests: (if cond #f #t) \\u2192 (boolean-not cond)\\n# ---------------------------------------------------------------------------\\n\\nclass TestBooleanNegationElimination:\\n    \\\"\\\"\\\"(if <cond> #f #t) is replaced by (boolean-not <cond>).\\\"\\\"\\\"\\n\\n    def test_if_false_true_replaced_by_boolean_not(self):\\n        \\\"\\\"\\\"(if (boolean? v0) #f #t) \\u2192 (boolean-not (boolean? v0))\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(False),\\n            else_plan=_bool_const(True),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        # Should be a call to boolean-not wrapping the original condition.\\n        assert isinstance(result.value_plan, MenaiIRCall)\\n        assert result.value_plan.builtin_name == 'boolean-not'\\n        assert len(result.value_plan.arg_plans) == 1\\n        inner = result.value_plan.arg_plans[0]\\n        assert isinstance(inner, MenaiIRCall)\\n        assert inner.builtin_name == 'boolean?'\\n\\n    def test_if_false_true_sets_changed_flag(self):\\n        \\\"\\\"\\\"changed is True when the negated pattern fires.\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(False),\\n            else_plan=_bool_const(True),\\n            in_tail_position=True,\\n        ))\\n        _, changed = _run(ir)\\n        assert changed is True\\n\\n    def test_if_false_true_tail_call_propagated(self):\\n        \\\"\\\"\\\"The boolean-not call inherits is_tail_call from in_tail_position.\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(False),\\n            else_plan=_bool_const(True),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result.value_plan, MenaiIRCall)\\n        assert result.value_plan.is_tail_call is True\\n\\n    def test_if_false_true_non_tail_call_propagated(self):\\n        \\\"\\\"\\\"is_tail_call is False when in_tail_position is False.\\\"\\\"\\\"\\n        cond = _bool_p_call(_local(0))\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=cond,\\n            then_plan=_bool_const(False),\\n            else_plan=_bool_const(True),\\n            in_tail_position=False,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result.value_plan, MenaiIRCall)\\n        assert result.value_plan.is_tail_call is False\\n\\n\\n# ---------------------------------------------------------------------------\\n# Unit tests: patterns that must NOT be transformed\\n# ---------------------------------------------------------------------------\\n\\nclass TestNoTransformation:\\n    \\\"\\\"\\\"Cases that look similar but must not be rewritten.\\\"\\\"\\\"\\n\\n    def test_then_true_else_non_boolean_not_rewritten(self):\\n        \\\"\\\"\\\"(if cond #t 42) \\u2014 else is not a boolean constant, no change.\\\"\\\"\\\"\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=_bool_p_call(_local(0)),\\n            then_plan=_bool_const(True),\\n            else_plan=_int_const(42),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        assert isinstance(result.value_plan, MenaiIRIf)\\n\\n    def test_then_non_boolean_else_false_not_rewritten(self):\\n        \\\"\\\"\\\"(if cond 42 #f) \\u2014 then is not a boolean constant, no change.\\\"\\\"\\\"\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=_bool_p_call(_local(0)),\\n            then_plan=_int_const(42),\\n            else_plan=_bool_const(False),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        assert isinstance(result.value_plan, MenaiIRIf)\\n\\n    def test_then_true_else_true_not_rewritten(self):\\n        \\\"\\\"\\\"(if cond #t #t) \\u2014 both branches same, but not the identity pattern.\\\"\\\"\\\"\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=_bool_p_call(_local(0)),\\n            then_plan=_bool_const(True),\\n            else_plan=_bool_const(True),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        assert isinstance(result.value_plan, MenaiIRIf)\\n\\n    def test_then_false_else_false_not_rewritten(self):\\n        \\\"\\\"\\\"(if cond #f #f) \\u2014 both branches same, but not the negation pattern.\\\"\\\"\\\"\\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\\n            condition_plan=_bool_p_call(_local(0)),\\n            then_plan=_bool_const(False),\\n            else_plan=_bool_const(False),\\n            in_tail_position=True,\\n        ))\\n        result = _run_opt(ir)\\n        assert isinstance(result, MenaiIRReturn)\\n        assert isinstance(result.value_plan, MenaiIRIf)\\n\\n\\n# ---------------------------------------------------------------------------\\n# Integration tests: correct runtime semantics\\n# ---------------------------------------------------------------------------\\n\\nclass TestBooleanIdentityIntegration:\\n    \\\"\\\"\\\"End-to-end: optimized code must produce the same results as unoptimized.\\\"\\\"\\\"\\n\\n    @pytest.fixture\\n    def menai(self):\\n        return Menai()\\n\\n    def test_identity_form_true_input(self):\\n        \\\"\\\"\\\"(if (boolean? x) #t #f) returns #t when x is a boolean.\\\"\\\"\\\"\\n        assert Menai().evaluate(\\\"(if (boolean? #t) #t #f)\\\") == True\\n\\n    def test_identity_form_false_input(self):\\n        \\\"\\\"\\\"(if (boolean? x) #t #f) returns #f when x is not a boolean.\\\"\\\"\\\"\\n        assert Menai().evaluate(\\\"(if (boolean? 42) #t #f)\\\") == False\\n\\n    def test_negation_form_true_input(self):\\n        \\\"\\\"\\\"(if (boolean? x) #f #t) returns #f when x is a boolean.\\\"\\\"\\\"\\n        assert Menai().evaluate(\\\"(if (boolean? #t) #f #t)\\\") == False\\n\\n    def test_negation_form_false_input(self):\\n        \\\"\\\"\\\"(if (boolean? x) #f #t) returns #t when x is not a boolean.\\\"\\\"\\\"\\n        assert Menai().evaluate(\\\"(if (boolean? 42) #f #t)\\\") == True\\n\\n    def test_identity_form_inside_lambda(self, menai):\\n        \\\"\\\"\\\"The pattern is correctly optimized and evaluated inside a lambda.\\\"\\\"\\\"\\n        result = menai.evaluate(\\\"\\\"\\\"\\n            (let ((coerce-bool (lambda (x) (if (boolean? x) #t #f))))\\n              (list (coerce-bool #t) (coerce-bool #f) (coerce-bool 0) (coerce-bool \\\"s\\\")))\\n        \\\"\\\"\\\")\\n        assert result == [True, True, False, False]\\n\\n    def test_negation_form_inside_lambda(self, menai):\\n        \\\"\\\"\\\"The negation pattern is correctly optimized and evaluated inside a lambda.\\\"\\\"\\\"\\n        result = menai.evaluate(\\\"\\\"\\\"\\n            (let ((not-bool (lambda (x) (if (boolean? x) #f #t))))\\n              (list (not-bool #t) (not-bool #f) (not-bool 0) (not-bool \\\"s\\\")))\\n        \\\"\\\"\\\")\\n        assert result == [False, False, True, True]\\n\\n    def test_nested_identity_forms(self, menai):\\n        \\\"\\\"\\\"Nested occurrences are both eliminated.\\\"\\\"\\\"\\n        result = menai.evaluate(\\\"\\\"\\\"\\n            (let ((f (lambda (x)\\n                       (if (if (boolean? x) #t #f)\\n                           \\\"was-bool\\\"\\n                           \\\"not-bool\\\"))))\\n              (list (f #t) (f 42)))\\n        \\\"\\\"\\\")\\n        assert result == [\\\"was-bool\\\", \\\"not-bool\\\"]\\n\\n    def test_identity_with_integer_predicate(self, menai):\\n        \\\"\\\"\\\"Works with any predicate, not just boolean?.\\\"\\\"\\\"\\n        result = menai.evaluate(\\\"\\\"\\\"\\n            (let ((is-int (lambda (x) (if (integer? x) #t #f))))\\n              (list (is-int 42) (is-int \\\"hi\\\") (is-int #t)))\\n        \\\"\\\"\\\")\\n        assert result == [True, False, False]\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"\nTests for the boolean identity elimination in MenaiIROptimizer.\n\nThe optimizer rewrites two structural forms of MenaiIRIf:\n\n    (if <cond> #t #f)  \u2192  <cond>\n    (if <cond> #f #t)  \u2192  (boolean-not <cond>)\n\nStrategy\n--------\n1. Unit tests on the optimizer directly, constructing IR nodes by hand.\n   These verify the structural transformation without going through the\n   full compiler pipeline.\n\n2. Integration tests that compile real Menai source and verify that the\n   optimized program produces the correct result for all input cases.\n   These catch regressions where the optimizer silently changes semantics.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom menai import Menai\nfrom menai.menai_ir import (\n    MenaiIRCall,\n    MenaiIRConstant,\n    MenaiIRIf,\n    MenaiIRReturn,\n    MenaiIRVariable,\n)\nfrom menai.menai_ir_optimizer import MenaiIROptimizer\nfrom menai.menai_value import MenaiBoolean, MenaiInteger\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\ndef _bool_const(value: bool) -> MenaiIRConstant:\n    return MenaiIRConstant(value=MenaiBoolean(value))\n\n\ndef _int_const(n: int) -> MenaiIRConstant:\n    return MenaiIRConstant(value=MenaiInteger(n))\n\n\ndef _global(name: str) -> MenaiIRVariable:\n    return MenaiIRVariable(name=name, var_type='global')\n\n\ndef _bool_p_call(arg: MenaiIRVariable) -> MenaiIRCall:\n    \"\"\"Emit (boolean? arg) as a builtin call.\"\"\"\n    return MenaiIRCall(\n        func_plan=_global('boolean?'),\n        arg_plans=[arg],\n        is_tail_call=False,\n        is_builtin=True,\n        builtin_name='boolean?',\n    )\n\n\ndef _local(index: int) -> MenaiIRVariable:\n    return MenaiIRVariable(\n        name=f\"v{index}\", var_type='local'\n    )\n\n\ndef _run(ir):\n    \"\"\"Run the optimizer and return (new_ir, changed).\"\"\"\n    return MenaiIROptimizer().optimize(ir)\n\n\ndef _run_opt(ir):\n    \"\"\"Run the optimizer and return just the new IR.\"\"\"\n    new_ir, _ = _run(ir)\n    return new_ir\n\n\n# ---------------------------------------------------------------------------\n# Unit tests: (if cond #t #f) \u2192 cond\n# ---------------------------------------------------------------------------\n\nclass TestBooleanIdentityElimination:\n    \"\"\"(if <cond> #t #f) is replaced by <cond> directly.\"\"\"\n\n    def test_if_true_false_replaced_by_condition(self):\n        \"\"\"(if (boolean? v0) #t #f) \u2192 (boolean? v0)\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        # The MenaiIRIf should have been eliminated entirely.\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.builtin_name == 'boolean?'\n\n    def test_if_true_false_sets_changed_flag(self):\n        \"\"\"changed is True when the pattern fires.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        _, changed = _run(ir)\n        assert changed is True\n\n    def test_no_change_when_pattern_absent(self):\n        \"\"\"changed is False when no boolean identity pattern is present.\"\"\"\n        # (if (boolean? v0) 1 2) \u2014 non-boolean branches, no transformation\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_int_const(1),\n            else_plan=_int_const(2),\n            in_tail_position=True,\n        ))\n        _, changed = _run(ir)\n        assert changed is False\n\n    def test_if_true_false_with_constant_condition(self):\n        \"\"\"(if #t #t #f) \u2192 #t  (condition is itself a constant).\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_const(True),\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRConstant)\n        assert result.value_plan.value == MenaiBoolean(True)\n\n    def test_if_true_false_non_tail(self):\n        \"\"\"Transformation preserves in_tail_position=False on the condition.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=False,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        # The if was in non-tail position; the condition replaces it directly.\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.builtin_name == 'boolean?'\n\n\n# ---------------------------------------------------------------------------\n# Unit tests: (if cond #f #t) \u2192 (boolean-not cond)\n# ---------------------------------------------------------------------------\n\nclass TestBooleanNegationElimination:\n    \"\"\"(if <cond> #f #t) is replaced by (boolean-not <cond>).\"\"\"\n\n    def test_if_false_true_replaced_by_boolean_not(self):\n        \"\"\"(if (boolean? v0) #f #t) \u2192 (boolean-not (boolean? v0))\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        # Should be a call to boolean-not wrapping the original condition.\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.builtin_name == 'boolean-not'\n        assert len(result.value_plan.arg_plans) == 1\n        inner = result.value_plan.arg_plans[0]\n        assert isinstance(inner, MenaiIRCall)\n        assert inner.builtin_name == 'boolean?'\n\n    def test_if_false_true_sets_changed_flag(self):\n        \"\"\"changed is True when the negated pattern fires.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        _, changed = _run(ir)\n        assert changed is True\n\n    def test_if_false_true_tail_call_propagated(self):\n        \"\"\"The boolean-not call inherits is_tail_call from in_tail_position.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.is_tail_call is True\n\n    def test_if_false_true_non_tail_call_propagated(self):\n        \"\"\"is_tail_call is False when in_tail_position is False.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=False,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.is_tail_call is False\n\n\n# ---------------------------------------------------------------------------\n# Unit tests: patterns that must NOT be transformed\n# ---------------------------------------------------------------------------\n\nclass TestNoTransformation:\n    \"\"\"Cases that look similar but must not be rewritten.\"\"\"\n\n    def test_then_true_else_non_boolean_not_rewritten(self):\n        \"\"\"(if cond #t 42) \u2014 else is not a boolean constant, no change.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_bool_const(True),\n            else_plan=_int_const(42),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n    def test_then_non_boolean_else_false_not_rewritten(self):\n        \"\"\"(if cond 42 #f) \u2014 then is not a boolean constant, no change.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_int_const(42),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n    def test_then_true_else_true_not_rewritten(self):\n        \"\"\"(if cond #t #t) \u2014 both branches same, but not the identity pattern.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n    def test_then_false_else_false_not_rewritten(self):\n        \"\"\"(if cond #f #f) \u2014 both branches same, but not the negation pattern.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n\n# ---------------------------------------------------------------------------\n# Integration tests: correct runtime semantics\n# ---------------------------------------------------------------------------\n\nclass TestBooleanIdentityIntegration:\n    \"\"\"End-to-end: optimized code must produce the same results as unoptimized.\"\"\"\n\n    @pytest.fixture\n    def menai(self):\n        return Menai()\n\n    def test_identity_form_true_input(self):\n        \"\"\"(if (boolean? x) #t #f) returns #t when x is a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? #t) #t #f)\") == True\n\n    def test_identity_form_false_input(self):\n        \"\"\"(if (boolean? x) #t #f) returns #f when x is not a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? 42) #t #f)\") == False\n\n    def test_negation_form_true_input(self):\n        \"\"\"(if (boolean? x) #f #t) returns #f when x is a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? #t) #f #t)\") == False\n\n    def test_negation_form_false_input(self):\n        \"\"\"(if (boolean? x) #f #t) returns #t when x is not a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? 42) #f #t)\") == True\n\n    def test_identity_form_inside_lambda(self, menai):\n        \"\"\"The pattern is correctly optimized and evaluated inside a lambda.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((coerce-bool (lambda (x) (if (boolean? x) #t #f))))\n              (list (coerce-bool #t) (coerce-bool #f) (coerce-bool 0) (coerce-bool \"s\")))\n        \"\"\")\n        assert result == [True, True, False, False]\n\n    def test_negation_form_inside_lambda(self, menai):\n        \"\"\"The negation pattern is correctly optimized and evaluated inside a lambda.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((not-bool (lambda (x) (if (boolean? x) #f #t))))\n              (list (not-bool #t) (not-bool #f) (not-bool 0) (not-bool \"s\")))\n        \"\"\")\n        assert result == [False, False, True, True]\n\n    def test_nested_identity_forms(self, menai):\n        \"\"\"Nested occurrences are both eliminated.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((f (lambda (x)\n                       (if (if (boolean? x) #t #f)\n                           \"was-bool\"\n                           \"not-bool\"))))\n              (list (f #t) (f 42)))\n        \"\"\")\n        assert result == [\"was-bool\", \"not-bool\"]\n\n    def test_identity_with_integer_predicate(self, menai):\n        \"\"\"Works with any predicate, not just boolean?.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((is-int (lambda (x) (if (integer? x) #t #f))))\n              (list (is-int 42) (is-int \"hi\") (is-int #t)))\n        \"\"\")\n        assert result == [True, False, False]\n\n```",
      "completed": true,
      "tool_results": [
        {
          "id": "toolu_0123xeBkdQFpJzFaeyXf8F1g",
          "name": "filesystem",
          "content": "\"\"\"\nTests for the boolean identity elimination in MenaiIROptimizer.\n\nThe optimizer rewrites two structural forms of MenaiIRIf:\n\n    (if <cond> #t #f)  \u2192  <cond>\n    (if <cond> #f #t)  \u2192  (boolean-not <cond>)\n\nStrategy\n--------\n1. Unit tests on the optimizer directly, constructing IR nodes by hand.\n   These verify the structural transformation without going through the\n   full compiler pipeline.\n\n2. Integration tests that compile real Menai source and verify that the\n   optimized program produces the correct result for all input cases.\n   These catch regressions where the optimizer silently changes semantics.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom menai import Menai\nfrom menai.menai_ir import (\n    MenaiIRCall,\n    MenaiIRConstant,\n    MenaiIRIf,\n    MenaiIRReturn,\n    MenaiIRVariable,\n)\nfrom menai.menai_ir_optimizer import MenaiIROptimizer\nfrom menai.menai_value import MenaiBoolean, MenaiInteger\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\ndef _bool_const(value: bool) -> MenaiIRConstant:\n    return MenaiIRConstant(value=MenaiBoolean(value))\n\n\ndef _int_const(n: int) -> MenaiIRConstant:\n    return MenaiIRConstant(value=MenaiInteger(n))\n\n\ndef _global(name: str) -> MenaiIRVariable:\n    return MenaiIRVariable(name=name, var_type='global')\n\n\ndef _bool_p_call(arg: MenaiIRVariable) -> MenaiIRCall:\n    \"\"\"Emit (boolean? arg) as a builtin call.\"\"\"\n    return MenaiIRCall(\n        func_plan=_global('boolean?'),\n        arg_plans=[arg],\n        is_tail_call=False,\n        is_builtin=True,\n        builtin_name='boolean?',\n    )\n\n\ndef _local(index: int) -> MenaiIRVariable:\n    return MenaiIRVariable(\n        name=f\"v{index}\", var_type='local'\n    )\n\n\ndef _run(ir):\n    \"\"\"Run the optimizer and return (new_ir, changed).\"\"\"\n    return MenaiIROptimizer().optimize(ir)\n\n\ndef _run_opt(ir):\n    \"\"\"Run the optimizer and return just the new IR.\"\"\"\n    new_ir, _ = _run(ir)\n    return new_ir\n\n\n# ---------------------------------------------------------------------------\n# Unit tests: (if cond #t #f) \u2192 cond\n# ---------------------------------------------------------------------------\n\nclass TestBooleanIdentityElimination:\n    \"\"\"(if <cond> #t #f) is replaced by <cond> directly.\"\"\"\n\n    def test_if_true_false_replaced_by_condition(self):\n        \"\"\"(if (boolean? v0) #t #f) \u2192 (boolean? v0)\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        # The MenaiIRIf should have been eliminated entirely.\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.builtin_name == 'boolean?'\n\n    def test_if_true_false_sets_changed_flag(self):\n        \"\"\"changed is True when the pattern fires.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        _, changed = _run(ir)\n        assert changed is True\n\n    def test_no_change_when_pattern_absent(self):\n        \"\"\"changed is False when no boolean identity pattern is present.\"\"\"\n        # (if (boolean? v0) 1 2) \u2014 non-boolean branches, no transformation\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_int_const(1),\n            else_plan=_int_const(2),\n            in_tail_position=True,\n        ))\n        _, changed = _run(ir)\n        assert changed is False\n\n    def test_if_true_false_with_constant_condition(self):\n        \"\"\"(if #t #t #f) \u2192 #t  (condition is itself a constant).\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_const(True),\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRConstant)\n        assert result.value_plan.value == MenaiBoolean(True)\n\n    def test_if_true_false_non_tail(self):\n        \"\"\"Transformation preserves in_tail_position=False on the condition.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(False),\n            in_tail_position=False,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        # The if was in non-tail position; the condition replaces it directly.\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.builtin_name == 'boolean?'\n\n\n# ---------------------------------------------------------------------------\n# Unit tests: (if cond #f #t) \u2192 (boolean-not cond)\n# ---------------------------------------------------------------------------\n\nclass TestBooleanNegationElimination:\n    \"\"\"(if <cond> #f #t) is replaced by (boolean-not <cond>).\"\"\"\n\n    def test_if_false_true_replaced_by_boolean_not(self):\n        \"\"\"(if (boolean? v0) #f #t) \u2192 (boolean-not (boolean? v0))\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        # Should be a call to boolean-not wrapping the original condition.\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.builtin_name == 'boolean-not'\n        assert len(result.value_plan.arg_plans) == 1\n        inner = result.value_plan.arg_plans[0]\n        assert isinstance(inner, MenaiIRCall)\n        assert inner.builtin_name == 'boolean?'\n\n    def test_if_false_true_sets_changed_flag(self):\n        \"\"\"changed is True when the negated pattern fires.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        _, changed = _run(ir)\n        assert changed is True\n\n    def test_if_false_true_tail_call_propagated(self):\n        \"\"\"The boolean-not call inherits is_tail_call from in_tail_position.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.is_tail_call is True\n\n    def test_if_false_true_non_tail_call_propagated(self):\n        \"\"\"is_tail_call is False when in_tail_position is False.\"\"\"\n        cond = _bool_p_call(_local(0))\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=cond,\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(True),\n            in_tail_position=False,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result.value_plan, MenaiIRCall)\n        assert result.value_plan.is_tail_call is False\n\n\n# ---------------------------------------------------------------------------\n# Unit tests: patterns that must NOT be transformed\n# ---------------------------------------------------------------------------\n\nclass TestNoTransformation:\n    \"\"\"Cases that look similar but must not be rewritten.\"\"\"\n\n    def test_then_true_else_non_boolean_not_rewritten(self):\n        \"\"\"(if cond #t 42) \u2014 else is not a boolean constant, no change.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_bool_const(True),\n            else_plan=_int_const(42),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n    def test_then_non_boolean_else_false_not_rewritten(self):\n        \"\"\"(if cond 42 #f) \u2014 then is not a boolean constant, no change.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_int_const(42),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n    def test_then_true_else_true_not_rewritten(self):\n        \"\"\"(if cond #t #t) \u2014 both branches same, but not the identity pattern.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_bool_const(True),\n            else_plan=_bool_const(True),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n    def test_then_false_else_false_not_rewritten(self):\n        \"\"\"(if cond #f #f) \u2014 both branches same, but not the negation pattern.\"\"\"\n        ir = MenaiIRReturn(value_plan=MenaiIRIf(\n            condition_plan=_bool_p_call(_local(0)),\n            then_plan=_bool_const(False),\n            else_plan=_bool_const(False),\n            in_tail_position=True,\n        ))\n        result = _run_opt(ir)\n        assert isinstance(result, MenaiIRReturn)\n        assert isinstance(result.value_plan, MenaiIRIf)\n\n\n# ---------------------------------------------------------------------------\n# Integration tests: correct runtime semantics\n# ---------------------------------------------------------------------------\n\nclass TestBooleanIdentityIntegration:\n    \"\"\"End-to-end: optimized code must produce the same results as unoptimized.\"\"\"\n\n    @pytest.fixture\n    def menai(self):\n        return Menai()\n\n    def test_identity_form_true_input(self):\n        \"\"\"(if (boolean? x) #t #f) returns #t when x is a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? #t) #t #f)\") == True\n\n    def test_identity_form_false_input(self):\n        \"\"\"(if (boolean? x) #t #f) returns #f when x is not a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? 42) #t #f)\") == False\n\n    def test_negation_form_true_input(self):\n        \"\"\"(if (boolean? x) #f #t) returns #f when x is a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? #t) #f #t)\") == False\n\n    def test_negation_form_false_input(self):\n        \"\"\"(if (boolean? x) #f #t) returns #t when x is not a boolean.\"\"\"\n        assert Menai().evaluate(\"(if (boolean? 42) #f #t)\") == True\n\n    def test_identity_form_inside_lambda(self, menai):\n        \"\"\"The pattern is correctly optimized and evaluated inside a lambda.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((coerce-bool (lambda (x) (if (boolean? x) #t #f))))\n              (list (coerce-bool #t) (coerce-bool #f) (coerce-bool 0) (coerce-bool \"s\")))\n        \"\"\")\n        assert result == [True, True, False, False]\n\n    def test_negation_form_inside_lambda(self, menai):\n        \"\"\"The negation pattern is correctly optimized and evaluated inside a lambda.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((not-bool (lambda (x) (if (boolean? x) #f #t))))\n              (list (not-bool #t) (not-bool #f) (not-bool 0) (not-bool \"s\")))\n        \"\"\")\n        assert result == [False, False, True, True]\n\n    def test_nested_identity_forms(self, menai):\n        \"\"\"Nested occurrences are both eliminated.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((f (lambda (x)\n                       (if (if (boolean? x) #t #f)\n                           \"was-bool\"\n                           \"not-bool\"))))\n              (list (f #t) (f 42)))\n        \"\"\")\n        assert result == [\"was-bool\", \"not-bool\"]\n\n    def test_identity_with_integer_predicate(self, menai):\n        \"\"\"Works with any predicate, not just boolean?.\"\"\"\n        result = menai.evaluate(\"\"\"\n            (let ((is-int (lambda (x) (if (integer? x) #t #f))))\n              (list (is-int 42) (is-int \"hi\") (is-int #t)))\n        \"\"\")\n        assert result == [True, False, False]\n",
