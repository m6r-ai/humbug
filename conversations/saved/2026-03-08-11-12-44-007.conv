      "content": "```json\n{\n  \"id\": \"toolu_01W5RgYERHnksQYBMa4ga4ig\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"\\nMenai IR Optimizer - transformation pass over the IR tree.\\n\\nConsumes an IRUseCounts annotation (produced by MenaiIRUseCounter) and applies\\nIR-level optimizations that are safe because Menai is a pure functional language\\n\\u2014 every binding is immutable and every expression is side-effect-free.\\n\\\"\\\"\\\"\\n\\nfrom typing import List, Tuple, cast\\n\\nfrom menai.menai_ir import (\\n    MenaiIRExpr,\\n    MenaiIRCall,\\n    MenaiIRConstant,\\n    MenaiIRBuildList,\\n    MenaiIRBuildDict,\\n    MenaiIREmptyList,\\n    MenaiIRError,\\n    MenaiIRIf,\\n    MenaiIRLambda,\\n    MenaiIRLet,\\n    MenaiIRLetrec,\\n    MenaiIRQuote,\\n    MenaiIRReturn,\\n    MenaiIRTrace,\\n    MenaiIRVariable,\\n)\\nfrom menai.menai_value import MenaiBoolean\\nfrom menai.menai_ir_use_counter import MenaiIRUseCounter, IRUseCounts\\nfrom menai.menai_ir_optimization_pass import MenaiIROptimizationPass\\n\\n\\nclass MenaiIROptimizer(MenaiIROptimizationPass):\\n    \\\"\\\"\\\"\\n    IR-level optimization pass.\\n\\n    Implements MenaiIROptimizationPass: call optimize(ir) to get back a\\n    transformed IR tree and a boolean indicating whether any changes were made.\\n    Use counts are computed internally so callers do not need to manage them.\\n\\n    Usage::\\n\\n        new_ir, changed = MenaiIROptimizer().optimize(ir)\\n    \\\"\\\"\\\"\\n\\n    def __init__(self) -> None:\\n        self._eliminations = 0\\n        self._counts: IRUseCounts | None = None\\n\\n    def optimize(self, ir: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\\n        \\\"\\\"\\\"Return an optimized IR tree and a boolean indicating whether any changes were made.\\\"\\\"\\\"\\n        self._eliminations = 0\\n        self._counts = MenaiIRUseCounter().count(ir)\\n        new_ir = self._opt(ir, frame_stack=[0])\\n        return new_ir, self._eliminations > 0\\n\\n    def _opt(self, ir: MenaiIRExpr, frame_stack: List[int]) -> MenaiIRExpr:\\n        \\\"\\\"\\\"Recursively walk the IR tree and apply optimizations.\\\"\\\"\\\"\\n        if isinstance(ir, MenaiIRLet):\\n            return self._opt_let(ir, frame_stack)\\n\\n        if isinstance(ir, MenaiIRLetrec):\\n            return self._opt_letrec(ir, frame_stack)\\n\\n        if isinstance(ir, MenaiIRIf):\\n            return self._opt_if(ir, frame_stack)\\n\\n        if isinstance(ir, MenaiIRLambda):\\n            return self._opt_lambda(ir, frame_stack)\\n\\n        if isinstance(ir, MenaiIRCall):\\n            return self._opt_call(ir, frame_stack)\\n\\n        if isinstance(ir, MenaiIRBuildList):\\n            return MenaiIRBuildList(\\n                element_plans=[self._opt(e, frame_stack) for e in ir.element_plans],\\n            )\\n\\n        if isinstance(ir, MenaiIRBuildDict):\\n            return MenaiIRBuildDict(\\n                pair_plans=[(self._opt(k, frame_stack), self._opt(v, frame_stack))\\n                            for k, v in ir.pair_plans],\\n            )\\n\\n        if isinstance(ir, MenaiIRReturn):\\n            return MenaiIRReturn(value_plan=self._opt(ir.value_plan, frame_stack))\\n\\n        if isinstance(ir, MenaiIRTrace):\\n            return MenaiIRTrace(\\n                message_plans=[self._opt(m, frame_stack) for m in ir.message_plans],\\n                value_plan=self._opt(ir.value_plan, frame_stack),\\n            )\\n\\n        if isinstance(ir, (MenaiIRConstant, MenaiIRVariable, MenaiIRQuote, MenaiIREmptyList, MenaiIRError)):\\n            return ir\\n\\n        raise TypeError(f\\\"MenaiIROptimizer: unhandled IR node type {type(ir).__name__}\\\")\\n\\n    def _opt_let(self, ir: MenaiIRLet, frame_stack: List[int]) -> MenaiIRExpr:\\n        \\\"\\\"\\\"Drop dead let bindings (total use count == 0).\\\"\\\"\\\"\\n        current_frame = frame_stack[-1]\\n        counts = cast(IRUseCounts, self._counts)\\n\\n        live: List[Tuple[str, MenaiIRExpr]] = []\\n        for binding in ir.bindings:\\n            name, value_plan, *_ = binding\\n            if counts.total_count(current_frame, id(binding)) == 0:\\n                self._eliminations += 1\\n                continue\\n            live.append((name, self._opt(value_plan, frame_stack)))\\n\\n        opt_body = self._opt(ir.body_plan, frame_stack)\\n\\n        if not live:\\n            return opt_body\\n\\n        return MenaiIRLet(\\n            bindings=live,\\n            body_plan=opt_body,\\n            in_tail_position=ir.in_tail_position,\\n        )\\n\\n    def _opt_letrec(self, ir: MenaiIRLetrec, frame_stack: List[int]) -> MenaiIRExpr:\\n        \\\"\\\"\\\"Drop dead letrec bindings (total use count == 0).\\\"\\\"\\\"\\n        current_frame = frame_stack[-1]\\n        counts = cast(IRUseCounts, self._counts)\\n\\n        live: List[Tuple[str, MenaiIRExpr]] = []\\n        for binding in ir.bindings:\\n            name, value_plan, *_ = binding\\n            if counts.total_count(current_frame, id(binding)) == 0:\\n                self._eliminations += 1\\n                continue\\n\\n            live.append((name, self._opt(value_plan, frame_stack)))\\n\\n        opt_body = self._opt(ir.body_plan, frame_stack)\\n\\n        if not live:\\n            return opt_body\\n\\n        return MenaiIRLetrec(\\n            bindings=live,\\n            body_plan=opt_body,\\n            in_tail_position=ir.in_tail_position,\\n        )\\n\\n    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\\n        opt_condition = self._opt(ir.condition_plan, frame_stack)\\n        opt_then = self._opt(ir.then_plan, frame_stack)\\n        opt_else = self._opt(ir.else_plan, frame_stack)\\n\\n        # Constant-condition elimination:\\n        #   (if #t then else)  \\u2192  then\\n        #   (if #f then else)  \\u2192  else\\n        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\\n            self._eliminations += 1\\n            if opt_condition.value.value:\\n                return opt_then\\n\\n            return opt_else\\n\\n        # Boolean identity elimination:\\n        #   (if <cond> #t #f)  \\u2192  <cond>\\n        #   (if <cond> #f #t)  \\u2192  (boolean-not <cond>)\\n        if (isinstance(opt_then, MenaiIRConstant)\\n                and isinstance(opt_then.value, MenaiBoolean)\\n                and isinstance(opt_else, MenaiIRConstant)\\n                and isinstance(opt_else.value, MenaiBoolean)):\\n            if opt_then.value.value and not opt_else.value.value:\\n                # (if cond #t #f) \\u2192  cond\\n                self._eliminations += 1\\n                return opt_condition\\n\\n            if not opt_then.value.value and opt_else.value.value:\\n                # (if cond #f #t) \\u2192 (boolean-not cond)\\n                self._eliminations += 1\\n                return MenaiIRCall(\\n                    func_plan=MenaiIRVariable(\\n                            name='boolean-not', var_type='global'\\n                    ),\\n                    arg_plans=[opt_condition],\\n                    is_tail_call=ir.in_tail_position,\\n                    is_builtin=True,\\n                    builtin_name='boolean-not',\\n                )\\n\\n        return MenaiIRIf(\\n            condition_plan=opt_condition,\\n            then_plan=opt_then,\\n            else_plan=opt_else,\\n            in_tail_position=ir.in_tail_position,\\n        )\\n\\n    def _opt_lambda(self, ir: MenaiIRLambda, frame_stack: List[int]) -> MenaiIRLambda:\\n        \\\"\\\"\\\"Optimize the body of a lambda.\\\"\\\"\\\"\\n        counts = cast(IRUseCounts, self._counts)\\n        lambda_frame_id = counts.lambda_frame_ids.get(id(ir))\\n        child_stack = frame_stack if lambda_frame_id is None else frame_stack + [lambda_frame_id]\\n\\n        return MenaiIRLambda(\\n            params=ir.params,\\n            body_plan=self._opt(ir.body_plan, child_stack),\\n            sibling_free_vars=ir.sibling_free_vars,\\n            sibling_free_var_plans=ir.sibling_free_var_plans,\\n            outer_free_vars=ir.outer_free_vars,\\n            outer_free_var_plans=ir.outer_free_var_plans,\\n            param_count=ir.param_count,\\n            is_variadic=ir.is_variadic,\\n            binding_name=ir.binding_name,\\n            source_line=ir.source_line,\\n            source_file=ir.source_file,\\n        )\\n\\n    def _opt_call(self, ir: MenaiIRCall, frame_stack: List[int]) -> MenaiIRCall:\\n        \\\"\\\"\\\"Optimize the function and argument plans of a call.\\\"\\\"\\\"\\n        return MenaiIRCall(\\n            func_plan=self._opt(ir.func_plan, frame_stack),\\n            arg_plans=[self._opt(a, frame_stack) for a in ir.arg_plans],\\n            is_tail_call=ir.is_tail_call,\\n            is_builtin=ir.is_builtin,\\n            builtin_name=ir.builtin_name,\\n        )\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"\nMenai IR Optimizer - transformation pass over the IR tree.\n\nConsumes an IRUseCounts annotation (produced by MenaiIRUseCounter) and applies\nIR-level optimizations that are safe because Menai is a pure functional language\n\u2014 every binding is immutable and every expression is side-effect-free.\n\"\"\"\n\nfrom typing import List, Tuple, cast\n\nfrom menai.menai_ir import (\n    MenaiIRExpr,\n    MenaiIRCall,\n    MenaiIRConstant,\n    MenaiIRBuildList,\n    MenaiIRBuildDict,\n    MenaiIREmptyList,\n    MenaiIRError,\n    MenaiIRIf,\n    MenaiIRLambda,\n    MenaiIRLet,\n    MenaiIRLetrec,\n    MenaiIRQuote,\n    MenaiIRReturn,\n    MenaiIRTrace,\n    MenaiIRVariable,\n)\nfrom menai.menai_value import MenaiBoolean\nfrom menai.menai_ir_use_counter import MenaiIRUseCounter, IRUseCounts\nfrom menai.menai_ir_optimization_pass import MenaiIROptimizationPass\n\n\nclass MenaiIROptimizer(MenaiIROptimizationPass):\n    \"\"\"\n    IR-level optimization pass.\n\n    Implements MenaiIROptimizationPass: call optimize(ir) to get back a\n    transformed IR tree and a boolean indicating whether any changes were made.\n    Use counts are computed internally so callers do not need to manage them.\n\n    Usage::\n\n        new_ir, changed = MenaiIROptimizer().optimize(ir)\n    \"\"\"\n\n    def __init__(self) -> None:\n        self._eliminations = 0\n        self._counts: IRUseCounts | None = None\n\n    def optimize(self, ir: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\n        \"\"\"Return an optimized IR tree and a boolean indicating whether any changes were made.\"\"\"\n        self._eliminations = 0\n        self._counts = MenaiIRUseCounter().count(ir)\n        new_ir = self._opt(ir, frame_stack=[0])\n        return new_ir, self._eliminations > 0\n\n    def _opt(self, ir: MenaiIRExpr, frame_stack: List[int]) -> MenaiIRExpr:\n        \"\"\"Recursively walk the IR tree and apply optimizations.\"\"\"\n        if isinstance(ir, MenaiIRLet):\n            return self._opt_let(ir, frame_stack)\n\n        if isinstance(ir, MenaiIRLetrec):\n            return self._opt_letrec(ir, frame_stack)\n\n        if isinstance(ir, MenaiIRIf):\n            return self._opt_if(ir, frame_stack)\n\n        if isinstance(ir, MenaiIRLambda):\n            return self._opt_lambda(ir, frame_stack)\n\n        if isinstance(ir, MenaiIRCall):\n            return self._opt_call(ir, frame_stack)\n\n        if isinstance(ir, MenaiIRBuildList):\n            return MenaiIRBuildList(\n                element_plans=[self._opt(e, frame_stack) for e in ir.element_plans],\n            )\n\n        if isinstance(ir, MenaiIRBuildDict):\n            return MenaiIRBuildDict(\n                pair_plans=[(self._opt(k, frame_stack), self._opt(v, frame_stack))\n                            for k, v in ir.pair_plans],\n            )\n\n        if isinstance(ir, MenaiIRReturn):\n            return MenaiIRReturn(value_plan=self._opt(ir.value_plan, frame_stack))\n\n        if isinstance(ir, MenaiIRTrace):\n            return MenaiIRTrace(\n                message_plans=[self._opt(m, frame_stack) for m in ir.message_plans],\n                value_plan=self._opt(ir.value_plan, frame_stack),\n            )\n\n        if isinstance(ir, (MenaiIRConstant, MenaiIRVariable, MenaiIRQuote, MenaiIREmptyList, MenaiIRError)):\n            return ir\n\n        raise TypeError(f\"MenaiIROptimizer: unhandled IR node type {type(ir).__name__}\")\n\n    def _opt_let(self, ir: MenaiIRLet, frame_stack: List[int]) -> MenaiIRExpr:\n        \"\"\"Drop dead let bindings (total use count == 0).\"\"\"\n        current_frame = frame_stack[-1]\n        counts = cast(IRUseCounts, self._counts)\n\n        live: List[Tuple[str, MenaiIRExpr]] = []\n        for binding in ir.bindings:\n            name, value_plan, *_ = binding\n            if counts.total_count(current_frame, id(binding)) == 0:\n                self._eliminations += 1\n                continue\n            live.append((name, self._opt(value_plan, frame_stack)))\n\n        opt_body = self._opt(ir.body_plan, frame_stack)\n\n        if not live:\n            return opt_body\n\n        return MenaiIRLet(\n            bindings=live,\n            body_plan=opt_body,\n            in_tail_position=ir.in_tail_position,\n        )\n\n    def _opt_letrec(self, ir: MenaiIRLetrec, frame_stack: List[int]) -> MenaiIRExpr:\n        \"\"\"Drop dead letrec bindings (total use count == 0).\"\"\"\n        current_frame = frame_stack[-1]\n        counts = cast(IRUseCounts, self._counts)\n\n        live: List[Tuple[str, MenaiIRExpr]] = []\n        for binding in ir.bindings:\n            name, value_plan, *_ = binding\n            if counts.total_count(current_frame, id(binding)) == 0:\n                self._eliminations += 1\n                continue\n\n            live.append((name, self._opt(value_plan, frame_stack)))\n\n        opt_body = self._opt(ir.body_plan, frame_stack)\n\n        if not live:\n            return opt_body\n\n        return MenaiIRLetrec(\n            bindings=live,\n            body_plan=opt_body,\n            in_tail_position=ir.in_tail_position,\n        )\n\n    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\n        opt_condition = self._opt(ir.condition_plan, frame_stack)\n        opt_then = self._opt(ir.then_plan, frame_stack)\n        opt_else = self._opt(ir.else_plan, frame_stack)\n\n        # Constant-condition elimination:\n        #   (if #t then else)  \u2192  then\n        #   (if #f then else)  \u2192  else\n        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\n            self._eliminations += 1\n            if opt_condition.value.value:\n                return opt_then\n\n            return opt_else\n\n        # Boolean identity elimination:\n        #   (if <cond> #t #f)  \u2192  <cond>\n        #   (if <cond> #f #t)  \u2192  (boolean-not <cond>)\n        if (isinstance(opt_then, MenaiIRConstant)\n                and isinstance(opt_then.value, MenaiBoolean)\n                and isinstance(opt_else, MenaiIRConstant)\n                and isinstance(opt_else.value, MenaiBoolean)):\n            if opt_then.value.value and not opt_else.value.value:\n                # (if cond #t #f) \u2192  cond\n                self._eliminations += 1\n                return opt_condition\n\n            if not opt_then.value.value and opt_else.value.value:\n                # (if cond #f #t) \u2192 (boolean-not cond)\n                self._eliminations += 1\n                return MenaiIRCall(\n                    func_plan=MenaiIRVariable(\n                            name='boolean-not', var_type='global'\n                    ),\n                    arg_plans=[opt_condition],\n                    is_tail_call=ir.in_tail_position,\n                    is_builtin=True,\n                    builtin_name='boolean-not',\n                )\n\n        return MenaiIRIf(\n            condition_plan=opt_condition,\n            then_plan=opt_then,\n            else_plan=opt_else,\n            in_tail_position=ir.in_tail_position,\n        )\n\n    def _opt_lambda(self, ir: MenaiIRLambda, frame_stack: List[int]) -> MenaiIRLambda:\n        \"\"\"Optimize the body of a lambda.\"\"\"\n        counts = cast(IRUseCounts, self._counts)\n        lambda_frame_id = counts.lambda_frame_ids.get(id(ir))\n        child_stack = frame_stack if lambda_frame_id is None else frame_stack + [lambda_frame_id]\n\n        return MenaiIRLambda(\n            params=ir.params,\n            body_plan=self._opt(ir.body_plan, child_stack),\n            sibling_free_vars=ir.sibling_free_vars,\n            sibling_free_var_plans=ir.sibling_free_var_plans,\n            outer_free_vars=ir.outer_free_vars,\n            outer_free_var_plans=ir.outer_free_var_plans,\n            param_count=ir.param_count,\n            is_variadic=ir.is_variadic,\n            binding_name=ir.binding_name,\n            source_line=ir.source_line,\n            source_file=ir.source_file,\n        )\n\n    def _opt_call(self, ir: MenaiIRCall, frame_stack: List[int]) -> MenaiIRCall:\n        \"\"\"Optimize the function and argument plans of a call.\"\"\"\n        return MenaiIRCall(\n            func_plan=self._opt(ir.func_plan, frame_stack),\n            arg_plans=[self._opt(a, frame_stack) for a in ir.arg_plans],\n            is_tail_call=ir.is_tail_call,\n            is_builtin=ir.is_builtin,\n            builtin_name=ir.builtin_name,\n        )\n\n```",
