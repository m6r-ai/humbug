          "content": "{\n  \"range\": \"1-20\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"\",\n    \"2\": \"Tests for the boolean identity elimination in MenaiIROptimizer.\",\n    \"3\": \"\",\n    \"4\": \"The optimizer rewrites two structural forms of MenaiIRIf:\",\n    \"5\": \"\",\n    \"6\": \"    (if <cond> #t #f)  \\u2192  <cond>\",\n    \"7\": \"    (if <cond> #f #t)  \\u2192  (boolean-not <cond>)\",\n    \"8\": \"\",\n    \"9\": \"Strategy\",\n    \"10\": \"--------\",\n    \"11\": \"1. Unit tests on the optimizer directly, constructing IR nodes by hand.\",\n    \"12\": \"   These verify the structural transformation without going through the\",\n    \"13\": \"   full compiler pipeline.\",\n    \"14\": \"\",\n    \"15\": \"2. Integration tests that compile real Menai source and verify that the\",\n    \"16\": \"   optimized program produces the correct result for all input cases.\",\n    \"17\": \"   These catch regressions where the optimizer silently changes semantics.\",\n    \"18\": \"\\\"\\\"\\\"\",\n    \"19\": \"\",\n    \"20\": \"from __future__ import annotations\"\n  }\n}",
          "error": null
        }
      ]
    },
