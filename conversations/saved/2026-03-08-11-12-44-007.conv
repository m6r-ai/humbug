        {
          "id": "toolu_012BhRge7LjEcTQMtR6jMGsM",
          "name": "editor",
          "content": "{\n  \"range\": \"all lines\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"\",\n    \"2\": \"Menai IR Optimizer - transformation pass over the IR tree.\",\n    \"3\": \"\",\n    \"4\": \"Consumes an IRUseCounts annotation (produced by MenaiIRUseCounter) and applies\",\n    \"5\": \"IR-level optimizations that are safe because Menai is a pure functional language\",\n    \"6\": \"\\u2014 every binding is immutable and every expression is side-effect-free.\",\n    \"7\": \"\\\"\\\"\\\"\",\n    \"8\": \"\",\n    \"9\": \"from typing import List, Tuple, cast\",\n    \"10\": \"\",\n    \"11\": \"from menai.menai_ir import (\",\n    \"12\": \"    MenaiIRExpr,\",\n    \"13\": \"    MenaiIRCall,\",\n    \"14\": \"    MenaiIRConstant,\",\n    \"15\": \"    MenaiIRBuildList,\",\n    \"16\": \"    MenaiIRBuildDict,\",\n    \"17\": \"    MenaiIREmptyList,\",\n    \"18\": \"    MenaiIRError,\",\n    \"19\": \"    MenaiIRIf,\",\n    \"20\": \"    MenaiIRLambda,\",\n    \"21\": \"    MenaiIRLet,\",\n    \"22\": \"    MenaiIRLetrec,\",\n    \"23\": \"    MenaiIRQuote,\",\n    \"24\": \"    MenaiIRReturn,\",\n    \"25\": \"    MenaiIRTrace,\",\n    \"26\": \"    MenaiIRVariable,\",\n    \"27\": \")\",\n    \"28\": \"from menai.menai_value import MenaiBoolean\",\n    \"29\": \"from menai.menai_ir_use_counter import MenaiIRUseCounter, IRUseCounts\",\n    \"30\": \"from menai.menai_ir_optimization_pass import MenaiIROptimizationPass\",\n    \"31\": \"\",\n    \"32\": \"\",\n    \"33\": \"class MenaiIROptimizer(MenaiIROptimizationPass):\",\n    \"34\": \"    \\\"\\\"\\\"\",\n    \"35\": \"    IR-level optimization pass.\",\n    \"36\": \"\",\n    \"37\": \"    Implements MenaiIROptimizationPass: call optimize(ir) to get back a\",\n    \"38\": \"    transformed IR tree and a boolean indicating whether any changes were made.\",\n    \"39\": \"    Use counts are computed internally so callers do not need to manage them.\",\n    \"40\": \"\",\n    \"41\": \"    Usage::\",\n    \"42\": \"\",\n    \"43\": \"        new_ir, changed = MenaiIROptimizer().optimize(ir)\",\n    \"44\": \"    \\\"\\\"\\\"\",\n    \"45\": \"\",\n    \"46\": \"    def __init__(self) -> None:\",\n    \"47\": \"        self._eliminations = 0\",\n    \"48\": \"        self._counts: IRUseCounts | None = None\",\n    \"49\": \"\",\n    \"50\": \"    def optimize(self, ir: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\",\n    \"51\": \"        \\\"\\\"\\\"Return an optimized IR tree and a boolean indicating whether any changes were made.\\\"\\\"\\\"\",\n    \"52\": \"        self._eliminations = 0\",\n    \"53\": \"        self._counts = MenaiIRUseCounter().count(ir)\",\n    \"54\": \"        new_ir = self._opt(ir, frame_stack=[0])\",\n    \"55\": \"        return new_ir, self._eliminations > 0\",\n    \"56\": \"\",\n    \"57\": \"    def _opt(self, ir: MenaiIRExpr, frame_stack: List[int]) -> MenaiIRExpr:\",\n    \"58\": \"        \\\"\\\"\\\"Recursively walk the IR tree and apply optimizations.\\\"\\\"\\\"\",\n    \"59\": \"        if isinstance(ir, MenaiIRLet):\",\n    \"60\": \"            return self._opt_let(ir, frame_stack)\",\n    \"61\": \"\",\n    \"62\": \"        if isinstance(ir, MenaiIRLetrec):\",\n    \"63\": \"            return self._opt_letrec(ir, frame_stack)\",\n    \"64\": \"\",\n    \"65\": \"        if isinstance(ir, MenaiIRIf):\",\n    \"66\": \"            return self._opt_if(ir, frame_stack)\",\n    \"67\": \"\",\n    \"68\": \"        if isinstance(ir, MenaiIRLambda):\",\n    \"69\": \"            return self._opt_lambda(ir, frame_stack)\",\n    \"70\": \"\",\n    \"71\": \"        if isinstance(ir, MenaiIRCall):\",\n    \"72\": \"            return self._opt_call(ir, frame_stack)\",\n    \"73\": \"\",\n    \"74\": \"        if isinstance(ir, MenaiIRBuildList):\",\n    \"75\": \"            return MenaiIRBuildList(\",\n    \"76\": \"                element_plans=[self._opt(e, frame_stack) for e in ir.element_plans],\",\n    \"77\": \"            )\",\n    \"78\": \"\",\n    \"79\": \"        if isinstance(ir, MenaiIRBuildDict):\",\n    \"80\": \"            return MenaiIRBuildDict(\",\n    \"81\": \"                pair_plans=[(self._opt(k, frame_stack), self._opt(v, frame_stack))\",\n    \"82\": \"                            for k, v in ir.pair_plans],\",\n    \"83\": \"            )\",\n    \"84\": \"\",\n    \"85\": \"        if isinstance(ir, MenaiIRReturn):\",\n    \"86\": \"            return MenaiIRReturn(value_plan=self._opt(ir.value_plan, frame_stack))\",\n    \"87\": \"\",\n    \"88\": \"        if isinstance(ir, MenaiIRTrace):\",\n    \"89\": \"            return MenaiIRTrace(\",\n    \"90\": \"                message_plans=[self._opt(m, frame_stack) for m in ir.message_plans],\",\n    \"91\": \"                value_plan=self._opt(ir.value_plan, frame_stack),\",\n    \"92\": \"            )\",\n    \"93\": \"\",\n    \"94\": \"        if isinstance(ir, (MenaiIRConstant, MenaiIRVariable, MenaiIRQuote, MenaiIREmptyList, MenaiIRError)):\",\n    \"95\": \"            return ir\",\n    \"96\": \"\",\n    \"97\": \"        raise TypeError(f\\\"MenaiIROptimizer: unhandled IR node type {type(ir).__name__}\\\")\",\n    \"98\": \"\",\n    \"99\": \"    def _opt_let(self, ir: MenaiIRLet, frame_stack: List[int]) -> MenaiIRExpr:\",\n    \"100\": \"        \\\"\\\"\\\"Drop dead let bindings (total use count == 0).\\\"\\\"\\\"\",\n    \"101\": \"        current_frame = frame_stack[-1]\",\n    \"102\": \"        counts = cast(IRUseCounts, self._counts)\",\n    \"103\": \"\",\n    \"104\": \"        live: List[Tuple[str, MenaiIRExpr]] = []\",\n    \"105\": \"        for binding in ir.bindings:\",\n    \"106\": \"            name, value_plan, *_ = binding\",\n    \"107\": \"            if counts.total_count(current_frame, id(binding)) == 0:\",\n    \"108\": \"                self._eliminations += 1\",\n    \"109\": \"                continue\",\n    \"110\": \"            live.append((name, self._opt(value_plan, frame_stack)))\",\n    \"111\": \"\",\n    \"112\": \"        opt_body = self._opt(ir.body_plan, frame_stack)\",\n    \"113\": \"\",\n    \"114\": \"        if not live:\",\n    \"115\": \"            return opt_body\",\n    \"116\": \"\",\n    \"117\": \"        return MenaiIRLet(\",\n    \"118\": \"            bindings=live,\",\n    \"119\": \"            body_plan=opt_body,\",\n    \"120\": \"            in_tail_position=ir.in_tail_position,\",\n    \"121\": \"        )\",\n    \"122\": \"\",\n    \"123\": \"    def _opt_letrec(self, ir: MenaiIRLetrec, frame_stack: List[int]) -> MenaiIRExpr:\",\n    \"124\": \"        \\\"\\\"\\\"Drop dead letrec bindings (total use count == 0).\\\"\\\"\\\"\",\n    \"125\": \"        current_frame = frame_stack[-1]\",\n    \"126\": \"        counts = cast(IRUseCounts, self._counts)\",\n    \"127\": \"\",\n    \"128\": \"        live: List[Tuple[str, MenaiIRExpr]] = []\",\n    \"129\": \"        for binding in ir.bindings:\",\n    \"130\": \"            name, value_plan, *_ = binding\",\n    \"131\": \"            if counts.total_count(current_frame, id(binding)) == 0:\",\n    \"132\": \"                self._eliminations += 1\",\n    \"133\": \"                continue\",\n    \"134\": \"\",\n    \"135\": \"            live.append((name, self._opt(value_plan, frame_stack)))\",\n    \"136\": \"\",\n    \"137\": \"        opt_body = self._opt(ir.body_plan, frame_stack)\",\n    \"138\": \"\",\n    \"139\": \"        if not live:\",\n    \"140\": \"            return opt_body\",\n    \"141\": \"\",\n    \"142\": \"        return MenaiIRLetrec(\",\n    \"143\": \"            bindings=live,\",\n    \"144\": \"            body_plan=opt_body,\",\n    \"145\": \"            in_tail_position=ir.in_tail_position,\",\n    \"146\": \"        )\",\n    \"147\": \"\",\n    \"148\": \"    def _opt_if(self, ir: MenaiIRIf, frame_stack: List[int]) -> MenaiIRExpr:\",\n    \"149\": \"        opt_condition = self._opt(ir.condition_plan, frame_stack)\",\n    \"150\": \"        opt_then = self._opt(ir.then_plan, frame_stack)\",\n    \"151\": \"        opt_else = self._opt(ir.else_plan, frame_stack)\",\n    \"152\": \"\",\n    \"153\": \"    @staticmethod\",\n    \"154\": \"    def _unwrap_return(node: MenaiIRExpr) -> tuple[MenaiIRExpr, bool]:\",\n    \"155\": \"        \\\"\\\"\\\"Return (inner, was_wrapped) \\u2014 strips a MenaiIRReturn wrapper if present.\\\"\\\"\\\"\",\n    \"156\": \"        opt_condition = self._opt(ir.condition_plan, frame_stack)\",\n    \"157\": \"        opt_then = self._opt(ir.then_plan, frame_stack)\",\n    \"158\": \"        opt_else = self._opt(ir.else_plan, frame_stack)\",\n    \"159\": \"\",\n    \"160\": \"        # Constant-condition elimination:\",\n    \"161\": \"        #   (if #t then else)  \\u2192  then\",\n    \"162\": \"        #   (if #f then else)  \\u2192  else\",\n    \"163\": \"        if isinstance(opt_condition, MenaiIRConstant) and isinstance(opt_condition.value, MenaiBoolean):\",\n    \"164\": \"            self._eliminations += 1\",\n    \"165\": \"            if opt_condition.value.value:\",\n    \"166\": \"                return opt_then\",\n    \"167\": \"\",\n    \"168\": \"            return opt_else\",\n    \"169\": \"\",\n    \"170\": \"        # Boolean identity elimination:\",\n    \"171\": \"        #   (if <cond> #t #f)  \\u2192  <cond>\",\n    \"172\": \"        #   (if <cond> #f #t)  \\u2192  (boolean-not <cond>)\",\n    \"173\": \"        # The IR builder wraps tail-position branches in MenaiIRReturn, so we\",\n    \"174\": \"        # must look through any such wrapper before checking for boolean constants.\",\n    \"175\": \"        then_inner, then_wrapped = self._unwrap_return(opt_then)\",\n    \"176\": \"        else_inner, else_wrapped = self._unwrap_return(opt_else)\",\n    \"177\": \"        assert then_wrapped == else_wrapped, \\\"Branches must both be wrapped or both bare\\\"\",\n    \"178\": \"        if (isinstance(then_inner, MenaiIRConstant)\",\n    \"179\": \"                and isinstance(then_inner.value, MenaiBoolean)\",\n    \"180\": \"                and isinstance(else_inner, MenaiIRConstant)\",\n    \"181\": \"                and isinstance(else_inner.value, MenaiBoolean)):\",\n    \"182\": \"            if then_inner.value.value and not else_inner.value.value:\",\n    \"183\": \"                # (if cond #t #f) \\u2192  cond  (or Return(cond) in tail position)\",\n    \"184\": \"                self._eliminations += 1\",\n    \"185\": \"                if then_wrapped:\",\n    \"186\": \"                    return MenaiIRReturn(value_plan=opt_condition)\",\n    \"187\": \"                return opt_condition\",\n    \"188\": \"\",\n    \"189\": \"            if not then_inner.value.value and else_inner.value.value:\",\n    \"190\": \"                # (if cond #f #t) \\u2192 (boolean-not cond)\",\n    \"191\": \"                self._eliminations += 1\",\n    \"192\": \"                not_call = MenaiIRCall(\",\n    \"193\": \"                    func_plan=MenaiIRVariable(\",\n    \"194\": \"                            name='boolean-not', var_type='global'\",\n    \"195\": \"                    ),\",\n    \"196\": \"                    arg_plans=[opt_condition],\",\n    \"197\": \"                    is_tail_call=ir.in_tail_position,\",\n    \"198\": \"                    is_builtin=True,\",\n    \"199\": \"                    builtin_name='boolean-not',\",\n    \"200\": \"                )\",\n    \"201\": \"                if then_wrapped:\",\n    \"202\": \"                    return MenaiIRReturn(value_plan=not_call)\",\n    \"203\": \"                return not_call\",\n    \"204\": \"\",\n    \"205\": \"        return MenaiIRIf(\",\n    \"206\": \"            condition_plan=opt_condition,\",\n    \"207\": \"            then_plan=opt_then,\",\n    \"208\": \"            else_plan=opt_else,\",\n    \"209\": \"            in_tail_position=ir.in_tail_position,\",\n    \"210\": \"        )\",\n    \"211\": \"\",\n    \"212\": \"    def _opt_lambda(self, ir: MenaiIRLambda, frame_stack: List[int]) -> MenaiIRLambda:\",\n    \"213\": \"        \\\"\\\"\\\"Optimize the body of a lambda.\\\"\\\"\\\"\",\n    \"214\": \"        counts = cast(IRUseCounts, self._counts)\",\n    \"215\": \"        lambda_frame_id = counts.lambda_frame_ids.get(id(ir))\",\n    \"216\": \"        child_stack = frame_stack if lambda_frame_id is None else frame_stack + [lambda_frame_id]\",\n    \"217\": \"\",\n    \"218\": \"        return MenaiIRLambda(\",\n    \"219\": \"            params=ir.params,\",\n    \"220\": \"            body_plan=self._opt(ir.body_plan, child_stack),\",\n    \"221\": \"            sibling_free_vars=ir.sibling_free_vars,\",\n    \"222\": \"            sibling_free_var_plans=ir.sibling_free_var_plans,\",\n    \"223\": \"            outer_free_vars=ir.outer_free_vars,\",\n    \"224\": \"            outer_free_var_plans=ir.outer_free_var_plans,\",\n    \"225\": \"            param_count=ir.param_count,\",\n    \"226\": \"            is_variadic=ir.is_variadic,\",\n    \"227\": \"            binding_name=ir.binding_name,\",\n    \"228\": \"            source_line=ir.source_line,\",\n    \"229\": \"            source_file=ir.source_file,\",\n    \"230\": \"        )\",\n    \"231\": \"\",\n    \"232\": \"    def _opt_call(self, ir: MenaiIRCall, frame_stack: List[int]) -> MenaiIRCall:\",\n    \"233\": \"        \\\"\\\"\\\"Optimize the function and argument plans of a call.\\\"\\\"\\\"\",\n    \"234\": \"        return MenaiIRCall(\",\n    \"235\": \"            func_plan=self._opt(ir.func_plan, frame_stack),\",\n    \"236\": \"            arg_plans=[self._opt(a, frame_stack) for a in ir.arg_plans],\",\n    \"237\": \"            is_tail_call=ir.is_tail_call,\",\n    \"238\": \"            is_builtin=ir.is_builtin,\",\n    \"239\": \"            builtin_name=ir.builtin_name,\",\n    \"240\": \"        )\"\n  }\n}",
