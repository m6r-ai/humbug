          "content": "{\n  \"range\": \"1-80\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"Unified conversation tab implementation.\\\"\\\"\\\"\",\n    \"2\": \"\",\n    \"3\": \"import logging\",\n    \"4\": \"import os\",\n    \"5\": \"from typing import Dict, Any\",\n    \"6\": \"\",\n    \"7\": \"from PySide6.QtWidgets import (\",\n    \"8\": \"    QApplication, QHBoxLayout, QSizePolicy, QVBoxLayout, QWidget\",\n    \"9\": \")\",\n    \"10\": \"from PySide6.QtCore import QObject, Qt, Signal, QRegularExpression\",\n    \"11\": \"\",\n    \"12\": \"from ai import AIConversationHistory, AIConversationSettings\",\n    \"13\": \"from ai_transcript_conversation import AITranscriptConversation\",\n    \"14\": \"from context.context_registry import ContextRegistry\",\n    \"15\": \"from conversation_context.conversation_context import ConversationContext\",\n    \"16\": \"\",\n    \"17\": \"from desktop.ai_backend_display import get_backend_display_name\",\n    \"18\": \"from desktop.conversation_tab.conversation_settings_dialog import ConversationSettingsDialog\",\n    \"19\": \"from desktop.conversation_tab.conversation_widget import ConversationWidget\",\n    \"20\": \"from desktop.conversation_tab.conversation_message import _BORDER_INSET, _BORDER_WIDTH_ACTIVE\",\n    \"21\": \"from desktop.color_role import ColorRole\",\n    \"22\": \"from desktop.language.language_manager import LanguageManager\",\n    \"23\": \"from desktop.mindspace.mindspace_manager import MindspaceManager\",\n    \"24\": \"from desktop.status_message import StatusMessage\",\n    \"25\": \"from desktop.style_manager import StyleManager\",\n    \"26\": \"from desktop.tab import TabBase, TabState\",\n    \"27\": \"from desktop.widgets import FindWidget\",\n    \"28\": \"\",\n    \"29\": \"\",\n    \"30\": \"class ConversationTab(TabBase):\",\n    \"31\": \"    \\\"\\\"\\\"Unified conversation tab.\\\"\\\"\\\"\",\n    \"32\": \"\",\n    \"33\": \"    conversation_completed = Signal(dict)  # Signal for conversation completion\",\n    \"34\": \"\",\n    \"35\": \"    def __init__(\",\n    \"36\": \"        self,\",\n    \"37\": \"        tab_id: str,\",\n    \"38\": \"        path: str,\",\n    \"39\": \"        parent: QWidget | None = None,\",\n    \"40\": \"        ai_transcript_conversation: AITranscriptConversation | None = None\",\n    \"41\": \"    ) -> None:\",\n    \"42\": \"        \\\"\\\"\\\"\",\n    \"43\": \"        Initialize the unified conversation tab.\",\n    \"44\": \"\",\n    \"45\": \"        Args:\",\n    \"46\": \"            tab_id: Unique identifier for this tab, or a UUID will be generated if not provided.\",\n    \"47\": \"            path: Full path to transcript file\",\n    \"48\": \"            parent: Optional parent widget\",\n    \"49\": \"            ai_transcript_conversation: An existing AITranscriptConversation to adopt, or None\",\n    \"50\": \"        \\\"\\\"\\\"\",\n    \"51\": \"        super().__init__(tab_id, parent)\",\n    \"52\": \"        self._logger = logging.getLogger(\\\"ConversationTab\\\")\",\n    \"53\": \"        self._path = path\",\n    \"54\": \"        self._conversation_settings_dialog: ConversationSettingsDialog | None = None\",\n    \"55\": \"\",\n    \"56\": \"        # Create layout\",\n    \"57\": \"        layout = QVBoxLayout(self)\",\n    \"58\": \"        layout.setContentsMargins(0, 0, 0, 0)\",\n    \"59\": \"        layout.setSpacing(0)\",\n    \"60\": \"\",\n    \"61\": \"        # Add find widget at top (initially hidden)\",\n    \"62\": \"        self._find_widget = FindWidget(self)\",\n    \"63\": \"        self._find_widget.hide()\",\n    \"64\": \"        self._find_widget.set_preferred_width(self.preferred_width)\",\n    \"65\": \"        self._find_widget.closed.connect(self._close_find)\",\n    \"66\": \"        self._find_widget.search_changed.connect(self._on_search_changed)\",\n    \"67\": \"        self._find_widget.find_next.connect(lambda: self._find_next(True))\",\n    \"68\": \"        self._find_widget.find_previous.connect(lambda: self._find_next(False))\",\n    \"69\": \"        layout.addWidget(self._find_widget)\",\n    \"70\": \"\",\n    \"71\": \"        # Create conversation widget\",\n    \"72\": \"        self._conversation_widget = ConversationWidget(\",\n    \"73\": \"            path, self,\",\n    \"74\": \"            ai_transcript_conversation=ai_transcript_conversation\",\n    \"75\": \"        )\",\n    \"76\": \"        self._conversation_widget.fork_from_index_requested.connect(self.fork_from_index)\",\n    \"77\": \"        self._conversation_widget.conversation_settings_requested.connect(\",\n    \"78\": \"            self.show_conversation_settings_dialog\",\n    \"79\": \"        )\",\n    \"80\": \"        self._conversation_widget.status_updated.connect(self.update_status)\"\n  }\n}",
