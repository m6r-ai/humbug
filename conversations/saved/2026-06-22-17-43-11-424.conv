          "content": "{\n  \"range\": \"660-720\",\n  \"lines\": {\n    \"660\": \"    def apply_style(self) -> None:\",\n    \"661\": \"        \\\"\\\"\\\"Apply current style settings.\\\"\\\"\\\"\",\n    \"662\": \"        # Apply style to all content blocks\",\n    \"663\": \"        for content_block in self._content_blocks:\",\n    \"664\": \"            content_block.apply_style()\",\n    \"665\": \"\",\n    \"666\": \"    def _show_context_menu(self, pos: QPoint) -> None:\",\n    \"667\": \"        \\\"\\\"\\\"\",\n    \"668\": \"        Create and show the context menu at the given position.\",\n    \"669\": \"\",\n    \"670\": \"        Args:\",\n    \"671\": \"            pos: Local coordinates for menu position\",\n    \"672\": \"        \\\"\\\"\\\"\",\n    \"673\": \"        menu = self._style_manager.create_menu(self)\",\n    \"674\": \"        strings = self._language_manager.strings()\",\n    \"675\": \"\",\n    \"676\": \"        copy_action = menu.addAction(strings.copy)\",\n    \"677\": \"        copy_action.setEnabled(self.has_selection())\",\n    \"678\": \"        copy_action.triggered.connect(self.copy)\",\n    \"679\": \"\",\n    \"680\": \"        if self._path and os.path.isfile(self._path):\",\n    \"681\": \"            menu.addSeparator()\",\n    \"682\": \"\",\n    \"683\": \"            editor_action = menu.addAction(strings.open_in_editor)\",\n    \"684\": \"            editor_action.triggered.connect(self._open_in_editor)\",\n    \"685\": \"\",\n    \"686\": \"            if MindspaceVCSPoller().has_repo():\",\n    \"687\": \"                diff_action = menu.addAction(strings.open_in_diff)\",\n    \"688\": \"                diff_action.setEnabled(MindspaceVCSPoller().has_vcs_changes(self._path))\",\n    \"689\": \"                diff_action.triggered.connect(self._open_in_diff)\",\n    \"690\": \"\",\n    \"691\": \"        menu.exec_(self.mapToGlobal(pos))\",\n    \"692\": \"\",\n    \"693\": \"    def _open_in_editor(self) -> N