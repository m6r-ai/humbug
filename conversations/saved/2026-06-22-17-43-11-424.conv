          "content": "{\n  \"range\": \"1-80\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"\",\n    \"2\": \"Shell tab implementation for Humbug application.\",\n    \"3\": \"\",\n    \"4\": \"This tab provides a shell command interface with its own persistent history.\",\n    \"5\": \"\\\"\\\"\\\"\",\n    \"6\": \"\",\n    \"7\": \"import logging\",\n    \"8\": \"\",\n    \"9\": \"from PySide6.QtCore import QObject, QRegularExpression, Qt\",\n    \"10\": \"from PySide6.QtWidgets import QApplication, QHBoxLayout, QSizePolicy, QVBoxLayout, QWidget\",\n    \"11\": \"\",\n    \"12\": \"from desktop.language.language_manager import LanguageManager\",\n    \"13\": \"from desktop.mindspace.mindspace_manager import MindspaceManager\",\n    \"14\": \"from desktop.status_message import StatusMessage\",\n    \"15\": \"from desktop.widgets import FindWidget\",\n    \"16\": \"from desktop.shell_tab.shell_widget import ShellWidget\",\n    \"17\": \"from desktop.tab import TabBase, TabState\",\n    \"18\": \"from desktop.style_manager import StyleManager\",\n    \"19\": \"from desktop.color_role import ColorRole\",\n    \"20\": \"\",\n    \"21\": \"\",\n    \"22\": \"class ShellTab(TabBase):\",\n    \"23\": \"    \\\"\\\"\\\"\",\n    \"24\": \"    Shell tab for Humbug application showing shell command history.\",\n    \"25\": \"\",\n    \"26\": \"    This tab provides an interactive shell command interface with its own\",\n    \"27\": \"    persistent history that is separate from the system-wide message log.\",\n    \"28\": \"    \\\"\\\"\\\"\",\n    \"29\": \"\",\n    \"30\": \"    def __init__(self, tab_id: str, parent: QWidget | None = None) -> None:\",\n    \"31\": \"        \\\"\\\"\\\"\",\n    \"32\": \"        Initialize the shell tab.\",\n    \"33\": \"\",\n    \"34\": \"        Args:\",\n    \"35\": \"            tab_id: Unique identifier for this tab, or a UUID will be generated if not provided.\",\n    \"36\": \"            parent: Optional parent widget\",\n    \"37\": \"        \\\"\\\"\\\"\",\n    \"38\": \"        super().__init__(tab_id, parent)\",\n    \"39\": \"        self._logger = logging.getLogger(\\\"ShellTab\\\")\",\n    \"40\": \"        self._mindspace_manager = MindspaceManager()\",\n    \"41\": \"\",\n    \"42\": \"        # Create layout\",\n    \"43\": \"        layout = QVBoxLayout(self)\",\n    \"44\": \"        layout.setContentsMargins(0, 0, 0, 0)\",\n    \"45\": \"        layout.setSpacing(0)\",\n    \"46\": \"\",\n    \"47\": \"        # Add find widget at top (initially hidden)\",\n    \"48\": \"        self._find_widget = FindWidget(self)\",\n    \"49\": \"        self._find_widget.hide()\",\n    \"50\": \"        self._find_widget.set_preferred_width(self.preferred_width)\",\n    \"51\": \"        self._find_widget.closed.connect(self._close_find)\",\n    \"52\": \"        self._find_widget.search_changed.connect(self._on_search_changed)\",\n    \"53\": \"        self._find_widget.find_next.connect(lambda: self._find_next(True))\",\n    \"54\": \"        self._find_widget.find_previous.connect(lambda: self._find_next(False))\",\n    \"55\": \"        layout.addWidget(self._find_widget)\",\n    \"56\": \"\",\n    \"57\": \"        # Create shell widget\",\n    \"58\": \"        self._shell_widget = ShellWidget(self._tab_id, self)\",\n    \"59\": \"        self._shell_widget.status_updated.connect(self.update_status)\",\n    \"60\": \"\",\n    \"61\": \"        shell_container = QWidget()\",\n    \"62\": \"        shell_container_layout = QHBoxLayout(shell_container)\",\n    \"63\": \"        shell_container_layout.setContentsMargins(0, 0, 0, 0)\",\n    \"64\": \"        shell_container_layout.setSpacing(0)\",\n    \"65\": \"        shell_container_layout.setAlignment(Qt.AlignmentFlag.AlignHCenter)\",\n    \"66\": \"        self._shell_widget.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)\",\n    \"67\": \"        shell_container_layout.addWidget(self._shell_widget)\",\n    \"68\": \"        layout.addWidget(shell_container)\",\n    \"69\": \"\",\n    \"70\": \"        self._language_manager = LanguageManager()\",\n    \"71\": \"        self._language_manager.language_changed.connect(self._on_language_changed)\",\n    \"72\": \"        self.apply_style()\",\n    \"73\": \"\",\n    \"74\": \"    def tool_name(self) -> str:\",\n    \"75\": \"        \\\"\\\"\\\"Return the tool name for this tab type.\\\"\\\"\\\"\",\n    \"76\": \"        return \\\"shell\\\"\",\n    \"77\": \"\",\n    \"78\": \"    def tab_title_from_path(self) -> str:\",\n    \"79\": \"        \\\"\\\"\\\"Return the fixed display title for the shell tab.\\\"\\\"\\\"\",\n    \"80\": \"        return \\\"Humbug Shell\\\"\"\n  }\n}",
          "error": null
        }
      ]
