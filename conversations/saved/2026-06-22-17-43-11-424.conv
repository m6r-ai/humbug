sources\\\",\\n      \\\"type\\\": \\\"directory\\\",\\n      \\\"size\\\": null\\n    },\\n    {\\n      \\\"name\\\": \\\"resources\\\",\\n      \\\"type\\\": \\\"directory\\\",\\n      \\\"size\\\": null\\n    },\\n    {\\n      \\\"name\\\": \\\"src\\\",\\n      \\\"type\\\": \\\"directory\\\",\\n      \\\"size\\\": null\\n    },\\n    {\\n      \\\"name\\\": \\\"tests\\\",\\n      \\\"type\\\": \\\"directory\\\",\\n      \\\"size\\\": null\\n    },\\n    {\\n      \\\"name\\\": \\\"tools\\\",\\n      \\\"type\\\": \\\"directory\\\",\\n      \\\"size\\\": null\\n    },\\n    {\\n      \\\"name\\\": \\\"venv\\\",\\n      \\\"type\\\": \\\"directory\\\",\\n      \\\"size\\\": null\\n    },\\n    {\\n      \\\"name\\\": \\\".DS_Store\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 18436\\n    },\\n    {\\n      \\\"name\\\": \\\".coverage\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 163840\\n    },\\n    {\\n      \\\"name\\\": \\\".gitignore\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 700\\n    },\\n    {\\n      \\\"name\\\": \\\"AGENTS.md\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 10788\\n    },\\n    {\\n      \\\"name\\\": \\\"CHANGELOG.md\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 75269\\n    },\\n    {\\n      \\\"name\\\": \\\"CONTRIBUTING.md\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 3190\\n    },\\n    {\\n      \\\"name\\\": \\\"CONTRIBUTORS.md\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 1552\\n    },\\n    {\\n      \\\"name\\\": \\\"LICENSE.txt\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 11358\\n    },\\n    {\\n      \\\"name\\\": \\\"Makefile\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 1629\\n    },\\n    {\\n      \\\"name\\\": \\\"README.docx\\\",\\n      \\\"type\\\": \\\"file\\\",\\n      \\\"size\\\": 4816935\\n    },\\n    {\\n      \\\"name\\\": \\\"README.md\\\",\\n      \\\"t