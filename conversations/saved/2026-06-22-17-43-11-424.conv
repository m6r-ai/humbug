    \"39\": \"            tab_id: Unique identifier for this tab, or a UUID will be generated if not provided.\",\n    \"40\": \"            path: Full path to preview file\",\n    \"41\": \"            parent: Optional parent widget\",\n    \"42\": \"        \\\"\\\"\\\"\",\n    \"43\": \"        super().__init__(tab_id, parent)\",\n    \"44\": \"        self._logger = logging.getLogger(\\\"PreviewTab\\\")\",\n    \"45\": \"        self._path = path\",\n    \"46\": \"\",\n    \"47\": \"        # Create layout\",\n    \"48\": \"        layout = QVBoxLayout(self)\",\n    \"49\": \"        layout.setContentsMargins(0, 0, 0, 0)\",\n    \"50\": \"        layout.setSpacing(0)\",\n    \"51\": \"\",\n    \"52\": \"        # Add find widget at top (initially hidden)\",\n    \"53\": \"        self._find_widget = FindWidget(self)\",\n    \"54\": \"        self._find_widget.hide()\",\n    \"55\": \"        self._find_widget.set_preferred_width(self.preferred_width)\",\n    \"56\": \"        self._find_widget.closed.connect(self._close_find)\",\n    \"57\": \"        self._find_widget.search_changed.connect(self._on_search_changed)\",\n    \"58\": \"        self._find_widget.find_next.connect(lambda: self._find_next(True))\",\n    \"59\": \"        self._find_widget.find_previous.connect(lambda: self._find_next(False))\",\n    \"60\": \"        layout.addWidget(self._find_widget)\",\n    \"61\": \"\",\n    \"62\": \"        # Create preview content widget\",\n    \"63\": \"        mindspace_manager = MindspaceManager()\",\n    \"64\": \"        self._preview_content_widget = PreviewWidget(path, mindspace_manager, self)\",\n    \"65\": \"        self._preview_content_widget.status_updated.connect(self.update_status)\",\n    \"66\": \"        self._preview_content_widget.open_link.connect(self._on_open_link)\",\n    \"67\": \"        self._preview_content_widget.edit_file.connect(self._on_edit_file)\",\n    \"68\": \"\",\n    \"69\": \"        # Connect new signals for file watching\",\n    \"70\": \"        self._preview_content_widget.content_refreshed.connect(self._on_content_refreshed)\",\n    \"71\": \"\",\n    \"72\": \"        preview_container = QWidget()\",\n    \"73\": \"        preview_container_layout = QHBoxLayout(preview_container)\",\n    \"74\": \"        preview_container_layout.setContentsMargins(0, 0, 0, 0)\",\n    \"75\": \"        preview_container_layout.setSpacing(0)\",\n    \"76\": \"        preview_container_layout.setAlignment(Qt.AlignmentFlag.AlignHCenter)\",\n    \"77\": \"        self._preview_content_widget.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)\",\n    \"78\": \"        preview_container_layout.addWidget(self._preview_content_widget)\",\n    \"79\": \"        layout.addWidget(preview_container)\",\n    \"80\": \"\",\n    \"81\": \"        self._language_manager = LanguageManager()\",\n    \"82\": \"        self._language_manager.language_changed.connect(self._on_language_changed)\",\n    \"83\": \"\",\n    \"84\": \"        # Load content\",\n    \"85\": \"        self._preview_content_widget.load_content()\",\n    \"86\": \"\",\n    \"87\": \"        self._start_file_watching(self._path)\",\n    \"88\": \"        self.apply_style()\",\n    \"89\": \"\",\n    \"90\": \"    def tool_name(self) -> str:\",\n    \"91\": \"        \\\"\\\"\\\"Return the tool name for this tab type.\\\"\\\"\\\"\",\n    \"92\": \"        return \\\"preview\\\"\",\n    \"93\": \"\",\n    \"94\": \"    def register_context_models(self, registry: ContextRegistry) -> None:\",\n    \"95\": \"        \\\"\\\"\\\"Register the PreviewContext with the registry.\\\"\\\"\\\"\",\n    \"96\": \"        preview_context = PreviewContext(\",\n    \"97\": \"            context_id=self._tab_id,\",\n    \"98\": \"            path=self._path,\",\n    \"99\": \"            content_blocks=self.get_content_blocks(),\",\n    \"100\": \"            on_scroll_to_position=self.scroll_to_content_position,\",\n    \"101\": \"        )\",\n    \"102\": \"        registry.register_model(self._tab_id, preview_context)\",\n    \"103\": \"\",\n    \"104\": \"    def on_path_renamed(self, new_path: str) -> None:\",\n    \"105\": \"        \\\"\\\"\\\"Update path and emit a new tab bar label after a file rename.\\\"\\\"\\\"\",\n    \"106\": \"        self.set_path(new_path)\",\n    \"107\": \"        self.tab_label_changed.emit(self._tab_id, os.path.basename(new_path))\",\n    \"108\": \"\",\n    \"109\": \"    def set_active(self, widget: QWidget, active: bool) -> None:\",\n    \"110\": \"        \\\"\\\"\\\"\",\n    \"111\": \"        Set the active state of the tab.\",\n    \"112\": \"\",\n    \"113\": \"        Args:\",\n    \"114\": \"            widget: Widget that is being activated/deactivated\",\n    \"115\": \"            active: True if the tab is now active, False otherwise\",\n    \"116\": \"        \\\"\\\"\\\"\",\n    \"117\": \"        if active:\",\n    \"118\": \"            self.activated.emit()\",\n    \"119\": \"\",\n    \"120\": \"    def activate(self) -> None:\"\n  }\n}",
