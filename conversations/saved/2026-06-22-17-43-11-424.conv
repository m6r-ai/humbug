8\": \"        layout.addWidget(shell_container)\",\n    \"69\": \"\",\n    \"70\": \"        self._language_manager = LanguageManager()\",\n    \"71\": \"        self._language_manager.language_changed.connect(self._on_language_changed)\",\n    \"72\": \"        self.apply_style()\",\n    \"73\": \"\",\n    \"74\": \"    def tool_name(self) -> str:\",\n    \"75\": \"        \\\"\\\"\\\"Return the tool name for this tab type.\\\"\\\"\\\"\",\n    \"76\": \"        return \\\"shell\\\"\",\n    \"77\": \"\",\n    \"78\": \"    def tab_title_from_path(self) -> str:\",\n    \"79\": \"        \\\"\\\"\\\"Return the fixed display title for the shell tab.\\\"\\\"\\\"\",\n    \"80\": \"        return \\\"Humbug Shell\\\"\"\n  }\n}",
