h = \\\"\\\"\",\n    \"35\": \"\",\n    \"36\": \"        # Initialize managers\",\n    \"37\": \"        self._language_manager = LanguageManager()\",\n    \"38\": \"        self._language_manager.language_changed.connect(self._on_language_changed)\",\n    \"39\": \"        self._style_manager = StyleManager()\",\n    \"40\": \"\",\n    \"41\": \"        # Container for source content\",\n    \"42\": \"        self._content_container = QWidget(self)\",\n    \"43\": \"        self._content_container.setObjectName(\\\"_content_container\\\")\",\n    \"44\": \"        self._content_layout = QVBoxLayout(self._content_container)\",\n    \"45\": \"        spacing = int(self._style_manager.message_bubble_spacing())\",\n    \"46\": \"        self._content_layout.setSpacing(spacing)\",\n    \"47\": \"        self._content_layout.setContentsMargins(0, 0, 0, 0)\",\n    \"48\": \"        self._layout.addWidget(self._content_container)\",\n    \"49\": \"        self._layout.setSpacing(spacing)\",\n    \"50\": \"        self._layout.setContentsMargins(spacing, spacing, spacing, spacing)\"\n  }\n}",
