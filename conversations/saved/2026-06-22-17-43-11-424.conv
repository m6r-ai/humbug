\",\n    \"32\": \"    # Signal to notify tab of status changes\",\n    \"33\": \"    status_updated = Signal()\",\n    \"34\": \"\",\n    \"35\": \"    # Emits when a link is clicked\",\n    \"36\": \"    open_link = Signal(str)\",\n    \"37\": \"\",\n    \"38\": \"    # Emits when a file edit button is clicked\",\n    \"39\": \"    edit_file = Signal(str)\",\n    \"40\": \"\",\n    \"41\": \"    # Emits when content has been refreshed due to file changes\",\n    \"42\": \"    content_refreshed = Signal()\",\n    \"43\": \"\",\n    \"44\": \"    def __init__(\",\n    \"45\": \"        self,\",\n    \"46\": \"        path: str,\",\n    \"47\": \"        mindspace_manager: MindspaceManager,\",\n    \"48\": \"        parent: QWidget | None = None\",\n    \"49\": \"    ) -> None:\",\n    \"50\": \"        \\\"\\\"\\\"\",\n    \"51\": \"        Initialize the preview content widget.\",\n    \"52\": \"\",\n    \"53\": \"        Args:\",\n    \"54\": \"            path: Full path to preview file\",\n    \"55\": \"            mindspace_manager: The mindspace manager, used for path resolution\",\n    \"56\": \"                in directory listings.\",\n    \"57\": \"            parent: Optional parent widget\",\n    \"58\": \"        \\\"\\\"\\\"\",\n    \"59\": \"        super().__init__(parent)\",\n    \"60\": \"        self._logger = logging.getLogger(\\\"PreviewWidget\\\")\"\n  }\n}",
