ef = tab_pref if pref is None else max(pref, tab_pref)\\\",\\n    \\\"1920\\\": \\\"\\\",\\n    \\\"1921\\\": \\\"            col_preferred.append(pref if pref is not None else default_col_width)\\\",\\n    \\\"1922\\\": \\\"\\\",\\n    \\\"1923\\\": \\\"        total_preferred = sum(max(min_col_width, p) for p in col_preferred)\\\",\\n    \\\"1924\\\": \\\"        sizes = [min_col_width] * len(self._tab_columns)\\\",\\n    \\\"1925\\\": \\\"\\\",\\n    \\\"1926\\\": \\\"        total_preferred += self._column_splitter.handleWidth() * (len(self._tab_columns) - 1)\\\",\\n    \\\"1927\\\": \\\"\\\",\\n    \\\"1928\\\": \\\"        if total_preferred <= available:\\\",\\n    \\\"1929\\\": \\\"            # Enough room: give each column its preferred width and centre with spacers.\\\",\\n    \\\"1930\\\": \\\"            for i, p in enumerate(col_preferred):\\\",\\n    \\\"1931\\\": \\\"                sizes[i] = max(min_col_width, p)\\\",\\n    \\\"1932\\\": \\\"\\\",\\n    \\\"1933\\\": \\\"            margin = (available - total_preferred) // 2\\\",\\n    \\\"1934\\\": \\\"            self._left_spacer.setFixedWidth(margin)\\\",\\n    \\\"1935\\\": \\\"            self._right_spacer.setFixedWidth(margin)\\\",\\n    \\\"1936\\\": \\\"\\\",\\n    \\\"1937\\\": \\\"        else:\\\",\\n    \\\"1938\\\": \\\"            # Not enough room: scale proportionally, no spacers.\\\",\\n    \\\"1939\\\": \\\"            scale = available / total_preferred\\\",\\n    \\\"1940\\\": \\\"            for i, p in enumerate(col_preferred):\\\",\\n    \\\"1941\\\": \\\"                sizes[i] = max(min_col_width, math.ceil(p * scale))\\\",\\n    \\\"1942\\\": \\\"\\\",\\n    \\\"1943\\\": \\\"            self._left_spacer.setFixedWidth(0)\\\",\\n    \\\"1944\\\": \\\"            self._right_spacer.setFixedWidth(0)\\\",\\n    \\\"1945\\\": \\\"\\\",\\n    \\\"1946\\\": \\\"        self._column_splitter.setSizes(sizes)\\\",\\n    \\\"1947\\\": \\\"        self._columns_layout.invalidate()\\\"\\n  }\\n}\",\n  \"error\": null\n}\n```\n`content` is:\n```json\n{\n  \"range\": \"1895-1948\",\n  \"lines\": {\n    \"1895\": \"\",\n    \"1896\": \"    def show_all_columns(self) -> None:\",\n    \"1897\": \"        \\\"\\\"\\\"Show all columns, sizing each to its preferred width where possible.\",\n    \"1898\": \"\",\n    \"1899\": \"        Each column is sized to its preferred width. Tabs that return None from preferred_width()\",\n    \"1900\": \"        are treated as having the zoom-scaled default preferred width. If the total of all column\",\n    \"1901\": \"        widths is less than the available width, symmetric spacers centre the content.\",\n    \"1902\": \"        \\\"\\\"\\\"\",\n    \"1903\": \"        if len(self._tab_columns) == 0:\",\n    \"1904\": \"            return\",\n    \"1905\": \"\",\n    \"1906\": \"        min_col_width = 200\",\n    \"1907\": \"        style_manager = self._style_manager\",\n    \"1908\": \"        default_col_width = style_manager.scaled_tab_width()\",\n    \"1909\": \"        available = self.width()\",\n    \"1910\": \"\",\n    \"1911\": \"        # Compute each column's preferred width. Tabs returning None use the default.\",\n    \"1912\": \"        col_preferred: List[int] = []\",\n    \"1913\": \"        for column in self._tab_columns:\",\n    \"1914\": \"            pref: int | None = None\",\n    \"1915\": \"            for i in range(column.count()):\",\n    \"1916\": \"                tab = cast(TabBase, column.widget(i))\",\n    \"1917\": \"                tab_pref = tab.preferred_width()\",\n    \"1918\": \"                if tab_pref is not None:\",\n    \"1919\": \"                    pref = tab_pref if pref is None else max(pref, tab_pref)\",\n    \"1920\": \"\",\n    \"1921\": \"            col_preferred.append(pref if pref is not None else default_col_width)\",\n    \"1922\": \"\",\n    \"1923\": \"        total_preferred = sum(max(min_col_width, p) for p in col_preferred)\",\n    \"1924\": \"        sizes = [min_col_width] * len(self._tab_columns)\",\n    \"1925\": \"\",\n    \"1926\": \"        total_preferred += self._column_splitter.handleWidth() * (len(self._tab_columns) - 1)\",\n    \"1927\": \"\",\n    \"1928\": \"        if total_preferred <= available:\",\n    \"1929\": \"            # Enough room: give each column its preferred width and centre with spacers.\",\n    \"1930\": \"            for i, p in enumerate(col_preferred):\",\n    \"1931\": \"                sizes[i] = max(min_col_width, p)\",\n    \"1932\": \"\",\n    \"1933\": \"            margin = (available - total_preferred) // 2\",\n    \"1934\": \"            self._left_spacer.setFixedWidth(margin)\",\n    \"1935\": \"            self._right_spacer.setFixedWidth(margin)\",\n    \"1936\": \"\",\n    \"1937\": \"        else:\",\n    \"1938\": \"            # Not enough room: scale proportionally, no spacers.\",\n    \"1939\": \"            scale = available / total_preferred\",\n    \"1940\": \"            for i, p in enumerate(col_preferred):\",\n    \"1941\": \"                sizes[i] = max(min_col_width, math.ceil(p * scale))\",\n    \"1942\": \"\",\n    \"1943\": \"            self._left_spacer.setFixedWidth(0)\",\n    \"1944\": \"            self._right_spacer.setFixedWidth(0)\",\n    \"1945\": \"\",\n    \"1946\": \"        self._column_splitter.setSizes(sizes)\",\n    \"1947\": \"        self._columns_layout.invalidate()\"\n  }\n}\n```",
