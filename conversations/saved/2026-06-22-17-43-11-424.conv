          "name": "filesystem",
          "content": "{\n  \"range\": \"100-160\",\n  \"lines\": {\n    \"100\": \"        assert settings is not None, \\\"Settings should be available in TerminalTab\\\"\",\n    \"101\": \"        scrollback_limit = None\",\n    \"102\": \"        if settings.terminal_scrollback_enabled:\",\n    \"103\": \"            scrollback_limit = settings.terminal_scrollback_lines\",\n    \"104\": \"\",\n    \"105\": \"        minimum_width = None\",\n    \"106\": \"        if settings.terminal_fixed_width_enabled:\",\n    \"107\": \"            minimum_width = settings.terminal_fixed_width\",\n    \"108\": \"\",\n    \"109\": \"        # Create terminal process and state before the widget so the context can own them\",\n    \"110\": \"        self._terminal_process: TerminalBase = create_terminal(self._mindspace_manager.mindspace_path())\",\n    \"111\": \"        self._terminal_state = TerminalState(24, minimum_width or 80, scrollback_limit, None)\",\n    \"112\": \"\",\n    \"113\": \"        # Create layout\",\n    \"114\": \"        layout = QVBoxLayout(self)\",\n    \"115\": \"        layout.setContentsMargins(0, 0, 0, 0)\",\n    \"116\": \"        layout.setSpacing(0)\",\n    \"117\": \"\",\n    \"118\": \"        # Add find widget at top (initially hidden)\",\n    \"119\": \"        self._find_widget = FindWidget()\",\n    \"120\": \"        self._find_widget.hide()\",\n    \"121\": \"        self._find_widget.closed.connect(self._close_find)\",\n    \"122\": \"        self._find_widget.search_changed.connect(self._on_search_changed)\",\n    \"123\": \"        self._find_widget.find_next.connect(lambda: self._find_next(True))\",\n    \"124\": \"        self._find_widget.find_previous.connect(lambda: self._find_next(False))\",\n    \"125\": \"        layout.addWidget(self._find_widget)\",\n    \"126\": \"\",\n    \"127\": \"        # Create terminal widget with scrollback limit\",\n    \"128\": \"        self._terminal_widget = TerminalWidget(self, scrollback_limit, minimum_width, self._terminal_state)\",\n    \"129\": \"\",\n    \"130\": \"        # Wrap terminal widget in a centring container so the scrollbar sits\",\n    \"131\": \"        # adjacent to the content rather than at the far right of the column.\",\n    \"132\": \"        terminal_container = QWidget()\",\n    \"133\": \"        terminal_container.setObjectName(\\\"TerminalContainer\\\")\",\n    \"134\": \"        terminal_container_layout = QHBoxLayout(terminal_container)\",\n    \"135\": \"        terminal_container_layout.setContentsMargins(0, 0, 0, 0)\",\n    \"136\": \"        terminal_container_layout.setSpacing(0)\",\n    \"137\": \"        terminal_container_layout.setAlignment(Qt.AlignmentFlag.AlignHCenter)\",\n    \"138\": \"        terminal_container_layout.addWidget(self._terminal_widget)\",\n    \"139\": \"        layout.addWidget(terminal_container)\",\n    \"140\": \"\",\n    \"141\": \"        self._find_widget.set_preferred_width(self.preferred_width)\",\n    \"142\": \"\",\n    \"143\": \"        # Connect signals\",\n    \"144\": \"        self._terminal_widget.data_ready.connect(self._on_data_ready)\",\n    \"145\": \"\",\n    \"146\": \"        self._language_manager = LanguageManager()\",\n    \"147\": \"        self._language_manager.language_changed.connect(self._on_language_changed)\",\n    \"148\": \"\",\n    \"149\": \"        # Initialize process and task tracking\",\n    \"150\": \"        self._tasks: Set[asyncio.Task] = set()\",\n    \"151\": \"        self._prev_rows = 0\",\n    \"152\": \"        self._prev_cols = 0\",\n    \"153\": \"        self._win_padding_lines = 0\",\n    \"154\": \"        self._running = True\",\n    \"155\": \"        self._transferring = False\",\n    \"156\": \"\",\n    \"157\": \"        # Initialize window size handling\",\n    \"158\": \"        self._terminal_widget.size_changed.connect(self._on_terminal_size_changed)\",\n    \"159\": \"\",\n    \"160\": \"        # Build the context and register it with the mindspace\"\n  }\n}",
