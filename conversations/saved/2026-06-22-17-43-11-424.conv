              diff_action = menu.addAction(strings.open_in_diff)\\\",\\n    \\\"688\\\": \\\"                diff_action.setEnabled(MindspaceVCSPoller().has_vcs_changes(self._path))\\\",\\n    \\\"689\\\": \\\"                diff_action.triggered.connect(self._open_in_diff)\\\",\\n    \\\"690\\\": \\\"\\\",\\n    \\\"691\\\": \\\"        menu.exec_(self.mapToGlobal(pos))\\\",\\n    \\\"692\\\": \\\"\\\",\\n    \\\"693\\\": \\\"    def _open_in_editor(self) -> None:\\\",\\n    \\\"694\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Open the current file in an editor tab.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"695\\\": \\\"        contexts = MindspaceManager().mindspace().contexts()\\\",\\n    \\\"696\\\": \\\"        existing = contexts.get_by_path_and_type(self._path, \\\\\\\"editor\\\\\\\")\\\",\\n    \\\"697\\\": \\\"        if existing:\\\",\\n    \\\"698\\\": \\\"            contexts.focus(existing.context_id)\\\",\\n    \\\"699\\\": \\\"        else:\\\",\\n    \\\"700\\\": \\\"            contexts.open(\\\",\\n    \\\"701\\\": \\\"                context_type=\\\\\\\"editor\\\\\\\",\\\",\\n    \\\"702\\\": \\\"                path=self._path,\\\",\\n    \\\"703\\\": \\\"                title=os.path.basename(self._path),\\\",\\n    \\\"704\\\": \\\"            )\\\",\\n    \\\"705\\\": \\\"\\\",\\n    \\\"706\\\": \\\"    def _open_in_diff(self) -> None:\\\",\\n    \\\"707\\\": \\\"        \\\\\\\"\\\\\\\"\\\\\\\"Open the current file in a diff tab.\\\\\\\"\\\\\\\"\\\\\\\"\\\",\\n    \\\"708\\\": \\\"        contexts = MindspaceManager().mindspace().contexts()\\\",\\n    \\\"709\\\": \\\"        existing = contexts.get_by_path_and_type(self._path, \\\\\\\"diff\\\\\\\")\\\",\\n    \\\"710\\\": \\\"        if existing:\\\",\\n    \\\"711\\\": \\\"            contexts.focus(existing.context_id)\\\",\\n    \\\"712\\\": \\\"        else:\\\",\\n    \\\"713\\\": \\\"            contexts.open(\\\",\\n    \\\"714\\\": \\\"                context_type=\\\\\\\"diff\\\\\\\",\\