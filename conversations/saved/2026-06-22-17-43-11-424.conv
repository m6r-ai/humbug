          "content": "{\n  \"range\": \"740-860\",\n  \"lines\": {\n    \"740\": \"        result: Dict[str, Dict[str, str]] = {}\",\n    \"741\": \"        for role, color in self._light_custom_palette.overrides().items():\",\n    \"742\": \"            result.setdefault(role.name, {})[ColorMode.LIGHT.name] = color\",\n    \"743\": \"\",\n    \"744\": \"        for role, color in self._dark_custom_palette.overrides().items():\",\n    \"745\": \"            result.setdefault(role.name, {})[ColorMode.DARK.name] = color\",\n    \"746\": \"\",\n    \"747\": \"        return result\",\n    \"748\": \"\",\n    \"749\": \"    def zoom_factor(self) -> float:\",\n    \"750\": \"        \\\"\\\"\\\"Current zoom scaling factor.\\\"\\\"\\\"\",\n    \"751\": \"        return self._zoom_factor\",\n    \"752\": \"\",\n    \"753\": \"    def set_zoom(self, factor: float) -> None:\",\n    \"754\": \"        \\\"\\\"\\\"\",\n    \"755\": \"        Set new zoom factor and update application styles.\",\n    \"756\": \"\",\n    \"757\": \"        Clears the scaled icon cache since all icons need to be re-rendered\",\n    \"758\": \"        at the new zoom level.\",\n    \"759\": \"        \\\"\\\"\\\"\",\n    \"760\": \"        if factor != self._zoom_factor:\",\n    \"761\": \"            self._zoom_factor = factor\",\n    \"762\": \"            self._scaled_icon_cache.clear()  # Invalidate scaled icons\",\n    \"763\": \"            self.style_changed.emit()\",\n    \"764\": \"\",\n    \"765\": \"    def get_space_width(self) -> float:\",\n    \"766\": \"        \\\"\\\"\\\"Get the width of a space character\\\"\\\"\\\"\",\n    \"767\": \"        font = QFont(self._code_font_families)\",\n    \"768\": \"        if not self._font_ligatures:\",\n    \"769\": \"            font.setStyleStrategy(QFont.StyleStrategy.PreferNoShaping)\",\n    \"770\": \"\",\n    \"771\": \"        font.setPointSizeF(self.base_font_size() * self._zoom_factor)\",\n    \"772\": \"        font_metrics = QFontMetricsF(font)\",\n    \"773\": \"        space_width = font_metrics.horizontalAdvance('        ') / 8\",\n    \"774\": \"        return space_width\",\n    \"775\": \"\",\n    \"776\": \"    def base_font_pixel_height(self) -> float:\",\n    \"777\": \"        \\\"\\\"\\\"Get the pixel height of the base font at the current zoom level.\",\n    \"778\": \"\",\n    \"779\": \"        Returns the line height (ascent + descent + leading) in device pixels,\",\n    \"780\": \"        which is the quantity that gets rounded to an integer by the font rasteriser.\",\n    \"781\": \"        This is used by the zoom logic to ensure each zoom step changes the rendered\",\n    \"782\": \"        font size by at least one pixel.\",\n    \"783\": \"        \\\"\\\"\\\"\",\n    \"784\": \"        font = QFont(self._code_font_families)\",\n    \"785\": \"        font.setPointSizeF(self.base_font_size() * self._zoom_factor)\",\n    \"786\": \"        font_metrics = QFontMetricsF(font)\",\n    \"787\": \"        return font_metrics.height()\",\n    \"788\": \"\",\n    \"789\": \"    def monospace_font_families(self) -> List[str]:\",\n    \"790\": \"        \\\"\\\"\\\"Get the standard monospace font family fallback sequence.\\\"\\\"\\\"\",\n    \"791\": \"        return self._code_font_families\",\n    \"792\": \"\",\n    \"793\": \"    def make_monospace_font(self) -> QFont:\",\n    \"794\": \"        \\\"\\\"\\\"\",\n    \"795\": \"        Create a monospace QFont configured with current style settings.\",\n    \"796\": \"\",\n    \"797\": \"        Applies PreferNoShaping when font ligatures are disabled so that all\",\n    \"798\": \"        monospace widgets get consistent ligature behaviour from a single place.\",\n    \"799\": \"        \\\"\\\"\\\"\",\n    \"800\": \"        font = QFont()\",\n    \"801\": \"        font.setFamilies(self._code_font_families)\",\n    \"802\": \"        font.setFixedPitch(True)\",\n    \"803\": \"        font.setPointSizeF(self.base_font_size() * self._zoom_factor)\",\n    \"804\": \"        if not self._font_ligatures:\",\n    \"805\": \"            font.setStyleStrategy(QFont.StyleStrategy.PreferNoShaping)\",\n    \"806\": \"\",\n    \"807\": \"        return font\",\n    \"808\": \"\",\n    \"809\": \"    def make_monospace_font_no_ligatures(self) -> QFont:\",\n    \"810\": \"        \\\"\\\"\\\"\",\n    \"811\": \"        Create a monospace QFont with ligatures unconditionally disabled.\",\n    \"812\": \"\",\n    \"813\": \"        Used by the terminal, which is a character-cell renderer where ligatures\",\n    \"814\": \"        would break glyph alignment regardless of the user preference.\",\n    \"815\": \"        \\\"\\\"\\\"\",\n    \"816\": \"        font = QFont()\",\n    \"817\": \"        font.setFamilies(self._code_font_families)\",\n    \"818\": \"        font.setFixedPitch(True)\",\n    \"819\": \"        font.setPointSizeF(self.base_font_size() * self._zoom_factor)\",\n    \"820\": \"        font.setStyleStrategy(QFont.StyleStrategy.PreferNoShaping)\",\n    \"821\": \"        return font\",\n    \"822\": \"\",\n    \"823\": \"    def proportional_font_families(self) -> List[str]:\",\n    \"824\": \"        \\\"\\\"\\\"Get the standard proportional font family fallback sequence.\\\"\\\"\\\"\",\n    \"825\": \"        return self._proportional_font_families\",\n    \"826\": \"\",\n    \"827\": \"    def message_bubble_spacing(self) -> float:\",\n    \"828\": \"        \\\"\\\"\\\"Get the number of pixels to use in message bubble spacing.\\\"\\\"\\\"\",\n    \"829\": \"        return 10.0\",\n    \"830\": \"\",\n    \"831\": \"    def nice_tab_width(self) -> float:\",\n    \"832\": \"        \\\"\\\"\\\"Get the ideal width for tabs to balance information density and readability.\\\"\\\"\\\"\",\n    \"833\": \"        return 1024.0\",\n    \"834\": \"\",\n    \"835\": \"    def scale(self, value: int | float) -> int:\",\n    \"836\": \"        \\\"\\\"\\\"Scale a UI metric by the current zoom factor.\\\"\\\"\\\"\",\n    \"837\": \"        return round(value * self._zoom_factor)\",\n    \"838\": \"\",\n    \"839\": \"    def spacing(self, units: int = 1) -> int:\",\n    \"840\": \"        \\\"\\\"\\\"Get a standard spacing value.\\\"\\\"\\\"\",\n    \"841\": \"        return self.scale(4 * units)\",\n    \"842\": \"\",\n    \"843\": \"    def radius(self, size: str = \\\"control\\\") -> int:\",\n    \"844\": \"        \\\"\\\"\\\"Get a standard border radius.\\\"\\\"\\\"\",\n    \"845\": \"        match size:\",\n    \"846\": \"            case \\\"panel\\\":\",\n    \"847\": \"                return self.scale(8)\",\n    \"848\": \"\",\n    \"849\": \"            case \\\"surface\\\":\",\n    \"850\": \"                return self.scale(6)\",\n    \"851\": \"\",\n    \"852\": \"            case _:\",\n    \"853\": \"                return self.scale(4)\",\n    \"854\": \"\",\n    \"855\": \"    def control_height(self) -> int:\",\n    \"856\": \"        \\\"\\\"\\\"Get the standard interactive control height.\\\"\\\"\\\"\",\n    \"857\": \"        return self.scale(32)\",\n    \"858\": \"\",\n    \"859\": \"    def row_height(self) -> int:\",\n    \"860\": \"        \\\"\\\"\\\"Get the standard list/tree row height.\\\"\\\"\\\"\"\n  }\n}",
          "error": null
