"        \\\"\\\"\\\"\",\n    \"37\": \"        Initialize the base content widget.\",\n    \"38\": \"\",\n    \"39\": \"        Args:\",\n    \"40\": \"            parent: Optional parent widget\",\n    \"41\": \"        \\\"\\\"\\\"\",\n    \"42\": \"        super().__init__(parent)\",\n    \"43\": \"        self._logger = logging.getLogger(self.__class__.__name__)\",\n    \"44\": \"\",\n    \"45\": \"        # Set frame style\",\n    \"46\": \"        self.setFrameStyle(QFrame.Shape.Box | QFrame.Shadow.Plain)\",\n    \"47\": \"\",\n    \"48\": \"        # Initialize style manager\",\n    \"49\": \"        self._style_manager = StyleManager()\",\n    \"50\": \"\",\n    \"51\": \"        # Create layout\",\n    \"52\": \"        self._layout = QVBoxLayout(self)\",\n    \"53\": \"        self.setLayout(self._layout)\",\n    \"54\": \"        self._layout.setContentsMargins(0, 0, 0, 0)\",\n    \"55\": \"        self._layout.setSpacing(0)\",\n    \"56\": \"\",\n    \"57\": \"    def apply_style(self) -> None:\",\n    \"58\": \"        \\\"\\\"\\\"\",\n    \"59\": \"        Apply styling to this content widget.\",\n    \"60\": \"\",\n    \"61\": \"        This method is called when the application style changes, such as\",\n    \"62\": \"        when the zoom factor or color scheme is updated. Subclasses should\",\n    \"63\": \"        override this to update their specific styling.\",\n    \"64\": \"        \\\"\\\"\\\"\",\n    \"65\": \"\",\n    \"66\": \"    def has_selection(self) -> bool:\",\n    \"67\": \"        \\\"\\\"\\\"\",\n    \"68\": \"        Check if any content has selected text.\",\n    \"69\": \"\",\n    \"70\": \"        Returns:\",\n    \"71\": \"            True if there is selected text, False otherwise\",\n    \"72\": \"        \\\"\\\"\\\"\",\n    \"73\": \"        return False\",\n    \"74\": \"\",\n    \"75\": \"    def get_selected_text(self) -> str:\",\n    \"76\": \"        \\\"\\\"\\\"\",\n    \"77\": \"        Get any selected text in this content.\",\n    \"78\": \"\",\n    \"79\": \"        Returns:\",\n    \"80\": \"            Currently selected text or empty string\"\n  }\n}",
          "error": null
