elf._style_manager.style_changed.connect(self.apply_style)\",\n    \"36\": \"        self._usage_widget.refreshed.connect(self._on_widget_refreshed)\",\n    \"37\": \"        self.apply_style()\",\n    \"38\": \"\",\n    \"39\": \"    def tool_name(self) -> str:\",\n    \"40\": \"        return \\\"usage\\\"\",\n    \"41\": \"\",\n    \"42\": \"    def tab_title_from_path(self) -> str:\",\n    \"43\": \"        return \\\"Token Usage\\\"\",\n    \"44\": \"\",\n    \"45\": \"    def on_path_renamed(self, new_path: str) -> None:\",\n    \"46\": \"        pass\",\n    \"47\": \"\",\n    \"48\": \"    def set_active(self, widget: QWidget, active: bool) -> None:\",\n    \"49\": \"        if active:\",\n    \"50\": \"            self.activated.emit()\",\n    \"51\": \"\",\n    \"52\": \"    def activate(self) -> None:\",\n    \"53\": \"        self._usage_widget.refresh()\",\n    \"54\": \"\",\n    \"55\": \"    def set_path(self, path: str) -> None:\",\n    \"56\": \"        pass\",\n    \"57\": \"\",\n    \"58\": \"    def can_close_tab(self) -> bool:\",\n    \"59\": \"        return True\",\n    \"60\": \"\",\n    \"61\": \"    def close_tab(self) -> None:\",\n    \"62\": \"        pass\",\n    \"63\": \"\",\n    \"64\": \"    def can_save(self) -> bool:\",\n    \"65\": \"        return False\",\n    \"66\": \"\",\n    \"67\": \"    def save(self) -> bool:\",\n    \"68\": \"        return True\",\n    \"69\": \"\",\n    \"70\": \"    def can_save_as(self) -> bool:\",\n    \"71\": \"        return False\",\n    \"72\": \"\",\n    \"73\": \"    def save_as(self) -> bool:\",\n    \"74\": \"        return True\",\n    \"75\": \"\",\n    \"76\": \"    def can_undo(self) -> bool:\",\n    \"77\": \"        return False\",\n    \"78\": \"\",\n    \"79\": \"    def undo(self) -> None:\",\n    \"80\": \"        pass\",\n    \"81\": \"\",\n    \"82\": \"    def can_redo(self) -> bool:\",\n    \"83\": \"        return False\",\n    \"84\": \"\",\n    \"85\": \"    def redo(self) -