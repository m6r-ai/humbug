          "id": "call_451bb584e4f34eea914b1dfa",
          "name": "filesystem",
          "content": "{\n  \"range\": \"1-90\",\n  \"lines\": {\n    \"1\": \"\\\"\\\"\\\"\",\n    \"2\": \"Log tab implementation for Humbug application.\",\n    \"3\": \"\",\n    \"4\": \"This tab provides a read-only view of the mindspace message log for viewing system interactions.\",\n    \"5\": \"\\\"\\\"\\\"\",\n    \"6\": \"\",\n    \"7\": \"import logging\",\n    \"8\": \"from typing import Dict, Any\",\n    \"9\": \"\",\n    \"10\": \"from PySide6.QtWidgets import QApplication, QHBoxLayout, QSizePolicy, QVBoxLayout, QWidget\",\n    \"11\": \"from PySide6.QtCore import QObject, Qt, QRegularExpression\",\n    \"12\": \"\",\n    \"13\": \"from desktop.language.language_manager import LanguageManager\",\n    \"14\": \"from desktop.mindspace.mindspace_manager import MindspaceManager\",\n    \"15\": \"from desktop.status_message import StatusMessage\",\n    \"16\": \"from desktop.widgets import FindWidget\",\n    \"17\": \"from desktop.log_tab.log_widget import LogWidget\",\n    \"18\": \"from desktop.tab import TabBase, TabState\",\n    \"19\": \"from desktop.style_manager import StyleManager\",\n    \"20\": \"from desktop.color_role import ColorRole\",\n    \"21\": \"\",\n    \"22\": \"\",\n    \"23\": \"class LogTab(TabBase):\",\n    \"24\": \"    \\\"\\\"\\\"\",\n    \"25\": \"    Log tab for Humbug application showing mindspace message log.\",\n    \"26\": \"\",\n    \"27\": \"    This tab provides a read-only way to view the mindspace message log\",\n    \"28\": \"    that tracks system interactions and events.\",\n    \"29\": \"    \\\"\\\"\\\"\",\n    \"30\": \"\",\n    \"31\": \"    def __init__(self, tab_id: str, parent: QWidget | None = None) -> None:\",\n    \"32\": \"        \\\"\\\"\\\"\",\n    \"33\": \"        Initialize the log tab.\",\n    \"34\": \"\",\n    \"35\": \"        Args:\",\n    \"36\": \"            tab_id: Unique identifier for this tab, or a UUID will be generated if not provided.\",\n    \"37\": \"            parent: Optional parent widget\",\n    \"38\": \"        \\\"\\\"\\\"\",\n    \"39\": \"        super().__init__(tab_id, parent)\",\n    \"40\": \"        self._logger = logging.getLogger(\\\"LogTab\\\")\",\n    \"41\": \"        self._mindspace_manager = MindspaceManager()\",\n    \"42\": \"\",\n    \"43\": \"        # Create layout\",\n    \"44\": \"        layout = QVBoxLayout(self)\",\n    \"45\": \"        layout.setContentsMargins(0, 0, 0, 0)\",\n    \"46\": \"        layout.setSpacing(0)\",\n    \"47\": \"\",\n    \"48\": \"        # Add find widget at top (initially hidden)\",\n    \"49\": \"        self._find_widget = FindWidget(self)\",\n    \"50\": \"        self._find_widget.hide()\",\n    \"51\": \"        self._find_widget.set_preferred_width(self.preferred_width)\",\n    \"52\": \"        self._find_widget.closed.connect(self._close_find)\",\n    \"53\": \"        self._find_widget.search_changed.connect(self._on_search_changed)\",\n    \"54\": \"        self._find_widget.find_next.connect(lambda: self._find_next(True))\",\n    \"55\": \"        self._find_widget.find_previous.connect(lambda: self._find_next(False))\",\n    \"56\": \"        layout.addWidget(self._find_widget)\",\n    \"57\": \"\",\n    \"58\": \"        # Create log widget\",\n    \"59\": \"        self._log_widget = LogWidget(self)\",\n    \"60\": \"        self._log_widget.status_updated.connect(self.update_status)\",\n    \"61\": \"        self._log_widget.update_label.connect(self._on_update_label)\",\n    \"62\": \"        self._log_widget.has_seen_latest_update_changed.connect(self._on_has_seen_latest_update_changed)\",\n    \"63\": \"\",\n    \"64\": \"        log_container = QWidget()\",\n    \"65\": \"        log_container_layout = QHBoxLayout(log_container)\",\n    \"66\": \"        log_container_layout.setContentsMargins(0, 0, 0, 0)\",\n    \"67\": \"        log_container_layout.setSpacing(0)\",\n    \"68\": \"        log_container_layout.setAlignment(Qt.AlignmentFlag.AlignHCenter)\",\n    \"69\": \"        self._log_widget.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)\",\n    \"70\": \"        log_container_layout.addWidget(self._log_widget)\",\n    \"71\": \"        layout.addWidget(log_container)\",\n    \"72\": \"\",\n    \"73\": \"        self._language_manager = LanguageManager()\",\n    \"74\": \"        self._language_manager.language_changed.connect(self._on_language_changed)\",\n    \"75\": \"        self.apply_style()\",\n    \"76\": \"\",\n    \"77\": \"    def tool_name(self) -> str:\",\n    \"78\": \"        \\\"\\\"\\\"Return the tool name for this tab type.\\\"\\\"\\\"\",\n    \"79\": \"        return \\\"log\\\"\",\n    \"80\": \"\",\n    \"81\": \"    def tab_title_from_path(self) -> str:\",\n    \"82\": \"        \\\"\\\"\\\"Return the fixed display title for the log tab.\\\"\\\"\\\"\",\n    \"83\": \"        return \\\"Mindspace Log\\\"\",\n    \"84\": \"\",\n    \"85\": \"    def on_path_renamed(self, new_path: str) -> None:\",\n    \"86\": \"        \\\"\\\"\\\"Log tabs have no path; ignore renames.\\\"\\\"\\\"\",\n    \"87\": \"\",\n    \"88\": \"    def set_active(self, widget: QWidget, active: bool) -> None:\",\n    \"89\": \"        \\\"\\\"\\\"\",\n    \"90\": \"        Set the active state of the tab.\"\n  }\n}",
