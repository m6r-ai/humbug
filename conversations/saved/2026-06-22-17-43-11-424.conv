0-based, inclusive)\",\n    \"352\": \"            levels: List of log levels to include (trace, info, warn, error)\",\n    \"353\": \"            limit: Maximum number of messages to return\",\n    \"354\": \"            include_content: Include full message content\",\n    \"355\": \"\",\n    \"356\": \"        Returns:\",\n    \"357\": \"            Dictionary containing messages and metadata\",\n    \"358\": \"        \\\"\\\"\\\"\",\n    \"359\": \"        return self._log_widget.read_messages(\",\n    \"360\": \"            start_index, end_index, levels, limit, include_content\",\n    \"361\": \"        )\",\n    \"362\": \"\",\n    \"363\": \"    def get_message_by_id_or_index(\",\n    \"364\": \"        self,\",\n    \"365\": \"        message_id: str | None = None,\",\n    \"366\": \"        message_index: int | None = None\",\n    \"367\": \"    ) -> Dict[str, Any] | None:\",\n    \"368\": \"        \\\"\\\"\\\"\",\n    \"369\": \"        Get a specific log message by ID or index.\",\n    \"370\": \"\",\n    \"371\": \"        Args:\",\n    \"372\": \"            message_id: Message UUID\",\n    \"373\": \"            message_index: Message index (0-based)\",\n    \"374\": \"\",\n    \"375\": \"        Returns:\",\n    \"376\": \"            Message dictionary or None if not found\",\n    \"377\": \"        \\\"\\\"\\\"\",\n    \"378\": \"        return self._log_widget.get_message_by_id_or_index(message_id, message_index)\",\n    \"379\": \"\",\n    \"380\": \"    def search_messages(\",\n    \"381\": \"        self,\",\n    \"382\": \"        search_text: str,\",\n    \"383\": \"        case_sensitive: bool = False,\",\n    \"384\": \"        levels: list[str] | None = None,\",\n    \"385\": \"        max_results: int = 50\",\n    \"386\": \"    ) -> Dict[str, Any]:\",\n    \"387\": \"        \\\"\\\"\\\"Search for text across log messages.\\\"\\\"\\\"\",\n    \"388\": \"        return self._log_widget.search_messages(\",\n    \"389\": \"            search_text, case_sensitive, levels, max_results\",\n    \"390\": \"        )\",\n    \"391\": \"\",\n    \"392\": \"    def scroll_to_message(\",\n    \"393\": \"        self,\",\n    \"394\": \"        message_id: str | None = None,\",\n    \"395\": \"        message_index: int | None = None\",\n    \"396\": \"    ) -> bool:\",\n    \"397\": \"        \\\"\\\"\\\"Scroll to a specific log message.\\\"\\\"\\\"\",\n    \"398\": \"        return self._log_widget.scroll_to_message_by_id_or_index(\",\n    \"399\": \"            message_id, message_index\",\n    \"400\": \"        )\",\n    \"401\": \"\",\n    \"402\": \"    def apply_style(self) -> None:\",\n    \"403\": \"        \\\"\\\"\\\"Apply current style settings to the tab's content widgets.\\\"\\\"\\\"\",\n    \"404\": \"        self._find_widget.apply_style()\",\n    \"405\": \"        style_manager = StyleManager()\",\n    \"406\": \"        self._log_widget.setMaximumWidth(style_manager.scaled_tab_width())\",\n    \"407\": \"        self._log_widget.apply_style()\",\n    \"408\": \"\",\n    \"409\": \"        new_stylesheet = self._build_stylesheet()\",\n    \"410\": \"        if new_stylesheet != self.styleSheet():\",\n    \"411\": \"            self.setStyleSheet(new_stylesheet)\",\n    \"412\": \"\",\n    \"413\": \"    def _build_stylesheet(self) -> str:\",\n    \"414\": \"        \\\"\\\"\\\"Build the stylesheet for this tab.\\\"\\\"\\\"\",\n    \"415\": \"        style_manager = StyleManager()\"\n  }\n}",
