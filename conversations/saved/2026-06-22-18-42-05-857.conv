    {
      "id": "e1f93f1f-aa0a-4c8e-8a81-0d7b13a4fde5",
      "timestamp": "2026-06-22T18:43:38.275314+00:00",
      "type": "tool_result",
      "content": "```json\n{\n  \"id\": \"toolu_01TgosRpzUiNJNGHRsaMzjCX\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"Anthropic backend implementation.\\\"\\\"\\\"\\nfrom typing import Dict, List, Any\\n\\nimport aiohttp\\n\\nfrom ai.ai_backend import AIBackend, RequestConfig\\nfrom ai.ai_conversation_settings import AIConversationSettings\\nfrom ai.ai_conversation_history import AIConversationHistory\\nfrom ai.ai_message import AIMessage, AIMessageSource\\nfrom ai.ai_model import AIReasoningEffort\\nfrom ai.anthropic.anthropic_stream_response import AnthropicStreamResponse\\nfrom ai_tool import AIToolCall, AIToolResult, AIToolDefinition\\n\\n\\nclass AnthropicBackend(AIBackend):\\n    \\\"\\\"\\\"Anthropic API backend implementation.\\\"\\\"\\\"\\n\\n    async def fetch_models(self) -> List[str]:\\n        \\\"\\\"\\\"Fetch available model IDs from the Anthropic API.\\\"\\\"\\\"\\n        url = self._api_url.replace(\\\"/messages\\\", \\\"/models\\\")\\n        headers = {\\n            \\\"x-api-key\\\": self._api_key,\\n            \\\"anthropic-version\\\": \\\"2023-06-01\\\",\\n        }\\n        async with aiohttp.ClientSession() as session:\\n            async with session.get(url, headers=headers, ssl=self._ssl_context) as response:\\n                response.raise_for_status()\\n                data = await response.json()\\n                return [m[\\\"id\\\"] for m in data.get(\\\"data\\\", [])]\\n\\n    def _format_tool_definition(self, tool_def: AIToolDefinition) -> Dict[str, Any]:\\n        \\\"\\\"\\\"\\n        Convert tool definition to Anthropic format.\\n\\n        Args:\\n            tool_def: Generic tool definition\\n\\n        Returns:\\n            Tool definition in Anthropic format\\n        \\\"\\\"\\\"\\n        properties: Dict[str, Any] = {}\\n        required = []\\n\\n        for param in tool_def.parameters:\\n            if param.type == \\\"array\\\":\\n                properties[param.name] = {\\n                    \\\"type\\\": \\\"array\\\",\\n                    \\\"description\\\": param.description,\\n                    \\\"items\\\": {\\n                        \\\"type\\\": \\\"string\\\"  # Assuming array of strings for simplicity\\n                    }\\n                }\\n\\n            else:\\n                properties[param.name] = {\\n                    \\\"type\\\": param.type,\\n                    \\\"description\\\": param.description\\n                }\\n\\n            if param.enum:\\n                properties[param.name][\\\"enum\\\"] = param.enum\\n\\n            if param.required:\\n                required.append(param.name)\\n\\n        return {\\n            \\\"name\\\": tool_def.name,\\n            \\\"description\\\": tool_def.description,\\n            \\\"input_schema\\\": {\\n                \\\"type\\\": \\\"object\\\",\\n                \\\"properties\\\": properties,\\n                \\\"required\\\": required\\n            }\\n        }\\n\\n    def _build_user_message(self, content: str, tool_results: List[AIToolResult] | None = None) -> Dict[str, Any]:\\n        \\\"\\\"\\\"\\n        Build user message for Anthropic format.\\n\\n        Args:\\n            content: User message content\\n            tool_results: Optional tool results to include\\n\\n        Returns:\\n            User message dictionary with structured content\\n        \\\"\\\"\\\"\\n        # For Anthropic, tool results are structured content within the user message\\n        content_parts = []\\n        if tool_results:\\n            # Add tool results as structured content\\n            for tool_result in tool_results:\\n                tool_content = tool_result.content if not tool_result.error else f\\\"Error: {tool_result.error}\\\"\\n\\n                result: Dict[str, Any] = {\\n                    \\\"type\\\": \\\"tool_result\\\",\\n                    \\\"tool_use_id\\\": tool_result.id,\\n                    \\\"content\\\": tool_content\\n                }\\n\\n                if tool_result.error:\\n                    result[\\\"is_error\\\"] = True\\n\\n                content_parts.append(result)\\n\\n        # Tool results must appear before text content\\n        if content:\\n            content_parts.append({\\n                \\\"type\\\": \\\"text\\\",\\n                \\\"text\\\": content\\n            })\\n\\n        return {\\n            \\\"role\\\": \\\"user\\\",\\n            \\\"content\\\": content_parts\\n        }\\n\\n    def _build_assistant_message(\\n            self,\\n            reasoning: str,\\n            signature: str,\\n            content: str,\\n            tool_calls: List[AIToolCall] | None = None,\\n            redacted_reasoning: str | None = None\\n        ) -> Dict[str, Any]:\\n        \\\"\\\"\\\"\\n        Build assistant message for Anthropic format.\\n\\n        Args:\\n            reasoning: Reasoning content if applicable\\n            signature: Signature of the assistant on any reasoning content\\n            content: Assistant message content\\n            tool_calls: Optional tool calls made by the assistant\\n            redacted_reasoning: Optional redacted thinking data to round-trip unchanged\\n\\n        Returns:\\n            Assistant message dictionary with structured content\\n        \\\"\\\"\\\"\\n        # For Anthropic, tool calls are structured content within the assistant message\\n        if tool_calls:\\n            content_parts: List[Dict[str, Any]] = []\\n\\n            # Add reasoning content if present\\n            if reasoning:\\n                content_parts.append({\\\"type\\\": \\\"thinking\\\", \\\"thinking\\\": reasoning, \\\"signature\\\": signature})\\n\\n            # Add redacted thinking block if present \\u2014 must be passed back unchanged for multi-turn continuity\\n            if redacted_reasoning:\\n                content_parts.append({\\\"type\\\": \\\"redacted_thinking\\\", \\\"data\\\": redacted_reasoning})\\n\\n            # Add text content if present\\n            if content:\\n                content_parts.append({\\\"type\\\": \\\"text\\\", \\\"text\\\": content})\\n\\n            # Add tool calls as structured content\\n            for tool_call in tool_calls:\\n                content_parts.append({\\n                    \\\"type\\\": \\\"tool_use\\\",\\n                    \\\"id\\\": tool_call.id,\\n                    \\\"name\\\": tool_call.name,\\n                    \\\"input\\\": tool_call.arguments,\\n                })\\n\\n            return {\\n                \\\"role\\\": \\\"assistant\\\",\\n                \\\"content\\\": content_parts\\n            }\\n\\n        # Simple text message\\n        return {\\n            \\\"role\\\": \\\"assistant\\\",\\n            \\\"content\\\": content\\n        }\\n\\n    def _format_messages_for_provider(\\n        self,\\n        conversation_history: AIConversationHistory,\\n        settings: AIConversationSettings\\n    ) -> List[Dict[str, Any]]:\\n        \\\"\\\"\\\"\\n        Format conversation history for Anthropic's API format in a single pass.\\n\\n        Args:\\n            conversation_history: List of AIMessage objects\\n            settings: Current conversation settings\\n\\n        Returns:\\n            List of messages formatted for Anthropic API\\n        \\\"\\\"\\\"\\n        result: List[Dict[str, Any]] = []\\n        last_user_message_index = -1\\n        current_turn_message_index = -1\\n        last_reasoning_message: AIMessage | None = None\\n\\n        for message in conversation_history.get_messages():\\n            if message.source == AIMessageSource.TOOL_CALL:\\n                # If we don't have a pending reasoning message, we don't need to do anything\\n                if last_reasoning_message is None:\\n                    continue\\n\\n                # Create assistant message with reasoning content and tool calls\\n                signature = \\\"\\\"\\n                if last_reasoning_message and last_reasoning_message.signature:\\n                    signature = last_reasoning_message.signature\\n\\n                assistant_msg = self._build_assistant_message(\\n                    reasoning=last_reasoning_message.content,\\n                    signature=signature,\\n                    content=\\\"\\\",\\n                    tool_calls=last_reasoning_message.tool_calls,\\n                    redacted_reasoning=last_reasoning_message.redacted_reasoning,\\n                )\\n                result.append(assistant_msg)\\n                last_reasoning_message = None\\n                continue\\n\\n            if message.source == AIMessageSource.AI:\\n                # Only include completed AI messages without errors\\n                if not message.completed or message.error:\\n                    last_reasoning_message = None\\n                    continue\\n\\n                signature = \\\"\\\"\\n                if last_reasoning_message and last_reasoning_message.signature:\\n                    signature = last_reasoning_message.signature\\n\\n                assistant_msg = self._build_assistant_message(\\n                    reasoning=last_reasoning_message.content if last_reasoning_message else \\\"\\\",\\n                    signature=signature,\\n                    content=message.content if message.content else \\\"...\\\",  # Never send empty content\\n                    tool_calls=message.tool_calls,\\n                    redacted_reasoning=last_reasoning_message.redacted_reasoning if last_reasoning_message else None,\\n                )\\n                result.append(assistant_msg)\\n                last_reasoning_message = None\\n\\n                # If we have an AI message that has no tool calls then we've finished this turn\\n                if not message.tool_calls:\\n                    current_turn_message_index = -1\\n                    last_user_message_index = -1\\n\\n                continue\\n\\n            # Clear any pending reasoning message when we encounter other message types\\n            last_reasoning_message = None\\n\\n            if message.source == AIMessageSource.USER:\\n                # If we have tool results this was an auto-generated user message - it doesn't count as a turn\\n                if not message.tool_results:\\n                    # If we never finished the last turn then we need to remove it\\n                    if current_turn_message_index >= 0:\\n                        self._logger.debug(\\\"Removing unfinished turn at index %d\\\", current_turn_message_index)\\n                        result = result[:current_turn_message_index]\\n\\n                    current_turn_message_index = len(result)\\n\\n                content = self._resolve_message_content(message, conversation_history)\\n                user_msg = self._build_user_message(\\n                    content=content,\\n                    tool_results=message.tool_results\\n                )\\n                result.append(user_msg)\\n\\n                last_user_message_index = len(result) - 1\\n                continue\\n\\n            if message.source == AIMessageSource.REASONING:\\n                if not message.completed or message.error:\\n                    continue\\n\\n                if not self._reasoning_model_matches(message, settings):\\n                    continue\\n\\n                last_reasoning_message = message\\n                continue\\n\\n        # Remove anything after the last user message - we'll start with that last one\\n        assert last_user_message_index >= 0, \\\"Last user message index should be valid\\\"\\n        result = result[:last_user_message_index+1]\\n\\n        # Find the last user message and ensure it has cache control set\\n        last_user_message = result[-1]\\n        last_user_content = last_user_message[\\\"content\\\"][0]\\n        last_user_content[\\\"cache_control\\\"] = {\\\"type\\\": \\\"ephemeral\\\"}\\n\\n        return result\\n\\n    def _build_request_config(\\n        self,\\n        conversation_history: AIConversationHistory,\\n        settings: AIConversationSettings\\n    ) -> RequestConfig:\\n        \\\"\\\"\\\"Build complete request configuration for Anthropic.\\\"\\\"\\\"\\n        messages = self._format_messages_for_provider(conversation_history, settings)\\n\\n        # Build request data\\n        data = {\\n            \\\"model\\\": settings.model,\\n            \\\"messages\\\": messages,\\n            \\\"max_tokens\\\": settings.max_output_tokens,\\n            \\\"stream\\\": True\\n        }\\n\\n        # Add system prompt if configured\\n        if self._system_prompt:\\n            data[\\\"system\\\"] = [\\n                {\\n                    \\\"type\\\": \\\"text\\\",\\n                    \\\"text\\\": self._system_prompt,\\n                    \\\"cache_control\\\": {\\\"type\\\": \\\"ephemeral\\\"}\\n                }\\n            ]\\n\\n        # Add thinking configuration if VISIBLE_REASONING is enabled.  Set budget at 90% of the maximum token count.\\n        thinking = False\\n        if settings.reasoning_effort not in (None, AIReasoningEffort.NONE):\\n            thinking = True\\n            model_config = AIConversationSettings.find_by_model_and_provider(settings.model, settings.provider)\\n            if model_config and model_config.adaptive_thinking_only:\\n                # Models like Opus 4.8 and 4.7 only accept adaptive thinking; manual budget_tokens\\n                # is not supported and returns a 400 error on these models.  display defaults to\\n                # \\\"omitted\\\" on these models so we must explicitly request \\\"summarized\\\" to receive\\n                # thinking content.\\n                data[\\\"thinking\\\"] = {\\\"type\\\": \\\"adaptive\\\", \\\"display\\\": \\\"summarized\\\"}\\n                data[\\\"output_config\\\"] = {\\\"effort\\\": settings.reasoning_effort}\\n\\n            else:\\n                data[\\\"thinking\\\"] = {\\n                    \\\"type\\\": \\\"enabled\\\",\\n                    \\\"budget_tokens\\\": int(settings.max_output_tokens * 0.9)\\n                }\\n\\n        # Only include temperature if supported by model\\n        if not thinking and AIConversationSettings.supports_temperature(settings.model, settings.provider):\\n            data[\\\"temperature\\\"] = settings.temperature\\n\\n        # Add tools if supported\\n        if self._supports_tools(settings):\\n            tool_definitions = self._tool_manager.get_tool_definitions()\\n            if tool_definitions:\\n                data[\\\"tools\\\"] = [self._format_tool_definition(tool_def) for tool_def in tool_definitions]\\n                self._logger.debug(\\\"Added %d tool definitions for anthropic\\\", len(tool_definitions))\\n\\n        # Build headers\\n        headers = {\\n            \\\"content-type\\\": \\\"application/json\\\",\\n            \\\"x-api-key\\\": self._api_key,\\n            \\\"anthropic-version\\\": \\\"2023-06-01\\\"\\n        }\\n\\n        return RequestConfig(\\n            url=self._api_url,\\n            headers=headers,\\n            data=data\\n        )\\n\\n    def _create_stream_response_handler(self) -> AnthropicStreamResponse:\\n        \\\"\\\"\\\"Create an Anthropic-specific stream response handler.\\\"\\\"\\\"\\n        return AnthropicStreamResponse()\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"Anthropic backend implementation.\"\"\"\nfrom typing import Dict, List, Any\n\nimport aiohttp\n\nfrom ai.ai_backend import AIBackend, RequestConfig\nfrom ai.ai_conversation_settings import AIConversationSettings\nfrom ai.ai_conversation_history import AIConversationHistory\nfrom ai.ai_message import AIMessage, AIMessageSource\nfrom ai.ai_model import AIReasoningEffort\nfrom ai.anthropic.anthropic_stream_response import AnthropicStreamResponse\nfrom ai_tool import AIToolCall, AIToolResult, AIToolDefinition\n\n\nclass AnthropicBackend(AIBackend):\n    \"\"\"Anthropic API backend implementation.\"\"\"\n\n    async def fetch_models(self) -> List[str]:\n        \"\"\"Fetch available model IDs from the Anthropic API.\"\"\"\n        url = self._api_url.replace(\"/messages\", \"/models\")\n        headers = {\n            \"x-api-key\": self._api_key,\n            \"anthropic-version\": \"2023-06-01\",\n        }\n        async with aiohttp.ClientSession() as session:\n            async with session.get(url, headers=headers, ssl=self._ssl_context) as response:\n                response.raise_for_status()\n                data = await response.json()\n                return [m[\"id\"] for m in data.get(\"data\", [])]\n\n    def _format_tool_definition(self, tool_def: AIToolDefinition) -> Dict[str, Any]:\n        \"\"\"\n        Convert tool definition to Anthropic format.\n\n        Args:\n            tool_def: Generic tool definition\n\n        Returns:\n            Tool definition in Anthropic format\n        \"\"\"\n        properties: Dict[str, Any] = {}\n        required = []\n\n        for param in tool_def.parameters:\n            if param.type == \"array\":\n                properties[param.name] = {\n                    \"type\": \"array\",\n                    \"description\": param.description,\n                    \"items\": {\n                        \"type\": \"string\"  # Assuming array of strings for simplicity\n                    }\n                }\n\n            else:\n                properties[param.name] = {\n                    \"type\": param.type,\n                    \"description\": param.description\n                }\n\n            if param.enum:\n                properties[param.name][\"enum\"] = param.enum\n\n            if param.required:\n                required.append(param.name)\n\n        return {\n            \"name\": tool_def.name,\n            \"description\": tool_def.description,\n            \"input_schema\": {\n                \"type\": \"object\",\n                \"properties\": properties,\n                \"required\": required\n            }\n        }\n\n    def _build_user_message(self, content: str, tool_results: List[AIToolResult] | None = None) -> Dict[str, Any]:\n        \"\"\"\n        Build user message for Anthropic format.\n\n        Args:\n            content: User message content\n            tool_results: Optional tool results to include\n\n        Returns:\n            User message dictionary with structured content\n        \"\"\"\n        # For Anthropic, tool results are structured content within the user message\n        content_parts = []\n        if tool_results:\n            # Add tool results as structured content\n            for tool_result in tool_results:\n                tool_content = tool_result.content if not tool_result.error else f\"Error: {tool_result.error}\"\n\n                result: Dict[str, Any] = {\n                    \"type\": \"tool_result\",\n                    \"tool_use_id\": tool_result.id,\n                    \"content\": tool_content\n                }\n\n                if tool_result.error:\n                    result[\"is_error\"] = True\n\n                content_parts.append(result)\n\n        # Tool results must appear before text content\n        if content:\n            content_parts.append({\n                \"type\": \"text\",\n                \"text\": content\n            })\n\n        return {\n            \"role\": \"user\",\n            \"content\": content_parts\n        }\n\n    def _build_assistant_message(\n            self,\n            reasoning: str,\n            signature: str,\n            content: str,\n            tool_calls: List[AIToolCall] | None = None,\n            redacted_reasoning: str | None = None\n        ) -> Dict[str, Any]:\n        \"\"\"\n        Build assistant message for Anthropic format.\n\n        Args:\n            reasoning: Reasoning content if applicable\n            signature: Signature of the assistant on any reasoning content\n            content: Assistant message content\n            tool_calls: Optional tool calls made by the assistant\n            redacted_reasoning: Optional redacted thinking data to round-trip unchanged\n\n        Returns:\n            Assistant message dictionary with structured content\n        \"\"\"\n        # For Anthropic, tool calls are structured content within the assistant message\n        if tool_calls:\n            content_parts: List[Dict[str, Any]] = []\n\n            # Add reasoning content if present\n            if reasoning:\n                content_parts.append({\"type\": \"thinking\", \"thinking\": reasoning, \"signature\": signature})\n\n            # Add redacted thinking block if present \u2014 must be passed back unchanged for multi-turn continuity\n            if redacted_reasoning:\n                content_parts.append({\"type\": \"redacted_thinking\", \"data\": redacted_reasoning})\n\n            # Add text content if present\n            if content:\n                content_parts.append({\"type\": \"text\", \"text\": content})\n\n            # Add tool calls as structured content\n            for tool_call in tool_calls:\n                content_parts.append({\n                    \"type\": \"tool_use\",\n                    \"id\": tool_call.id,\n                    \"name\": tool_call.name,\n                    \"input\": tool_call.arguments,\n                })\n\n            return {\n                \"role\": \"assistant\",\n                \"content\": content_parts\n            }\n\n        # Simple text message\n        return {\n            \"role\": \"assistant\",\n            \"content\": content\n        }\n\n    def _format_messages_for_provider(\n        self,\n        conversation_history: AIConversationHistory,\n        settings: AIConversationSettings\n    ) -> List[Dict[str, Any]]:\n        \"\"\"\n        Format conversation history for Anthropic's API format in a single pass.\n\n        Args:\n            conversation_history: List of AIMessage objects\n            settings: Current conversation settings\n\n        Returns:\n            List of messages formatted for Anthropic API\n        \"\"\"\n        result: List[Dict[str, Any]] = []\n        last_user_message_index = -1\n        current_turn_message_index = -1\n        last_reasoning_message: AIMessage | None = None\n\n        for message in conversation_history.get_messages():\n            if message.source == AIMessageSource.TOOL_CALL:\n                # If we don't have a pending reasoning message, we don't need to do anything\n                if last_reasoning_message is None:\n                    continue\n\n                # Create assistant message with reasoning content and tool calls\n                signature = \"\"\n                if last_reasoning_message and last_reasoning_message.signature:\n                    signature = last_reasoning_message.signature\n\n                assistant_msg = self._build_assistant_message(\n                    reasoning=last_reasoning_message.content,\n                    signature=signature,\n                    content=\"\",\n                    tool_calls=last_reasoning_message.tool_calls,\n                    redacted_reasoning=last_reasoning_message.redacted_reasoning,\n                )\n                result.append(assistant_msg)\n                last_reasoning_message = None\n                continue\n\n            if message.source == AIMessageSource.AI:\n                # Only include completed AI messages without errors\n                if not message.completed or message.error:\n                    last_reasoning_message = None\n                    continue\n\n                signature = \"\"\n                if last_reasoning_message and last_reasoning_message.signature:\n                    signature = last_reasoning_message.signature\n\n                assistant_msg = self._build_assistant_message(\n                    reasoning=last_reasoning_message.content if last_reasoning_message else \"\",\n                    signature=signature,\n                    content=message.content if message.content else \"...\",  # Never send empty content\n                    tool_calls=message.tool_calls,\n                    redacted_reasoning=last_reasoning_message.redacted_reasoning if last_reasoning_message else None,\n                )\n                result.append(assistant_msg)\n                last_reasoning_message = None\n\n                # If we have an AI message that has no tool calls then we've finished this turn\n                if not message.tool_calls:\n                    current_turn_message_index = -1\n                    last_user_message_index = -1\n\n                continue\n\n            # Clear any pending reasoning message when we encounter other message types\n            last_reasoning_message = None\n\n            if message.source == AIMessageSource.USER:\n                # If we have tool results this was an auto-generated user message - it doesn't count as a turn\n                if not message.tool_results:\n                    # If we never finished the last turn then we need to remove it\n                    if current_turn_message_index >= 0:\n                        self._logger.debug(\"Removing unfinished turn at index %d\", current_turn_message_index)\n                        result = result[:current_turn_message_index]\n\n                    current_turn_message_index = len(result)\n\n                content = self._resolve_message_content(message, conversation_history)\n                user_msg = self._build_user_message(\n                    content=content,\n                    tool_results=message.tool_results\n                )\n                result.append(user_msg)\n\n                last_user_message_index = len(result) - 1\n                continue\n\n            if message.source == AIMessageSource.REASONING:\n                if not message.completed or message.error:\n                    continue\n\n                if not self._reasoning_model_matches(message, settings):\n                    continue\n\n                last_reasoning_message = message\n                continue\n\n        # Remove anything after the last user message - we'll start with that last one\n        assert last_user_message_index >= 0, \"Last user message index should be valid\"\n        result = result[:last_user_message_index+1]\n\n        # Find the last user message and ensure it has cache control set\n        last_user_message = result[-1]\n        last_user_content = last_user_message[\"content\"][0]\n        last_user_content[\"cache_control\"] = {\"type\": \"ephemeral\"}\n\n        return result\n\n    def _build_request_config(\n        self,\n        conversation_history: AIConversationHistory,\n        settings: AIConversationSettings\n    ) -> RequestConfig:\n        \"\"\"Build complete request configuration for Anthropic.\"\"\"\n        messages = self._format_messages_for_provider(conversation_history, settings)\n\n        # Build request data\n        data = {\n            \"model\": settings.model,\n            \"messages\": messages,\n            \"max_tokens\": settings.max_output_tokens,\n            \"stream\": True\n        }\n\n        # Add system prompt if configured\n        if self._system_prompt:\n            data[\"system\"] = [\n                {\n                    \"type\": \"text\",\n                    \"text\": self._system_prompt,\n                    \"cache_control\": {\"type\": \"ephemeral\"}\n                }\n            ]\n\n        # Add thinking configuration if VISIBLE_REASONING is enabled.  Set budget at 90% of the maximum token count.\n        thinking = False\n        if settings.reasoning_effort not in (None, AIReasoningEffort.NONE):\n            thinking = True\n            model_config = AIConversationSettings.find_by_model_and_provider(settings.model, settings.provider)\n            if model_config and model_config.adaptive_thinking_only:\n                # Models like Opus 4.8 and 4.7 only accept adaptive thinking; manual budget_tokens\n                # is not supported and returns a 400 error on these models.  display defaults to\n                # \"omitted\" on these models so we must explicitly request \"summarized\" to receive\n                # thinking content.\n                data[\"thinking\"] = {\"type\": \"adaptive\", \"display\": \"summarized\"}\n                data[\"output_config\"] = {\"effort\": settings.reasoning_effort}\n\n            else:\n                data[\"thinking\"] = {\n                    \"type\": \"enabled\",\n                    \"budget_tokens\": int(settings.max_output_tokens * 0.9)\n                }\n\n        # Only include temperature if supported by model\n        if not thinking and AIConversationSettings.supports_temperature(settings.model, settings.provider):\n            data[\"temperature\"] = settings.temperature\n\n        # Add tools if supported\n        if self._supports_tools(settings):\n            tool_definitions = self._tool_manager.get_tool_definitions()\n            if tool_definitions:\n                data[\"tools\"] = [self._format_tool_definition(tool_def) for tool_def in tool_definitions]\n                self._logger.debug(\"Added %d tool definitions for anthropic\", len(tool_definitions))\n\n        # Build headers\n        headers = {\n            \"content-type\": \"application/json\",\n            \"x-api-key\": self._api_key,\n            \"anthropic-version\": \"2023-06-01\"\n        }\n\n        return RequestConfig(\n            url=self._api_url,\n            headers=headers,\n            data=data\n        )\n\n    def _create_stream_response_handler(self) -> AnthropicStreamResponse:\n        \"\"\"Create an Anthropic-specific stream response handler.\"\"\"\n        return AnthropicStreamResponse()\n\n```",
