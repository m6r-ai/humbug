      "content": "```json\n{\n  \"id\": \"toolu_01KfKTwhHjBU9USpeXLqusiA\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"Handles streaming response from xAI API.\\\"\\\"\\\"\\n\\nimport json\\nfrom typing import Dict\\n\\nfrom ai.ai_stream_response import AIStreamResponse\\nfrom ai_tool import AIToolCall\\n\\n\\nclass XAIStreamResponse(AIStreamResponse):\\n    \\\"\\\"\\\"Handles streaming response from xAI API.\\\"\\\"\\\"\\n\\n    def __init__(self) -> None:\\n        \\\"\\\"\\\"Initialize stream response handler.\\\"\\\"\\\"\\n        super().__init__()\\n\\n        # Track streaming tool calls\\n        self._current_tool_calls: Dict[str, Dict] = {}\\n\\n    def _handle_choices(self, choices: Dict) -> None:\\n        \\\"\\\"\\\"\\n        Handle choices from the xAI API response.\\n\\n        Args:\\n            choices: Choices from xAI API response\\n        \\\"\\\"\\\"\\n        if not choices:\\n            return\\n\\n        delta = choices[0].get(\\\"delta\\\", {})\\n        if \\\"reasoning_content\\\" in delta:\\n            new_reasoning = delta[\\\"reasoning_content\\\"]\\n            if new_reasoning:\\n                self.reasoning += new_reasoning\\n\\n        if \\\"content\\\" in delta:\\n            new_content = delta[\\\"content\\\"]\\n            if new_content:\\n                self.content += new_content\\n\\n        if \\\"tool_calls\\\" in delta:\\n            tool_calls = delta[\\\"tool_calls\\\"]\\n            for tool_call_delta in tool_calls:\\n                tool_call_index = tool_call_delta.get(\\\"index\\\", -1)\\n                if tool_call_index == -1:\\n                    continue\\n\\n                tool_call_id = tool_call_delta.get(\\\"id\\\", \\\"\\\")\\n\\n                # Initialize tool call if we haven't seen it before\\n                if tool_call_index not in self._current_tool_calls:\\n                    self._current_tool_calls[tool_call_index] = {\\n                        \\\"index\\\": tool_call_index,\\n                        \\\"id\\\": tool_call_id,\\n                        \\\"name\\\": \\\"\\\",\\n                        \\\"arguments\\\": \\\"\\\"\\n                    }\\n\\n                current_call = self._current_tool_calls[tool_call_index]\\n\\n                # Update function name if provided\\n                function = tool_call_delta.get(\\\"function\\\", {})\\n                if \\\"name\\\" in function:\\n                    current_call[\\\"name\\\"] = function[\\\"name\\\"]\\n\\n                # Accumulate arguments if provided\\n                if \\\"arguments\\\" in function:\\n                    current_call[\\\"arguments\\\"] += function[\\\"arguments\\\"]\\n\\n    def _handle_usage(self, usage: Dict) -> None:\\n        \\\"\\\"\\\"\\n        Handle usage data from the xAI API response.\\n\\n        Args:\\n            usage: Usage data from xAI API response\\n        \\\"\\\"\\\"\\n        if not usage:\\n            return\\n\\n        self._update_usage(\\n            prompt_tokens=usage.get(\\\"prompt_tokens\\\", 0),\\n            completion_tokens=usage.get(\\\"completion_tokens\\\", 0),\\n            total_tokens=usage.get(\\\"total_tokens\\\", 0)\\n        )\\n\\n        # Process all accumulated tool calls\\n        for call_data in self._current_tool_calls.values():\\n            # Create the tool call\\n            json_args = {}\\n            try:\\n                if call_data[\\\"arguments\\\"]:\\n                    json_args = json.loads(call_data[\\\"arguments\\\"])\\n\\n            except json.JSONDecodeError as e:\\n                self._logger.warning(\\\"Failed to parse tool arguments: %s (%s)\\\", call_data[\\\"arguments\\\"], str(e))\\n\\n            tool_call = AIToolCall(\\n                id=call_data[\\\"id\\\"],\\n                name=call_data[\\\"name\\\"],\\n                arguments=json_args\\n            )\\n\\n            # Add to our tool calls list\\n            self._add_tool_call(tool_call)\\n\\n    def update_from_chunk(self, chunk: Dict) -> None:\\n        \\\"\\\"\\\"\\n        Update from a response chunk and return new content if any.\\n\\n        Args:\\n            chunk: Response chunk from xAI API\\n        \\\"\\\"\\\"\\n        if \\\"error\\\" in chunk:\\n            self._handle_error(chunk[\\\"error\\\"])\\n            return\\n\\n        if \\\"choices\\\" in chunk:\\n            self._handle_choices(chunk[\\\"choices\\\"])\\n\\n        if \\\"usage\\\" in chunk:\\n            self._handle_usage(chunk[\\\"usage\\\"])\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"Handles streaming response from xAI API.\"\"\"\n\nimport json\nfrom typing import Dict\n\nfrom ai.ai_stream_response import AIStreamResponse\nfrom ai_tool import AIToolCall\n\n\nclass XAIStreamResponse(AIStreamResponse):\n    \"\"\"Handles streaming response from xAI API.\"\"\"\n\n    def __init__(self) -> None:\n        \"\"\"Initialize stream response handler.\"\"\"\n        super().__init__()\n\n        # Track streaming tool calls\n        self._current_tool_calls: Dict[str, Dict] = {}\n\n    def _handle_choices(self, choices: Dict) -> None:\n        \"\"\"\n        Handle choices from the xAI API response.\n\n        Args:\n            choices: Choices from xAI API response\n        \"\"\"\n        if not choices:\n            return\n\n        delta = choices[0].get(\"delta\", {})\n        if \"reasoning_content\" in delta:\n            new_reasoning = delta[\"reasoning_content\"]\n            if new_reasoning:\n                self.reasoning += new_reasoning\n\n        if \"content\" in delta:\n            new_content = delta[\"content\"]\n            if new_content:\n                self.content += new_content\n\n        if \"tool_calls\" in delta:\n            tool_calls = delta[\"tool_calls\"]\n            for tool_call_delta in tool_calls:\n                tool_call_index = tool_call_delta.get(\"index\", -1)\n                if tool_call_index == -1:\n                    continue\n\n                tool_call_id = tool_call_delta.get(\"id\", \"\")\n\n                # Initialize tool call if we haven't seen it before\n                if tool_call_index not in self._current_tool_calls:\n                    self._current_tool_calls[tool_call_index] = {\n                        \"index\": tool_call_index,\n                        \"id\": tool_call_id,\n                        \"name\": \"\",\n                        \"arguments\": \"\"\n                    }\n\n                current_call = self._current_tool_calls[tool_call_index]\n\n                # Update function name if provided\n                function = tool_call_delta.get(\"function\", {})\n                if \"name\" in function:\n                    current_call[\"name\"] = function[\"name\"]\n\n                # Accumulate arguments if provided\n                if \"arguments\" in function:\n                    current_call[\"arguments\"] += function[\"arguments\"]\n\n    def _handle_usage(self, usage: Dict) -> None:\n        \"\"\"\n        Handle usage data from the xAI API response.\n\n        Args:\n            usage: Usage data from xAI API response\n        \"\"\"\n        if not usage:\n            return\n\n        self._update_usage(\n            prompt_tokens=usage.get(\"prompt_tokens\", 0),\n            completion_tokens=usage.get(\"completion_tokens\", 0),\n            total_tokens=usage.get(\"total_tokens\", 0)\n        )\n\n        # Process all accumulated tool calls\n        for call_data in self._current_tool_calls.values():\n            # Create the tool call\n            json_args = {}\n            try:\n                if call_data[\"arguments\"]:\n                    json_args = json.loads(call_data[\"arguments\"])\n\n            except json.JSONDecodeError as e:\n                self._logger.warning(\"Failed to parse tool arguments: %s (%s)\", call_data[\"arguments\"], str(e))\n\n            tool_call = AIToolCall(\n                id=call_data[\"id\"],\n                name=call_data[\"name\"],\n                arguments=json_args\n            )\n\n            # Add to our tool calls list\n            self._add_tool_call(tool_call)\n\n    def update_from_chunk(self, chunk: Dict) -> None:\n        \"\"\"\n        Update from a response chunk and return new content if any.\n\n        Args:\n            chunk: Response chunk from xAI API\n        \"\"\"\n        if \"error\" in chunk:\n            self._handle_error(chunk[\"error\"])\n            return\n\n        if \"choices\" in chunk:\n            self._handle_choices(chunk[\"choices\"])\n\n        if \"usage\" in chunk:\n            self._handle_usage(chunk[\"usage\"])\n\n```",
