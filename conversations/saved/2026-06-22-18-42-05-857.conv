      "content": "```json\n{\n  \"id\": \"toolu_01Daff8cGqwrT2TQwx2nAKBD\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"Handles streaming response from Google Gemini API.\\\"\\\"\\\"\\n\\nfrom typing import Dict\\n\\nfrom ai.ai_stream_response import AIStreamResponse\\nfrom ai_tool import AIToolCall\\n\\n\\nclass GoogleStreamResponse(AIStreamResponse):\\n    \\\"\\\"\\\"Handles streaming response from Google Gemini API.\\\"\\\"\\\"\\n\\n    def __init__(self) -> None:\\n        \\\"\\\"\\\"Initialize stream response handler.\\\"\\\"\\\"\\n        super().__init__()\\n\\n        # Track streaming tool calls\\n        self._current_tool_calls: Dict[str, Dict] = {}\\n\\n    def _handle_candidates(self, chunk: Dict) -> None:\\n        # Extract text content and function calls\\n        candidate = chunk[\\\"candidates\\\"][0]\\n        if \\\"content\\\" in candidate and \\\"parts\\\" in candidate[\\\"content\\\"]:\\n            for part in candidate[\\\"content\\\"][\\\"parts\\\"]:\\n                # Handle text content\\n                if \\\"text\\\" in part:\\n                    text = part[\\\"text\\\"]\\n                    if text:\\n                        if part.get(\\\"thought\\\"):\\n                            self.reasoning += text\\n\\n                        else:\\n                            self.content += text\\n\\n                # Handle function calls\\n                if \\\"functionCall\\\" in part:\\n                    function_call = part[\\\"functionCall\\\"]\\n                    function_name = function_call.get(\\\"name\\\", \\\"\\\")\\n                    function_args = function_call.get(\\\"args\\\", {})\\n\\n                    if not function_name:\\n                        return\\n\\n                    # Use function name as key since Google doesn't provide call IDs in streaming\\n                    call_key = function_name\\n\\n                    # Store the complete function call\\n                    self._current_tool_calls[call_key] = {\\n                        \\\"name\\\": function_name,\\n                        \\\"arguments\\\": function_args\\n                    }\\n\\n                # Handle thought signatures\\n                if \\\"thoughtSignature\\\" in part:\\n                    self.redacted_reasoning = part[\\\"thoughtSignature\\\"]\\n\\n        # Check for completion reason and process usage\\n        if candidate.get(\\\"finishReason\\\") == \\\"STOP\\\" and \\\"usageMetadata\\\" in chunk:\\n            metadata = chunk[\\\"usageMetadata\\\"]\\n            self._update_usage(\\n                prompt_tokens=metadata.get(\\\"promptTokenCount\\\", 0),\\n                completion_tokens=metadata.get(\\\"candidatesTokenCount\\\", 0),\\n                total_tokens=metadata.get(\\\"totalTokenCount\\\", 0)\\n            )\\n\\n            # Process all accumulated tool calls\\n            if self._current_tool_calls:\\n                for i, (call_key, call_data) in enumerate(self._current_tool_calls.items()):\\n                    # Generate a unique ID for the tool call\\n                    tool_call_id = f\\\"call_{i}\\\"\\n\\n                    tool_call = AIToolCall(\\n                        id=tool_call_id,\\n                        name=call_data[\\\"name\\\"],\\n                        arguments=call_data[\\\"arguments\\\"]\\n                    )\\n\\n                    # Add to our tool calls list\\n                    self._add_tool_call(tool_call)\\n\\n    def update_from_chunk(self, chunk: Dict) -> None:\\n        \\\"\\\"\\\"\\n        Update from a response chunk and return new content if any.\\n\\n        Args:\\n            chunk: Response chunk from Google API\\n        \\\"\\\"\\\"\\n        if \\\"error\\\" in chunk:\\n            error_data = chunk[\\\"error\\\"]\\n            self._handle_error(error_data)\\n            return\\n\\n        if \\\"candidates\\\" in chunk and chunk[\\\"candidates\\\"]:\\n            self._handle_candidates(chunk)\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"Handles streaming response from Google Gemini API.\"\"\"\n\nfrom typing import Dict\n\nfrom ai.ai_stream_response import AIStreamResponse\nfrom ai_tool import AIToolCall\n\n\nclass GoogleStreamResponse(AIStreamResponse):\n    \"\"\"Handles streaming response from Google Gemini API.\"\"\"\n\n    def __init__(self) -> None:\n        \"\"\"Initialize stream response handler.\"\"\"\n        super().__init__()\n\n        # Track streaming tool calls\n        self._current_tool_calls: Dict[str, Dict] = {}\n\n    def _handle_candidates(self, chunk: Dict) -> None:\n        # Extract text content and function calls\n        candidate = chunk[\"candidates\"][0]\n        if \"content\" in candidate and \"parts\" in candidate[\"content\"]:\n            for part in candidate[\"content\"][\"parts\"]:\n                # Handle text content\n                if \"text\" in part:\n                    text = part[\"text\"]\n                    if text:\n                        if part.get(\"thought\"):\n                            self.reasoning += text\n\n                        else:\n                            self.content += text\n\n                # Handle function calls\n                if \"functionCall\" in part:\n                    function_call = part[\"functionCall\"]\n                    function_name = function_call.get(\"name\", \"\")\n                    function_args = function_call.get(\"args\", {})\n\n                    if not function_name:\n                        return\n\n                    # Use function name as key since Google doesn't provide call IDs in streaming\n                    call_key = function_name\n\n                    # Store the complete function call\n                    self._current_tool_calls[call_key] = {\n                        \"name\": function_name,\n                        \"arguments\": function_args\n                    }\n\n                # Handle thought signatures\n                if \"thoughtSignature\" in part:\n                    self.redacted_reasoning = part[\"thoughtSignature\"]\n\n        # Check for completion reason and process usage\n        if candidate.get(\"finishReason\") == \"STOP\" and \"usageMetadata\" in chunk:\n            metadata = chunk[\"usageMetadata\"]\n            self._update_usage(\n                prompt_tokens=metadata.get(\"promptTokenCount\", 0),\n                completion_tokens=metadata.get(\"candidatesTokenCount\", 0),\n                total_tokens=metadata.get(\"totalTokenCount\", 0)\n            )\n\n            # Process all accumulated tool calls\n            if self._current_tool_calls:\n                for i, (call_key, call_data) in enumerate(self._current_tool_calls.items()):\n                    # Generate a unique ID for the tool call\n                    tool_call_id = f\"call_{i}\"\n\n                    tool_call = AIToolCall(\n                        id=tool_call_id,\n                        name=call_data[\"name\"],\n                        arguments=call_data[\"arguments\"]\n                    )\n\n                    # Add to our tool calls list\n                    self._add_tool_call(tool_call)\n\n    def update_from_chunk(self, chunk: Dict) -> None:\n        \"\"\"\n        Update from a response chunk and return new content if any.\n\n        Args:\n            chunk: Response chunk from Google API\n        \"\"\"\n        if \"error\" in chunk:\n            error_data = chunk[\"error\"]\n            self._handle_error(error_data)\n            return\n\n        if \"candidates\" in chunk and chunk[\"candidates\"]:\n            self._handle_candidates(chunk)\n\n```",
