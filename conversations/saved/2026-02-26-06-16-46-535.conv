    {
      "id": "dcc8afb4-3779-4c44-a48d-8ad76c944e74",
      "timestamp": "2026-02-26T10:53:02.246405+00:00",
      "type": "tool_result",
      "content": "```json\n{\n  \"id\": \"toolu_0172k8xbwXf9ThqzGU7y2Ccv\",\n  \"name\": \"filesystem\",\n  \"content\": \"\\\"\\\"\\\"AIFPL Value hierarchy - immutable runtime value types.\\n\\nThese are lightweight runtime values used by the VM and bytecode.\\nThey do NOT carry source location metadata - that's only in AIFPLASTNode.\\nThis separation keeps runtime values fast and memory-efficient.\\n\\\"\\\"\\\"\\n\\nfrom abc import ABC, abstractmethod\\nfrom dataclasses import dataclass, field\\nfrom typing import Any, List, Tuple\\n\\nfrom aifpl.aifpl_error import AIFPLEvalError\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLValue(ABC):\\n    \\\"\\\"\\\"\\n    Abstract base class for all AIFPL runtime values.\\n\\n    All runtime values are immutable and lightweight (no metadata).\\n    \\\"\\\"\\\"\\n\\n    @abstractmethod\\n    def to_python(self) -> Any:\\n        \\\"\\\"\\\"Convert to Python value for operations.\\\"\\\"\\\"\\n\\n    @abstractmethod\\n    def type_name(self) -> str:\\n        \\\"\\\"\\\"Return AIFPL type name for error messages.\\\"\\\"\\\"\\n\\n    @abstractmethod\\n    def describe(self) -> str:\\n        \\\"\\\"\\\"Describe the value.\\\"\\\"\\\"\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLSymbol(AIFPLValue):\\n    \\\"\\\"\\\"Represents symbols that require environment lookup.\\\"\\\"\\\"\\n    name: str\\n\\n    def to_python(self) -> str:\\n        \\\"\\\"\\\"Symbols convert to their name string.\\\"\\\"\\\"\\n        return self.name\\n\\n    def type_name(self) -> str:\\n        return \\\"symbol\\\"\\n\\n    def describe(self) -> str:\\n        return self.name\\n\\n    def __str__(self) -> str:\\n        return self.name\\n\\n    def __repr__(self) -> str:\\n        return f'AIFPLSymbol({self.name!r})'\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLFunction(AIFPLValue):\\n    \\\"\\\"\\\"\\n    Represents a function (both user-defined lambdas and builtins).\\n\\n    This is a first-class value that can be passed around as a value.\\n    \\\"\\\"\\\"\\n    parameters: Tuple[str, ...]\\n    name: str | None = None\\n    bytecode: Any = None  # CodeObject for bytecode-compiled functions\\n    captured_values: Tuple[Any, ...] = ()  # Captured free variables for closures\\n    is_variadic: bool = False  # True if function accepts variable number of args\\n    parent_frame: Any = None  # Parent frame for LOAD_PARENT_VAR (lexical parent)\\n\\n    def to_python(self) -> 'AIFPLFunction | str':\\n        \\\"\\\"\\\"Functions return themselves (or their name for builtins as string).\\\"\\\"\\\"\\n        return self\\n\\n    def type_name(self) -> str:\\n        return \\\"function\\\"\\n\\n    def describe(self) -> str:\\n        \\\"\\\"\\\"Return a human-readable description of this function.\\\"\\\"\\\"\\n        param_str = ', '.join(self.parameters)\\n        if self.is_variadic and len(self.parameters) > 0:\\n            # Last parameter is variadic (rest parameter)\\n            regular_params = ', '.join(self.parameters[:-1]) if len(self.parameters) > 1 else ''\\n            rest_param = self.parameters[-1]\\n            param_str = f\\\"{regular_params} . {rest_param}\\\".strip(' .')\\n\\n        return f\\\"<lambda ({param_str})>\\\"\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLBoolean(AIFPLValue):\\n    \\\"\\\"\\\"Represents boolean values.\\\"\\\"\\\"\\n    value: bool\\n\\n    def to_python(self) -> bool:\\n        return self.value\\n\\n    def type_name(self) -> str:\\n        return \\\"boolean\\\"\\n\\n    def describe(self) -> str:\\n        return \\\"#t\\\" if self.value else \\\"#f\\\"\\n\\n    def __eq__(self, other: Any) -> bool:\\n        \\\"\\\"\\\"Compare boolean values, ignoring metadata (line, column).\\\"\\\"\\\"\\n        if not isinstance(other, AIFPLBoolean):\\n            return False\\n\\n        return self.value == other.value\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLInteger(AIFPLValue):\\n    \\\"\\\"\\\"Represents integer values.\\\"\\\"\\\"\\n    value: int\\n\\n    def to_python(self) -> int:\\n        return self.value\\n\\n    def type_name(self) -> str:\\n        return \\\"integer\\\"\\n\\n    def describe(self) -> str:\\n        return str(self.value)\\n\\n    def __eq__(self, other: Any) -> bool:\\n        \\\"\\\"\\\"Compare numeric values.\\\"\\\"\\\"\\n        if not isinstance(other, AIFPLInteger):\\n            return False\\n\\n        return self.value == other.value\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLFloat(AIFPLValue):\\n    \\\"\\\"\\\"Represents floating-point values.\\\"\\\"\\\"\\n    value: float\\n\\n    def to_python(self) -> float:\\n        return self.value\\n\\n    def type_name(self) -> str:\\n        return \\\"float\\\"\\n\\n    def describe(self) -> str:\\n        return str(self.value)\\n\\n    def __eq__(self, other: Any) -> bool:\\n        \\\"\\\"\\\"Compare numeric values.\\\"\\\"\\\"\\n        if not isinstance(other, AIFPLFloat):\\n            return False\\n\\n        return self.value == other.value\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLComplex(AIFPLValue):\\n    \\\"\\\"\\\"Represents complex number values.\\\"\\\"\\\"\\n    value: complex\\n\\n    def to_python(self) -> complex:\\n        return self.value\\n\\n    def type_name(self) -> str:\\n        return \\\"complex\\\"\\n\\n    def describe(self) -> str:\\n        r = self.value.real\\n        i = self.value.imag\\n        def _fmt_float(x: float) -> str:\\n            \\\"\\\"\\\"Format a float component: use integer notation when exact, else full float.\\\"\\\"\\\"\\n            try:\\n                as_int = int(x)\\n                if x == as_int:\\n                    return str(as_int)\\n            except (ValueError, OverflowError):\\n                pass\\n            return str(x)\\n\\n        if r == 0.0 and i == 0.0:\\n            return \\\"0+0j\\\"\\n        if r == 0.0:\\n            # Pure imaginary: omit the real part entirely\\n            return f\\\"{_fmt_float(i)}j\\\"\\n        # General case: always show both parts with explicit sign on imaginary\\n        real_str = _fmt_float(r)\\n        if i >= 0.0:\\n            imag_str = f\\\"+{_fmt_float(i)}j\\\"\\n        else:\\n            imag_str = f\\\"{_fmt_float(i)}j\\\"\\n        return f\\\"{real_str}{imag_str}\\\"\\n\\n    def __eq__(self, other: Any) -> bool:\\n        \\\"\\\"\\\"Compare numeric values.\\\"\\\"\\\"\\n        if not isinstance(other, AIFPLComplex):\\n            return False\\n\\n        return self.value == other.value\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLString(AIFPLValue):\\n    \\\"\\\"\\\"Represents string values.\\\"\\\"\\\"\\n    value: str\\n\\n    def to_python(self) -> str:\\n        return self.value\\n\\n    def type_name(self) -> str:\\n        return \\\"string\\\"\\n\\n    def _escape_string(self, s: str) -> str:\\n        \\\"\\\"\\\"Escape a string for display format.\\\"\\\"\\\"\\n        result = []\\n        for char in s:\\n            if char == '\\\"':\\n                result.append('\\\\\\\\\\\"')\\n\\n            elif char == '\\\\\\\\':\\n                result.append('\\\\\\\\\\\\\\\\')\\n\\n            elif char == '\\\\n':\\n                result.append('\\\\\\\\n')\\n\\n            elif char == '\\\\t':\\n                result.append('\\\\\\\\t')\\n\\n            elif char == '\\\\r':\\n                result.append('\\\\\\\\r')\\n\\n            elif ord(char) < 32:  # Other control characters\\n                result.append(f'\\\\\\\\u{ord(char):04x}')\\n\\n            else:\\n                result.append(char)  # Keep Unicode as-is\\n\\n        return ''.join(result)\\n\\n    def describe(self) -> str:\\n        escaped_content = self._escape_string(self.value)\\n        return f'\\\"{escaped_content}\\\"'\\n\\n    def __eq__(self, other: Any) -> bool:\\n        \\\"\\\"\\\"Compare string values, ignoring metadata (line, column).\\\"\\\"\\\"\\n        if not isinstance(other, AIFPLString):\\n            return False\\n\\n        return self.value == other.value\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLList(AIFPLValue):\\n    \\\"\\\"\\\"Represents lists of AIFPL values.\\\"\\\"\\\"\\n    elements: Tuple[AIFPLValue, ...] = ()\\n\\n    def to_python(self) -> List[Any]:\\n        \\\"\\\"\\\"Convert to Python list with Python values.\\\"\\\"\\\"\\n        return [elem.to_python() for elem in self.elements]\\n\\n    def type_name(self) -> str:\\n        return \\\"list\\\"\\n\\n    def describe(self) -> str:\\n        # Format list: (element1 element2 ...)\\n        if self.is_empty():\\n            return \\\"()\\\"\\n\\n        formatted_elements = []\\n        for element in self.elements:\\n            formatted_elements.append(element.describe())\\n\\n        return f\\\"({' '.join(formatted_elements)})\\\"\\n\\n    def length(self) -> int:\\n        \\\"\\\"\\\"Return the length of the list.\\\"\\\"\\\"\\n        return len(self.elements)\\n\\n    def is_empty(self) -> bool:\\n        \\\"\\\"\\\"Check if the list is empty.\\\"\\\"\\\"\\n        return len(self.elements) == 0\\n\\n    def first(self) -> AIFPLValue:\\n        \\\"\\\"\\\"Get the first element (raises IndexError if empty).\\\"\\\"\\\"\\n        if not self.elements:\\n            raise IndexError(\\\"Cannot get first element of empty list\\\")\\n\\n        return self.elements[0]\\n\\n    def rest(self) -> 'AIFPLList':\\n        \\\"\\\"\\\"Get all elements except the first (raises IndexError if empty).\\\"\\\"\\\"\\n        if not self.elements:\\n            raise IndexError(\\\"Cannot get rest of empty list\\\")\\n\\n        return AIFPLList(self.elements[1:])\\n\\n    def last(self) -> AIFPLValue:\\n        \\\"\\\"\\\"Get the last element (raises IndexError if empty).\\\"\\\"\\\"\\n        if not self.elements:\\n            raise IndexError(\\\"Cannot get last element of empty list\\\")\\n\\n        return self.elements[-1]\\n\\n    def cons(self, element: AIFPLValue) -> 'AIFPLList':\\n        \\\"\\\"\\\"Prepend an element to the front of the list.\\\"\\\"\\\"\\n        return AIFPLList((element,) + self.elements)\\n\\n    def append_list(self, other: 'AIFPLList') -> 'AIFPLList':\\n        \\\"\\\"\\\"Append another list to this one.\\\"\\\"\\\"\\n        return AIFPLList(self.elements + other.elements)\\n\\n    def reverse(self) -> 'AIFPLList':\\n        \\\"\\\"\\\"Return a reversed copy of the list.\\\"\\\"\\\"\\n        return AIFPLList(tuple(reversed(self.elements)))\\n\\n    def get(self, index: int) -> AIFPLValue:\\n        \\\"\\\"\\\"Get element at index (raises IndexError if out of bounds).\\\"\\\"\\\"\\n        return self.elements[index]\\n\\n    def contains(self, value: AIFPLValue) -> bool:\\n        \\\"\\\"\\\"Check if the list contains a value (using AIFPL equality).\\\"\\\"\\\"\\n        return value in self.elements\\n\\n    def remove_all(self, value: AIFPLValue) -> 'AIFPLList':\\n        \\\"\\\"\\\"Remove all occurrences of a value.\\\"\\\"\\\"\\n        new_elements = tuple(elem for elem in self.elements if elem != value)\\n        return AIFPLList(new_elements)\\n\\n    def position(self, value: AIFPLValue) -> int | None:\\n        \\\"\\\"\\\"Find the first position of a value, or None if not found.\\\"\\\"\\\"\\n        for i, elem in enumerate(self.elements):\\n            if elem == value:\\n                return i\\n\\n        return None\\n\\n\\n@dataclass(frozen=True)\\nclass AIFPLAList(AIFPLValue):\\n    \\\"\\\"\\\"\\n    Represents association lists (alists) - immutable key-value mappings.\\n\\n    Internally uses a dict for O(1) lookups while maintaining insertion order.\\n    Keys must be hashable (strings, numbers, booleans, symbols).\\n    \\\"\\\"\\\"\\n    pairs: Tuple[Tuple[AIFPLValue, AIFPLValue], ...] = ()\\n    _lookup: dict = field(default_factory=dict, init=False, repr=False, compare=False)\\n\\n    def __post_init__(self) -> None:\\n        \\\"\\\"\\\"Build internal lookup dict after initialization.\\\"\\\"\\\"\\n        # Use object.__setattr__ because dataclass is frozen\\n        lookup = {}\\n        for key, value in self.pairs:\\n            hashable_key = self._to_hashable_key(key)\\n            lookup[hashable_key] = (key, value)\\n        object.__setattr__(self, '_lookup', lookup)\\n\\n    def to_python(self) -> dict:\\n        \\\"\\\"\\\"Convert to Python dict.\\\"\\\"\\\"\\n        result = {}\\n        for key, value in self.pairs:\\n            # Use string representation for Python dict keys\\n            if isinstance(key, AIFPLString):\\n                py_key = key.value\\n\\n            elif isinstance(key, AIFPLSymbol):\\n                py_key = key.name\\n\\n            else:\\n                py_key = str(key.to_python())\\n\\n            result[py_key] = value.to_python()\\n\\n        return result\\n\\n    def type_name(self) -> str:\\n        \\\"\\\"\\\"Return type name for error messages.\\\"\\\"\\\"\\n        return \\\"alist\\\"\\n\\n    def describe(self) -> str:\\n        # Format alist with curly braces: {(key1 val1) (key2 val2) ...}\\n        if self.is_empty():\\n            return \\\"{}\\\"\\n\\n        formatted_pairs = []\\n        for key, value in self.pairs:\\n            formatted_key = key.describe()\\n            formatted_value = value.describe()\\n            formatted_pairs.append(f\\\"({formatted_key} {formatted_value})\\\")\\n\\n        pairs_str = ' '.join(formatted_pairs)\\n        return f\\\"{{{pairs_str}}}\\\"\\n\\n    def get(self, key: AIFPLValue) -> AIFPLValue | None:\\n        \\\"\\\"\\\"Get value by key, returns None if not found.\\\"\\\"\\\"\\n        hashable_key = self._to_hashable_key(key)\\n        if hashable_key in self._lookup:\\n            _, value = self._lookup[hashable_key]\\n            return value\\n\\n        return None\\n\\n    def has_key(self, key: AIFPLValue) -> bool:\\n        \\\"\\\"\\\"Check if key exists.\\\"\\\"\\\"\\n        hashable_key = self._to_hashable_key(key)\\n        return hashable_key in self._lookup\\n\\n    def set(self, key: AIFPLValue, value: AIFPLValue) -> 'AIFPLAList':\\n        \\\"\\\"\\\"Return new alist with key set (immutable update).\\\"\\\"\\\"\\n        hashable_key = self._to_hashable_key(key)\\n\\n        # Build new pairs list, replacing or appending\\n        new_pairs = []\\n        found = False\\n\\n        for k, v in self.pairs:\\n            if self._to_hashable_key(k) == hashable_key:\\n                new_pairs.append((key, value))  # Replace with new value\\n                found = True\\n\\n            else:\\n                new_pairs.append((k, v))\\n\\n        if not found:\\n            new_pairs.append((key, value))  # Append new pair\\n\\n        return AIFPLAList(tuple(new_pairs))\\n\\n    def remove(self, key: AIFPLValue) -> 'AIFPLAList':\\n        \\\"\\\"\\\"Return new alist without key.\\\"\\\"\\\"\\n        hashable_key = self._to_hashable_key(key)\\n        new_pairs = tuple(\\n            (k, v) for k, v in self.pairs\\n            if self._to_hashable_key(k) != hashable_key\\n        )\\n        return AIFPLAList(new_pairs)\\n\\n    def keys(self) -> Tuple[AIFPLValue, ...]:\\n        \\\"\\\"\\\"Get all keys in insertion order.\\\"\\\"\\\"\\n        return tuple(k for k, _ in self.pairs)\\n\\n    def values(self) -> Tuple[AIFPLValue, ...]:\\n        \\\"\\\"\\\"Get all values in insertion order.\\\"\\\"\\\"\\n        return tuple(v for _, v in self.pairs)\\n\\n    def merge(self, other: 'AIFPLAList') -> 'AIFPLAList':\\n        \\\"\\\"\\\"Merge with another alist (other's values win on conflicts).\\\"\\\"\\\"\\n        # Start with self's pairs\\n        result_dict = {}\\n        for k, v in self.pairs:\\n            hashable_key = self._to_hashable_key(k)\\n            result_dict[hashable_key] = (k, v)\\n\\n        # Override/add from other\\n        for k, v in other.pairs:\\n            hashable_key = self._to_hashable_key(k)\\n            result_dict[hashable_key] = (k, v)\\n\\n        # Preserve insertion order: self's keys first, then other's new keys\\n        new_pairs = []\\n        seen = set()\\n\\n        # Add all of self's keys (with potentially updated values)\\n        for k, _ in self.pairs:\\n            hashable_key = self._to_hashable_key(k)\\n            new_pairs.append(result_dict[hashable_key])\\n            seen.add(hashable_key)\\n\\n        # Add other's keys that weren't in self\\n        for k, v in other.pairs:\\n            hashable_key = self._to_hashable_key(k)\\n            if hashable_key not in seen:\\n                new_pairs.append((k, v))\\n\\n        return AIFPLAList(tuple(new_pairs))\\n\\n    def length(self) -> int:\\n        \\\"\\\"\\\"Number of key-value pairs.\\\"\\\"\\\"\\n        return len(self.pairs)\\n\\n    def is_empty(self) -> bool:\\n        \\\"\\\"\\\"Check if alist is empty.\\\"\\\"\\\"\\n        return len(self.pairs) == 0\\n\\n    @staticmethod\\n    def _to_hashable_key(key: AIFPLValue) -> Tuple[str, Any]:\\n        \\\"\\\"\\\"Convert AIFPL key to hashable Python value.\\\"\\\"\\\"\\n        if isinstance(key, AIFPLString):\\n            return ('str', key.value)\\n\\n        if isinstance(key, (AIFPLInteger, AIFPLFloat, AIFPLComplex)):\\n            return ('num', key.value)\\n\\n        if isinstance(key, AIFPLBoolean):\\n            return ('bool', key.value)\\n\\n        if isinstance(key, AIFPLSymbol):\\n            return ('sym', key.name)\\n\\n        raise AIFPLEvalError(\\n            message=\\\"AList keys must be strings, numbers, booleans, or symbols\\\",\\n            received=f\\\"Key type: {key.type_name()}\\\",\\n            example='(alist (\\\"name\\\" \\\"Alice\\\") (\\\"age\\\" 30))',\\n            suggestion=\\\"Use strings for most keys\\\"\\n        )\\n\",\n  \"error\": null\n}\n```\n`content` is:\n```python\n\"\"\"AIFPL Value hierarchy - immutable runtime value types.\n\nThese are lightweight runtime values used by the VM and bytecode.\nThey do NOT carry source location metadata - that's only in AIFPLASTNode.\nThis separation keeps runtime values fast and memory-efficient.\n\"\"\"\n\nfrom abc import ABC, abstractmethod\nfrom dataclasses import dataclass, field\nfrom typing import Any, List, Tuple\n\nfrom aifpl.aifpl_error import AIFPLEvalError\n\n\n@dataclass(frozen=True)\nclass AIFPLValue(ABC):\n    \"\"\"\n    Abstract base class for all AIFPL runtime values.\n\n    All runtime values are immutable and lightweight (no metadata).\n    \"\"\"\n\n    @abstractmethod\n    def to_python(self) -> Any:\n        \"\"\"Convert to Python value for operations.\"\"\"\n\n    @abstractmethod\n    def type_name(self) -> str:\n        \"\"\"Return AIFPL type name for error messages.\"\"\"\n\n    @abstractmethod\n    def describe(self) -> str:\n        \"\"\"Describe the value.\"\"\"\n\n\n@dataclass(frozen=True)\nclass AIFPLSymbol(AIFPLValue):\n    \"\"\"Represents symbols that require environment lookup.\"\"\"\n    name: str\n\n    def to_python(self) -> str:\n        \"\"\"Symbols convert to their name string.\"\"\"\n        return self.name\n\n    def type_name(self) -> str:\n        return \"symbol\"\n\n    def describe(self) -> str:\n        return self.name\n\n    def __str__(self) -> str:\n        return self.name\n\n    def __repr__(self) -> str:\n        return f'AIFPLSymbol({self.name!r})'\n\n\n@dataclass(frozen=True)\nclass AIFPLFunction(AIFPLValue):\n    \"\"\"\n    Represents a function (both user-defined lambdas and builtins).\n\n    This is a first-class value that can be passed around as a value.\n    \"\"\"\n    parameters: Tuple[str, ...]\n    name: str | None = None\n    bytecode: Any = None  # CodeObject for bytecode-compiled functions\n    captured_values: Tuple[Any, ...] = ()  # Captured free variables for closures\n    is_variadic: bool = False  # True if function accepts variable number of args\n    parent_frame: Any = None  # Parent frame for LOAD_PARENT_VAR (lexical parent)\n\n    def to_python(self) -> 'AIFPLFunction | str':\n        \"\"\"Functions return themselves (or their name for builtins as string).\"\"\"\n        return self\n\n    def type_name(self) -> str:\n        return \"function\"\n\n    def describe(self) -> str:\n        \"\"\"Return a human-readable description of this function.\"\"\"\n        param_str = ', '.join(self.parameters)\n        if self.is_variadic and len(self.parameters) > 0:\n            # Last parameter is variadic (rest parameter)\n            regular_params = ', '.join(self.parameters[:-1]) if len(self.parameters) > 1 else ''\n            rest_param = self.parameters[-1]\n            param_str = f\"{regular_params} . {rest_param}\".strip(' .')\n\n        return f\"<lambda ({param_str})>\"\n\n\n@dataclass(frozen=True)\nclass AIFPLBoolean(AIFPLValue):\n    \"\"\"Represents boolean values.\"\"\"\n    value: bool\n\n    def to_python(self) -> bool:\n        return self.value\n\n    def type_name(self) -> str:\n        return \"boolean\"\n\n    def describe(self) -> str:\n        return \"#t\" if self.value else \"#f\"\n\n    def __eq__(self, other: Any) -> bool:\n        \"\"\"Compare boolean values, ignoring metadata (line, column).\"\"\"\n        if not isinstance(other, AIFPLBoolean):\n            return False\n\n        return self.value == other.value\n\n\n@dataclass(frozen=True)\nclass AIFPLInteger(AIFPLValue):\n    \"\"\"Represents integer values.\"\"\"\n    value: int\n\n    def to_python(self) -> int:\n        return self.value\n\n    def type_name(self) -> str:\n        return \"integer\"\n\n    def describe(self) -> str:\n        return str(self.value)\n\n    def __eq__(self, other: Any) -> bool:\n        \"\"\"Compare numeric values.\"\"\"\n        if not isinstance(other, AIFPLInteger):\n            return False\n\n        return self.value == other.value\n\n\n@dataclass(frozen=True)\nclass AIFPLFloat(AIFPLValue):\n    \"\"\"Represents floating-point values.\"\"\"\n    value: float\n\n    def to_python(self) -> float:\n        return self.value\n\n    def type_name(self) -> str:\n        return \"float\"\n\n    def describe(self) -> str:\n        return str(self.value)\n\n    def __eq__(self, other: Any) -> bool:\n        \"\"\"Compare numeric values.\"\"\"\n        if not isinstance(other, AIFPLFloat):\n            return False\n\n        return self.value == other.value\n\n\n@dataclass(frozen=True)\nclass AIFPLComplex(AIFPLValue):\n    \"\"\"Represents complex number values.\"\"\"\n    value: complex\n\n    def to_python(self) -> complex:\n        return self.value\n\n    def type_name(self) -> str:\n        return \"complex\"\n\n    def describe(self) -> str:\n        r = self.value.real\n        i = self.value.imag\n        def _fmt_float(x: float) -> str:\n            \"\"\"Format a float component: use integer notation when exact, else full float.\"\"\"\n            try:\n                as_int = int(x)\n                if x == as_int:\n                    return str(as_int)\n            except (ValueError, OverflowError):\n                pass\n            return str(x)\n\n        if r == 0.0 and i == 0.0:\n            return \"0+0j\"\n        if r == 0.0:\n            # Pure imaginary: omit the real part entirely\n            return f\"{_fmt_float(i)}j\"\n        # General case: always show both parts with explicit sign on imaginary\n        real_str = _fmt_float(r)\n        if i >= 0.0:\n            imag_str = f\"+{_fmt_float(i)}j\"\n        else:\n            imag_str = f\"{_fmt_float(i)}j\"\n        return f\"{real_str}{imag_str}\"\n\n    def __eq__(self, other: Any) -> bool:\n        \"\"\"Compare numeric values.\"\"\"\n        if not isinstance(other, AIFPLComplex):\n            return False\n\n        return self.value == other.value\n\n\n@dataclass(frozen=True)\nclass AIFPLString(AIFPLValue):\n    \"\"\"Represents string values.\"\"\"\n    value: str\n\n    def to_python(self) -> str:\n        return self.value\n\n    def type_name(self) -> str:\n        return \"string\"\n\n    def _escape_string(self, s: str) -> str:\n        \"\"\"Escape a string for display format.\"\"\"\n        result = []\n        for char in s:\n            if char == '\"':\n                result.append('\\\\\"')\n\n            elif char == '\\\\':\n                result.append('\\\\\\\\')\n\n            elif char == '\\n':\n                result.append('\\\\n')\n\n            elif char == '\\t':\n                result.append('\\\\t')\n\n            elif char == '\\r':\n                result.append('\\\\r')\n\n            elif ord(char) < 32:  # Other control characters\n                result.append(f'\\\\u{ord(char):04x}')\n\n            else:\n                result.append(char)  # Keep Unicode as-is\n\n        return ''.join(result)\n\n    def describe(self) -> str:\n        escaped_content = self._escape_string(self.value)\n        return f'\"{escaped_content}\"'\n\n    def __eq__(self, other: Any) -> bool:\n        \"\"\"Compare string values, ignoring metadata (line, column).\"\"\"\n        if not isinstance(other, AIFPLString):\n            return False\n\n        return self.value == other.value\n\n\n@dataclass(frozen=True)\nclass AIFPLList(AIFPLValue):\n    \"\"\"Represents lists of AIFPL values.\"\"\"\n    elements: Tuple[AIFPLValue, ...] = ()\n\n    def to_python(self) -> List[Any]:\n        \"\"\"Convert to Python list with Python values.\"\"\"\n        return [elem.to_python() for elem in self.elements]\n\n    def type_name(self) -> str:\n        return \"list\"\n\n    def describe(self) -> str:\n        # Format list: (element1 element2 ...)\n        if self.is_empty():\n            return \"()\"\n\n        formatted_elements = []\n        for element in self.elements:\n            formatted_elements.append(element.describe())\n\n        return f\"({' '.join(formatted_elements)})\"\n\n    def length(self) -> int:\n        \"\"\"Return the length of the list.\"\"\"\n        return len(self.elements)\n\n    def is_empty(self) -> bool:\n        \"\"\"Check if the list is empty.\"\"\"\n        return len(self.elements) == 0\n\n    def first(self) -> AIFPLValue:\n        \"\"\"Get the first element (raises IndexError if empty).\"\"\"\n        if not self.elements:\n            raise IndexError(\"Cannot get first element of empty list\")\n\n        return self.elements[0]\n\n    def rest(self) -> 'AIFPLList':\n        \"\"\"Get all elements except the first (raises IndexError if empty).\"\"\"\n        if not self.elements:\n            raise IndexError(\"Cannot get rest of empty list\")\n\n        return AIFPLList(self.elements[1:])\n\n    def last(self) -> AIFPLValue:\n        \"\"\"Get the last element (raises IndexError if empty).\"\"\"\n        if not self.elements:\n            raise IndexError(\"Cannot get last element of empty list\")\n\n        return self.elements[-1]\n\n    def cons(self, element: AIFPLValue) -> 'AIFPLList':\n        \"\"\"Prepend an element to the front of the list.\"\"\"\n        return AIFPLList((element,) + self.elements)\n\n    def append_list(self, other: 'AIFPLList') -> 'AIFPLList':\n        \"\"\"Append another list to this one.\"\"\"\n        return AIFPLList(self.elements + other.elements)\n\n    def reverse(self) -> 'AIFPLList':\n        \"\"\"Return a reversed copy of the list.\"\"\"\n        return AIFPLList(tuple(reversed(self.elements)))\n\n    def get(self, index: int) -> AIFPLValue:\n        \"\"\"Get element at index (raises IndexError if out of bounds).\"\"\"\n        return self.elements[index]\n\n    def contains(self, value: AIFPLValue) -> bool:\n        \"\"\"Check if the list contains a value (using AIFPL equality).\"\"\"\n        return value in self.elements\n\n    def remove_all(self, value: AIFPLValue) -> 'AIFPLList':\n        \"\"\"Remove all occurrences of a value.\"\"\"\n        new_elements = tuple(elem for elem in self.elements if elem != value)\n        return AIFPLList(new_elements)\n\n    def position(self, value: AIFPLValue) -> int | None:\n        \"\"\"Find the first position of a value, or None if not found.\"\"\"\n        for i, elem in enumerate(self.elements):\n            if elem == value:\n                return i\n\n        return None\n\n\n@dataclass(frozen=True)\nclass AIFPLAList(AIFPLValue):\n    \"\"\"\n    Represents association lists (alists) - immutable key-value mappings.\n\n    Internally uses a dict for O(1) lookups while maintaining insertion order.\n    Keys must be hashable (strings, numbers, booleans, symbols).\n    \"\"\"\n    pairs: Tuple[Tuple[AIFPLValue, AIFPLValue], ...] = ()\n    _lookup: dict = field(default_factory=dict, init=False, repr=False, compare=False)\n\n    def __post_init__(self) -> None:\n        \"\"\"Build internal lookup dict after initialization.\"\"\"\n        # Use object.__setattr__ because dataclass is frozen\n        lookup = {}\n        for key, value in self.pairs:\n            hashable_key = self._to_hashable_key(key)\n            lookup[hashable_key] = (key, value)\n        object.__setattr__(self, '_lookup', lookup)\n\n    def to_python(self) -> dict:\n        \"\"\"Convert to Python dict.\"\"\"\n        result = {}\n        for key, value in self.pairs:\n            # Use string representation for Python dict keys\n            if isinstance(key, AIFPLString):\n                py_key = key.value\n\n            elif isinstance(key, AIFPLSymbol):\n                py_key = key.name\n\n            else:\n                py_key = str(key.to_python())\n\n            result[py_key] = value.to_python()\n\n        return result\n\n    def type_name(self) -> str:\n        \"\"\"Return type name for error messages.\"\"\"\n        return \"alist\"\n\n    def describe(self) -> str:\n        # Format alist with curly braces: {(key1 val1) (key2 val2) ...}\n        if self.is_empty():\n            return \"{}\"\n\n        formatted_pairs = []\n        for key, value in self.pairs:\n            formatted_key = key.describe()\n            formatted_value = value.describe()\n            formatted_pairs.append(f\"({formatted_key} {formatted_value})\")\n\n        pairs_str = ' '.join(formatted_pairs)\n        return f\"{{{pairs_str}}}\"\n\n    def get(self, key: AIFPLValue) -> AIFPLValue | None:\n        \"\"\"Get value by key, returns None if not found.\"\"\"\n        hashable_key = self._to_hashable_key(key)\n        if hashable_key in self._lookup:\n            _, value = self._lookup[hashable_key]\n            return value\n\n        return None\n\n    def has_key(self, key: AIFPLValue) -> bool:\n        \"\"\"Check if key exists.\"\"\"\n        hashable_key = self._to_hashable_key(key)\n        return hashable_key in self._lookup\n\n    def set(self, key: AIFPLValue, value: AIFPLValue) -> 'AIFPLAList':\n        \"\"\"Return new alist with key set (immutable update).\"\"\"\n        hashable_key = self._to_hashable_key(key)\n\n        # Build new pairs list, replacing or appending\n        new_pairs = []\n        found = False\n\n        for k, v in self.pairs:\n            if self._to_hashable_key(k) == hashable_key:\n                new_pairs.append((key, value))  # Replace with new value\n                found = True\n\n            else:\n                new_pairs.append((k, v))\n\n        if not found:\n            new_pairs.append((key, value))  # Append new pair\n\n        return AIFPLAList(tuple(new_pairs))\n\n    def remove(self, key: AIFPLValue) -> 'AIFPLAList':\n        \"\"\"Return new alist without key.\"\"\"\n        hashable_key = self._to_hashable_key(key)\n        new_pairs = tuple(\n            (k, v) for k, v in self.pairs\n            if self._to_hashable_key(k) != hashable_key\n        )\n        return AIFPLAList(new_pairs)\n\n    def keys(self) -> Tuple[AIFPLValue, ...]:\n        \"\"\"Get all keys in insertion order.\"\"\"\n        return tuple(k for k, _ in self.pairs)\n\n    def values(self) -> Tuple[AIFPLValue, ...]:\n        \"\"\"Get all values in insertion order.\"\"\"\n        return tuple(v for _, v in self.pairs)\n\n    def merge(self, other: 'AIFPLAList') -> 'AIFPLAList':\n        \"\"\"Merge with another alist (other's values win on conflicts).\"\"\"\n        # Start with self's pairs\n        result_dict = {}\n        for k, v in self.pairs:\n            hashable_key = self._to_hashable_key(k)\n            result_dict[hashable_key] = (k, v)\n\n        # Override/add from other\n        for k, v in other.pairs:\n            hashable_key = self._to_hashable_key(k)\n            result_dict[hashable_key] = (k, v)\n\n        # Preserve insertion order: self's keys first, then other's new keys\n        new_pairs = []\n        seen = set()\n\n        # Add all of self's keys (with potentially updated values)\n        for k, _ in self.pairs:\n            hashable_key = self._to_hashable_key(k)\n            new_pairs.append(result_dict[hashable_key])\n            seen.add(hashable_key)\n\n        # Add other's keys that weren't in self\n        for k, v in other.pairs:\n            hashable_key = self._to_hashable_key(k)\n            if hashable_key not in seen:\n                new_pairs.append((k, v))\n\n        return AIFPLAList(tuple(new_pairs))\n\n    def length(self) -> int:\n        \"\"\"Number of key-value pairs.\"\"\"\n        return len(self.pairs)\n\n    def is_empty(self) -> bool:\n        \"\"\"Check if alist is empty.\"\"\"\n        return len(self.pairs) == 0\n\n    @staticmethod\n    def _to_hashable_key(key: AIFPLValue) -> Tuple[str, Any]:\n        \"\"\"Convert AIFPL key to hashable Python value.\"\"\"\n        if isinstance(key, AIFPLString):\n            return ('str', key.value)\n\n        if isinstance(key, (AIFPLInteger, AIFPLFloat, AIFPLComplex)):\n            return ('num', key.value)\n\n        if isinstance(key, AIFPLBoolean):\n            return ('bool', key.value)\n\n        if isinstance(key, AIFPLSymbol):\n            return ('sym', key.name)\n\n        raise AIFPLEvalError(\n            message=\"AList keys must be strings, numbers, booleans, or symbols\",\n            received=f\"Key type: {key.type_name()}\",\n            example='(alist (\"name\" \"Alice\") (\"age\" 30))',\n            suggestion=\"Use strings for most keys\"\n        )\n\n```",
