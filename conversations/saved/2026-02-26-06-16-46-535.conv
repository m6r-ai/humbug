          "content": "{\n  \"path\": \".\",\n  \"type\": \"directory\",\n  \"items\": {\n    \"total\": 37,\n    \"files\": 19,\n    \"directories\": 18\n  },\n  \"modified\": \"2026-02-26T05:54:09.210039Z\",\n  \"permissions\": \"755\"\n}",
