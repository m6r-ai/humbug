   \"type\": \"file\",\n      \"size\": 7993\n    },\n    {\n      \"name\": \"aifpl_ir.py\",\n      \"type\": \"file\",\n      \"size\": 4276\n    },\n    {\n      \"name\": \"aifpl_ir_builder.py\",\n      \"type\": \"file\",\n      \"size\": 32985\n    },\n    {\n      \"name\": \"aifpl_lexer.py\",\n      \"type\": \"file\",\n      \"size\": 33080\n    },\n    {\n      \"name\": \"aifpl_module_resolver.py\",\n      \"type\": \"file\",\n      \"size\": 5641\n    },\n    {\n      \"name\": \"aifpl_optimization_pass.py\",\n      \"type\": \"file\",\n      \"size\": 441\n    },\n    {\n      \"name\": \"aifpl_parser.py\",\n      \"type\": \"file\",\n      \"size\": 29759\n    },\n    {\n      \"name\": \"aifpl_pretty_printer.py\",\n      \"type\": \"file\",\n      \"size\": 21540\n    },\n    {\n      \"name\": \"aifpl_semantic_analyzer.py\",\n      \"type\": \"file\",\n      \"size\": 38367\n    },\n    {\n      \"name\": \"aifpl_token.py\",\n      \"type\": \"file\",\n      \"size\": 808\n    },\n    {\n      \"name\": \"aifpl_trace.py\",\n      \"type\": \"file\",\n      \"size\": 3685\n    },\n    {\n      \"name\": \"aifpl_value.py\",\n      \"type\": \"file\",\n      \"size\": 15478\n    },\n    {\n      \"name\": \"aifpl_vm.py\",\n      \"type\": \"file\",\n      \"size\": 112763\n    }\n  ]\n}",
